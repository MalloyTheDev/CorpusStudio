{
  "$defs": {
    "AdapterMethod": {
      "enum": [
        "none",
        "lora",
        "qlora",
        "dora",
        "ia3",
        "full_finetune",
        "prompt_tuning",
        "prefix_tuning"
      ],
      "title": "AdapterMethod",
      "type": "string"
    },
    "AttentionImpl": {
      "description": "``math``/``eager`` is forced on native-Windows/WDDM Blackwell sm_120 because the fused flash\nkernel deadlocks there. Other platforms require their own functional capability result; WSL\nevidence is not bare-Linux proof.",
      "enum": [
        "math",
        "eager",
        "sdpa",
        "flash_attention_2",
        "flash_attention_3",
        "mem_efficient",
        "xformers"
      ],
      "title": "AttentionImpl",
      "type": "string"
    },
    "AttentionKernel": {
      "description": "The exact attention implementation an execution policy permits at runtime.",
      "enum": [
        "eager",
        "torch_sdpa_math",
        "torch_sdpa_flash",
        "torch_sdpa_mem_efficient",
        "flash_attention_2",
        "flash_attention_3",
        "xformers"
      ],
      "title": "AttentionKernel",
      "type": "string"
    },
    "CheckpointImpl": {
      "enum": [
        "full_state",
        "adapter_only",
        "sharded",
        "distcp",
        "safetensors"
      ],
      "title": "CheckpointImpl",
      "type": "string"
    },
    "CommunicationBackend": {
      "enum": [
        "none",
        "nccl",
        "gloo",
        "mpi",
        "ucc",
        "backend_native"
      ],
      "title": "CommunicationBackend",
      "type": "string"
    },
    "DeviceKind": {
      "enum": [
        "cuda",
        "rocm",
        "mps",
        "xpu",
        "cpu"
      ],
      "title": "DeviceKind",
      "type": "string"
    },
    "EffectiveCapabilities": {
      "additionalProperties": false,
      "description": "The intersection of what a backend DECLARES and what PROVED to work on this host. The planner\nresolves a RunPlan against this, not the raw BackendManifest.",
      "properties": {
        "adapter_methods": {
          "items": {
            "$ref": "#/$defs/AdapterMethod"
          },
          "title": "Adapter Methods",
          "type": "array"
        },
        "attention_impls": {
          "items": {
            "$ref": "#/$defs/AttentionImpl"
          },
          "title": "Attention Impls",
          "type": "array"
        },
        "attention_kernels": {
          "items": {
            "$ref": "#/$defs/AttentionKernel"
          },
          "title": "Attention Kernels",
          "type": "array"
        },
        "checkpoint_impls": {
          "items": {
            "$ref": "#/$defs/CheckpointImpl"
          },
          "title": "Checkpoint Impls",
          "type": "array"
        },
        "communication_backends": {
          "items": {
            "$ref": "#/$defs/CommunicationBackend"
          },
          "title": "Communication Backends",
          "type": "array"
        },
        "execution_combinations": {
          "items": {
            "$ref": "#/$defs/ExecutionCapabilityCombination"
          },
          "title": "Execution Combinations",
          "type": "array"
        },
        "execution_contract_versions": {
          "items": {
            "type": "string"
          },
          "title": "Execution Contract Versions",
          "type": "array"
        },
        "loss_impls": {
          "items": {
            "$ref": "#/$defs/LossImpl"
          },
          "title": "Loss Impls",
          "type": "array"
        },
        "objective_capabilities": {
          "items": {
            "pattern": "^[A-Za-z0-9._-]+$",
            "type": "string"
          },
          "title": "Objective Capabilities",
          "type": "array"
        },
        "offload_strategies": {
          "items": {
            "$ref": "#/$defs/OffloadStrategy"
          },
          "title": "Offload Strategies",
          "type": "array"
        },
        "optimizers": {
          "items": {
            "$ref": "#/$defs/Optimizer"
          },
          "title": "Optimizers",
          "type": "array"
        },
        "parallelism_kinds": {
          "items": {
            "$ref": "#/$defs/ParallelismKind"
          },
          "title": "Parallelism Kinds",
          "type": "array"
        },
        "placement_modes": {
          "items": {
            "$ref": "#/$defs/PlacementMode"
          },
          "title": "Placement Modes",
          "type": "array"
        },
        "placement_tiers": {
          "items": {
            "$ref": "#/$defs/MemoryTier"
          },
          "title": "Placement Tiers",
          "type": "array"
        },
        "precision_modes": {
          "items": {
            "$ref": "#/$defs/PrecisionMode"
          },
          "title": "Precision Modes",
          "type": "array"
        },
        "quantization_modes": {
          "items": {
            "$ref": "#/$defs/QuantizationMode"
          },
          "title": "Quantization Modes",
          "type": "array"
        },
        "trainer_fields": {
          "items": {
            "type": "string"
          },
          "title": "Trainer Fields",
          "type": "array"
        },
        "trainer_init_fields": {
          "items": {
            "type": "string"
          },
          "title": "Trainer Init Fields",
          "type": "array"
        }
      },
      "title": "EffectiveCapabilities",
      "type": "object"
    },
    "ExecutionCapabilityCombination": {
      "additionalProperties": false,
      "description": "One execution tuple demonstrated together by a bounded functional probe.\n\nIndependent successes on precision, quantization, adapter, optimizer, loss, attention, and\ncheckpoint axes are diagnostic only. The planner may seal a run only from one of these complete\ntuples, preventing a union of unrelated probes from becoming a fictional capability.",
      "properties": {
        "adapter_method": {
          "$ref": "#/$defs/AdapterMethod"
        },
        "attention_impl": {
          "$ref": "#/$defs/AttentionImpl"
        },
        "attention_kernel": {
          "$ref": "#/$defs/AttentionKernel"
        },
        "checkpoint_impl": {
          "$ref": "#/$defs/CheckpointImpl"
        },
        "device": {
          "$ref": "#/$defs/DeviceKind"
        },
        "execution_contract_version": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Execution Contract Version",
          "type": "string"
        },
        "export_format": {
          "$ref": "#/$defs/ExportFormat"
        },
        "loss_impl": {
          "$ref": "#/$defs/LossImpl"
        },
        "optimizer": {
          "$ref": "#/$defs/Optimizer"
        },
        "precision": {
          "$ref": "#/$defs/PrecisionMode"
        },
        "probe": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Probe",
          "type": "string"
        },
        "quantization": {
          "$ref": "#/$defs/QuantizationMode"
        },
        "runtime_mode": {
          "enum": [
            "training",
            "cpu_toy"
          ],
          "title": "Runtime Mode",
          "type": "string"
        }
      },
      "required": [
        "runtime_mode",
        "device",
        "precision",
        "quantization",
        "adapter_method",
        "attention_impl",
        "attention_kernel",
        "optimizer",
        "loss_impl",
        "checkpoint_impl",
        "export_format",
        "execution_contract_version",
        "probe"
      ],
      "title": "ExecutionCapabilityCombination",
      "type": "object"
    },
    "ExportFormat": {
      "enum": [
        "adapter_peft",
        "merged_safetensors",
        "merged_fp16",
        "gguf",
        "onnx",
        "awq",
        "gptq",
        "mlx"
      ],
      "title": "ExportFormat",
      "type": "string"
    },
    "FailureTaxonomy": {
      "description": "Terminal outcome category. ``PASS`` is included so the same enum classifies a completed\nprobe/run, not only failures. Grounded in the exact hazards the engine documents: the sm_120\nfused-attention deadlock (KERNEL_STALL), the WDDM silent spill (ACCIDENTAL_SPILL vs a clean\nOOM), and env/dependency mismatches (ENVIRONMENT_FAILURE).",
      "enum": [
        "PASS",
        "FAIL",
        "OOM",
        "TIMEOUT",
        "KERNEL_STALL",
        "NUMERICAL_FAILURE",
        "CHECKPOINT_FAILURE",
        "ENVIRONMENT_FAILURE",
        "UNSUPPORTED_CONFIGURATION",
        "ACCIDENTAL_SPILL",
        "CONTROLLED_OFFLOAD"
      ],
      "title": "FailureTaxonomy",
      "type": "string"
    },
    "HashRef": {
      "additionalProperties": false,
      "description": "An algorithm-tagged digest. The engine emits sha256 today; the algo tag makes a future\nmigration additive (cf. versions/version_registry.FINGERPRINT_ALGO).",
      "properties": {
        "algo": {
          "default": "sha256",
          "enum": [
            "sha256",
            "sha256-ordered-exact-v1",
            "blake3",
            "none"
          ],
          "title": "Algo",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "title": "HashRef",
      "type": "object"
    },
    "LossImpl": {
      "enum": [
        "cross_entropy",
        "liger_fused_ce",
        "chunked_ce",
        "dpo",
        "orpo",
        "kto",
        "ipo",
        "reward_bt"
      ],
      "title": "LossImpl",
      "type": "string"
    },
    "MemoryTier": {
      "description": "A physical state tier. A RunPlan names the intended tier; only runtime evidence may claim\nactual residency there.",
      "enum": [
        "gpu",
        "pinned_ram",
        "pageable_ram",
        "nvme",
        "sata",
        "remote",
        "unknown"
      ],
      "title": "MemoryTier",
      "type": "string"
    },
    "OffloadStrategy": {
      "description": "The ``controlled_*`` values are the deliberate, planned counterparts of the accidental spills\nin :class:`FitClass`.",
      "enum": [
        "none",
        "controlled_activation_offload",
        "controlled_optimizer_offload",
        "controlled_parameter_offload",
        "cpu_offload",
        "disk_offload",
        "deepspeed_zero2",
        "deepspeed_zero3"
      ],
      "title": "OffloadStrategy",
      "type": "string"
    },
    "Optimizer": {
      "enum": [
        "adamw_torch",
        "adamw_torch_fused",
        "adamw_8bit",
        "adamw_bnb_8bit",
        "paged_adamw_8bit",
        "paged_adamw_32bit",
        "adafactor",
        "lion",
        "sgd"
      ],
      "title": "Optimizer",
      "type": "string"
    },
    "PackageLock": {
      "additionalProperties": false,
      "description": "A resolved dependency and its install provenance.\n\n``hash`` seals the installed distribution's RECORD metadata when that evidence is available; it\nis not mislabelled as the original wheel hash. ``direct_url`` and ``artifact`` preserve the\nstronger source identity pip exposes for direct/VCS/local installs. ``dependencies`` is the\ninstalled metadata dependency graph, not a second resolver.",
      "properties": {
        "artifact": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact"
        },
        "dependencies": {
          "items": {
            "type": "string"
          },
          "title": "Dependencies",
          "type": "array"
        },
        "direct_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Direct Url"
        },
        "hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "installer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Installer"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "requested": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requested"
        },
        "source": {
          "default": "unknown",
          "enum": [
            "pypi",
            "wheel",
            "sdist",
            "conda",
            "vcs",
            "local",
            "unknown"
          ],
          "title": "Source",
          "type": "string"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        }
      },
      "required": [
        "name"
      ],
      "title": "PackageLock",
      "type": "object"
    },
    "ParallelismKind": {
      "enum": [
        "data",
        "tensor",
        "pipeline",
        "expert",
        "sequence",
        "context"
      ],
      "title": "ParallelismKind",
      "type": "string"
    },
    "PlacementMode": {
      "enum": [
        "single_resource",
        "identity_scoped",
        "replicated",
        "sharded",
        "tiered",
        "expert_scoped"
      ],
      "title": "PlacementMode",
      "type": "string"
    },
    "PrecisionMode": {
      "enum": [
        "fp32",
        "tf32",
        "fp16",
        "bf16",
        "fp8",
        "mixed_bf16",
        "mixed_fp16"
      ],
      "title": "PrecisionMode",
      "type": "string"
    },
    "ProbeResult": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "execution_combinations": {
          "items": {
            "$ref": "#/$defs/ExecutionCapabilityCombination"
          },
          "title": "Execution Combinations",
          "type": "array"
        },
        "measured": {
          "additionalProperties": true,
          "title": "Measured",
          "type": "object"
        },
        "outcome": {
          "$ref": "#/$defs/FailureTaxonomy"
        },
        "probe": {
          "title": "Probe",
          "type": "string"
        },
        "proves": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Proves",
          "type": "object"
        }
      },
      "required": [
        "probe",
        "outcome"
      ],
      "title": "ProbeResult",
      "type": "object"
    },
    "QuantizationMode": {
      "enum": [
        "none",
        "int8",
        "int4",
        "nf4",
        "fp4",
        "gptq",
        "awq",
        "hqq"
      ],
      "title": "QuantizationMode",
      "type": "string"
    },
    "Ref": {
      "additionalProperties": false,
      "description": "A stable reference to another contract instance by id, optionally pinned to a content hash so\nthe reference cannot silently re-point.",
      "properties": {
        "hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        }
      },
      "required": [
        "id"
      ],
      "title": "Ref",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "The DYNAMIC, measured counterpart of a BackendManifest: probe results against a specific\nEnvironmentProfile. Formalizes environment.probe_training_runtime (ready/cpu_toy_ready/\nbitsandbytes_ok/notes) and generalizes it to per-probe outcomes tagged with FailureTaxonomy.",
  "properties": {
    "backend_id": {
      "title": "Backend Id",
      "type": "string"
    },
    "backend_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Backend Version"
    },
    "bitsandbytes_ok": {
      "default": false,
      "title": "Bitsandbytes Ok",
      "type": "boolean"
    },
    "contract_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Contract Version",
      "type": "string"
    },
    "effective_capabilities": {
      "anyOf": [
        {
          "$ref": "#/$defs/EffectiveCapabilities"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "environment_ref": {
      "$ref": "#/$defs/Ref"
    },
    "generated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated At"
    },
    "installed_packages": {
      "items": {
        "$ref": "#/$defs/PackageLock"
      },
      "title": "Installed Packages",
      "type": "array"
    },
    "missing_packages": {
      "items": {
        "type": "string"
      },
      "title": "Missing Packages",
      "type": "array"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "title": "Notes",
      "type": "array"
    },
    "probe_results": {
      "items": {
        "$ref": "#/$defs/ProbeResult"
      },
      "title": "Probe Results",
      "type": "array"
    },
    "readiness": {
      "enum": [
        "ready",
        "cpu_toy_only",
        "not_ready"
      ],
      "title": "Readiness",
      "type": "string"
    }
  },
  "required": [
    "backend_id",
    "environment_ref",
    "readiness"
  ],
  "title": "CapabilityReport",
  "type": "object"
}
