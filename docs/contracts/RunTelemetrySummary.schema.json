            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "measured_fit": {
          "anyOf": [
            {
              "$ref": "#/$defs/FitClassification"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "state": {
          "enum": [
            "prepared",
            "running",
            "succeeded",
            "failed",
            "cancelled",
            "interrupted"
          ],
          "title": "State",
          "type": "string"
        },
        "training_success": {
          "default": false,
          "title": "Training Success",
          "type": "boolean"
        }
      },
      "required": [
        "state"
      ],
      "title": "RunOutcomeSummary",
      "type": "object"
    },
    "SamplingCadence": {
      "additionalProperties": false,
      "description": "The observed inter-sample cadence, so a claimed 200 ms rate is checked against reality and no\nprecision beyond the true cadence is invented.",
      "properties": {
        "observed_max_interval_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed Max Interval Ms"
        },
        "observed_median_interval_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed Median Interval Ms"
        },
        "observed_min_interval_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed Min Interval Ms"
        },
        "requested_interval_ms": {
