{
  "$defs": {
    "CountHandling": {
      "enum": [
        "included",
        "excluded",
        "deduplicated",
        "represented_separately",
        "not_applicable",
        "unknown"
      ],
      "title": "CountHandling",
      "type": "string"
    },
    "HashRef": {
      "additionalProperties": false,
      "description": "An algorithm-tagged digest. The engine emits sha256 today; the algo tag makes a future\nmigration additive (cf. versions/version_registry.FINGERPRINT_ALGO).",
      "properties": {
        "algo": {
          "default": "sha256",
          "enum": [
            "sha256",
            "sha256-ordered-exact-v1",
            "blake3",
            "none"
          ],
          "title": "Algo",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "title": "HashRef",
      "type": "object"
    },
    "MemoryTier": {
      "description": "A physical state tier. A RunPlan names the intended tier; only runtime evidence may claim\nactual residency there.",
      "enum": [
        "gpu",
        "pinned_ram",
        "pageable_ram",
        "nvme",
        "sata",
        "remote",
        "unknown"
      ],
      "title": "MemoryTier",
      "type": "string"
    },
    "ParameterAccountingProfile": {
      "description": "The evidence set a report is trying to complete.",
      "enum": [
        "model_static",
        "training_plan",
        "training_runtime",
        "inference_runtime",
        "checkpoint",
        "evaluation"
      ],
      "title": "ParameterAccountingProfile",
      "type": "string"
    },
    "ParameterAccountingStatus": {
      "enum": [
        "complete",
        "incomplete",
        "conflicting"
      ],
      "title": "ParameterAccountingStatus",
      "type": "string"
    },
    "ParameterConflict": {
      "additionalProperties": false,
      "properties": {
        "conflict_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Conflict Id",
          "type": "string"
        },
        "explanation": {
          "minLength": 1,
          "title": "Explanation",
          "type": "string"
        },
        "observation_ids": {
          "items": {
            "pattern": "^[A-Za-z0-9._-]+$",
            "type": "string"
          },
          "minItems": 2,
          "title": "Observation Ids",
          "type": "array"
        },
        "reason_code": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Reason Code",
          "type": "string"
        }
      },
      "required": [
        "conflict_id",
        "observation_ids",
        "reason_code",
        "explanation"
      ],
      "title": "ParameterConflict",
      "type": "object"
    },
    "ParameterCountHandling": {
      "additionalProperties": false,
      "properties": {
        "decompressed_caches": {
          "$ref": "#/$defs/CountHandling",
          "default": "not_applicable"
        },
        "generated": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        },
        "optimizer_shadows": {
          "$ref": "#/$defs/CountHandling",
          "default": "not_applicable"
        },
        "quantized": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        },
        "replicated": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        },
        "shared": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        },
        "tied": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        }
      },
      "title": "ParameterCountHandling",
      "type": "object"
    },
    "ParameterCountKind": {
      "description": "Distinct parameter quantities required for dense-safe and MoE-safe accounting.",
      "enum": [
        "logical",
        "active_token",
        "active_sequence",
        "touched_window",
        "resident",
        "updated_window",
        "exposed_window",
        "effective"
      ],
      "title": "ParameterCountKind",
      "type": "string"
    },
    "ParameterEvidenceGap": {
      "additionalProperties": false,
      "properties": {
        "explanation": {
          "minLength": 1,
          "title": "Explanation",
          "type": "string"
        },
        "gap_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Gap Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ParameterCountKind"
        },
        "reason": {
          "$ref": "#/$defs/ParameterGapReason"
        },
        "resolution": {
          "minLength": 1,
          "title": "Resolution",
          "type": "string"
        },
        "scope": {
          "$ref": "#/$defs/ParameterScope"
        },
        "window": {
          "$ref": "#/$defs/ParameterWindow"
        }
      },
      "required": [
        "gap_id",
        "kind",
        "scope",
        "window",
        "reason",
        "explanation",
        "resolution"
      ],
      "title": "ParameterEvidenceGap",
      "type": "object"
    },
    "ParameterEvidenceSource": {
      "additionalProperties": false,
      "properties": {
        "backend_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/Ref"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "captured_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Captured At"
        },
        "environment_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/Ref"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "kind": {
          "$ref": "#/$defs/ParameterEvidenceSourceKind"
        },
        "method": {
          "minLength": 1,
          "title": "Method",
          "type": "string"
        },
        "producer": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Producer",
          "type": "string"
        },
        "producer_version": {
          "minLength": 1,
          "title": "Producer Version",
          "type": "string"
        },
        "source_ref": {
          "$ref": "#/$defs/Ref"
        }
      },
      "required": [
        "kind",
        "producer",
        "producer_version",
        "method",
        "source_ref"
      ],
      "title": "ParameterEvidenceSource",
      "type": "object"
    },
    "ParameterEvidenceSourceKind": {
      "enum": [
        "model_config",
        "model_descriptor",
        "safetensors_header",
        "planner",
        "backend_worker",
        "checkpoint_inventory",
        "evaluation_runtime",
        "user_supplied"
      ],
      "title": "ParameterEvidenceSourceKind",
      "type": "string"
    },
    "ParameterGapReason": {
      "enum": [
        "missing_observation",
        "unknown_handling",
        "unpinned_model",
        "unstructured_claim",
        "stored_elements_not_logical",
        "incomplete_inventory",
        "unsupported_format",
        "malformed_evidence",
        "changed_during_read",
        "runtime_instrumentation_required",
        "estimated_only",
        "measured_evidence_required",
        "conflicting_evidence",
        "incomparable_evidence"
      ],
      "title": "ParameterGapReason",
      "type": "string"
    },
    "ParameterIdentityBasis": {
      "enum": [
        "independent_coordinates",
        "stored_tensor_elements",
        "optimizer_addressable_coordinates",
        "runtime_identity_set",
        "topology_formula",
        "declared_definition",
        "unknown"
      ],
      "title": "ParameterIdentityBasis",
      "type": "string"
    },
    "ParameterObservation": {
      "additionalProperties": false,
      "description": "One evidence-bearing parameter count. Unknown evidence is represented as a gap, never zero.",
      "properties": {
        "assumptions": {
          "items": {
            "type": "string"
          },
          "title": "Assumptions",
          "type": "array"
        },
        "coverage": {
          "$ref": "#/$defs/ParameterObservationCoverage"
        },
        "definition": {
          "minLength": 1,
          "title": "Definition",
          "type": "string"
        },
        "evidence": {
          "enum": [
            "measured",
            "estimated",
            "declared"
          ],
          "title": "Evidence",
          "type": "string"
        },
        "handling": {
          "$ref": "#/$defs/ParameterCountHandling"
        },
        "identity_basis": {
          "$ref": "#/$defs/ParameterIdentityBasis"
        },
        "kind": {
          "$ref": "#/$defs/ParameterCountKind"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "observation_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Observation Id",
          "type": "string"
        },
        "scope": {
          "$ref": "#/$defs/ParameterScope"
        },
        "source": {
          "$ref": "#/$defs/ParameterEvidenceSource"
        },
        "unit": {
          "default": "coordinates",
          "enum": [
            "coordinates",
            "elements",
            "parameters"
          ],
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "minimum": 0,
          "title": "Value",
          "type": "integer"
        },
        "value_relation": {
          "$ref": "#/$defs/ParameterValueRelation"
        },
        "window": {
          "$ref": "#/$defs/ParameterWindow"
        }
      },
      "required": [
        "observation_id",
        "kind",
        "value",
        "scope",
        "window",
        "evidence",
        "source",
        "coverage",
        "value_relation",
        "identity_basis",
        "handling",
        "definition"
      ],
      "title": "ParameterObservation",
      "type": "object"
    },
    "ParameterObservationCoverage": {
      "enum": [
        "complete",
        "sampled",
        "partial"
      ],
      "title": "ParameterObservationCoverage",
      "type": "string"
    },
    "ParameterScope": {
      "additionalProperties": false,
      "description": "Stable coordinate universe for an authoritative parameter observation.\n\nRuntime addresses are never identities. Sparse scopes carry stable expert IDs, and every scope\nis tied to one exact model reference plus a named coordinate universe.",
      "properties": {
        "component_ids": {
          "items": {
            "pattern": "^[A-Za-z0-9._-]+$",
            "type": "string"
          },
          "title": "Component Ids",
          "type": "array"
        },
        "coordinate_universe_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Coordinate Universe Id",
          "type": "string"
        },
        "coordinate_universe_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Coordinate Universe Sha256"
        },
        "definition": {
          "minLength": 1,
          "title": "Definition",
          "type": "string"
        },
        "device_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Device Id"
        },
        "expert_ids": {
          "items": {
            "pattern": "^[A-Za-z0-9._-]+$",
            "type": "string"
          },
          "title": "Expert Ids",
          "type": "array"
        },
        "kind": {
          "$ref": "#/$defs/ParameterScopeKind"
        },
        "memory_tier": {
          "anyOf": [
            {
              "$ref": "#/$defs/MemoryTier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "model_ref": {
          "$ref": "#/$defs/Ref"
        },
        "scope_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Scope Id",
          "type": "string"
        }
      },
      "required": [
        "scope_id",
        "kind",
        "model_ref",
        "coordinate_universe_id",
        "definition"
      ],
      "title": "ParameterScope",
      "type": "object"
    },
    "ParameterScopeKind": {
      "enum": [
        "model",
        "component_set",
        "shared",
        "router",
        "expert_group",
        "expert_set",
        "adapter",
        "embedding",
        "output_head",
        "device_residency",
        "custom"
      ],
      "title": "ParameterScopeKind",
      "type": "string"
    },
    "ParameterValueRelation": {
      "enum": [
        "exact",
        "estimate",
        "lower_bound",
        "upper_bound"
      ],
      "title": "ParameterValueRelation",
      "type": "string"
    },
    "ParameterWindow": {
      "additionalProperties": false,
      "description": "The exact computation or scheduling window a count describes.",
      "properties": {
        "captured_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Captured At"
        },
        "definition": {
          "minLength": 1,
          "title": "Definition",
          "type": "string"
        },
        "event_seq_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Seq End"
        },
        "event_seq_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Seq Start"
        },
        "kind": {
          "$ref": "#/$defs/ParameterWindowKind"
        },
        "microstep_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Microstep End"
        },
        "microstep_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Microstep Start"
        },
        "optimizer_step_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Optimizer Step End"
        },
        "optimizer_step_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Optimizer Step Start"
        },
        "plan_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/Ref"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "run_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/Ref"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "sequence_id": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z0-9._-]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sequence Id"
        },
        "token_index": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Token Index"
        },
        "window_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Window Id",
          "type": "string"
        }
      },
      "required": [
        "window_id",
        "kind",
        "definition"
      ],
      "title": "ParameterWindow",
      "type": "object"
    },
    "ParameterWindowKind": {
      "enum": [
        "static_snapshot",
        "token",
        "sequence",
        "instant",
        "microbatch",
        "optimizer_window",
        "run"
      ],
      "title": "ParameterWindowKind",
      "type": "string"
    },
    "Ref": {
      "additionalProperties": false,
      "description": "A stable reference to another contract instance by id, optionally pinned to a content hash so\nthe reference cannot silently re-point.",
      "properties": {
        "hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        }
      },
      "required": [
        "id"
      ],
      "title": "Ref",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Hash-sealed, auditable reconciliation of parameter evidence for one exact model context.",
  "properties": {
    "artifact_refs": {
      "items": {
        "$ref": "#/$defs/Ref"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "conflicts": {
      "items": {
        "$ref": "#/$defs/ParameterConflict"
      },
      "title": "Conflicts",
      "type": "array"
    },
    "contract_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Contract Version",
      "type": "string"
    },
    "evaluation_refs": {
      "items": {
        "$ref": "#/$defs/Ref"
      },
      "title": "Evaluation Refs",
      "type": "array"
    },
    "gaps": {
      "items": {
        "$ref": "#/$defs/ParameterEvidenceGap"
      },
      "title": "Gaps",
      "type": "array"
    },
    "generated_at": {
      "title": "Generated At",
      "type": "string"
    },
    "model_ref": {
      "$ref": "#/$defs/Ref"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "title": "Notes",
      "type": "array"
    },
    "observations": {
      "items": {
        "$ref": "#/$defs/ParameterObservation"
      },
      "title": "Observations",
      "type": "array"
    },
    "parent_report_refs": {
      "items": {
        "$ref": "#/$defs/Ref"
      },
      "title": "Parent Report Refs",
      "type": "array"
    },
    "plan_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/Ref"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "profile": {
      "$ref": "#/$defs/ParameterAccountingProfile"
    },
    "report_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Report Hash",
      "type": "string"
    },
    "report_id": {
      "pattern": "^[A-Za-z0-9._-]+$",
      "title": "Report Id",
      "type": "string"
    },
    "run_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/Ref"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "status": {
      "$ref": "#/$defs/ParameterAccountingStatus"
    }
  },
  "required": [
    "report_id",
    "report_hash",
    "generated_at",
    "profile",
    "status",
    "model_ref"
  ],
  "title": "ParameterAccountingReport",
  "type": "object"
}
