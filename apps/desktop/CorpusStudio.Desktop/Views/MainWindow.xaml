                                        Width="108"
                                        Margin="0,0,8,0"
                                        Click="UseAiAssistSuggestionButton_Click" />
                                <Button AutomationProperties.AutomationId="AcceptAiAssistReviewButton"
                                        Content="Accept"
                                        Width="84"
                                        Margin="0,0,8,0"
                                        Click="AcceptAiAssistReviewButton_Click" />
                                <Button AutomationProperties.AutomationId="RejectAiAssistReviewButton"
                                        Content="Reject"
                                        Width="84"
                                        Click="RejectAiAssistReviewButton_Click" />
                            </WrapPanel>

                            <Grid Grid.Row="2"
                                  Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="1.4*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="120" />
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0"
                                         AutomationProperties.AutomationId="AiAssistSummaryTextBox"
                                         Text="{Binding AiAssistSummary, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />

                                <TextBlock Grid.Row="1"
                                           AutomationProperties.AutomationId="AiAssistQueueSummaryTextBlock"
                                           Text="{Binding AiAssistQueueSummary, Mode=OneWay}"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,4"
                                           TextWrapping="Wrap" />

                                <WrapPanel Grid.Row="2"
                                           Margin="0,0,0,6">
                                    <TextBlock Text="Filter"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <ComboBox AutomationProperties.AutomationId="AiAssistQueueFilterComboBox"
                                              ItemsSource="{Binding AiAssistQueueFilterOptions}"
                                              SelectedItem="{Binding AiAssistQueueFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Width="104"
                                              Margin="0,0,8,0" />
                                    <TextBlock Text="Search"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBox AutomationProperties.AutomationId="AiAssistQueueSearchTextBox"
                                             Text="{Binding AiAssistQueueSearch, UpdateSourceTrigger=PropertyChanged}"
                                             Width="136"
                                             Margin="0,0,8,0" />
                                    <TextBlock Text="Sort"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <ComboBox AutomationProperties.AutomationId="AiAssistQueueSortComboBox"
                                              ItemsSource="{Binding AiAssistQueueSortOptions}"
                                              SelectedItem="{Binding AiAssistQueueSort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Width="104"
                                              Margin="0,0,8,0" />
                                    <Button AutomationProperties.AutomationId="BulkAcceptAiAssistReviewsButton"
                                            Content="Accept Visible"
                                            Width="104"
                                            Margin="0,0,8,0"
                                            Click="BulkAcceptAiAssistReviewsButton_Click" />
                                    <Button AutomationProperties.AutomationId="BulkRejectAiAssistReviewsButton"
                                            Content="Reject Visible"
                                            Width="104"
                                            Margin="0,0,8,0"
                                            Click="BulkRejectAiAssistReviewsButton_Click" />
                                    <Button AutomationProperties.AutomationId="UndoBulkAiAssistReviewsButton"
                                            Content="Undo Bulk"
                                            Width="92"
                                            Click="UndoBulkAiAssistReviewsButton_Click" />
                                </WrapPanel>

                                <WrapPanel Grid.Row="3"
                                           Margin="0,0,0,6">
                                    <TextBlock Text="View"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <ComboBox AutomationProperties.AutomationId="AiAssistQueueViewComboBox"
                                              ItemsSource="{Binding AiAssistQueueViews}"
                                              SelectedItem="{Binding SelectedAiAssistQueueView, Mode=TwoWay}"
                                              DisplayMemberPath="DisplayName"
                                              Width="136"
                                              Margin="0,0,8,0" />
                                    <TextBox AutomationProperties.AutomationId="AiAssistQueueViewNameTextBox"
                                             Text="{Binding AiAssistQueueViewName, UpdateSourceTrigger=PropertyChanged}"
                                             Width="128"
                                             Margin="0,0,8,0" />
                                    <Button AutomationProperties.AutomationId="SaveAiAssistQueueViewButton"
                                            Content="Save View"
                                            Width="84"
                                            Margin="0,0,8,0"
                                            Click="SaveAiAssistQueueViewButton_Click" />
                                    <Button AutomationProperties.AutomationId="LoadAiAssistQueueViewButton"
                                            Content="Load View"
                                            Width="84"
                                            Click="LoadAiAssistQueueViewButton_Click" />
                                </WrapPanel>

                                <Grid Grid.Row="4">
                                    <ListBox x:Name="AiAssistReviewQueueListBox"
                                             AutomationProperties.AutomationId="AiAssistReviewQueueListBox"
                                             ItemsSource="{Binding AiAssistReviewQueue}"
                                             SelectedItem="{Binding SelectedAiAssistReviewQueueItem, Mode=TwoWay}"
                                             DisplayMemberPath="DisplayName"
                                             MinHeight="140" />
                                    <TextBlock Style="{StaticResource ListEmptyPlaceholderStyle}"
                                               Text="No AI Assist reviews yet. Run AI Assist to queue a suggestion for review."
                                               Visibility="{Binding HasItems, ElementName=AiAssistReviewQueueListBox, Converter={StaticResource InverseBoolToVis}}" />
                                </Grid>

                                <TextBlock Grid.Row="5"
                                           Text="Rewrite Batches"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,4" />

                                <WrapPanel Grid.Row="6"
                                           Margin="0,0,0,6">
                                    <Button AutomationProperties.AutomationId="ResumeAiAssistRewriteBatchButton"
                                            Content="Resume Batch"
                                            Width="112"
                                            Margin="0,0,8,0"
                                            Click="ResumeAiAssistRewriteBatchButton_Click" />
                                    <TextBlock AutomationProperties.AutomationId="AiAssistRewriteBatchSummaryTextBlock"
                                               Text="{Binding AiAssistRewriteBatchSummary, Mode=OneWay}"
                                               Width="188"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </WrapPanel>

                                <ListBox Grid.Row="7"
                                         AutomationProperties.AutomationId="AiAssistRewriteBatchesListBox"
                                         ItemsSource="{Binding AiAssistRewriteBatches}"
                                         SelectedItem="{Binding SelectedAiAssistRewriteBatch, Mode=TwoWay}"
                                         DisplayMemberPath="DisplayName" />
                            </Grid>

                            <Grid Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="12,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="3*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4*" />
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0"
                                         AutomationProperties.AutomationId="AiAssistReviewTextBox"
                                         Text="{Binding AiAssistReviewText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto" />

                                <TextBox Grid.Row="1"
                                         AutomationProperties.AutomationId="AiAssistDiffSummaryTextBox"
                                         Text="{Binding AiAssistDiffSummary, Mode=OneWay}"
                                         Margin="0,8,0,8"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap" />

                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Source Draft"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="Suggested JSONL"
                                               FontWeight="SemiBold"
                                               Margin="8,0,0,4" />

                                    <TextBox Grid.Row="1"
                                             Grid.Column="0"
                                             AutomationProperties.AutomationId="AiAssistSourceDraftTextBox"
                                             Text="{Binding AiAssistSourceDraftText, Mode=OneWay}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             AutomationProperties.AutomationId="AiAssistSuggestedJsonlTextBox"
                                             Text="{Binding AiAssistSuggestedJsonlText, Mode=OneWay}"
                                             Margin="8,0,0,0"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto" />
                                </Grid>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="TrainingTab" Header="Training">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <WrapPanel Grid.Row="0"
                                       Grid.ColumnSpan="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,8">
                                <TextBlock Text="Target"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="TrainingTargetTextBox"
                                         Text="{Binding TrainingTarget, UpdateSourceTrigger=PropertyChanged}"
                                         Width="132"
                                         Margin="0,0,12,0" />
                                <TextBlock Text="Base Model"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="TrainingBaseModelTextBox"
                                         Text="{Binding TrainingBaseModel, UpdateSourceTrigger=PropertyChanged}"
                                         Width="240"
                                         Margin="0,0,12,0" />
                                <TextBlock Text="Format"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="TrainingFormatTextBox"
                                         Text="{Binding TrainingFormat, UpdateSourceTrigger=PropertyChanged}"
                                         Width="112"
                                         Margin="0,0,12,0" />
                                <Button AutomationProperties.AutomationId="CheckTrainingCompatibilityButton"
                                        Content="Check Compatibility"
                                        Width="150"
                                        Margin="0,0,8,0"
                                        Click="CheckTrainingCompatibilityButton_Click" />
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        AutomationProperties.AutomationId="GenerateTrainingConfigButton"
                                        Content="Generate Config"
                                        Width="132"
                                        Click="GenerateTrainingConfigButton_Click" />
                                <Button AutomationProperties.AutomationId="CopyLaunchCommandButton"
                                        Content="Copy launch command"
                                        Margin="8,0,0,0"
                                        Click="CopyLaunchCommandButton_Click" />
                            </WrapPanel>

                            <WrapPanel Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,8">
                                <TextBlock Text="Seq Len"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="TrainingSequenceLenTextBox"
                                         Text="{Binding TrainingSequenceLen, UpdateSourceTrigger=PropertyChanged}"
                                         Width="72"
                                         Margin="0,0,12,0" />
                                <TextBlock Text="LoRA r"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="TrainingLoraRTextBox"
                                         Text="{Binding TrainingLoraR, UpdateSourceTrigger=PropertyChanged}"
                                         Width="56"
                                         Margin="0,0,12,0" />
                                <TextBlock Text="Alpha"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="TrainingLoraAlphaTextBox"
                                         Text="{Binding TrainingLoraAlpha, UpdateSourceTrigger=PropertyChanged}"
                                         Width="56"
                                         Margin="0,0,12,0" />
                                <TextBlock Text="Micro Batch"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="TrainingMicroBatchSizeTextBox"
                                         Text="{Binding TrainingMicroBatchSize, UpdateSourceTrigger=PropertyChanged}"
                                         Width="56"
                                         Margin="0,0,12,0" />
                                <TextBlock Text="Grad Accum"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="TrainingGradientAccumulationStepsTextBox"
                                         Text="{Binding TrainingGradientAccumulationSteps, UpdateSourceTrigger=PropertyChanged}"
                                         Width="56"
                                         Margin="0,0,12,0" />
                                <TextBlock Text="LR"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="TrainingLearningRateTextBox"
                                         Text="{Binding TrainingLearningRate, UpdateSourceTrigger=PropertyChanged}"
                                         Width="80" />
                            </WrapPanel>

                            <TextBox Grid.Row="2"
                                     Grid.Column="0"
                                     AutomationProperties.AutomationId="TrainingSummaryTextBox"
                                     Text="{Binding TrainingSummary, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />

                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     AutomationProperties.AutomationId="TrainingConfigPreviewTextBox"
                                     Text="{Binding TrainingConfigPreview, Mode=OneWay}"
                                     Margin="12,0,0,0"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Settings">
                        <StackPanel Margin="8">
                            <TextBox Text="{Binding SettingsSummary, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     MinHeight="120"
                                     Margin="0,0,0,8"
                                     VerticalScrollBarVisibility="Auto" />
                            <TextBlock Text="{Binding LabSettingsSummary, Mode=OneWay}"
                                       AutomationProperties.AutomationId="LabSettingsSummaryTextBlock"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <Button AutomationProperties.AutomationId="SaveLabSettingsButton"
                                    Content="Save Lab Settings"
                                    Width="140"
                                    HorizontalAlignment="Left"
                                    Click="SaveLabSettingsButton_Click" />
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1,0,0,0"
                Padding="18">
            <StackPanel>
                <TextBlock Text="Validation"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#0F172A" />
                <TextBox AutomationProperties.AutomationId="ValidationSummaryTextBox"
                         Text="{Binding ValidationSummary, Mode=OneWay}"
                         Margin="0,8,0,8"
                         MinHeight="120"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
                <TextBlock Text="Issues"
                           FontWeight="SemiBold"
                           Foreground="#334155" />
                <Grid Margin="0,8,0,24">
                    <ListBox x:Name="ValidationIssuesListBox"
                             AutomationProperties.AutomationId="ValidationIssuesListBox"
                             ItemsSource="{Binding ValidationIssues}"
                             SelectedItem="{Binding SelectedValidationIssue, Mode=TwoWay}"
                             DisplayMemberPath="DisplayName"
                             SelectionChanged="ValidationIssuesListBox_SelectionChanged"
                             Height="96" />
                    <TextBlock Style="{StaticResource ListEmptyPlaceholderStyle}"
                               Text="No validation issues. Validate a draft to see any errors here."
                               Visibility="{Binding HasItems, ElementName=ValidationIssuesListBox, Converter={StaticResource InverseBoolToVis}}" />
                </Grid>

                <TextBlock Text="Quality"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#0F172A" />
                <TextBox AutomationProperties.AutomationId="QualitySummaryTextBox"
                         Text="{Binding QualitySummary, Mode=OneWay}"
                         Margin="0,8,0,8"
                         MinHeight="96"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        AutomationProperties.AutomationId="RunQualityButton"
                        Content="Run _Quality"
                        Margin="0,0,0,8"
                        Click="RunQualityButton_Click" />
                <TextBlock Text="Synthetic Triage"
                           FontWeight="SemiBold"
                           Foreground="#334155" />
                <Grid Margin="0,8,0,8">
                    <ListBox x:Name="SyntheticPatternIssuesListBox"
                             AutomationProperties.AutomationId="SyntheticPatternIssuesListBox"
                             ItemsSource="{Binding SyntheticPatternIssues}"
                             SelectedItem="{Binding SelectedSyntheticPatternIssue, Mode=TwoWay}"
                             DisplayMemberPath="DisplayName"
                             Height="92" />
                    <TextBlock Style="{StaticResource ListEmptyPlaceholderStyle}"
                               Text="No synthetic-pattern issues found."
                               Visibility="{Binding HasItems, ElementName=SyntheticPatternIssuesListBox, Converter={StaticResource InverseBoolToVis}}" />
                </Grid>
                <TextBlock AutomationProperties.AutomationId="QualityTriageSummaryTextBlock"
                           Text="{Binding QualityTriageSummary, Mode=OneWay}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />
                <Button AutomationProperties.AutomationId="PrepareSyntheticRewriteButton"
                        Content="Prepare Rewrite"
                        Margin="0,0,0,8"
                        Click="PrepareSyntheticRewriteButton_Click" />
                <Button AutomationProperties.AutomationId="PrepareSyntheticBatchRewriteButton"
                        Content="Prepare Batch Rewrite"
                        Margin="0,0,0,8"
                        Click="PrepareSyntheticBatchRewriteButton_Click" />
                <TextBlock Text="History"
                           FontWeight="SemiBold"
                           Foreground="#334155" />
                <TextBox AutomationProperties.AutomationId="QualityHistoryTextBox"
                         Text="{Binding QualityHistorySummary, Mode=OneWay}"
                         Margin="0,8,0,24"
                         MinHeight="72"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />

                <TextBlock Text="Export"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#0F172A" />
                <Button AutomationProperties.AutomationId="ValidateButton"
                        Content="_Validate"
                        Margin="0,8,0,8"
                        Click="ValidateButton_Click" />
                <TextBlock Text="Cleaning (applied only to the exported file):"
                           Foreground="#475569"
                           Margin="0,4,0,4"
                           TextWrapping="Wrap" />
                <CheckBox x:Name="ExportRemoveDuplicatesCheckBox"
                          AutomationProperties.AutomationId="ExportRemoveDuplicatesCheckBox"
                          Content="Remove duplicate rows (exact + normalized)"
                          Margin="0,0,0,4" />
                <CheckBox x:Name="ExportRemoveLowInformationCheckBox"
                          AutomationProperties.AutomationId="ExportRemoveLowInformationCheckBox"
                          Content="Remove low-information rows"
                          Margin="0,0,0,8" />
                <Button x:Name="ExportJsonlButton"
                        Style="{StaticResource PrimaryButtonStyle}"
                        AutomationProperties.AutomationId="ExportJsonlButton"
                        Content="_Export JSONL"
                        Click="ExportJsonlButton_Click" />
                <Button AutomationProperties.AutomationId="GenerateDatasetCardButton"
                        Content="Generate Dataset Card"
                        Margin="0,8,0,8"
                        Click="GenerateDatasetCardButton_Click" />
                <TextBox AutomationProperties.AutomationId="DatasetCardSummaryTextBox"
                         Text="{Binding DatasetCardSummary, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         MinHeight="48"
                         Margin="0,0,0,8"
                         VerticalScrollBarVisibility="Auto" />
                <TextBox AutomationProperties.AutomationId="DatasetCardPreviewTextBox"
                         Text="{Binding DatasetCardPreview, Mode=OneWay}"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         TextWrapping="NoWrap"
                         MinHeight="120"
                         Margin="0,0,0,8"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>
        </Border>
        <Border Grid.ColumnSpan="3"
                Panel.ZIndex="100"
                Background="#73101828"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="28,22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock AutomationProperties.AutomationId="BusyStatusTextBlock"
                               Text="{Binding BusyStatus, Mode=OneWay}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource HeadingTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14" />
                    <ProgressBar IsIndeterminate="True" Width="240" Height="6" />
                    <Button x:Name="CancelEngineButton"
                            AutomationProperties.AutomationId="CancelEngineButton"
                            Content="Cancel"
                            Click="CancelEngineButton_Click"
                            HorizontalAlignment="Center"
                            Padding="16,6"
                            Margin="0,16,0,0" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
