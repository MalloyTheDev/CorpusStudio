{
  "$defs": {
    "AttentionImpl": {
      "description": "``math``/``eager`` is forced on native-Windows/WDDM Blackwell sm_120 because the fused flash\nkernel deadlocks there. Other platforms require their own functional capability result; WSL\nevidence is not bare-Linux proof.",
      "enum": [
        "math",
        "eager",
        "sdpa",
        "flash_attention_2",
        "flash_attention_3",
        "mem_efficient",
        "xformers"
      ],
      "title": "AttentionImpl",
      "type": "string"
    },
    "CountHandling": {
      "enum": [
        "included",
        "excluded",
        "deduplicated",
        "represented_separately",
        "not_applicable",
        "unknown"
      ],
      "title": "CountHandling",
      "type": "string"
    },
    "EventMetrics": {
      "additionalProperties": false,
      "description": "Present on metric/heartbeat events. All optional \u2014 a worker emits what it can sample. The\nmemory block + step_time make the WDDM spill (10-25x slowdown, non-zero shared bytes) visible.",
      "properties": {
        "gpu_utilization": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gpu Utilization"
        },
        "grad_norm": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Grad Norm"
        },
        "learning_rate": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Learning Rate"
        },
        "loss": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Loss"
        },
        "memory": {
          "anyOf": [
            {
              "$ref": "#/$defs/MemoryMetrics"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "memory_controller_utilization": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Memory Controller Utilization"
        },
        "parameter_observations": {
          "items": {
            "$ref": "#/$defs/ParameterObservation"
          },
          "title": "Parameter Observations",
          "type": "array"
        },
        "pcie_rx_bytes_per_sec": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pcie Rx Bytes Per Sec"
        },
        "pcie_tx_bytes_per_sec": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pcie Tx Bytes Per Sec"
        },
        "power_watts": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Power Watts"
        },
        "step_time_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Step Time Seconds"
        },
        "supervised_tokens_per_sec": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Supervised Tokens Per Sec"
        },
        "temperature_c": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature C"
        },
        "tokens_per_sec": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tokens Per Sec"
        }
      },
      "title": "EventMetrics",
      "type": "object"
    },
    "FitClass": {
      "description": "The fit verdict. ``NATIVE_*`` = fully resident. ``CONTROLLED_*`` = a deliberate, planned\noffload (acceptable, slower). ``ACCIDENTAL_*`` / ``THRASHING`` = an unplanned spill the platform\ndid silently (the failure mode the engine warns about). ``FAIL`` = will not run.",
      "enum": [
        "PLANNED_UNPROVEN",
        "NATIVE_SAFE",
        "NATIVE_TIGHT",
        "NATIVE_UNPROVEN",
        "MARGINAL",
        "CONTROLLED_ACTIVATION_OFFLOAD",
        "CONTROLLED_OPTIMIZER_OFFLOAD",
        "CONTROLLED_PARAMETER_OFFLOAD",
        "ACCIDENTAL_UNIFIED_MEMORY_PAGING",
        "ACCIDENTAL_WDDM_SPILL",
        "THRASHING",
        "FAIL"
      ],
      "title": "FitClass",
      "type": "string"
    },
    "FitClassification": {
      "additionalProperties": false,
      "description": "The planner/calibrator verdict on whether a resolved RunPlan fits the target environment, and\nHOW: a native fit, a deliberately-offloaded fit, or an ACCIDENTAL spill (the silent WDDM/unified\npaging that looks frozen but crawls at 10-25x). NEW \u2014 the engine emits only a coarse warn/pass\nVRAM band (preflight.gpu_memory, _VRAM_SAFETY_MARGIN_GB).",
      "properties": {
        "attention_path": {
          "anyOf": [
            {
              "$ref": "#/$defs/AttentionImpl"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "classification": {
          "$ref": "#/$defs/FitClass"
        },
        "contract_version": {
          "const": "1.0.0",
          "default": "1.0.0",
          "title": "Contract Version",
          "type": "string"
        },
        "device_capacity_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Device Capacity Bytes"
        },
        "estimated_peak_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Peak Bytes"
        },
        "headroom_bytes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Headroom Bytes"
        },
        "rationale": {
          "default": "",
          "title": "Rationale",
          "type": "string"
        }
      },
      "required": [
        "classification"
      ],
      "title": "FitClassification",
      "type": "object"
    },
    "HashRef": {
      "additionalProperties": false,
      "description": "An algorithm-tagged digest. The engine emits sha256 today; the algo tag makes a future\nmigration additive (cf. versions/version_registry.FINGERPRINT_ALGO).",
      "properties": {
        "algo": {
          "default": "sha256",
          "enum": [
            "sha256",
            "sha256-ordered-exact-v1",
            "blake3",
            "none"
          ],
          "title": "Algo",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "title": "HashRef",
      "type": "object"
    },
    "MemoryMetrics": {
      "additionalProperties": false,
      "description": "The full memory-signature block sampled during a run. Distinguishes PyTorch's allocator view,\nraw CUDA device memory, and OS-level residency (``dedicated`` vs ``shared`` GPU memory) so a\nWindows/WDDM spill to shared memory is VISIBLE rather than hidden inside 'used VRAM'. Grounded in\ngpu_probe.GpuMemory + the estimators note that torch.max_memory_allocated counts the WDDM spill.",
      "properties": {
        "cuda_device_free_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cuda Device Free Bytes"
        },
        "cuda_device_used_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cuda Device Used Bytes"
        },
        "dedicated_gpu_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dedicated Gpu Bytes"
        },
        "process_rss_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Process Rss Bytes"
        },
        "shared_gpu_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Shared Gpu Bytes"
        },
        "system_ram_used_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "System Ram Used Bytes"
        },
        "torch_allocated_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Torch Allocated Bytes"
        },
        "torch_peak_allocated_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Torch Peak Allocated Bytes"
        },
        "torch_peak_reserved_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Torch Peak Reserved Bytes"
        },
        "torch_reserved_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Torch Reserved Bytes"
        }
      },
      "title": "MemoryMetrics",
      "type": "object"
    },
    "MemoryTier": {
      "description": "A physical state tier. A RunPlan names the intended tier; only runtime evidence may claim\nactual residency there.",
      "enum": [
        "gpu",
        "pinned_ram",
        "pageable_ram",
        "nvme",
        "sata",
        "remote",
        "unknown"
      ],
      "title": "MemoryTier",
      "type": "string"
    },
    "ParameterCountHandling": {
      "additionalProperties": false,
      "properties": {
        "decompressed_caches": {
          "$ref": "#/$defs/CountHandling",
          "default": "not_applicable"
        },
        "generated": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        },
        "optimizer_shadows": {
          "$ref": "#/$defs/CountHandling",
          "default": "not_applicable"
        },
        "quantized": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        },
        "replicated": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        },
        "shared": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        },
        "tied": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        }
      },
      "title": "ParameterCountHandling",
      "type": "object"
    },
    "ParameterCountKind": {
      "description": "Distinct parameter quantities required for dense-safe and MoE-safe accounting.",
      "enum": [
        "logical",
        "active_token",
        "active_sequence",
        "touched_window",
        "resident",
        "updated_window",
        "exposed_window",
        "effective"
      ],
      "title": "ParameterCountKind",
      "type": "string"
    },
    "ParameterEvidenceSource": {
      "additionalProperties": false,
      "properties": {
        "backend_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/Ref"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "captured_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Captured At"
        },
        "environment_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/Ref"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "kind": {
          "$ref": "#/$defs/ParameterEvidenceSourceKind"
        },
        "method": {
          "minLength": 1,
          "title": "Method",
          "type": "string"
        },
        "producer": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Producer",
          "type": "string"
        },
        "producer_version": {
          "minLength": 1,
          "title": "Producer Version",
          "type": "string"
        },
        "source_ref": {
          "$ref": "#/$defs/Ref"
        }
      },
      "required": [
        "kind",
        "producer",
        "producer_version",
        "method",
        "source_ref"
      ],
      "title": "ParameterEvidenceSource",
      "type": "object"
    },
    "ParameterEvidenceSourceKind": {
      "enum": [
        "model_config",
        "model_descriptor",
        "safetensors_header",
        "planner",
        "backend_worker",
        "checkpoint_inventory",
        "evaluation_runtime",
        "user_supplied"
      ],
      "title": "ParameterEvidenceSourceKind",
      "type": "string"
    },
    "ParameterIdentityBasis": {
      "enum": [
        "independent_coordinates",
        "stored_tensor_elements",
        "optimizer_addressable_coordinates",
        "runtime_identity_set",
        "topology_formula",
        "declared_definition",
        "unknown"
      ],
      "title": "ParameterIdentityBasis",
      "type": "string"
    },
    "ParameterObservation": {
      "additionalProperties": false,
      "description": "One evidence-bearing parameter count. Unknown evidence is represented as a gap, never zero.",
      "properties": {
        "assumptions": {
          "items": {
            "type": "string"
          },
          "title": "Assumptions",
          "type": "array"
        },
        "coverage": {
          "$ref": "#/$defs/ParameterObservationCoverage"
        },
        "definition": {
          "minLength": 1,
          "title": "Definition",
          "type": "string"
        },
        "evidence": {
          "enum": [
            "measured",
            "estimated",
            "declared"
          ],
          "title": "Evidence",
          "type": "string"
        },
        "handling": {
          "$ref": "#/$defs/ParameterCountHandling"
        },
        "identity_basis": {
          "$ref": "#/$defs/ParameterIdentityBasis"
        },
        "kind": {
          "$ref": "#/$defs/ParameterCountKind"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "observation_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Observation Id",
          "type": "string"
        },
        "scope": {
          "$ref": "#/$defs/ParameterScope"
        },
        "source": {
          "$ref": "#/$defs/ParameterEvidenceSource"
        },
        "unit": {
          "default": "coordinates",
          "enum": [
            "coordinates",
            "elements",
            "parameters"
          ],
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "minimum": 0,
          "title": "Value",
          "type": "integer"
        },
        "value_relation": {
          "$ref": "#/$defs/ParameterValueRelation"
        },
        "window": {
          "$ref": "#/$defs/ParameterWindow"
        }
      },
      "required": [
        "observation_id",
        "kind",
        "value",
        "scope",
        "window",
        "evidence",
        "source",
        "coverage",
        "value_relation",
        "identity_basis",
        "handling",
        "definition"
      ],
      "title": "ParameterObservation",
      "type": "object"
    },
    "ParameterObservationCoverage": {
      "enum": [
        "complete",
        "sampled",
        "partial"
      ],
      "title": "ParameterObservationCoverage",
      "type": "string"
    },
    "ParameterScope": {
      "additionalProperties": false,
      "description": "Stable coordinate universe for an authoritative parameter observation.\n\nRuntime addresses are never identities. Sparse scopes carry stable expert IDs, and every scope\nis tied to one exact model reference plus a named coordinate universe.",
      "properties": {
        "component_ids": {
          "items": {
            "pattern": "^[A-Za-z0-9._-]+$",
            "type": "string"
          },
          "title": "Component Ids",
          "type": "array"
        },
        "coordinate_universe_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Coordinate Universe Id",
          "type": "string"
        },
        "coordinate_universe_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Coordinate Universe Sha256"
        },
        "definition": {
          "minLength": 1,
          "title": "Definition",
          "type": "string"
        },
        "device_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Device Id"
        },
        "expert_ids": {
          "items": {
            "pattern": "^[A-Za-z0-9._-]+$",
            "type": "string"
          },
          "title": "Expert Ids",
          "type": "array"
        },
        "kind": {
          "$ref": "#/$defs/ParameterScopeKind"
        },
        "memory_tier": {
          "anyOf": [
            {
              "$ref": "#/$defs/MemoryTier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "model_ref": {
          "$ref": "#/$defs/Ref"
        },
        "scope_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Scope Id",
          "type": "string"
        }
      },
      "required": [
        "scope_id",
        "kind",
        "model_ref",
        "coordinate_universe_id",
        "definition"
      ],
      "title": "ParameterScope",
      "type": "object"
    },
    "ParameterScopeKind": {
      "enum": [
        "model",
        "component_set",
        "shared",
        "router",
        "expert_group",
        "expert_set",
        "adapter",
        "embedding",
        "output_head",
        "device_residency",
        "custom"
      ],
      "title": "ParameterScopeKind",
      "type": "string"
    },
    "ParameterValueRelation": {
      "enum": [
        "exact",
        "estimate",
        "lower_bound",
        "upper_bound"
      ],
      "title": "ParameterValueRelation",
      "type": "string"
    },
    "ParameterWindow": {
      "additionalProperties": false,
      "description": "The exact computation or scheduling window a count describes.",
      "properties": {
        "captured_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Captured At"
        },
        "definition": {
          "minLength": 1,
          "title": "Definition",
          "type": "string"
        },
        "event_seq_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Seq End"
        },
        "event_seq_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Seq Start"
        },
        "kind": {
          "$ref": "#/$defs/ParameterWindowKind"
        },
        "microstep_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Microstep End"
        },
        "microstep_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Microstep Start"
        },
        "optimizer_step_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Optimizer Step End"
        },
        "optimizer_step_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Optimizer Step Start"
        },
        "plan_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/Ref"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "run_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/Ref"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "sequence_id": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z0-9._-]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sequence Id"
        },
        "token_index": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Token Index"
        },
        "window_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Window Id",
          "type": "string"
        }
      },
      "required": [
        "window_id",
        "kind",
        "definition"
      ],
      "title": "ParameterWindow",
      "type": "object"
    },
    "ParameterWindowKind": {
      "enum": [
        "static_snapshot",
        "token",
        "sequence",
        "instant",
        "microbatch",
        "optimizer_window",
        "run"
      ],
      "title": "ParameterWindowKind",
      "type": "string"
    },
    "Ref": {
      "additionalProperties": false,
