{
  "$defs": {
    "BackendCompatibilityEntry": {
      "additionalProperties": false,
      "properties": {
        "backend_ref": {
          "$ref": "#/$defs/Ref"
        },
        "capability_report_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/Ref"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "environment_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/Ref"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "status": {
          "default": "unverified",
          "enum": [
            "compatible",
            "incompatible",
            "unverified"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "backend_ref"
      ],
      "title": "BackendCompatibilityEntry",
      "type": "object"
    },
    "CountHandling": {
      "enum": [
        "included",
        "excluded",
        "deduplicated",
        "represented_separately",
        "not_applicable",
        "unknown"
      ],
      "title": "CountHandling",
      "type": "string"
    },
    "DescriptorFile": {
      "additionalProperties": false,
      "description": "One safe, portable inventory entry. sha256 is separate from hash_status so skipped hashing\nand unreadable content are never confused with a verified empty digest.",
      "properties": {
        "format": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelFormat"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "hash_status": {
          "default": "not_requested",
          "enum": [
            "verified",
            "not_requested",
            "unreadable",
            "skipped_unsafe"
          ],
          "title": "Hash Status",
          "type": "string"
        },
        "is_link": {
          "default": false,
          "title": "Is Link",
          "type": "boolean"
        },
        "path": {
          "minLength": 1,
          "pattern": "^(?:[^/\\\\:.][^/\\\\:]*|\\.[^./\\\\:][^/\\\\:]*)(?:/(?:[^/\\\\:.][^/\\\\:]*|\\.[^./\\\\:][^/\\\\:]*))*$",
          "title": "Path",
          "type": "string"
        },
        "role": {
          "$ref": "#/$defs/DescriptorFileRole",
          "default": "other"
        },
        "serialization_risk": {
          "default": "unknown",
          "enum": [
            "safe",
            "pickle",
            "executable_code",
            "archive",
            "unknown"
          ],
          "title": "Serialization Risk",
          "type": "string"
        },
        "sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sha256"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "size_bytes"
      ],
      "title": "DescriptorFile",
      "type": "object"
    },
    "DescriptorFileRole": {
      "enum": [
        "config",
        "weights",
        "weight_index",
        "tokenizer",
        "tokenizer_config",
        "special_tokens",
        "generation_config",
        "model_card",
        "license",
        "custom_code",
        "other"
      ],
      "title": "DescriptorFileRole",
      "type": "string"
    },
    "DescriptorSource": {
      "additionalProperties": false,
      "description": "Identity of the requested source and the immutable revision actually inspected.\n\nrequested_revision is user intent. resolved_revision/resolved_commit are evidence. They are\nintentionally separate so a mutable branch name is never misreported as a pinned snapshot.",
      "properties": {
        "artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/Ref"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "evidence_source": {
          "default": "user_input",
          "title": "Evidence Source",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ModelSourceKind"
        },
        "local_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Local Path"
        },
        "repository": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repository"
        },
        "requested_revision": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requested Revision"
        },
        "resolved_commit": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{7,64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolved Commit"
        },
        "resolved_revision": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolved Revision"
        },
        "revision_pinned": {
          "default": false,
          "title": "Revision Pinned",
          "type": "boolean"
        },
        "snapshot_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Snapshot Sha256"
        }
      },
      "required": [
        "kind"
      ],
      "title": "DescriptorSource",
      "type": "object"
    },
    "DescriptorVerification": {
      "additionalProperties": false,
      "description": "Independent evidence axes. Integrity never implies compatibility or hardware support.",
      "properties": {
        "custom_code_policy": {
          "$ref": "#/$defs/VerificationOutcome",
          "default": "not_checked"
        },
        "evidence_refs": {
          "items": {
            "$ref": "#/$defs/Ref"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "inspected_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inspected At"
        },
        "inspector": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inspector"
        },
        "integrity": {
          "$ref": "#/$defs/VerificationOutcome",
          "default": "not_checked"
        },
        "license": {
          "$ref": "#/$defs/VerificationOutcome",
          "default": "not_checked"
        },
        "metadata": {
          "$ref": "#/$defs/VerificationOutcome",
          "default": "not_checked"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "title": "DescriptorVerification",
      "type": "object"
    },
    "DimensionEvidence": {
      "additionalProperties": false,
      "properties": {
        "evidence": {
          "$ref": "#/$defs/EvidenceKind"
        },
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        },
        "value": {
          "minimum": 0,
          "title": "Value",
          "type": "integer"
        }
      },
      "required": [
        "value",
        "source",
        "evidence"
      ],
      "title": "DimensionEvidence",
      "type": "object"
    },
    "EmbeddingVocabulary": {
      "additionalProperties": false,
      "properties": {
        "declared_vocab_size": {
          "anyOf": [
            {
              "$ref": "#/$defs/DimensionEvidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "input_embedding_rows": {
          "anyOf": [
            {
              "$ref": "#/$defs/DimensionEvidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "output_head_rows": {
          "anyOf": [
            {
              "$ref": "#/$defs/DimensionEvidence"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "tied_embeddings": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tied Embeddings"
        }
      },
      "title": "EmbeddingVocabulary",
      "type": "object"
    },
    "EvidenceKind": {
      "enum": [
        "measured",
        "estimated",
        "declared",
        "unknown"
      ],
      "title": "EvidenceKind",
      "type": "string"
    },
    "ExpertGroup": {
      "additionalProperties": false,
      "description": "One routed-expert layout repeated at each listed layer.\n\nexpert_count is the total logical expert identities per listed layer. routed_expert_count and\nalways-active shared_expert_count partition that total. experts_per_token counts only routed\nexperts selected per token; neither it nor any other field here is a parameter count.",
      "properties": {
        "component_path": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Component Path"
        },
        "expert_count": {
          "minimum": 1,
          "title": "Expert Count",
          "type": "integer"
        },
        "expert_identity_scheme": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expert Identity Scheme"
        },
        "expert_registry_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/Ref"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "experts_per_token": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Experts Per Token"
        },
        "group_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Group Id",
          "type": "string"
        },
        "heterogeneous": {
          "default": false,
          "title": "Heterogeneous",
          "type": "boolean"
        },
        "layer_indices": {
          "items": {
            "type": "integer"
          },
          "title": "Layer Indices",
          "type": "array"
        },
        "layer_namespace": {
          "default": "decoder",
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Layer Namespace",
          "type": "string"
        },
        "metadata_sources": {
          "items": {
            "type": "string"
          },
          "title": "Metadata Sources",
          "type": "array"
        },
        "routed_expert_count": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Routed Expert Count"
        },
        "shared_expert_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Shared Expert Count"
        }
      },
      "required": [
        "group_id",
        "expert_count"
      ],
      "title": "ExpertGroup",
      "type": "object"
    },
    "ExpertTopologyCounts": {
      "additionalProperties": false,
      "description": "Derived structural counts across one full model pass for one token.\n\nThe unit is expert instances, not parameter coordinates. These values therefore never substitute\nfor N_logical/N_active in ParameterAccountingReport.",
      "properties": {
        "active_expert_instances_per_token": {
          "minimum": 1,
          "title": "Active Expert Instances Per Token",
          "type": "integer"
        },
        "active_routed_expert_instances_per_token": {
          "minimum": 1,
          "title": "Active Routed Expert Instances Per Token",
          "type": "integer"
        },
        "active_shared_expert_instances_per_token": {
          "minimum": 0,
          "title": "Active Shared Expert Instances Per Token",
          "type": "integer"
        },
        "logical_expert_instances": {
          "minimum": 1,
          "title": "Logical Expert Instances",
          "type": "integer"
        },
        "moe_layer_count": {
          "minimum": 1,
          "title": "Moe Layer Count",
          "type": "integer"
        },
        "routed_expert_instances": {
          "minimum": 1,
          "title": "Routed Expert Instances",
          "type": "integer"
        },
        "shared_expert_instances": {
          "minimum": 0,
          "title": "Shared Expert Instances",
          "type": "integer"
        },
        "unit": {
          "const": "expert_instances",
          "default": "expert_instances",
          "title": "Unit",
          "type": "string"
        }
      },
      "required": [
        "moe_layer_count",
        "routed_expert_instances",
        "shared_expert_instances",
        "logical_expert_instances",
        "active_routed_expert_instances_per_token",
        "active_shared_expert_instances_per_token",
        "active_expert_instances_per_token"
      ],
      "title": "ExpertTopologyCounts",
      "type": "object"
    },
    "HashRef": {
      "additionalProperties": false,
      "description": "An algorithm-tagged digest. The engine emits sha256 today; the algo tag makes a future\nmigration additive (cf. versions/version_registry.FINGERPRINT_ALGO).",
      "properties": {
        "algo": {
          "default": "sha256",
          "enum": [
            "sha256",
            "sha256-ordered-exact-v1",
            "blake3",
            "none"
          ],
          "title": "Algo",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "title": "HashRef",
      "type": "object"
    },
    "License": {
      "additionalProperties": false,
      "description": "License metadata for a dataset, base model, or produced artifact. The engine reminds users\nthe BASE model's license governs a produced adapter (training/model_card).",
      "properties": {
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "redistributable": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Redistributable"
        },
        "source": {
          "default": "unknown",
          "enum": [
            "declared",
            "model_card",
            "dataset_card",
            "user_asserted",
            "unknown"
          ],
          "title": "Source",
          "type": "string"
        },
        "spdx_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Spdx Id"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        }
      },
      "title": "License",
      "type": "object"
    },
    "ModelAttentionType": {
      "enum": [
        "full",
        "sliding_window",
        "block_sparse",
        "linear",
        "state_space",
        "hybrid",
        "custom",
        "unknown"
      ],
      "title": "ModelAttentionType",
      "type": "string"
    },
    "ModelExecutionKind": {
      "enum": [
        "dense",
        "sparse",
        "mixture_of_experts",
        "conditional",
        "hybrid",
        "unknown"
      ],
      "title": "ModelExecutionKind",
      "type": "string"
    },
    "ModelFormat": {
      "enum": [
        "safetensors",
        "pytorch_pickle",
        "gguf",
        "onnx",
        "torchscript",
        "numpy",
        "other",
        "unknown"
      ],
      "title": "ModelFormat",
      "type": "string"
    },
    "ModelSourceKind": {
      "description": "Where a model/tokenizer identity originated. A local snapshot may still carry a repository\nand revision, but network retrieval is never implied by this value.",
      "enum": [
        "local",
        "huggingface",
        "ollama",
        "artifact",
        "generated",
        "external",
        "unknown"
      ],
      "title": "ModelSourceKind",
      "type": "string"
    },
    "ModelTaskClass": {
      "enum": [
        "causal_lm",
        "masked_lm",
        "seq2seq_lm",
        "classification",
        "embedding",
        "reranker",
        "reward_model",
        "vision",
        "speech",
        "multimodal",
        "custom",
        "unknown"
      ],
      "title": "ModelTaskClass",
      "type": "string"
    },
    "ModelTopology": {
      "additionalProperties": false,
      "properties": {
        "execution_kind": {
          "$ref": "#/$defs/ModelExecutionKind",
          "default": "unknown"
        },
        "expert_counts": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExpertTopologyCounts"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "expert_groups": {
          "items": {
            "$ref": "#/$defs/ExpertGroup"
          },
          "title": "Expert Groups",
          "type": "array"
        },
        "inspection": {
          "$ref": "#/$defs/TopologyInspection"
        },
        "physical_scheduler_owner": {
          "const": "run_plan",
          "default": "run_plan",
          "title": "Physical Scheduler Owner",
          "type": "string"
        },
        "semantic_routing": {
          "anyOf": [
            {
              "$ref": "#/$defs/SemanticRouting"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "ModelTopology",
      "type": "object"
    },
    "ParameterComponent": {
      "additionalProperties": false,
      "description": "A representation component such as shared weights, router, experts, or an adapter.\n\nStored dtype is a raw representation string, not PrecisionMode (which describes run compute and\nincludes values such as tf32/mixed_bf16 that are not on-disk dtypes).",
      "properties": {
        "component_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Component Id",
          "type": "string"
        },
        "file_refs": {
          "items": {
            "type": "string"
          },
          "title": "File Refs",
          "type": "array"
        },
        "format": {
          "$ref": "#/$defs/ModelFormat"
        },
        "quantization": {
          "anyOf": [
            {
              "$ref": "#/$defs/QuantizationMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "quantization_details": {
          "additionalProperties": true,
          "title": "Quantization Details",
          "type": "object"
        },
        "scope": {
          "default": "all",
          "enum": [
            "all",
            "embedding",
            "shared",
            "router",
            "expert_group",
            "output_head",
            "adapter",
            "other"
          ],
          "title": "Scope",
          "type": "string"
        },
        "storage_dtype": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Storage Dtype"
        }
      },
      "required": [
        "component_id",
        "format"
      ],
      "title": "ParameterComponent",
      "type": "object"
    },
    "ParameterCount": {
      "additionalProperties": false,
      "description": "One explicitly scoped count. There is deliberately no scalar parameter_count field.",
      "properties": {
        "evidence": {
          "$ref": "#/$defs/EvidenceKind"
        },
        "handling": {
          "$ref": "#/$defs/ParameterCountHandling"
        },
        "kind": {
          "$ref": "#/$defs/ParameterCountKind"
        },
        "measurement_window": {
          "minLength": 1,
          "title": "Measurement Window",
          "type": "string"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "scope": {
          "minLength": 1,
          "title": "Scope",
          "type": "string"
        },
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        },
        "unit": {
          "default": "coordinates",
          "enum": [
            "coordinates",
            "elements",
            "parameters"
          ],
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "minimum": 0,
          "title": "Value",
          "type": "integer"
        }
      },
      "required": [
        "kind",
        "value",
        "scope",
        "measurement_window",
        "source",
        "evidence"
      ],
      "title": "ParameterCount",
      "type": "object"
    },
    "ParameterCountHandling": {
      "additionalProperties": false,
      "properties": {
        "decompressed_caches": {
          "$ref": "#/$defs/CountHandling",
          "default": "not_applicable"
        },
        "generated": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        },
        "optimizer_shadows": {
          "$ref": "#/$defs/CountHandling",
          "default": "not_applicable"
        },
        "quantized": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        },
        "replicated": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        },
        "shared": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        },
        "tied": {
          "$ref": "#/$defs/CountHandling",
          "default": "unknown"
        }
      },
      "title": "ParameterCountHandling",
      "type": "object"
    },
    "ParameterCountKind": {
      "description": "Distinct parameter quantities required for dense-safe and MoE-safe accounting.",
      "enum": [
        "logical",
        "active_token",
        "active_sequence",
        "touched_window",
        "resident",
        "updated_window",
        "exposed_window",
        "effective"
      ],
      "title": "ParameterCountKind",
      "type": "string"
    },
    "ParameterRepresentation": {
      "additionalProperties": false,
      "properties": {
        "components": {
          "items": {
            "$ref": "#/$defs/ParameterComponent"
          },
          "title": "Components",
          "type": "array"
        },
        "counts": {
          "items": {
            "$ref": "#/$defs/ParameterCount"
          },
          "title": "Counts",
          "type": "array"
        },
        "kind": {
          "$ref": "#/$defs/ModelExecutionKind",
          "default": "unknown"
        }
      },
