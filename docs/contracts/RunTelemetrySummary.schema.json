            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "MemoryWindowSummary",
      "type": "object"
    },
    "MetricSummary": {
      "additionalProperties": false,
      "description": "Descriptive statistics for one metric over a value set (measured steps/samples for a single\nrun, or trial values for a cross-trial set). ``sample_standard_deviation`` uses the ``n-1``\ndenominator and is null for ``count < 2``. Inputs are always the unrounded raw values.",
      "properties": {
        "count": {
          "minimum": 0,
          "title": "Count",
          "type": "integer"
        },
        "maximum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum"
        },
        "mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean"
        },
        "median": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Median"
        },
        "minimum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum"
        },
        "sample_standard_deviation": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sample Standard Deviation"
        },
        "unit": {
          "title": "Unit",
          "type": "string"
        }
      },
      "required": [
        "unit",
        "count"
      ],
      "title": "MetricSummary",
      "type": "object"
    },
    "OperatingSystem": {
      "enum": [
        "windows",
        "wsl",
        "linux",
        "macos",
        "unknown"
