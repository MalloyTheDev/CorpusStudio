{
  "$defs": {
    "AdapterMethod": {
      "enum": [
        "none",
        "lora",
        "qlora",
        "dora",
        "ia3",
        "full_finetune",
        "prompt_tuning",
        "prefix_tuning"
      ],
      "title": "AdapterMethod",
      "type": "string"
    },
    "AttentionImpl": {
      "description": "``math``/``eager`` is forced on native-Windows/WDDM Blackwell sm_120 because the fused flash\nkernel deadlocks there. Other platforms require their own functional capability result; WSL\nevidence is not bare-Linux proof.",
      "enum": [
        "math",
        "eager",
        "sdpa",
        "flash_attention_2",
        "flash_attention_3",
        "mem_efficient",
        "xformers"
      ],
      "title": "AttentionImpl",
      "type": "string"
    },
    "AttentionKernel": {
      "description": "The exact attention implementation an execution policy permits at runtime.",
      "enum": [
        "eager",
        "torch_sdpa_math",
        "torch_sdpa_flash",
        "torch_sdpa_mem_efficient",
        "flash_attention_2",
        "flash_attention_3",
        "xformers"
      ],
      "title": "AttentionKernel",
      "type": "string"
    },
    "CheckpointImpl": {
      "enum": [
        "full_state",
        "adapter_only",
        "sharded",
        "distcp",
        "safetensors"
      ],
      "title": "CheckpointImpl",
      "type": "string"
    },
    "DeviceKind": {
      "enum": [
        "cuda",
        "rocm",
        "mps",
        "xpu",
        "cpu"
      ],
      "title": "DeviceKind",
      "type": "string"
    },
    "ExecutionCapabilityCombination": {
      "additionalProperties": false,
      "description": "One execution tuple demonstrated together by a bounded functional probe.\n\nIndependent successes on precision, quantization, adapter, optimizer, loss, attention, and\ncheckpoint axes are diagnostic only. The planner may seal a run only from one of these complete\ntuples, preventing a union of unrelated probes from becoming a fictional capability.",
      "properties": {
        "adapter_method": {
          "$ref": "#/$defs/AdapterMethod"
        },
        "attention_impl": {
          "$ref": "#/$defs/AttentionImpl"
        },
        "attention_kernel": {
          "$ref": "#/$defs/AttentionKernel"
        },
        "checkpoint_impl": {
          "$ref": "#/$defs/CheckpointImpl"
        },
        "device": {
          "$ref": "#/$defs/DeviceKind"
        },
        "execution_contract_version": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Execution Contract Version",
          "type": "string"
        },
        "export_format": {
          "$ref": "#/$defs/ExportFormat"
        },
        "loss_impl": {
          "$ref": "#/$defs/LossImpl"
        },
        "optimizer": {
          "$ref": "#/$defs/Optimizer"
        },
        "precision": {
          "$ref": "#/$defs/PrecisionMode"
        },
        "probe": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Probe",
          "type": "string"
        },
        "quantization": {
          "$ref": "#/$defs/QuantizationMode"
        },
        "runtime_mode": {
          "enum": [
            "training",
            "cpu_toy"
          ],
          "title": "Runtime Mode",
          "type": "string"
        }
      },
      "required": [
        "runtime_mode",
        "device",
        "precision",
        "quantization",
        "adapter_method",
        "attention_impl",
        "attention_kernel",
        "optimizer",
        "loss_impl",
        "checkpoint_impl",
        "export_format",
        "execution_contract_version",
        "probe"
      ],
      "title": "ExecutionCapabilityCombination",
      "type": "object"
    },
    "ExportFormat": {
      "enum": [
        "adapter_peft",
        "merged_safetensors",
        "merged_fp16",
        "gguf",
        "onnx",
        "awq",
        "gptq",
        "mlx"
      ],
      "title": "ExportFormat",
      "type": "string"
    },
    "HashRef": {
      "additionalProperties": false,
      "description": "An algorithm-tagged digest. The engine emits sha256 today; the algo tag makes a future\nmigration additive (cf. versions/version_registry.FINGERPRINT_ALGO).",
      "properties": {
        "algo": {
          "default": "sha256",
          "enum": [
            "sha256",
            "sha256-ordered-exact-v1",
            "blake3",
            "none"
          ],
          "title": "Algo",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "title": "HashRef",
      "type": "object"
    },
    "InstallStep": {
      "additionalProperties": false,
      "description": "One bounded, argv-structured install command \u2014 NEVER a shell string, so an untrusted package or\nindex name can't inject a command (mirrors the no-shell trainer-launch invariant). ``argv[0]`` is\nthe executable; the rest are literal arguments.",
      "properties": {
        "argv": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Argv",
          "type": "array"
        },
        "configured_index_urls": {
          "items": {
            "type": "string"
          },
          "title": "Configured Index Urls",
          "type": "array"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "environment": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Environment",
          "type": "object"
        },
        "evidence_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Path"
        },
        "expected_outputs": {
          "items": {
            "type": "string"
          },
          "title": "Expected Outputs",
          "type": "array"
        },
        "native_build_expected": {
          "default": false,
          "title": "Native Build Expected",
          "type": "boolean"
        },
        "network_required": {
          "default": false,
          "title": "Network Required",
          "type": "boolean"
        },
        "phase": {
          "enum": [
            "create_venv",
            "upgrade_pip",
            "install",
            "verify"
          ],
          "title": "Phase",
          "type": "string"
        },
        "timeout_seconds": {
          "default": 1800,
          "minimum": 1,
          "title": "Timeout Seconds",
          "type": "integer"
        },
        "working_directory": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Working Directory"
        }
      },
      "required": [
        "phase",
        "argv"
      ],
      "title": "InstallStep",
      "type": "object"
    },
    "LossImpl": {
      "enum": [
        "cross_entropy",
        "liger_fused_ce",
        "chunked_ce",
        "dpo",
        "orpo",
        "kto",
        "ipo",
        "reward_bt"
      ],
      "title": "LossImpl",
      "type": "string"
    },
    "OperatingSystem": {
      "enum": [
        "windows",
        "wsl",
        "linux",
        "macos",
        "unknown"
      ],
      "title": "OperatingSystem",
      "type": "string"
    },
    "Optimizer": {
      "enum": [
        "adamw_torch",
        "adamw_torch_fused",
        "adamw_8bit",
        "adamw_bnb_8bit",
        "paged_adamw_8bit",
        "paged_adamw_32bit",
        "adafactor",
        "lion",
        "sgd"
      ],
      "title": "Optimizer",
      "type": "string"
    },
    "PrecisionMode": {
      "enum": [
        "fp32",
        "tf32",
        "fp16",
        "bf16",
        "fp8",
        "mixed_bf16",
        "mixed_fp16"
      ],
      "title": "PrecisionMode",
      "type": "string"
    },
    "PythonRuntime": {
      "additionalProperties": false,
      "description": "A discovered Python executable that can potentially create an isolated worker environment.\n\nDiscovery never assumes the control-plane interpreter is the only installation. Compatibility is\nan explicit verdict against the selected recipe, while ``venv_available`` proves the stdlib venv\nmodule can be located without creating anything.",
      "properties": {
        "architecture": {
          "default": "",
          "title": "Architecture",
          "type": "string"
        },
        "compatible": {
          "default": false,
          "title": "Compatible",
          "type": "boolean"
        },
        "contract_version": {
          "const": "1.0.0",
          "default": "1.0.0",
          "title": "Contract Version",
          "type": "string"
        },
        "executable": {
          "minLength": 1,
          "title": "Executable",
          "type": "string"
        },
        "implementation": {
          "default": "",
          "title": "Implementation",
          "type": "string"
        },
        "incompatibility_reasons": {
          "items": {
            "type": "string"
          },
          "title": "Incompatibility Reasons",
          "type": "array"
        },
        "is_virtual_environment": {
          "default": false,
          "title": "Is Virtual Environment",
          "type": "boolean"
        },
        "os": {
          "$ref": "#/$defs/OperatingSystem",
          "default": "unknown"
        },
        "platform": {
          "default": "",
          "title": "Platform",
          "type": "string"
        },
        "runtime_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Runtime Id",
          "type": "string"
        },
        "venv_available": {
          "default": false,
          "title": "Venv Available",
          "type": "boolean"
        },
        "version": {
          "default": "",
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "runtime_id",
        "executable"
      ],
      "title": "PythonRuntime",
      "type": "object"
    },
    "QloraExecutionProbeSpec": {
      "additionalProperties": false,
      "description": "The exact complete QLoRA tuple a readiness environment must prove as one operation.\n\nMath and flash tuples are independent identities. A math-only seal is never a flash claim, and\nindependent flash/bitsandbytes/optimizer probes cannot be unioned into a complete capability.",
      "properties": {
        "attention_api": {
          "const": "sdpa",
          "default": "sdpa",
          "title": "Attention Api",
          "type": "string"
        },
        "compute_dtype": {
          "const": "bf16",
          "default": "bf16",
          "description": "Seals both 4-bit dequantization compute and forward activation autocast; complete probe evidence must observe this value for compute_dtype and forward_autocast.",
          "title": "Compute Dtype",
          "type": "string"
        },
        "device": {
          "const": "cuda:0",
          "default": "cuda:0",
          "title": "Device",
          "type": "string"
        },
        "double_quantization": {
          "const": true,
          "default": true,
          "title": "Double Quantization",
          "type": "boolean"
        },
        "execution_combination": {
          "$ref": "#/$defs/ExecutionCapabilityCombination"
        },
        "flash_sdp_enabled": {
          "default": false,
          "title": "Flash Sdp Enabled",
          "type": "boolean"
        },
        "gradient_checkpointing": {
          "const": true,
          "default": true,
          "title": "Gradient Checkpointing",
          "type": "boolean"
        },
        "math_sdp_enabled": {
          "default": true,
          "title": "Math Sdp Enabled",
          "type": "boolean"
        },
        "memory_efficient_sdp_enabled": {
          "const": false,
          "default": false,
          "title": "Memory Efficient Sdp Enabled",
          "type": "boolean"
        },
        "optimizer": {
          "const": "adamw_torch",
          "default": "adamw_torch",
          "title": "Optimizer",
          "type": "string"
        },
        "probe": {
          "default": "cuda_qlora_math_execution",
          "enum": [
            "cuda_qlora_math_execution",
            "cuda_qlora_sdpa_flash_execution"
          ],
          "title": "Probe",
          "type": "string"
        },
        "quantization": {
          "const": "nf4",
          "default": "nf4",
          "title": "Quantization",
          "type": "string"
        },
        "require_adapter_round_trip": {
          "const": true,
          "default": true,
          "title": "Require Adapter Round Trip",
          "type": "boolean"
        },
        "required_distributions": {
          "items": {
            "type": "string"
          },
          "title": "Required Distributions",
          "type": "array"
        },
        "target_modules": {
          "const": "all-linear",
          "default": "all-linear",
          "title": "Target Modules",
          "type": "string"
        }
      },
      "required": [
        "execution_combination"
      ],
      "title": "QloraExecutionProbeSpec",
      "type": "object"
    },
    "QuantizationMode": {
      "enum": [
        "none",
        "int8",
        "int4",
        "nf4",
        "fp4",
        "gptq",
        "awq",
        "hqq"
      ],
      "title": "QuantizationMode",
      "type": "string"
    },
    "Ref": {
      "additionalProperties": false,
      "description": "A stable reference to another contract instance by id, optionally pinned to a content hash so\nthe reference cannot silently re-point.",
      "properties": {
        "hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        }
      },
      "required": [
        "id"
      ],
      "title": "Ref",
      "type": "object"
    },
    "WorkerArtifactIdentity": {
      "additionalProperties": false,
      "description": "Immutable identity of the exact wheel executed by a managed backend worker.\n\nA mutable checkout is not a worker identity. The plan binds a concrete wheel before mutation;\nthe post-install lock binds the same wheel and the installed distribution evidence.",
      "properties": {
        "content_hash": {
          "$ref": "#/$defs/HashRef"
        },
        "contract_version": {
          "const": "1.0.0",
          "default": "1.0.0",
          "title": "Contract Version",
          "type": "string"
        },
        "distribution_name": {
          "minLength": 1,
          "title": "Distribution Name",
          "type": "string"
        },
        "filename": {
          "minLength": 1,
          "title": "Filename",
          "type": "string"
        },
        "metadata_hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "normalized_name": {
          "minLength": 1,
          "title": "Normalized Name",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 1,
          "title": "Size Bytes",
          "type": "integer"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "distribution_name",
        "normalized_name",
        "version",
        "filename",
        "path",
        "size_bytes",
        "content_hash"
      ],
      "title": "WorkerArtifactIdentity",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "The resolved PREVIEW of provisioning a recipe on a specific host \u2014 the exact argv steps, the\nchosen wheel index, and the disk/network cost \u2014 for explicit user confirmation BEFORE anything is\ninstalled. Pure/derivable; no environment is created to produce it. NEW.",
  "properties": {
    "accelerator_tag": {
      "default": "cpu",
      "title": "Accelerator Tag",
      "type": "string"
    },
    "blocking_reasons": {
      "items": {
        "type": "string"
      },
      "title": "Blocking Reasons",
      "type": "array"
    },
    "contract_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Contract Version",
      "type": "string"
    },
    "environment_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/Ref"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "environment_root": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Environment Root"
    },
    "estimated_disk_bytes": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Estimated Disk Bytes"
    },
    "estimated_download_bytes": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Estimated Download Bytes"
    },
    "install_steps": {
      "items": {
        "$ref": "#/$defs/InstallStep"
      },
      "title": "Install Steps",
      "type": "array"
    },
    "manager_version": {
      "default": "",
      "title": "Manager Version",
      "type": "string"
    },
    "os": {
      "$ref": "#/$defs/OperatingSystem",
      "default": "unknown"
    },
    "python_version": {
      "default": "",
      "title": "Python Version",
      "type": "string"
    },
    "recipe_ref": {
      "$ref": "#/$defs/Ref"
    },
    "required_execution_probe": {
      "anyOf": [
        {
          "$ref": "#/$defs/QloraExecutionProbeSpec"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "required_git_ancestor": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Required Git Ancestor"
    },
    "resolution_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Resolution Hash"
    },
    "resolvable": {
      "default": true,
      "title": "Resolvable",
      "type": "boolean"
    },
    "resolved_index_urls": {
      "items": {
        "type": "string"
      },
      "title": "Resolved Index Urls",
      "type": "array"
    },
    "runtime": {
      "anyOf": [
        {
          "$ref": "#/$defs/PythonRuntime"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    },
    "worker_artifact": {
      "anyOf": [
        {
          "$ref": "#/$defs/WorkerArtifactIdentity"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "worker_source_commit": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Worker Source Commit"
    }
  },
  "required": [
    "recipe_ref"
  ],
  "title": "DependencyResolution",
  "type": "object"
}
