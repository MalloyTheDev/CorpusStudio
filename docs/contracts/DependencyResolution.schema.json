{
  "$defs": {
    "HashRef": {
      "additionalProperties": false,
      "description": "An algorithm-tagged digest. The engine emits sha256 today; the algo tag makes a future\nmigration additive (cf. versions/version_registry.FINGERPRINT_ALGO).",
      "properties": {
        "algo": {
          "default": "sha256",
          "enum": [
            "sha256",
            "sha256-ordered-exact-v1",
            "blake3",
            "none"
          ],
          "title": "Algo",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "title": "HashRef",
      "type": "object"
    },
    "InstallStep": {
      "additionalProperties": false,
      "description": "One bounded, argv-structured install command \u2014 NEVER a shell string, so an untrusted package or\nindex name can't inject a command (mirrors the no-shell trainer-launch invariant). ``argv[0]`` is\nthe executable; the rest are literal arguments.",
      "properties": {
        "argv": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Argv",
          "type": "array"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "environment": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Environment",
          "type": "object"
        },
        "expected_outputs": {
          "items": {
            "type": "string"
          },
          "title": "Expected Outputs",
          "type": "array"
        },
        "native_build_expected": {
          "default": false,
          "title": "Native Build Expected",
          "type": "boolean"
        },
        "network_required": {
          "default": false,
          "title": "Network Required",
          "type": "boolean"
        },
        "phase": {
          "enum": [
            "create_venv",
            "upgrade_pip",
            "install",
            "verify"
          ],
          "title": "Phase",
          "type": "string"
        },
        "timeout_seconds": {
          "default": 1800,
          "minimum": 1,
          "title": "Timeout Seconds",
          "type": "integer"
        },
        "working_directory": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Working Directory"
        }
      },
      "required": [
        "phase",
        "argv"
      ],
      "title": "InstallStep",
      "type": "object"
    },
    "OperatingSystem": {
      "enum": [
        "windows",
        "wsl",
        "linux",
        "macos",
        "unknown"
      ],
      "title": "OperatingSystem",
      "type": "string"
    },
    "PythonRuntime": {
      "additionalProperties": false,
      "description": "A discovered Python executable that can potentially create an isolated worker environment.\n\nDiscovery never assumes the control-plane interpreter is the only installation. Compatibility is\nan explicit verdict against the selected recipe, while ``venv_available`` proves the stdlib venv\nmodule can be located without creating anything.",
      "properties": {
        "architecture": {
          "default": "",
          "title": "Architecture",
          "type": "string"
        },
        "compatible": {
          "default": false,
          "title": "Compatible",
          "type": "boolean"
        },
        "contract_version": {
          "const": "1.0.0",
          "default": "1.0.0",
          "title": "Contract Version",
          "type": "string"
        },
        "executable": {
          "minLength": 1,
          "title": "Executable",
          "type": "string"
        },
        "implementation": {
          "default": "",
          "title": "Implementation",
          "type": "string"
        },
        "incompatibility_reasons": {
          "items": {
            "type": "string"
          },
          "title": "Incompatibility Reasons",
          "type": "array"
        },
        "is_virtual_environment": {
          "default": false,
          "title": "Is Virtual Environment",
          "type": "boolean"
        },
        "os": {
          "$ref": "#/$defs/OperatingSystem",
          "default": "unknown"
        },
        "platform": {
          "default": "",
          "title": "Platform",
          "type": "string"
        },
        "runtime_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Runtime Id",
          "type": "string"
        },
        "venv_available": {
          "default": false,
          "title": "Venv Available",
          "type": "boolean"
        },
        "version": {
          "default": "",
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "runtime_id",
        "executable"
      ],
      "title": "PythonRuntime",
      "type": "object"
    },
    "Ref": {
      "additionalProperties": false,
      "description": "A stable reference to another contract instance by id, optionally pinned to a content hash so\nthe reference cannot silently re-point.",
      "properties": {
        "hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        }
      },
      "required": [
        "id"
      ],
      "title": "Ref",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "The resolved PREVIEW of provisioning a recipe on a specific host \u2014 the exact argv steps, the\nchosen wheel index, and the disk/network cost \u2014 for explicit user confirmation BEFORE anything is\ninstalled. Pure/derivable; no environment is created to produce it. NEW.",
  "properties": {
    "accelerator_tag": {
      "default": "cpu",
      "title": "Accelerator Tag",
      "type": "string"
    },
    "blocking_reasons": {
      "items": {
        "type": "string"
      },
      "title": "Blocking Reasons",
      "type": "array"
    },
    "contract_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Contract Version",
      "type": "string"
    },
    "environment_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/Ref"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "environment_root": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Environment Root"
    },
    "estimated_disk_bytes": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Estimated Disk Bytes"
    },
    "estimated_download_bytes": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Estimated Download Bytes"
    },
    "install_steps": {
      "items": {
        "$ref": "#/$defs/InstallStep"
      },
      "title": "Install Steps",
      "type": "array"
    },
    "manager_version": {
      "default": "",
      "title": "Manager Version",
      "type": "string"
    },
    "os": {
      "$ref": "#/$defs/OperatingSystem",
      "default": "unknown"
    },
    "python_version": {
      "default": "",
      "title": "Python Version",
      "type": "string"
    },
    "recipe_ref": {
      "$ref": "#/$defs/Ref"
    },
    "resolution_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Resolution Hash"
    },
    "resolvable": {
      "default": true,
      "title": "Resolvable",
      "type": "boolean"
    },
    "resolved_index_urls": {
      "items": {
        "type": "string"
      },
      "title": "Resolved Index Urls",
      "type": "array"
    },
    "runtime": {
      "anyOf": [
        {
          "$ref": "#/$defs/PythonRuntime"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "recipe_ref"
  ],
  "title": "DependencyResolution",
  "type": "object"
}
