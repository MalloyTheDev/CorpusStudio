<Window x:Class="CorpusStudio.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CorpusStudio.Desktop.ViewModels"
        xmlns:local="clr-namespace:CorpusStudio.Desktop"
        Title="Corpus Studio"
        Height="800"
        Width="1180"
        MinHeight="680"
        MinWidth="960"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <!-- DataContext is injected by the DI container in App.OnStartup (backlog #4) so the shell
         view-model can compose child per-tab view-models via constructor injection. -->

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F7FB" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D8E0EA" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#101828" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#F8FAFC" />

        <Style TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#102033" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#B8C4D4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF4FF" />
                                <Setter Property="BorderBrush" Value="#93B4F8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DBEAFE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#94A3B8" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF2F7" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D8E0EA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="#CAD5E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="SelectionBrush" Value="#BBD3FF" />
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="#CAD5E3" />
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="#CAD5E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Padding" Value="13,8" />
            <Setter Property="Margin" Value="0,0,6,8" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <!-- Flat by default so a 14-tab strip reads as a light segmented control,
                             not a wall of boxes; the selected tab lifts to a white pill. -->
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#E7EEF8" />
                                <Setter Property="Foreground" Value="#334155" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource PanelBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#DCE5F0" />
                                <Setter Property="Foreground" Value="#1D4ED8" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StagePillStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#EEF4FF" />
            <Setter Property="BorderBrush" Value="#C7D7FE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="11,6" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <SolidColorBrush x:Key="HeadingTextBrush" Color="#0F172A" />

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E40AF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#E2E8F0" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#93B4F8" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#93B4F8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeaderTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource HeadingTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,9" />
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <!-- Dashboard (v1.2.10) — roomier, softer cards + a bigger section header + a large
             metric value, so the overview reads as a calm dashboard instead of dense boxes. -->
        <Style x:Key="DashboardCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="#E6EDF5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#1E293B" BlurRadius="16" ShadowDepth="2"
                                      Direction="270" Opacity="0.07" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardSectionHeaderStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource HeadingTextBrush}" />
            <Setter Property="Margin" Value="2,0,0,12" />
        </Style>

        <Style x:Key="DashboardCardLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DashboardMetricStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="32" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource HeadingTextBrush}" />
        </Style>

        <Style x:Key="FilterGroupBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#FBFCFE" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />

        <Style x:Key="ListEmptyPlaceholderStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="16" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <!-- Workspace activity-bar buttons (v1.2.4 view layer) -->
        <Style x:Key="ActivityButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ActivityBorder" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActivityBorder" Property="Background" Value="#1F2937" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActivityBrandStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2563EB" Offset="0" />
                                    <GradientStop Color="#1D4ED8" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Start Center primary + secondary action buttons -->
        <Style x:Key="StartActionPrimaryStyle" TargetType="{x:Type Button}">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="StartBorder" CornerRadius="9" Padding="15,13" Background="#2563EB" BorderBrush="#2563EB" BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StartBorder" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="StartBorder" Property="BorderBrush" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StartActionSecondaryStyle" TargetType="{x:Type Button}">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="StartBorder" CornerRadius="9" Padding="15,13" Background="#FFFFFF" BorderBrush="#CAD5E3" BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StartBorder" Property="Background" Value="#EEF4FF" />
                                <Setter TargetName="StartBorder" Property="BorderBrush" Value="#93B4F8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Explorer sidebar header icon buttons -->
        <Style x:Key="ExplorerIconStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ExplorerIconBorder" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ExplorerIconBorder" Property="Background" Value="#EEF4FF" />
                                <Setter Property="Foreground" Value="#2563EB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Projects list on the dark sidebar (v1.2.14): two-line cards that fit the theme,
             replacing the harsh white box + truncated "Name (id)" rows. -->
        <Style x:Key="SidebarProjectItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1E293B" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1D4ED8" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">

        <!-- ===================== WORKSPACE SHELL (activity bar + Studio/Files) ===================== -->
        <!-- Visible unless the full-window Start Center is showing. -->
        <Grid Visibility="{Binding IsStartCenter, Converter={StaticResource InverseBoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- activity bar -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <DockPanel Margin="0,10">
                    <Button x:Name="ActivitySettingsButton" DockPanel.Dock="Bottom" Click="ActivitySettingsButton_Click"
                            ToolTip="Settings" Style="{StaticResource ActivityButtonStyle}" HorizontalAlignment="Center">
                        <Path Data="M12,8 A4,4 0 1 0 12.001,8 M12,3 V5 M12,19 V21 M3,12 H5 M19,12 H21 M6,6 L7.5,7.5 M16.5,16.5 L18,18 M6,18 L7.5,16.5 M16.5,7.5 L18,6"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Width="19" Height="19" Stretch="Uniform" />
                    </Button>
                    <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center">
                        <Button x:Name="ActivityHomeButton" Click="ActivityHomeButton_Click" ToolTip="Start Center"
                                Style="{StaticResource ActivityBrandStyle}" Content="C" Margin="0,0,0,8" />
                        <Button x:Name="ActivityFilesButton" Click="ActivityFilesButton_Click" ToolTip="Explorer (Files)"
                                Style="{StaticResource ActivityButtonStyle}" Margin="0,2">
                            <Path Data="M3,6 A1,1 0 0 1 4,5 H8 L10,7 H20 A1,1 0 0 1 21,8 V18 A1,1 0 0 1 20,19 H4 A1,1 0 0 1 3,18 Z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" />
                        </Button>
                        <Button x:Name="ActivityStudioButton" Click="ActivityStudioButton_Click" ToolTip="Studio (Dashboard &amp; Labs)"
                                Style="{StaticResource ActivityButtonStyle}" Margin="0,2">
                            <Path Data="M4,4 H10 V11 H4 Z M14,4 H20 V9 H14 Z M14,13 H20 V20 H14 Z M4,15 H10 V20 H4 Z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" />
                        </Button>
                        <Border Width="22" Height="1" Background="#1F2937" Margin="0,8" />
                        <Button x:Name="SearchButton" Click="ActivitySearchButton_Click" ToolTip="Search (find in files)" Style="{StaticResource ActivityButtonStyle}" Margin="0,2">
                            <Path Data="M11,4 A7,7 0 1 0 11.001,4 M16.5,16.5 L21,21"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent" Width="18" Height="18" Stretch="Uniform" />
                        </Button>
                        <Button x:Name="ProblemsButton" Click="ProblemsButton_Click" ToolTip="Problems (dataset gate findings)" Style="{StaticResource ActivityButtonStyle}" Margin="0,2">
                            <Grid Width="24" Height="24">
                                <Path Data="M12,3 L21,20 H3 Z M12,9 V14 M12,17 H12.01"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent" Width="18" Height="18" Stretch="Uniform" />
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                                        Background="{Binding ProblemsBadgeColor}" CornerRadius="7" MinWidth="14" Height="14" Padding="3,0"
                                        Visibility="{Binding HasProblemsBadge, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding ProblemsBadge}" Foreground="White" FontSize="9" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Button>
                        <Button x:Name="OutputButton" Click="OutputButton_Click" ToolTip="Output / Logs (engine activity)" Style="{StaticResource ActivityButtonStyle}" Margin="0,2">
                            <Path Data="M4,7 H20 M4,12 H20 M4,17 H14"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Width="18" Height="18" Stretch="Uniform" />
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- content: Studio (existing app) or Files (placeholder) -->
            <Grid Grid.Column="1">

                <!-- FILES VIEW — Universal Workspace Explorer -->
                <Grid Visibility="{Binding IsFiles, Converter={StaticResource BoolToVis}}" Background="{StaticResource AppBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="266" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- explorer sidebar -->
                    <Border Grid.Column="0" Background="#FBFCFE" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                        <DockPanel>
                            <!-- header -->
                            <Grid DockPanel.Dock="Top" Margin="12,11,8,8">
                                <TextBlock Text="EXPLORER" FontSize="11" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button ToolTip="New File" Click="ExplorerNewFile_Click" Style="{StaticResource ExplorerIconStyle}">
                                        <Path Data="M14,3 H7 A2,2 0 0 0 5,5 V19 A2,2 0 0 0 7,21 H17 A2,2 0 0 0 19,19 V8 Z M14,3 V8 H19 M12,12 V17 M9.5,14.5 H14.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" Fill="Transparent" Width="15" Height="15" Stretch="Uniform" />
                                    </Button>
                                    <Button ToolTip="New Folder" Click="ExplorerNewFolder_Click" Style="{StaticResource ExplorerIconStyle}">
                                        <Path Data="M3,7 A2,2 0 0 1 5,5 H9 L11,7 H19 A2,2 0 0 1 21,9 V17 A2,2 0 0 1 19,19 H5 A2,2 0 0 1 3,17 Z M12,11 V16 M9.5,13.5 H14.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" Fill="Transparent" Width="15" Height="15" Stretch="Uniform" />
                                    </Button>
                                    <Button ToolTip="Refresh" Click="ExplorerRefresh_Click" Style="{StaticResource ExplorerIconStyle}">
                                        <Path Data="M21,12 A9,9 0 1 1 18,5.3 L21,8 M21,3 V8 H16" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" Fill="Transparent" Width="15" Height="15" Stretch="Uniform" />
                                    </Button>
                                    <Button ToolTip="Collapse all" Click="ExplorerCollapseAll_Click" Style="{StaticResource ExplorerIconStyle}">
                                        <Path Data="M9,4 V9 H4 M15,20 V15 H20 M20,4 L15,9 M4,20 L9,15" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" Fill="Transparent" Width="15" Height="15" Stretch="Uniform" />
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- workspace root row -->
                            <Border DockPanel.Dock="Top" BorderBrush="#EEF2F7" BorderThickness="0,0,0,1" Padding="12,2,12,8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="20" Height="20" CornerRadius="5" Margin="0,0,7,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#2563EB" Offset="0" />
                                                <GradientStop Color="#1D4ED8" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="C" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="{Binding Explorer.WorkspaceName}" FontSize="12" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>

                            <!-- status bar -->
                            <Border DockPanel.Dock="Bottom" BorderBrush="#EEF2F7" BorderThickness="0,1,0,0" Padding="12,7">
                                <TextBlock Text="{Binding Explorer.ExplorerStatus}" FontSize="11" Foreground="#94A3B8" TextTrimming="CharacterEllipsis" />
                            </Border>

                            <!-- tree -->
                            <TreeView x:Name="ExplorerTree" ItemsSource="{Binding Explorer.RootNode.Children}"
                                      SelectedItemChanged="ExplorerTree_SelectedItemChanged"
                                      BorderThickness="0" Background="Transparent" Padding="4">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="{x:Type TreeViewItem}">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Height="22">
                                            <Path Data="M3,7 A1,1 0 0 1 4,6 H8 L10,8 H20 A1,1 0 0 1 21,9 V17 A1,1 0 0 1 20,18 H4 A1,1 0 0 1 3,17 Z"
                                                  Stroke="#94A3B8" StrokeThickness="1.3" Fill="#EEF2F7" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center"
                                                  Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVis}}" />
                                            <Border Width="22" Height="14" CornerRadius="3" Background="#EEF4FF" VerticalAlignment="Center"
                                                    Visibility="{Binding IsDirectory, Converter={StaticResource InverseBoolToVis}}">
                                                <TextBlock Text="{Binding ChipLabel}" FontSize="7.5" FontWeight="Bold" Foreground="#1D4ED8" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontSize="12.5" Foreground="#334155" VerticalAlignment="Center" Margin="6,0,0,0" />
                                            <Ellipse Width="6" Height="6" Fill="#F59E0B" VerticalAlignment="Center" Margin="6,0,0,0" ToolTip="Generated · opens read-only"
                                                     Visibility="{Binding IsGeneratedArtifact, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </DockPanel>
                    </Border>

                    <!-- editor column -->
                    <Grid Grid.Column="1" Background="#FFFFFF">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- document tabs -->
                        <Border Grid.Row="0" Height="38" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Explorer.OpenDocuments}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Border x:Name="Tab" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0" Cursor="Hand"
                                                        MouseLeftButtonDown="DocTab_Click" Padding="13,0,8,0">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12.5" Foreground="#0F172A" VerticalAlignment="Center" />
                                                        <Path Data="M5,11 H19 V20 H5 Z M8,11 V8 A4,4 0 0 1 16,8 V11" Stroke="#94A3B8" StrokeThickness="1.5" Fill="Transparent" Width="11" Height="11" Stretch="Uniform" Margin="6,0,0,0" VerticalAlignment="Center"
                                                              Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}}" />
                                                        <Border MouseLeftButtonDown="DocTabClose_Click" Width="18" Height="18" CornerRadius="4" Background="Transparent" Margin="6,0,0,0" Cursor="Hand">
                                                            <Grid>
                                                                <Ellipse Width="8" Height="8" Fill="#2563EB" Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}" />
                                                                <TextBlock Text="✕" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsDirty, Converter={StaticResource InverseBoolToVis}}" />
                                                            </Grid>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                                <Border x:Name="Accent" Height="2" VerticalAlignment="Top" Background="#2563EB" Visibility="Collapsed" />
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter TargetName="Tab" Property="Background" Value="#FFFFFF" />
                                                    <Setter TargetName="Accent" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <!-- editor toolbar -->
                        <Border Grid.Row="1" Height="40" Background="#FBFCFE" BorderBrush="#EEF2F7" BorderThickness="0,0,0,1">
                            <Grid Margin="14,0">
                                <TextBlock Text="{Binding Explorer.ActiveRelPath}" FontFamily="Consolas" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Border Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="11" Padding="9,2" Margin="0,0,8,0" VerticalAlignment="Center"
                                            Visibility="{Binding Explorer.ActiveDocument.IsReadOnly, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                        <TextBlock Text="Read-only" Foreground="#9A3412" FontSize="10.5" FontWeight="SemiBold" />
                                    </Border>
                                    <Button Content="Reveal" Click="ExplorerReveal_Click" Height="28" Padding="10,0" Margin="0,0,8,0" />
                                    <Button Content="Copy path" Click="ExplorerCopyPath_Click" Height="28" Padding="10,0" Margin="0,0,8,0" />
                                    <Button Content="Save" Click="ExplorerSave_Click" Height="28" Padding="13,0"
                                            IsEnabled="{Binding Explorer.ActiveDocument.IsDirty, FallbackValue=False}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- examples.jsonl caution -->
                        <Border Grid.Row="2" Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="0,0,0,1" Padding="14,8"
                                Visibility="{Binding Explorer.IsExamplesFile, Converter={StaticResource BoolToVis}}">
                            <TextBlock Foreground="#92400E" FontSize="12" TextWrapping="Wrap"
                                       Text="This is the dataset's single source of rows. The desktop is its only writer — edits here are explicit and never auto-formatted. Use Writing Studio / Import for row-level changes." />
                        </Border>

                        <!-- viewer + metadata -->
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="240" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <!-- text / report -->
                                <TextBox Visibility="{Binding Explorer.IsTextDocument, Converter={StaticResource BoolToVis}}"
                                         Text="{Binding Explorer.ActiveDocument.TextContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}"
                                         IsReadOnly="{Binding Explorer.ActiveDocument.IsReadOnly, FallbackValue=True}"
                                         FontFamily="Consolas" FontSize="13" AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         BorderThickness="0" Padding="14" Background="#FFFFFF" />
                                <!-- image -->
                                <Grid Visibility="{Binding Explorer.IsImageDocument, Converter={StaticResource BoolToVis}}" Background="#F1F5F9">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" MaxWidth="480">
                                            <Image Source="{Binding Explorer.ActiveDocument.ImagePreviewPath}" Stretch="Uniform" MaxHeight="320" />
                                        </Border>
                                        <TextBlock Text="Preview only — opening an image never creates a dataset row." Foreground="#64748B" FontSize="11" Margin="0,12,0,0" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                                <!-- binary / unknown -->
                                <Grid Visibility="{Binding Explorer.IsBinaryDocument, Converter={StaticResource BoolToVis}}" Background="#F8FAFC">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360">
                                        <TextBlock Text="Binary file — no text preview" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Center" />
                                        <TextBlock Text="Weight/artifact files are referenced by path and never modified by Corpus Studio. See metadata on the right." Foreground="#64748B" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap" TextAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                                <!-- empty -->
                                <TextBlock Visibility="{Binding Explorer.IsNoDocument, Converter={StaticResource BoolToVis}}"
                                           Text="Select a file in the Explorer to open it." Foreground="#94A3B8" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>

                            <!-- metadata panel -->
                            <Border Grid.Column="1" Background="#FBFCFE" BorderBrush="#EEF2F7" BorderThickness="1,0,0,0" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="SELECTED FILE" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,10" />
                                    <ItemsControl ItemsSource="{Binding Explorer.MetadataRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,11">
                                                    <TextBlock Text="{Binding Key}" FontSize="10.5" Foreground="#94A3B8" />
                                                    <TextBlock Text="{Binding Value}" FontSize="12" Foreground="#334155" TextWrapping="Wrap" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Select a file to see its details." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap"
                                               Visibility="{Binding Explorer.IsNoDocument, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- STUDIO = the existing 14-tab app, preserved intact -->
                <Grid Visibility="{Binding IsStudio, Converter={StaticResource BoolToVis}}" Background="{StaticResource AppBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="270" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="#1F2937"
                BorderThickness="0,0,1,0"
                Padding="20,22">
            <StackPanel>
                <TextBlock Text="Corpus Studio"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#F8FAFC" />
                <TextBlock Text="Dataset Creation Studio"
                           Margin="0,5,0,28"
                           Foreground="#CBD5E1" />

                <Button Style="{StaticResource PrimaryButtonStyle}"
                        AutomationProperties.AutomationId="NewDatasetProjectButton"
                        Content="New Dataset Project"
                        Margin="0,0,0,10"
                        Click="NewDatasetProjectButton_Click" />
                <Button AutomationProperties.AutomationId="ImportDatasetButton"
                        Content="Import Dataset"
                        Margin="0,0,0,10"
                        Click="ImportDatasetButton_Click" />
                <Button AutomationProperties.AutomationId="ImportFromHuggingFaceButton"
                        Content="Import from Hugging Face"
                        Margin="0,0,0,10"
                        Click="ImportFromHuggingFaceButton_Click" />
                <Button AutomationProperties.AutomationId="ExportCenterButton"
                        Content="Export Center"
                        Margin="0,0,0,28"
                        Click="ExportCenterButton_Click" />

                <TextBlock Text="Projects"
                           FontWeight="Bold"
                           Foreground="#E2E8F0"
                           Margin="0,0,0,10" />
                <Grid Margin="0,0,0,8">
                    <TextBox x:Name="ProjectSearchBox"
                             AutomationProperties.AutomationId="ProjectSearchTextBox"
                             Text="{Binding ProjectSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Filter projects by name, id, or schema"
                             Background="#0B1220" Foreground="#E2E8F0" BorderBrush="#293548"
                             CaretBrush="#E2E8F0" Padding="9,6" />
                    <TextBlock Text="Filter projects…" IsHitTestVisible="False"
                               Foreground="#64748B" Margin="11,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=ProjectSearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <ListBox AutomationProperties.AutomationId="ProjectsListBox"
                         ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                         SelectionChanged="ProjectsListBox_SelectionChanged"
                         Background="Transparent" BorderThickness="0" Padding="0"
                         MaxHeight="340"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource SidebarProjectItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />
                                <TextBlock Text="{Binding SchemaId}" FontSize="10.5" Foreground="#94A3B8"
                                           TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button AutomationProperties.AutomationId="RebuildProjectIndexButton"
                        Content="Rebuild Index"
                        Margin="0,10,0,6"
                        Click="RebuildProjectIndexButton_Click" />
                <TextBlock AutomationProperties.AutomationId="ProjectIndexSummaryTextBlock"
                           Text="{Binding ProjectIndexSummary, Mode=OneWay}"
                           Foreground="#94A3B8"
                           FontSize="11"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Padding="26,24"
                Background="{StaticResource AppBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="22,20"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding ActiveProjectTitle}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />
                            <TextBlock Text="{Binding ActiveSchemaDescription}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />
                            <WrapPanel Margin="0,10,0,0">
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Dataset" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Validate" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Split" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Evaluate" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Assist" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Export" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Train Config" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="16,0,0,0">
                        <!-- Dataset debt grade badge (v1.2.8). At-a-glance grade in the header;
                             passive (reflects the last debt check, invalidates on dataset change,
                             never auto-runs); click opens the Debt tab to run / see the ledger. -->
                        <Button Click="GoToDebtTab_Click" ToolTip="Dataset debt grade — click for the debt ledger"
                                Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0"
                                VerticalAlignment="Top">
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="8" Padding="12,8">
                                <StackPanel>
                                    <TextBlock Text="Dataset debt" FontWeight="SemiBold" FontSize="11"
                                               Foreground="#475569" HorizontalAlignment="Center" />
                                    <Border Width="34" Height="34" CornerRadius="8" Margin="0,5,0,0"
                                            Background="{Binding Debt.DebtGradeColor, Mode=OneWay}" HorizontalAlignment="Center">
                                        <TextBlock AutomationProperties.AutomationId="DashboardDebtGradeBadge"
                                                   Text="{Binding Debt.DebtGrade, Mode=OneWay}"
                                                   Foreground="White" FontSize="17" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="stale" FontSize="9" FontWeight="SemiBold" Foreground="#D97706"
                                               HorizontalAlignment="Center" Margin="0,3,0,0"
                                               Visibility="{Binding Debt.DebtStale, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Border>
                        </Button>
                        <Border Background="#ECFDF5"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,8"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Local-first"
                                           FontWeight="SemiBold"
                                           Foreground="#166534" />
                                <TextBlock Text="Files stay inspectable"
                                           Foreground="#166534" />
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#FEF2F2"
                        BorderBrush="#FCA5A5"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,0,0,12"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="&#x26A0;"
                                       FontSize="15"
                                       Foreground="#B91C1C"
                                       VerticalAlignment="Top"
                                       Margin="0,0,10,0" />
                            <TextBlock AutomationProperties.AutomationId="ErrorBannerTextBlock"
                                       Text="{Binding ErrorMessage, Mode=OneWay}"
                                       Foreground="#7F1D1D"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                AutomationProperties.AutomationId="DismissErrorButton"
                                Content="Dismiss"
                                Width="88"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                Click="DismissErrorButton_Click" />
                    </Grid>
                </Border>

                <TabControl Grid.Row="2">
                    <TabItem x:Name="DashboardTab" Header="Dashboard">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="22,20,18,20">
                            <StackPanel>
                                <TextBlock Text="Quick actions"
                                           Style="{StaticResource DashboardSectionHeaderStyle}" />
                                <WrapPanel Margin="0,0,0,26">
                                    <Button Style="{StaticResource PrimaryButtonStyle}"
                                            AutomationProperties.AutomationId="DashboardAuthorButton"
                                            Content="Author examples"
                                            Width="150" MinHeight="38" Margin="0,0,10,10"
                                            Click="GoToWritingStudioButton_Click" />
                                    <Button AutomationProperties.AutomationId="DashboardRunQualityButton"
                                            Content="Run quality"
                                            Width="132" MinHeight="38" Margin="0,0,10,10"
                                            Click="RunQualityButton_Click" />
                                    <Button AutomationProperties.AutomationId="DashboardSplitsButton"
                                            Content="Generate splits"
                                            Width="132" MinHeight="38" Margin="0,0,10,10"
                                            Click="GoToSplitsButton_Click" />
                                    <Button AutomationProperties.AutomationId="DashboardEvaluationButton"
                                            Content="Run evaluation"
                                            Width="132" MinHeight="38" Margin="0,0,10,10"
                                            Click="GoToEvaluationButton_Click" />
                                    <Button AutomationProperties.AutomationId="DashboardTrainingButton"
                                            Content="Training config"
                                            Width="132" MinHeight="38" Margin="0,0,10,10"
                                            Click="GoToTrainingButton_Click" />
                                    <Button AutomationProperties.AutomationId="DashboardNewProjectButton"
                                            Content="New project"
                                            Width="132" MinHeight="38" Margin="0,0,10,10"
                                            Click="NewDatasetProjectButton_Click" />
                                </WrapPanel>

                                <TextBlock Text="Project overview"
                                           Style="{StaticResource DashboardSectionHeaderStyle}"
                                           Margin="2,2,0,12" />
                                <StackPanel>
                                    <!-- Dataset -->
                                    <Border Style="{StaticResource DashboardCardStyle}"
                                            Margin="0,0,0,14">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Border Width="34" Height="34" CornerRadius="9" Background="#EFF6FF">
                                                    <Path Data="M12,3 L21,8 L12,13 L3,8 Z M3,12 L12,17 L21,12 M3,16 L12,21 L21,16"
                                                          Stroke="#2563EB" StrokeThickness="1.5" Fill="Transparent"
                                                          Width="18" Height="18" Stretch="Uniform"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="Dataset" Style="{StaticResource DashboardCardLabelStyle}" Margin="11,0,0,0" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Examples.Items.Count, Mode=OneWay}"
                                                           Style="{StaticResource DashboardMetricStyle}" />
                                                <TextBlock Text="saved examples"
                                                           Style="{StaticResource CaptionTextStyle}"
                                                           VerticalAlignment="Bottom" Margin="9,0,0,6" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding ActiveSchemaDescription, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextStyle}" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Quality -->
                                    <Border Style="{StaticResource DashboardCardStyle}"
                                            Margin="0,0,0,14">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Border Width="34" Height="34" CornerRadius="9" Background="#ECFDF5">
                                                    <Path Data="M12,3 L20,6 V11 C20,16 16,20 12,21 C8,20 4,16 4,11 V6 Z M9,11.5 L11,13.5 L15,9.5"
                                                          Stroke="#16A34A" StrokeThickness="1.5" Fill="Transparent"
                                                          Width="18" Height="18" Stretch="Uniform"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="Quality" Style="{StaticResource DashboardCardLabelStyle}" Margin="11,0,0,0" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding QualitySummary, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Splits -->
                                    <Border Style="{StaticResource DashboardCardStyle}"
                                            Margin="0,0,0,14">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Border Width="34" Height="34" CornerRadius="9" Background="#F5F3FF">
                                                    <Path Data="M4,6 H20 V18 H4 Z M11,6 V18 M15.5,6 V18"
                                                          Stroke="#7C3AED" StrokeThickness="1.5" Fill="Transparent"
                                                          Width="18" Height="18" Stretch="Uniform"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="Splits" Style="{StaticResource DashboardCardLabelStyle}" Margin="11,0,0,0" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Splits.SplitSummary, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Evaluation -->
                                    <Border Style="{StaticResource DashboardCardStyle}"
                                            Margin="0,0,0,14">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Border Width="34" Height="34" CornerRadius="9" Background="#FFF7ED">
                                                    <Path Data="M5,20 V11 M11,20 V5 M17,20 V14 M4,20 H20"
                                                          Stroke="#EA580C" StrokeThickness="1.6" Fill="Transparent"
                                                          Width="18" Height="18" Stretch="Uniform"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="Evaluation" Style="{StaticResource DashboardCardLabelStyle}" Margin="11,0,0,0" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding EvaluationSummary, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem x:Name="WritingStudioTab" Header="Writing Studio">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
