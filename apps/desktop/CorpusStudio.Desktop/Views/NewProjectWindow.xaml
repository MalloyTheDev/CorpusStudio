<Window x:Class="CorpusStudio.Desktop.Views.NewProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Dataset Project"
        Width="520"
        Height="360"
        MinWidth="480"
        MinHeight="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="New Dataset Project" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Pick a schema and create the local project files."
                       Margin="0,4,0,0"
                       Opacity="0.7" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Project name" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox x:Name="ProjectNameTextBox"
                     AutomationProperties.AutomationId="ProjectNameTextBox"
                     MinHeight="32"
                     TextChanged="ProjectNameTextBox_TextChanged" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Project ID" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox x:Name="ProjectIdTextBox"
                     AutomationProperties.AutomationId="ProjectIdTextBox"
                     MinHeight="32"
                     TextChanged="ProjectIdTextBox_TextChanged" />
        </StackPanel>

        <StackPanel Grid.Row="3">
            <TextBlock Text="Schema" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ComboBox x:Name="SchemaComboBox"
                      AutomationProperties.AutomationId="SchemaComboBox"
                      MinHeight="32"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id" />
            <TextBlock x:Name="ErrorTextBlock"
                       Margin="0,12,0,0"
                       Foreground="#A40000"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Cancel"
                    Width="92"
                    Margin="0,0,8,0"
                    IsCancel="True" />
            <Button AutomationProperties.AutomationId="CreateProjectButton"
                    Content="Create"
                    Width="92"
                    IsDefault="True"
                    Click="CreateButton_Click" />
        </StackPanel>
    </Grid>
</Window>
