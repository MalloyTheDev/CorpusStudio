                                             AutomationProperties.AutomationId="EvaluationReportHistoryListBox"
                                             ItemsSource="{Binding EvaluationReportHistory}"
                                             SelectedItem="{Binding SelectedEvaluationReportHistoryItem, Mode=TwoWay}"
                                             DisplayMemberPath="DisplayName" />

