                                               Margin="0,0,0,6">
                                        <ComboBox AutomationProperties.AutomationId="EvaluationCompareReportComboBox"
                                                  ItemsSource="{Binding EvaluationReportHistory}"
                                                  SelectedItem="{Binding SecondaryEvaluationReportHistoryItem, Mode=TwoWay}"
