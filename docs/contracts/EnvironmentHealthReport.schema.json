{
  "$defs": {
    "AdapterMethod": {
      "enum": [
        "none",
        "lora",
        "qlora",
        "dora",
        "ia3",
        "full_finetune",
        "prompt_tuning",
        "prefix_tuning"
      ],
      "title": "AdapterMethod",
      "type": "string"
    },
    "AttentionImpl": {
      "description": "``math``/``eager`` is forced on native-Windows/WDDM Blackwell sm_120 because the fused flash\nkernel deadlocks there. Other platforms require their own functional capability result; WSL\nevidence is not bare-Linux proof.",
      "enum": [
        "math",
        "eager",
        "sdpa",
        "flash_attention_2",
        "flash_attention_3",
        "mem_efficient",
        "xformers"
      ],
      "title": "AttentionImpl",
      "type": "string"
    },
    "AttentionKernel": {
      "description": "The exact attention implementation an execution policy permits at runtime.",
      "enum": [
        "eager",
        "torch_sdpa_math",
        "torch_sdpa_flash",
        "torch_sdpa_mem_efficient",
        "flash_attention_2",
        "flash_attention_3",
        "xformers"
      ],
      "title": "AttentionKernel",
      "type": "string"
    },
    "CheckpointImpl": {
      "enum": [
        "full_state",
        "adapter_only",
        "sharded",
        "distcp",
        "safetensors"
      ],
      "title": "CheckpointImpl",
      "type": "string"
    },
    "DeviceKind": {
      "enum": [
        "cuda",
        "rocm",
        "mps",
        "xpu",
        "cpu"
      ],
      "title": "DeviceKind",
      "type": "string"
    },
    "EnvironmentProbeEvidence": {
      "additionalProperties": false,
      "description": "Hash-sealed evidence that a required complete execution tuple passed as a unit.",
      "properties": {
        "capability_report_hash": {
          "$ref": "#/$defs/HashRef"
        },
        "contract_version": {
          "const": "1.0.0",
          "default": "1.0.0",
          "title": "Contract Version",
          "type": "string"
        },
        "evidence_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Evidence Hash",
          "type": "string"
        },
        "evidence_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Evidence Id",
          "type": "string"
        },
        "memory": {
          "$ref": "#/$defs/ProbeMemoryEvidence"
        },
        "profile_signature": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Profile Signature",
          "type": "string"
        },
        "required_spec": {
          "$ref": "#/$defs/QloraExecutionProbeSpec"
        },
        "tuple_result": {
          "$ref": "#/$defs/ProbeResult"
        }
      },
      "required": [
        "evidence_id",
        "required_spec",
        "profile_signature",
        "capability_report_hash",
        "tuple_result",
        "memory",
        "evidence_hash"
      ],
      "title": "EnvironmentProbeEvidence",
      "type": "object"
    },
    "EnvironmentState": {
      "description": "The lifecycle state of a managed environment. The escalation is deliberate \u2014 \"installed\" is\nNEVER \"supported\": a package importing (IMPORTABLE) is not proof a kernel runs\n(FUNCTIONAL_PROBE_PASSED), which is not proof the hardware supports it (HARDWARE_VERIFIED). Only\nHARDWARE_VERIFIED earns \"supported\". The terminal-degraded states record WHY an env is unusable.",
      "enum": [
        "NOT_INSTALLED",
        "INSTALLING",
        "INSTALLED_UNCHECKED",
        "IMPORTABLE",
        "DEPENDENCY_PROBE_PASSED",
        "FUNCTIONAL_PROBE_PASSED",
        "HARDWARE_VERIFIED",
        "DEGRADED",
        "INCOMPATIBLE",
        "DRIFTED",
        "BROKEN"
      ],
      "title": "EnvironmentState",
      "type": "string"
    },
    "ExecutionCapabilityCombination": {
      "additionalProperties": false,
      "description": "One execution tuple demonstrated together by a bounded functional probe.\n\nIndependent successes on precision, quantization, adapter, optimizer, loss, attention, and\ncheckpoint axes are diagnostic only. The planner may seal a run only from one of these complete\ntuples, preventing a union of unrelated probes from becoming a fictional capability.",
      "properties": {
        "adapter_method": {
          "$ref": "#/$defs/AdapterMethod"
        },
        "attention_impl": {
          "$ref": "#/$defs/AttentionImpl"
        },
        "attention_kernel": {
          "$ref": "#/$defs/AttentionKernel"
        },
        "checkpoint_impl": {
          "$ref": "#/$defs/CheckpointImpl"
        },
        "device": {
          "$ref": "#/$defs/DeviceKind"
        },
        "execution_contract_version": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Execution Contract Version",
          "type": "string"
        },
        "export_format": {
          "$ref": "#/$defs/ExportFormat"
        },
        "loss_impl": {
          "$ref": "#/$defs/LossImpl"
        },
        "optimizer": {
          "$ref": "#/$defs/Optimizer"
        },
        "precision": {
          "$ref": "#/$defs/PrecisionMode"
        },
        "probe": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Probe",
          "type": "string"
        },
        "quantization": {
          "$ref": "#/$defs/QuantizationMode"
        },
        "runtime_mode": {
          "enum": [
            "training",
            "cpu_toy"
          ],
          "title": "Runtime Mode",
          "type": "string"
        }
      },
      "required": [
        "runtime_mode",
        "device",
        "precision",
        "quantization",
        "adapter_method",
        "attention_impl",
        "attention_kernel",
        "optimizer",
        "loss_impl",
        "checkpoint_impl",
        "export_format",
        "execution_contract_version",
        "probe"
      ],
      "title": "ExecutionCapabilityCombination",
      "type": "object"
    },
    "ExportFormat": {
      "enum": [
        "adapter_peft",
        "merged_safetensors",
        "merged_fp16",
        "gguf",
        "onnx",
        "awq",
        "gptq",
        "mlx"
      ],
      "title": "ExportFormat",
      "type": "string"
    },
    "FailureRecord": {
      "additionalProperties": false,
      "description": "A structured, classified terminal outcome for a run, capability probe, or export. The\ntaxonomy turns 'it died' into an actionable category \u2014 a real OOM vs a KERNEL_STALL (the sm_120\nfused-attention deadlock) vs an ACCIDENTAL_SPILL vs a CONTROLLED_OFFLOAD. NEW.",
      "properties": {
        "contract_version": {
          "const": "1.0.0",
          "default": "1.0.0",
          "title": "Contract Version",
          "type": "string"
        },
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "detected_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detected At"
        },
        "exception_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Exception Type"
        },
        "exit_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Exit Code"
        },
        "fit_at_failure": {
          "anyOf": [
            {
              "$ref": "#/$defs/FitClassification"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "memory_at_failure": {
          "anyOf": [
            {
              "$ref": "#/$defs/MemoryMetrics"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "reconciled": {
          "default": false,
          "title": "Reconciled",
          "type": "boolean"
        },
        "remediation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remediation"
        },
        "run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Run Id"
        },
        "signal": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Signal"
        },
        "stage": {
          "anyOf": [
            {
              "$ref": "#/$defs/StageMarker"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "taxonomy": {
          "$ref": "#/$defs/FailureTaxonomy"
        }
      },
      "required": [
        "taxonomy",
        "message"
      ],
      "title": "FailureRecord",
      "type": "object"
    },
    "FailureTaxonomy": {
      "description": "Terminal outcome category. ``PASS`` is included so the same enum classifies a completed\nprobe/run, not only failures. Grounded in the exact hazards the engine documents: the sm_120\nfused-attention deadlock (KERNEL_STALL), the WDDM silent spill (ACCIDENTAL_SPILL vs a clean\nOOM), and env/dependency mismatches (ENVIRONMENT_FAILURE).",
      "enum": [
        "PASS",
        "FAIL",
        "OOM",
        "TIMEOUT",
        "KERNEL_STALL",
        "NUMERICAL_FAILURE",
        "CHECKPOINT_FAILURE",
        "ENVIRONMENT_FAILURE",
        "UNSUPPORTED_CONFIGURATION",
        "ACCIDENTAL_SPILL",
        "CONTROLLED_OFFLOAD"
      ],
      "title": "FailureTaxonomy",
      "type": "string"
    },
    "FitClass": {
      "description": "The fit verdict. ``NATIVE_*`` = fully resident. ``CONTROLLED_*`` = a deliberate, planned\noffload (acceptable, slower). ``ACCIDENTAL_*`` / ``THRASHING`` = an unplanned spill the platform\ndid silently (the failure mode the engine warns about). ``FAIL`` = will not run.",
      "enum": [
        "PLANNED_UNPROVEN",
        "NATIVE_SAFE",
        "NATIVE_TIGHT",
        "NATIVE_UNPROVEN",
        "MARGINAL",
        "CONTROLLED_ACTIVATION_OFFLOAD",
        "CONTROLLED_OPTIMIZER_OFFLOAD",
        "CONTROLLED_PARAMETER_OFFLOAD",
        "ACCIDENTAL_UNIFIED_MEMORY_PAGING",
        "ACCIDENTAL_WDDM_SPILL",
        "THRASHING",
        "FAIL"
      ],
      "title": "FitClass",
      "type": "string"
    },
    "FitClassification": {
      "additionalProperties": false,
      "description": "The planner/calibrator verdict on whether a resolved RunPlan fits the target environment, and\nHOW: a native fit, a deliberately-offloaded fit, or an ACCIDENTAL spill (the silent WDDM/unified\npaging that looks frozen but crawls at 10-25x). NEW \u2014 the engine emits only a coarse warn/pass\nVRAM band (preflight.gpu_memory, _VRAM_SAFETY_MARGIN_GB).",
      "properties": {
        "attention_path": {
          "anyOf": [
            {
              "$ref": "#/$defs/AttentionImpl"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "classification": {
          "$ref": "#/$defs/FitClass"
        },
        "contract_version": {
          "const": "1.0.0",
          "default": "1.0.0",
          "title": "Contract Version",
          "type": "string"
        },
        "device_capacity_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Device Capacity Bytes"
        },
        "estimated_peak_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Peak Bytes"
        },
        "headroom_bytes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Headroom Bytes"
        },
        "rationale": {
          "default": "",
          "title": "Rationale",
          "type": "string"
        }
      },
      "required": [
        "classification"
      ],
      "title": "FitClassification",
      "type": "object"
    },
    "HashRef": {
      "additionalProperties": false,
      "description": "An algorithm-tagged digest. The engine emits sha256 today; the algo tag makes a future\nmigration additive (cf. versions/version_registry.FINGERPRINT_ALGO).",
      "properties": {
        "algo": {
          "default": "sha256",
          "enum": [
            "sha256",
            "sha256-ordered-exact-v1",
            "blake3",
            "none"
          ],
          "title": "Algo",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "title": "HashRef",
      "type": "object"
    },
    "LossImpl": {
      "enum": [
        "cross_entropy",
        "liger_fused_ce",
        "chunked_ce",
        "dpo",
        "orpo",
        "kto",
        "ipo",
        "reward_bt"
      ],
      "title": "LossImpl",
      "type": "string"
    },
    "MemoryMetrics": {
      "additionalProperties": false,
      "description": "The full memory-signature block sampled during a run. Distinguishes PyTorch's allocator view,\nraw CUDA device memory, and OS-level residency (``dedicated`` vs ``shared`` GPU memory) so a\nWindows/WDDM spill to shared memory is VISIBLE rather than hidden inside 'used VRAM'. Grounded in\ngpu_probe.GpuMemory + the estimators note that torch.max_memory_allocated counts the WDDM spill.",
      "properties": {
        "cuda_device_free_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cuda Device Free Bytes"
        },
        "cuda_device_used_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cuda Device Used Bytes"
        },
        "dedicated_gpu_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dedicated Gpu Bytes"
        },
        "process_rss_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Process Rss Bytes"
        },
        "shared_gpu_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Shared Gpu Bytes"
        },
        "system_ram_used_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "System Ram Used Bytes"
        },
        "torch_allocated_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Torch Allocated Bytes"
        },
        "torch_peak_allocated_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Torch Peak Allocated Bytes"
        },
        "torch_peak_reserved_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Torch Peak Reserved Bytes"
        },
        "torch_reserved_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Torch Reserved Bytes"
        }
      },
      "title": "MemoryMetrics",
      "type": "object"
    },
    "Optimizer": {
      "enum": [
        "adamw_torch",
        "adamw_torch_fused",
        "adamw_8bit",
        "adamw_bnb_8bit",
        "paged_adamw_8bit",
        "paged_adamw_32bit",
        "adafactor",
        "lion",
        "sgd"
      ],
      "title": "Optimizer",
      "type": "string"
    },
    "PackageLock": {
      "additionalProperties": false,
      "description": "A resolved dependency and its install provenance.\n\n``hash`` seals the installed distribution's RECORD metadata when that evidence is available; it\nis not mislabelled as the original wheel hash. ``direct_url`` and ``artifact`` preserve the\nstronger source identity pip exposes for direct/VCS/local installs. ``dependencies`` is the\ninstalled metadata dependency graph, not a second resolver.",
      "properties": {
        "artifact": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact"
        },
        "artifact_hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "dependencies": {
          "items": {
            "type": "string"
          },
          "title": "Dependencies",
          "type": "array"
        },
        "direct": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Direct"
        },
        "direct_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Direct Url"
        },
        "editable": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Editable"
        },
        "hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "installer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Installer"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "normalized_name": {
          "default": "",
          "title": "Normalized Name",
          "type": "string"
        },
        "record_entries": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Record Entries"
        },
        "record_failed_entries": {
          "items": {
            "type": "string"
          },
          "title": "Record Failed Entries",
          "type": "array"
        },
        "record_integrity": {
          "default": "unknown",
          "enum": [
            "verified",
            "failed",
            "missing",
            "unknown"
          ],
          "title": "Record Integrity",
          "type": "string"
        },
        "record_verified_entries": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Record Verified Entries"
        },
        "requested": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requested"
        },
        "source": {
          "default": "unknown",
          "enum": [
            "pypi",
            "wheel",
            "sdist",
            "conda",
            "vcs",
            "local",
            "unknown"
          ],
          "title": "Source",
          "type": "string"
        },
        "source_evidence_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Evidence Reason"
        },
        "source_index_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Index Url"
        },
        "vcs_commit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vcs Commit"
        },
        "vcs_repository": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vcs Repository"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        }
      },
      "required": [
        "name"
      ],
      "title": "PackageLock",
      "type": "object"
    },
    "PrecisionMode": {
      "enum": [
        "fp32",
        "tf32",
        "fp16",
        "bf16",
        "fp8",
        "mixed_bf16",
        "mixed_fp16"
      ],
      "title": "PrecisionMode",
      "type": "string"
    },
    "ProbeMemoryEvidence": {
      "additionalProperties": false,
      "description": "Measured resource evidence for one bounded probe, with scopes kept explicit.",
      "properties": {
        "baseline_gpu_allocated_bytes": {
          "minimum": 0,
          "title": "Baseline Gpu Allocated Bytes",
          "type": "integer"
        },
        "baseline_gpu_reserved_bytes": {
          "minimum": 0,
          "title": "Baseline Gpu Reserved Bytes",
          "type": "integer"
        },
        "baseline_host_rss_bytes": {
          "minimum": 0,
          "title": "Baseline Host Rss Bytes",
          "type": "integer"
        },
        "baseline_nvidia_smi_process_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Baseline Nvidia Smi Process Bytes"
        },
        "duration_seconds": {
          "minimum": 0,
          "title": "Duration Seconds",
          "type": "number"
        },
        "gpu_allocator_scope": {
          "const": "pytorch_cuda_allocator_process",
          "default": "pytorch_cuda_allocator_process",
          "title": "Gpu Allocator Scope",
          "type": "string"
        },
        "gpu_device_scope": {
          "default": "unavailable",
          "enum": [
            "nvidia_smi_current_process",
