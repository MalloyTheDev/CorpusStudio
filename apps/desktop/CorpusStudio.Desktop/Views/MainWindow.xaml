                                    Click="RetryQuarantineItemButton_Click" />
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="SplitsTab" Header="Splits">
                        <Grid Margin="16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,8">
                                <TextBlock Text="Train %"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="SplitTrainPercentTextBox"
                                         Text="{Binding Splits.SplitTrainPercent, UpdateSourceTrigger=PropertyChanged}"
                                         Width="64"
                                         Margin="0,0,12,0" />
                                <TextBlock Text="Validation %"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="SplitValidationPercentTextBox"
                                         Text="{Binding Splits.SplitValidationPercent, UpdateSourceTrigger=PropertyChanged}"
                                         Width="64"
                                         Margin="0,0,12,0" />
                                <TextBlock Text="Seed"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="SplitSeedTextBox"
                                         Text="{Binding Splits.SplitSeed, UpdateSourceTrigger=PropertyChanged}"
