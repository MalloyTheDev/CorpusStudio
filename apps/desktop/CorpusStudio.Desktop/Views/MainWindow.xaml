                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBox AutomationProperties.AutomationId="EvaluationLimitTextBox"
                                             Text="{Binding EvaluationLimit, UpdateSourceTrigger=PropertyChanged}"
                                             Width="64"
                                             Margin="0,0,12,0" />
