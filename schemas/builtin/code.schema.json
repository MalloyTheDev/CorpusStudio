{
  "id": "code",
  "name": "Code Dataset",
  "version": "0.1.0",
  "description": "Code-generation examples: a task label, language, natural-language instruction, target code output, and optional input and tests.",
  "fields": [
    {
      "name": "task",
      "type": "string",
      "required": true
    },
    {
      "name": "language",
      "type": "string",
      "required": true
    },
    {
      "name": "instruction",
      "type": "text",
      "required": true
    },
    {
      "name": "input",
      "type": "code",
      "required": false
    },
    {
      "name": "output",
      "type": "code",
      "required": true
    },
    {
      "name": "tests",
      "type": "list",
      "item_type": "string",
      "required": false
    }
  ],
  "example": {
    "task": "function-implementation",
    "language": "python",
    "instruction": "Write a function that returns the factorial of a non-negative integer.",
    "input": "",
    "output": "def factorial(n): return 1 if n < 2 else n * factorial(n - 1)",
    "tests": ["assert factorial(0) == 1", "assert factorial(5) == 120"]
  }
}
