                                        Content="Refresh Models"
                                        Width="116"
                                        Margin="0,0,8,0"
                                        Click="RefreshEvaluationModelsButton_Click" />
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        AutomationProperties.AutomationId="RunEvaluationButton"
                                        Content="Run Evaluation"
                                        Width="124"
                                        Margin="0,0,8,0"
                                        Click="RunEvaluationButton_Click" />
                                <TextBlock AutomationProperties.AutomationId="EvaluationModelListSummaryTextBlock"
                                           Text="{Binding EvaluationModelListSummary, Mode=OneWay}"
                                           Width="260"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </WrapPanel>

                            <Border Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Style="{StaticResource CardBorderStyle}"
                                    Margin="0,0,0,8">
