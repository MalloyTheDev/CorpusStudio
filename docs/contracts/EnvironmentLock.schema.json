{
  "$defs": {
    "HashRef": {
      "additionalProperties": false,
      "description": "An algorithm-tagged digest. The engine emits sha256 today; the algo tag makes a future\nmigration additive (cf. versions/version_registry.FINGERPRINT_ALGO).",
      "properties": {
        "algo": {
          "default": "sha256",
          "enum": [
            "sha256",
            "sha256-ordered-exact-v1",
            "blake3",
            "none"
          ],
          "title": "Algo",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "title": "HashRef",
      "type": "object"
    },
    "OperatingSystem": {
      "enum": [
        "windows",
        "wsl",
        "linux",
        "macos",
        "unknown"
      ],
      "title": "OperatingSystem",
      "type": "string"
    },
    "PackageLock": {
      "additionalProperties": false,
      "description": "A resolved dependency and its install provenance.\n\n``hash`` seals the installed distribution's RECORD metadata when that evidence is available; it\nis not mislabelled as the original wheel hash. ``direct_url`` and ``artifact`` preserve the\nstronger source identity pip exposes for direct/VCS/local installs. ``dependencies`` is the\ninstalled metadata dependency graph, not a second resolver.",
      "properties": {
        "artifact": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact"
        },
        "dependencies": {
          "items": {
            "type": "string"
          },
          "title": "Dependencies",
          "type": "array"
        },
        "direct_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Direct Url"
        },
        "hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "installer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Installer"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "requested": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requested"
        },
        "source": {
          "default": "unknown",
          "enum": [
            "pypi",
            "wheel",
            "sdist",
            "conda",
            "vcs",
            "local",
            "unknown"
          ],
          "title": "Source",
          "type": "string"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        }
      },
      "required": [
        "name"
      ],
      "title": "PackageLock",
      "type": "object"
    },
    "PythonRuntime": {
      "additionalProperties": false,
      "description": "A discovered Python executable that can potentially create an isolated worker environment.\n\nDiscovery never assumes the control-plane interpreter is the only installation. Compatibility is\nan explicit verdict against the selected recipe, while ``venv_available`` proves the stdlib venv\nmodule can be located without creating anything.",
      "properties": {
        "architecture": {
          "default": "",
          "title": "Architecture",
          "type": "string"
        },
        "compatible": {
          "default": false,
          "title": "Compatible",
          "type": "boolean"
        },
        "contract_version": {
          "const": "1.0.0",
          "default": "1.0.0",
          "title": "Contract Version",
          "type": "string"
        },
        "executable": {
          "minLength": 1,
          "title": "Executable",
          "type": "string"
        },
        "implementation": {
          "default": "",
          "title": "Implementation",
          "type": "string"
        },
        "incompatibility_reasons": {
          "items": {
            "type": "string"
          },
          "title": "Incompatibility Reasons",
          "type": "array"
        },
        "is_virtual_environment": {
          "default": false,
          "title": "Is Virtual Environment",
          "type": "boolean"
        },
        "os": {
          "$ref": "#/$defs/OperatingSystem",
          "default": "unknown"
        },
        "platform": {
          "default": "",
          "title": "Platform",
          "type": "string"
        },
        "runtime_id": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Runtime Id",
          "type": "string"
        },
        "venv_available": {
          "default": false,
          "title": "Venv Available",
          "type": "boolean"
        },
        "version": {
          "default": "",
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "runtime_id",
        "executable"
      ],
      "title": "PythonRuntime",
      "type": "object"
    },
    "Ref": {
      "additionalProperties": false,
      "description": "A stable reference to another contract instance by id, optionally pinned to a content hash so\nthe reference cannot silently re-point.",
      "properties": {
        "hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        }
      },
      "required": [
        "id"
      ],
      "title": "Ref",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "The exact, reproducible record of what an environment actually contains \u2014 the post-install\ncounterpart of a recipe (which is only intent). ``packages`` are the resolved installs with\nversions + hashes; ``lock_hash`` seals the set for drift detection. NEW.",
  "properties": {
    "architecture": {
      "default": "",
      "title": "Architecture",
      "type": "string"
    },
    "compute_capability": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Compute Capability"
    },
    "contract_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Contract Version",
      "type": "string"
    },
    "created_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Created At"
    },
    "cuda_runtime_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cuda Runtime Version"
    },
    "implementation": {
      "default": "",
      "title": "Implementation",
      "type": "string"
    },
    "index_urls": {
      "items": {
        "type": "string"
      },
      "title": "Index Urls",
      "type": "array"
    },
    "lock_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Lock Hash"
    },
    "lock_id": {
      "pattern": "^[A-Za-z0-9._-]+$",
      "title": "Lock Id",
      "type": "string"
    },
    "manager_version": {
      "default": "",
      "title": "Manager Version",
      "type": "string"
    },
    "packages": {
      "items": {
        "$ref": "#/$defs/PackageLock"
      },
      "title": "Packages",
      "type": "array"
    },
    "platform_tag": {
      "default": "",
      "title": "Platform Tag",
      "type": "string"
    },
    "python_version": {
      "default": "",
      "title": "Python Version",
      "type": "string"
    },
    "recipe_ref": {
      "$ref": "#/$defs/Ref"
    },
    "runtime": {
      "anyOf": [
        {
          "$ref": "#/$defs/PythonRuntime"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "torch_build": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Torch Build"
    },
    "torch_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Torch Version"
    }
  },
  "required": [
    "lock_id",
    "recipe_ref"
  ],
  "title": "EnvironmentLock",
  "type": "object"
}
