<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CorpusStudio.Desktop.ViewModels;assembly=CorpusStudio.Core"
        xmlns:models="clr-namespace:CorpusStudio.Desktop.Models;assembly=CorpusStudio.Core"
        x:Class="CorpusStudio.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/app.ico"
        Width="1180" Height="800"
        Title="Corpus Studio — Avalonia (full shell over the shared view-models)">
  <Grid ColumnDefinitions="52,*">

    <!-- Activity bar: mode switches + panel toggles bound to the shell VM's ICommands (RelayCommand).
         The lone code-behind is the theme toggle — switching the app's light/dark variant is an
         Application/View concern (Application.Current.RequestedThemeVariant), not shared VM state. -->
    <DockPanel Grid.Column="0" Background="#0F172A">
      <StackPanel DockPanel.Dock="Top" Spacing="2">
        <Button Content="⌂" Command="{Binding ShowStartCenterCommand}" Background="Transparent" Foreground="White"
                FontSize="18" Width="52" Height="44" HorizontalContentAlignment="Center"/>
        <Button Content="🗀" Command="{Binding ShowFilesCommand}" Background="Transparent" Foreground="White"
                FontSize="15" Width="52" Height="44" HorizontalContentAlignment="Center"/>
        <Button Content="▦" Command="{Binding ShowStudioCommand}" Background="Transparent" Foreground="White"
                FontSize="15" Width="52" Height="44" HorizontalContentAlignment="Center"/>
        <Button Content="⚠" Command="{Binding ToggleProblemsPanelCommand}" Background="Transparent" Foreground="White"
                FontSize="15" Width="52" Height="44" HorizontalContentAlignment="Center"/>
        <Button Content="≡" Command="{Binding ToggleOutputPanelCommand}" Background="Transparent" Foreground="White"
                FontSize="15" Width="52" Height="44" HorizontalContentAlignment="Center"/>
      </StackPanel>
      <!-- Pinned to the bottom of the bar. Cycles System → Light → Dark. -->
      <Button DockPanel.Dock="Bottom" Content="◐" Click="CycleTheme_Click" Background="Transparent" Foreground="White"
              FontSize="16" Width="52" Height="44" HorizontalContentAlignment="Center" VerticalAlignment="Bottom"
              ToolTip.Tip="Theme: System → Light → Dark"/>
    </DockPanel>

    <Grid Grid.Column="1" RowDefinitions="*,Auto">
      <Panel Grid.Row="0">

        <!-- Start Center mode (IsVisible←IsStartCenter): the recent-workspaces registry. -->
        <ScrollViewer IsVisible="{Binding IsStartCenter}">
          <StackPanel Margin="28" Spacing="10">
            <TextBlock Text="Start a workspace" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="{Binding StartCenter.RecentCountLabel}" Foreground="{DynamicResource AppTextMuted}"/>
            <ListBox ItemsSource="{Binding StartCenter.Recents}" MaxWidth="680" HorizontalAlignment="Left">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:RecentWorkspaceDisplayItem">
                  <StackPanel Margin="0,3">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Path}" Foreground="{DynamicResource AppTextMuted}" FontSize="11"/>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </ScrollViewer>

        <!-- Files / Universal Explorer mode (IsVisible←IsFiles): the hierarchical file TREE +
             open-document tabs + the active document. Proves the TreeView / TreeDataTemplate shape. -->
        <Grid IsVisible="{Binding IsFiles}" ColumnDefinitions="300,*" Margin="12">
          <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="{Binding Explorer.WorkspaceName}"
                       FontWeight="Bold" Margin="0,0,0,6"/>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
              <Button Content="New File" Command="{Binding Explorer.NewFileCommand}"/>
              <Button Content="New Folder" Command="{Binding Explorer.NewFolderCommand}"/>
              <Button Content="Refresh" Command="{Binding Explorer.RefreshTreeCommand}"/>
              <Button Content="Collapse" Command="{Binding Explorer.CollapseAllCommand}"/>
            </StackPanel>
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding Explorer.ExplorerStatus}"
                       Foreground="{DynamicResource AppTextMuted}" FontSize="11" Margin="0,6,0,0"/>
            <!-- ExplorerTree is named so the per-node context menu (whose DataContext is the node) can
                 reach the shell VM's file-op commands via an element-name compiled binding (#223). -->
            <TreeView x:Name="ExplorerTree" ItemsSource="{Binding Explorer.RootNode.Children}">
              <TreeView.ItemTemplate>
                <TreeDataTemplate x:DataType="models:WorkspaceTreeNode" ItemsSource="{Binding Children}">
                  <StackPanel Orientation="Horizontal" Spacing="6" Height="20">
                    <StackPanel.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Rename…"
                                  Command="{Binding #ExplorerTree.((vm:MainWindowViewModel)DataContext).Explorer.RenameNodeCommand}"
                                  CommandParameter="{Binding}"/>
                        <Separator/>
                        <MenuItem Header="Delete"
                                  Command="{Binding #ExplorerTree.((vm:MainWindowViewModel)DataContext).Explorer.DeleteNodeCommand}"
                                  CommandParameter="{Binding}"/>
                      </ContextMenu>
                    </StackPanel.ContextMenu>
                    <TextBlock Text="🗀" IsVisible="{Binding IsDirectory}" VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource AppChipBg}" CornerRadius="3" Padding="3,0" VerticalAlignment="Center"
                            IsVisible="{Binding !IsDirectory}">
                      <TextBlock Text="{Binding ChipLabel}" FontSize="8" FontWeight="Bold"
                                 Foreground="{DynamicResource AppChipText}" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                    <Ellipse Width="6" Height="6" Fill="#F59E0B" VerticalAlignment="Center"
                             IsVisible="{Binding IsGeneratedArtifact}"/>
                  </StackPanel>
                </TreeDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>
          </DockPanel>
          <DockPanel Grid.Column="1" Margin="12,0,0,0">
            <ListBox DockPanel.Dock="Top" ItemsSource="{Binding Explorer.OpenDocuments}"
                     SelectedItem="{Binding Explorer.ActiveDocument}" MaxHeight="90">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:OpenWorkspaceDocument">
                  <TextBlock Text="{Binding DisplayName}" Margin="0,1"/>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <TextBox IsReadOnly="True" AcceptsReturn="True" Margin="0,8,0,0"
                     FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding Explorer.ActiveRelPath}"/>
          </DockPanel>
        </Grid>

        <!-- Studio mode (IsVisible←IsStudio): hero + projects sidebar + the 14-tab TabControl + Quality panel. -->
        <Grid IsVisible="{Binding IsStudio}" RowDefinitions="Auto,*" ColumnDefinitions="170,*,300">
          <Border Grid.Row="0" Grid.ColumnSpan="3" Background="{DynamicResource AppBackground}" Padding="14,10" Margin="0,0,0,6">
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Text="{Binding ActiveProjectTitle}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ActiveSchemaDescription}" Foreground="{DynamicResource AppTextMuted}" VerticalAlignment="Center"/>
                <Border CornerRadius="6" Padding="10,4" VerticalAlignment="Center"
                        Background="{Binding Debt.DebtGradeColor, Converter={StaticResource StringToBrush}}">
                  <TextBlock Text="{Binding Debt.DebtGrade}" Foreground="White" FontWeight="Bold"/>
                </Border>
              </StackPanel>
              <!-- Project-level actions bound to the shared shell commands (issue #245 — sync with WPF). -->
              <WrapPanel>
                <Button Content="Import dataset" Command="{Binding ImportDatasetCommand}" Margin="0,0,6,4"/>
                <Button Content="Import from HF" Command="{Binding ImportFromHuggingFaceCommand}" Margin="0,0,6,4"/>
                <Button Content="Rebuild index" Command="{Binding RebuildProjectIndexCommand}" Margin="0,0,6,4"/>
                <Button Content="Generate card" Command="{Binding GenerateDatasetCardCommand}" Margin="0,0,6,4"/>
                <Button Content="Run gates" Command="{Binding RunGatesCommand}" Margin="0,0,6,4"/>
                <Button Content="Run chat gates" Command="{Binding RunChatGatesCommand}" Margin="0,0,6,4"/>
                <Button Content="Check provenance" Command="{Binding RunProvenanceGateCommand}" Margin="0,0,6,4"/>
                <Button Content="Benchmark" Command="{Binding RunBenchmarkCommand}" Margin="0,0,6,4"/>
              </WrapPanel>
              <!-- Per-row provenance verdict (issue: WBG licensing landmine). Badge + summary,
                   shown once the gate has run — the shared command feeds both heads. -->
              <StackPanel IsVisible="{Binding HasProvenanceGateReport}" Spacing="4" Margin="0,2,0,0">
                <Border CornerRadius="4" Padding="7,1" HorizontalAlignment="Left"
                        Background="{Binding ProvenanceGateColor, Converter={StaticResource StringToBrush}}">
                  <TextBlock Text="{Binding ProvenanceGateStatus}" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                </Border>
                <TextBox Text="{Binding ProvenanceGateSummary}" IsReadOnly="True" AcceptsReturn="True"
                         FontFamily="Consolas" FontSize="11.5" MaxHeight="150" TextWrapping="Wrap"/>
              </StackPanel>
              <WrapPanel VerticalAlignment="Center">
                <CheckBox Content="dedupe" IsChecked="{Binding ExportRemoveDuplicates}" Margin="0,0,8,0"/>
                <CheckBox Content="drop low-info" IsChecked="{Binding ExportRemoveLowInformation}" Margin="0,0,8,0"/>
                <TextBox Text="{Binding ExportFormat}" Watermark="jsonl/csv/tsv/parquet" Width="150" Margin="0,0,6,0"/>
                <Button Content="Export dataset" Command="{Binding ExportJsonlCommand}" Margin="0,0,10,0"/>
                <Button Content="Debt" Command="{Binding GoToDebtCommand}" Margin="0,0,4,0"/>
                <Button Content="Eval" Command="{Binding GoToEvaluationCommand}" Margin="0,0,4,0"/>
                <Button Content="Splits" Command="{Binding GoToSplitsCommand}" Margin="0,0,4,0"/>
                <Button Content="Train" Command="{Binding GoToTrainingCommand}" Margin="0,0,4,0"/>
                <Button Content="Studio" Command="{Binding GoToWritingStudioCommand}" Margin="0,0,4,0"/>
              </WrapPanel>
              <!-- Engine setup (shown when the engine is not located) + the error-banner dismiss. -->
              <WrapPanel IsVisible="{Binding IsEngineUnavailable}">
                <TextBlock Text="{Binding EngineUnavailableMessage}" Foreground="{DynamicResource AppWarn}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Content="Locate engine…" Command="{Binding LocateEngineCommand}" Margin="0,0,6,0"/>
                <Button Content="Retry" Command="{Binding RetryEngineCommand}" Margin="0,0,6,0"/>
              </WrapPanel>
              <WrapPanel IsVisible="{Binding HasError}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource AppError}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Content="Dismiss" Command="{Binding DismissErrorCommand}"/>
              </WrapPanel>
            </StackPanel>
          </Border>
          <ListBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding Projects}"
                   SelectedItem="{Binding SelectedProject}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:DatasetProjectListItem">
                <TextBlock Text="{Binding DisplayName}" Margin="0,2"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <TabControl Grid.Row="1" Grid.Column="1" Margin="8,0">

    <!-- Debt: read bindings + IsVisible bound to a bool (the Visibility→IsVisible port, proven). -->
    <TabItem Header="Debt">
      <ScrollViewer>
        <StackPanel Margin="20" Spacing="10">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="{Binding Debt.DebtGrade}" FontSize="44" FontWeight="Bold"
                       Foreground="{Binding Debt.DebtGradeColor, Converter={StaticResource StringToBrush}}"/>
            <TextBlock Text="stale" VerticalAlignment="Center" Foreground="{DynamicResource AppWarn}"
                       IsVisible="{Binding Debt.DebtStale}"/>
          </StackPanel>
          <!-- The same shared async engine command the WPF head binds — one run, both heads. -->
          <Button Content="Run debt check" Command="{Binding RunDatasetDebtCommand}" HorizontalAlignment="Left"/>
          <TextBlock Text="{Binding Debt.DebtSummary}" TextWrapping="Wrap"/>
          <ItemsControl ItemsSource="{Binding Debt.DebtItems}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:DebtDisplayItem">
                <Border Padding="8" Margin="0,2" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="6">
                  <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <!-- Arena: TwoWay text bindings on get/set VM inputs (proven) + a read binding. -->
    <TabItem Header="Arena">
      <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Prompts (one per line)"/>
        <TextBox Text="{Binding Arena.ArenaPromptsInput}" AcceptsReturn="True" Height="90"/>
        <TextBlock Text="Models (comma or newline)"/>
        <TextBox Text="{Binding Arena.ArenaModelsInput}"/>
        <TextBlock Text="Judge model (optional)"/>
        <TextBox Text="{Binding Arena.ArenaJudgeModelInput}"/>
        <Button Content="Run Arena" Command="{Binding RunArenaCommand}" HorizontalAlignment="Left"/>
        <TextBlock Text="{Binding Arena.ArenaSummary}" TextWrapping="Wrap" Margin="0,8,0,0"/>
      </StackPanel>
    </TabItem>

    <!-- Settings: two read-only summary panes (SetSettings / ApplyProviderPolicies feed them). -->
    <TabItem Header="Settings">
      <ScrollViewer>
        <StackPanel Margin="20" Spacing="8">
          <TextBlock Text="App settings" FontWeight="Bold" FontSize="16"/>
          <TextBlock Text="{Binding Settings.SettingsSummary}" TextWrapping="Wrap" FontFamily="Consolas"/>
          <Button Content="Save gate thresholds" Command="{Binding SaveGateThresholdsCommand}" HorizontalAlignment="Left" Margin="0,6,0,0"/>
          <TextBlock Text="Provider generation policy" FontWeight="Bold" FontSize="16" Margin="0,14,0,0"/>
          <TextBlock Text="{Binding Settings.ProviderPolicySummary}" TextWrapping="Wrap" FontFamily="Consolas"/>
          <TextBox Text="{Binding Settings.ProviderApprovalProvider}" Watermark="provider" Margin="0,6,0,0"/>
          <TextBox Text="{Binding Settings.ProviderApprovalModel}" Watermark="model"/>
          <WrapPanel>
            <Button Content="Refresh policies" Command="{Binding RefreshProviderPoliciesCommand}" Margin="0,0,6,4"/>
            <Button Content="Approve" Command="{Binding ApproveProviderGenerationCommand}" Margin="0,0,6,4"/>
            <Button Content="Revoke" Command="{Binding RevokeProviderGenerationCommand}" Margin="0,0,6,4"/>
          </WrapPanel>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <!-- Versions: ItemsSource + TwoWay SelectedItem + a DataTemplate item + TwoWay label input. -->
    <TabItem Header="Versions">
      <Grid Margin="16" ColumnDefinitions="300,*">
        <DockPanel Grid.Column="0">
          <TextBlock DockPanel.Dock="Top" Text="{Binding Versions.DatasetVersionSummary}"
                     TextWrapping="Wrap" Margin="0,0,0,8"/>
          <ListBox ItemsSource="{Binding Versions.DatasetVersions}"
                   SelectedItem="{Binding Versions.SelectedDatasetVersion}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:DatasetVersionDisplayItem">
                <StackPanel Margin="0,2">
                  <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Integrity}" Foreground="{DynamicResource AppTextMuted}" FontSize="11"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
        <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="8">
          <TextBlock Text="Version label"/>
          <TextBox Text="{Binding Versions.DatasetVersionLabel}"/>
          <WrapPanel>
            <Button Content="Capture version" Command="{Binding CaptureDatasetVersionCommand}" Margin="0,0,6,4"/>
            <Button Content="Refresh" Command="{Binding RefreshDatasetVersionsCommand}" Margin="0,0,6,4"/>
            <Button Content="View card" Command="{Binding ViewDatasetVersionCardCommand}" Margin="0,0,6,4"/>
            <Button Content="Diff versions" Command="{Binding DiffVersionsCommand}" Margin="0,0,6,4"/>
            <Button Content="Restore" Command="{Binding RestoreDatasetVersionCommand}" Margin="0,0,6,4"/>
            <Button Content="Clean up row store" Command="{Binding RunRowStoreGcCommand}" Margin="0,0,6,4"/>
          </WrapPanel>
          <TextBlock Text="{Binding Versions.DatasetDiffBaseLabel}" Foreground="{DynamicResource AppTextMuted}"/>
          <TextBlock Text="{Binding Versions.DatasetVersionDetail}" TextWrapping="Wrap" Margin="0,8,0,0"/>
        </StackPanel>
      </Grid>
    </TabItem>

    <!-- Suites: two collections + TwoWay selection + a read report pane + IsVisible on a bool. -->
    <TabItem Header="Suites">
      <Grid Margin="16" ColumnDefinitions="300,*">
        <DockPanel Grid.Column="0">
          <TextBlock DockPanel.Dock="Top" Text="{Binding Suites.SuitesStatus}"
                     TextWrapping="Wrap" Margin="0,0,0,8"/>
          <ListBox ItemsSource="{Binding Suites.Suites}"
                   SelectedItem="{Binding Suites.SelectedSuite}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:SuiteSummary">
                <TextBlock Text="{Binding DisplayLabel}" Margin="0,2"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
        <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="8">
          <TextBox Text="{Binding Suites.NewSuiteName}" Watermark="new suite name"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="New suite" Command="{Binding NewSuiteCommand}"/>
            <Button Content="Run" Command="{Binding RunSuiteCommand}"/>
            <Button Content="Refresh" Command="{Binding RefreshSuitesCommand}"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding Suites.HasSuiteReport}">
            <TextBlock Text="Overall verdict:" FontWeight="Bold"/>
            <TextBlock Text="{Binding Suites.SuiteOverallStatus}" FontWeight="Bold"
                       Foreground="{Binding Suites.SuiteOverallColor, Converter={StaticResource StringToBrush}}"/>
          </StackPanel>
          <TextBlock Text="{Binding Suites.SuiteReportSummary}" TextWrapping="Wrap"/>
          <TextBlock Text="Per-metric rollup" FontWeight="SemiBold" Margin="0,8,0,0"
                     IsVisible="{Binding Suites.HasSuiteReport}"/>
          <ItemsControl ItemsSource="{Binding Suites.SuiteMetricRows}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:SuiteMetricRollup">
                <TextBlock Text="{Binding DisplayLabel}" Margin="0,1"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="{Binding Suites.SuiteHonestyNote}" TextWrapping="Wrap"
                     Foreground="{DynamicResource AppTextMuted}" FontSize="11" Margin="0,8,0,0"/>
        </StackPanel>
      </Grid>
    </TabItem>

    <!-- Splits: three TwoWay percent/seed inputs + a read summary. -->
    <TabItem Header="Splits">
      <StackPanel Margin="20" Spacing="8" MaxWidth="360" HorizontalAlignment="Left">
        <TextBlock Text="Train %"/>
        <TextBox Text="{Binding Splits.SplitTrainPercent}"/>
        <TextBlock Text="Validation %"/>
        <TextBox Text="{Binding Splits.SplitValidationPercent}"/>
        <TextBlock Text="Seed"/>
        <TextBox Text="{Binding Splits.SplitSeed}"/>
        <Button Content="Generate splits" Command="{Binding GenerateSplitsCommand}" HorizontalAlignment="Left" Margin="0,4,0,0"/>
        <TextBlock Text="{Binding Splits.SplitSummary}" TextWrapping="Wrap" Margin="0,10,0,0"/>
      </StackPanel>
    </TabItem>

    <!-- Examples: the dataset spine — ItemsSource + TwoWay selection + a read JSON pane. -->
    <TabItem Header="Examples">
      <Grid Margin="16" ColumnDefinitions="300,*">
        <ListBox Grid.Column="0" ItemsSource="{Binding Examples.Items}"
                 SelectedItem="{Binding Examples.SelectedExample}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:SavedExampleItem">
              <TextBlock Text="{Binding DisplayName}" Margin="0,2"/>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <TextBox Grid.Column="1" Margin="16,0,0,0" Text="{Binding Examples.SelectedExampleJson}"
                 IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas"
                 TextWrapping="Wrap" VerticalAlignment="Stretch"/>
      </Grid>
    </TabItem>

    <!-- Quarantine: failed-import rows list + TwoWay selection + a read detail pane. -->
    <TabItem Header="Quarantine">
      <Grid Margin="16" ColumnDefinitions="300,*">
        <ListBox Grid.Column="0" ItemsSource="{Binding Quarantine.ImportQuarantineItems}"
                 SelectedItem="{Binding Quarantine.SelectedImportQuarantineItem}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:ImportQuarantineItem">
              <StackPanel Margin="0,2">
                <TextBlock Text="{Binding SourcePath}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding RowNumber}" Foreground="{DynamicResource AppTextMuted}" FontSize="11"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <TextBox Grid.Column="1" Margin="16,0,0,0" Text="{Binding Quarantine.SelectedImportQuarantineDetail}"
                 IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas"
                 TextWrapping="Wrap" VerticalAlignment="Stretch"/>
      </Grid>
    </TabItem>

    <!-- Preference Review: list + TwoWay selection + read panes + a ComboBox (ItemsSource + SelectedItem). -->
    <TabItem Header="Preference Review">
      <Grid Margin="16" ColumnDefinitions="300,*">
        <DockPanel Grid.Column="0">
          <ComboBox DockPanel.Dock="Top" Margin="0,0,0,8" HorizontalAlignment="Stretch"
                    ItemsSource="{Binding PreferenceReview.PreferenceContrastFilterOptions}"
                    SelectedItem="{Binding PreferenceReview.PreferenceContrastFilter}"/>
          <ListBox ItemsSource="{Binding PreferenceReview.PreferenceReviewItems}"
                   SelectedItem="{Binding PreferenceReview.SelectedPreferenceReviewItem}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:PreferenceReviewItem">
                <TextBlock Text="{Binding Prompt}" TextTrimming="CharacterEllipsis" Margin="0,2"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
        <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="6">
          <WrapPanel>
            <Button Content="Export for training" Command="{Binding ExportPreferenceForTrainingCommand}" Margin="0,0,6,4"/>
            <Button Content="Export ranking" Command="{Binding ExportPreferenceRankingCommand}" Margin="0,0,6,4"/>
            <Button Content="Prepare judge review" Command="{Binding PreparePreferenceJudgeReviewCommand}" Margin="0,0,6,4"/>
            <Button Content="Batch judge" Command="{Binding PreparePreferenceBatchJudgeReviewCommand}" Margin="0,0,6,4"/>
          </WrapPanel>
          <TextBlock Text="{Binding PreferenceReview.PreferenceRankingSummary}" TextWrapping="Wrap"/>
          <TextBlock Text="Prompt" FontWeight="SemiBold" Margin="0,6,0,0"/>
          <TextBlock Text="{Binding PreferenceReview.PreferencePromptText}" TextWrapping="Wrap"/>
          <TextBlock Text="Chosen" FontWeight="SemiBold" Margin="0,6,0,0"/>
          <TextBlock Text="{Binding PreferenceReview.PreferenceChosenText}" TextWrapping="Wrap"/>
          <TextBlock Text="Rejected" FontWeight="SemiBold" Margin="0,6,0,0"/>
          <TextBlock Text="{Binding PreferenceReview.PreferenceRejectedText}" TextWrapping="Wrap"/>
          <TextBlock Text="{Binding PreferenceReview.PreferenceReviewSummary}" TextWrapping="Wrap"
                     Foreground="{DynamicResource AppTextMuted}" Margin="0,8,0,0"/>
        </StackPanel>
      </Grid>
    </TabItem>

    <!-- Writing Studio: the shared draft editor — TwoWay text + an IsVisible dirty indicator. -->
    <TabItem Header="Writing Studio">
      <DockPanel Margin="16">
        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
          <Button Content="Validate draft" Command="{Binding ValidateDraftCommand}" Margin="0,0,6,0"/>
          <Button Content="Save example" Command="{Binding SaveExampleCommand}" Margin="0,0,6,0"/>
        </WrapPanel>
        <TextBlock DockPanel.Dock="Top" Text="Unsaved changes" Foreground="{DynamicResource AppWarn}" Margin="0,0,0,6"
                   IsVisible="{Binding WritingStudio.IsDraftDirty}"/>
        <TextBox Text="{Binding WritingStudio.DraftText}" AcceptsReturn="True"
                 FontFamily="Consolas" TextWrapping="NoWrap"
                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
      </DockPanel>
    </TabItem>

    <!-- AI Assist: the connection child + action ComboBox + review queue + the colored candidate gate. -->
    <TabItem Header="AI Assist">
      <Grid Margin="16" ColumnDefinitions="320,*" RowDefinitions="Auto,*">
        <StackPanel Grid.Column="0" Grid.RowSpan="2" Spacing="6">
          <TextBlock Text="Backend / model"/>
          <TextBox Text="{Binding AiAssistConnection.AiAssistBackend}"/>
          <TextBox Text="{Binding AiAssistConnection.AiAssistModel}"/>
          <TextBox Text="{Binding AiAssistConnection.AiAssistBaseUrl}"/>
          <TextBlock Text="{Binding AiAssistConnection.AiAssistModelListSummary}"
                     Foreground="{DynamicResource AppTextMuted}" FontSize="11" TextWrapping="Wrap"/>
          <TextBlock Text="Action" Margin="0,6,0,0"/>
          <ComboBox HorizontalAlignment="Stretch"
                    ItemsSource="{Binding AiAssist.AiAssistActionPresets}"
                    SelectedItem="{Binding AiAssist.AiAssistAction}"/>
          <TextBlock Text="{Binding AiAssist.AiAssistQueueSummary}" Margin="0,6,0,0"/>
          <ComboBox HorizontalAlignment="Stretch"
                    ItemsSource="{Binding AiAssist.AiAssistQueueFilterOptions}"
                    SelectedItem="{Binding AiAssist.AiAssistQueueFilter}"/>
          <TextBox Text="{Binding AiAssist.AiAssistQueueSearch}" Watermark="search"/>
          <ListBox ItemsSource="{Binding AiAssist.AiAssistReviewQueue}"
                   SelectedItem="{Binding AiAssist.SelectedAiAssistReviewQueueItem}" Height="200">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:AiAssistReviewQueueItem">
                <StackPanel Margin="0,2">
                  <TextBlock Text="{Binding ReviewId}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding ReviewState}" Foreground="{DynamicResource AppTextMuted}" FontSize="11"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
        <StackPanel Grid.Column="1" Grid.Row="0" Margin="16,0,0,0" Spacing="6">
          <TextBlock Text="Instruction"/>
          <TextBox Text="{Binding AiAssist.AiAssistInstruction}" AcceptsReturn="True" Height="60"/>
          <WrapPanel>
            <Button Content="Check backend" Command="{Binding CheckAiAssistBackendCommand}" Margin="0,0,6,4"/>
            <Button Content="Refresh models" Command="{Binding RefreshAiAssistModelsCommand}" Margin="0,0,6,4"/>
            <Button Content="Run AI Assist" Command="{Binding RunAiAssistCommand}" Margin="0,0,6,4"/>
          </WrapPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Candidate gate:" FontWeight="Bold"/>
            <TextBlock Text="{Binding AiAssist.AiAssistCandidateGateStatus}"
                       Foreground="{Binding AiAssist.AiAssistCandidateGateColor, Converter={StaticResource StringToBrush}}"/>
          </StackPanel>
          <TextBlock Text="{Binding AiAssist.AiAssistSummary}" TextWrapping="Wrap"/>
        </StackPanel>
        <TextBox Grid.Column="1" Grid.Row="1" Margin="16,8,0,0"
                 Text="{Binding AiAssist.AiAssistSuggestedJsonlText}" IsReadOnly="True"
                 AcceptsReturn="True" FontFamily="Consolas" TextWrapping="Wrap"/>
      </Grid>
    </TabItem>

    <!-- Evaluation: run inputs + results list/selection + filter ComboBox + report-history comparison. -->
    <TabItem Header="Evaluation">
      <Grid Margin="16" ColumnDefinitions="320,*">
        <StackPanel Grid.Column="0" Spacing="6">
          <TextBlock Text="Limit / score threshold"/>
          <TextBox Text="{Binding Evaluation.EvaluationLimit}"/>
          <TextBox Text="{Binding Evaluation.EvaluationScoreThreshold}"/>
          <TextBlock Text="Judge (optional): model / backend / base-url" FontSize="11" Foreground="{DynamicResource AppTextMuted}"/>
          <TextBox Text="{Binding EvaluationConnection.EvaluationJudgeModel}" Watermark="judge model"/>
          <TextBox Text="{Binding EvaluationConnection.EvaluationJudgeBackend}" Watermark="judge backend (blank = eval backend)"/>
          <TextBox Text="{Binding EvaluationConnection.EvaluationJudgeBaseUrl}" Watermark="judge base url (blank = eval base url)"/>
          <WrapPanel>
            <Button Content="Check backend" Command="{Binding CheckEvaluationBackendCommand}" Margin="0,0,6,4"/>
            <Button Content="Refresh models" Command="{Binding RefreshEvaluationModelsCommand}" Margin="0,0,6,4"/>
            <Button Content="Run Evaluation" Command="{Binding RunEvaluationCommand}" Margin="0,0,6,4"/>
            <Button Content="Rerun report" Command="{Binding RerunEvaluationReportCommand}" Margin="0,0,6,4"/>
            <Button Content="Prepare failure review" Command="{Binding PrepareEvaluationFailureReviewCommand}" Margin="0,0,6,4"/>
          </WrapPanel>
          <StackPanel IsVisible="{Binding Evaluation.IsEvaluationInProgress}" Spacing="3">
            <TextBlock Text="{Binding Evaluation.EvaluationProgressText}" FontSize="11"/>
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding Evaluation.EvaluationProgressPercent}"/>
          </StackPanel>
          <TextBlock Text="{Binding Evaluation.EvaluationSummary}" TextWrapping="Wrap" Margin="0,6,0,0"/>
          <TextBlock Text="{Binding Evaluation.EvaluationResultsSummary}" Margin="0,6,0,0"/>
          <ComboBox HorizontalAlignment="Stretch"
                    ItemsSource="{Binding Evaluation.EvaluationResultFilterOptions}"
                    SelectedItem="{Binding Evaluation.EvaluationResultFilter}"/>
          <ListBox ItemsSource="{Binding Evaluation.EvaluationResults}"
                   SelectedItem="{Binding Evaluation.SelectedEvaluationExampleResult}" Height="220">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:EvaluationExampleResult">
                <StackPanel Margin="0,2">
                  <TextBlock Text="{Binding ExampleId}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Score}" Foreground="{DynamicResource AppTextMuted}" FontSize="11"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="6">
          <TextBlock Text="{Binding Evaluation.SelectedEvaluationExampleDetail}" TextWrapping="Wrap"/>
          <TextBlock Text="Manual score / notes" Margin="0,6,0,0"/>
          <TextBox Text="{Binding Evaluation.EvaluationManualScore}"/>
          <TextBox Text="{Binding Evaluation.EvaluationManualNotes}" AcceptsReturn="True" Height="50"/>
          <TextBlock Text="{Binding Evaluation.EvaluationReviewSummary}" Foreground="{DynamicResource AppTextMuted}" TextWrapping="Wrap"/>
          <TextBlock Text="Report comparison" FontWeight="SemiBold" Margin="0,8,0,0"/>
          <ComboBox HorizontalAlignment="Stretch"
                    ItemsSource="{Binding Evaluation.EvaluationReportHistory}"
                    SelectedItem="{Binding Evaluation.SelectedEvaluationReportHistoryItem}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="models:EvaluationReportHistoryItem">
                <TextBlock Text="{Binding DisplayName}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <!-- Same ICommand the WPF head binds — one shared action, both heads. -->
          <Button Content="Compare reports" Command="{Binding Evaluation.CompareReportsCommand}"
                  HorizontalAlignment="Left"/>
          <TextBlock Text="{Binding Evaluation.EvaluationComparisonSummary}" TextWrapping="Wrap"/>
        </StackPanel>
      </Grid>
    </TabItem>

    <!-- Training: the config form (TwoWay inputs) + status/IsVisible + the live run log. -->
    <TabItem Header="Training">
      <Grid Margin="16" ColumnDefinitions="*,*">
        <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,10,0">
          <TextBlock Text="Config" FontWeight="Bold"/>
          <TextBox Text="{Binding Training.TrainingTarget}" Watermark="target"/>
          <TextBox Text="{Binding Training.TrainingBaseModel}" Watermark="base model"/>
          <TextBox Text="{Binding Training.TrainingFormat}" Watermark="format"/>
          <TextBox Text="{Binding Training.TrainingSequenceLen}" Watermark="seq len"/>
          <TextBox Text="{Binding Training.TrainingLoraR}" Watermark="lora r"/>
          <TextBox Text="{Binding Training.TrainingLoraAlpha}" Watermark="lora alpha"/>
          <TextBox Text="{Binding Training.TrainingLearningRate}" Watermark="learning rate"/>
          <WrapPanel Margin="0,4,0,0">
            <Button Content="Check compatibility" Command="{Binding CheckTrainingCompatibilityCommand}" Margin="0,0,6,4"/>
            <Button Content="Generate config" Command="{Binding GenerateTrainingConfigCommand}" Margin="0,0,6,4"/>
          </WrapPanel>
          <TextBlock Text="{Binding Training.TrainingSummary}" TextWrapping="Wrap" Margin="0,6,0,0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="6" Margin="10,0,0,0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Status:" FontWeight="Bold"/>
            <TextBlock Text="{Binding Training.TrainingRunStatus}"/>
            <TextBlock Text="running" Foreground="{DynamicResource AppWarn}" IsVisible="{Binding Training.IsTrainingRunning}"/>
          </StackPanel>
          <WrapPanel>
            <Button Content="Launch" Command="{Binding LaunchTrainingCommand}" IsEnabled="{Binding Training.CanLaunchTraining}" Margin="0,0,6,4"/>
            <Button Content="Stop" Command="{Binding StopTrainingCommand}" IsEnabled="{Binding Training.IsTrainingRunning}" Margin="0,0,6,4"/>
            <Button Content="Resume" Command="{Binding ResumeTrainingCommand}" IsEnabled="{Binding Training.CanResumeTraining}" Margin="0,0,6,4"/>
            <Button Content="Refresh checkpoints" Command="{Binding RefreshTrainingCheckpointsCommand}" Margin="0,0,6,4"/>
            <Button Content="Regression gate" Command="{Binding GateTrainingRunCommand}" Margin="0,0,6,4"/>
          </WrapPanel>
          <!-- First-party trainer (corpus_studio target): preflight, CPU-toy smoke path, and adapter merge. -->
          <WrapPanel IsVisible="{Binding Training.IsFirstPartyTarget}">
            <Button Content="Check runtime" Command="{Binding CheckTrainingRuntimeCommand}" Margin="0,0,6,4"
                    ToolTip.Tip="Preflight the first-party training runtime (train-check): deps, GPU, QLoRA vs CPU-toy"/>
            <CheckBox Content="CPU toy" IsChecked="{Binding Training.CpuToyMode}" Margin="0,0,6,4"
                      ToolTip.Tip="Run the tiny CPU smoke path — proves the pipeline runs; does NOT train a usable model"/>
            <Button Content="Merge adapter" Command="{Binding MergeAdapterCommand}" IsEnabled="{Binding Training.CanMergeAdapter}" Margin="0,0,6,4"
                    ToolTip.Tip="Merge the trained LoRA adapter into its base (train-merge, auto → GPU / CPU-offload / adapter-only)"/>
          </WrapPanel>
          <TextBlock Text="{Binding Training.TrainingLaunchCommand}" TextWrapping="Wrap"
                     FontFamily="Consolas" FontSize="11"/>
          <TextBox Text="{Binding Training.TrainingRunLog}" IsReadOnly="True" AcceptsReturn="True"
                   FontFamily="Consolas" Height="200" TextWrapping="Wrap"/>
          <TextBlock Text="{Binding Training.TrainingCheckpointsSummary}" TextWrapping="Wrap"/>
          <TextBlock Text="{Binding Training.TrainingComparisonSummary}" TextWrapping="Wrap"/>
          <TextBox Text="{Binding Training.TrainingRuntimeSummary}" IsVisible="{Binding Training.IsFirstPartyTarget}"
                   IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" FontSize="11" MaxHeight="140" TextWrapping="Wrap"/>
          <TextBox Text="{Binding Training.TrainingMergeSummary}" IsVisible="{Binding Training.IsFirstPartyTarget}"
                   IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" FontSize="11" MaxHeight="140" TextWrapping="Wrap"/>
        </StackPanel>
      </Grid>
    </TabItem>

    <!-- Artifacts: registered adapters/checkpoints list + TwoWay selection + summary/detail panes. -->
    <TabItem Header="Artifacts">
      <Grid Margin="16" ColumnDefinitions="320,*">
        <DockPanel Grid.Column="0">
          <TextBlock DockPanel.Dock="Top" Text="{Binding Artifacts.ArtifactSummary}"
                     TextWrapping="Wrap" Margin="0,0,0,8"/>
          <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button Content="View weight card" Command="{Binding ViewArtifactCardCommand}" Margin="0,0,6,4"/>
            <Button Content="Refresh" Command="{Binding RefreshArtifactsCommand}" Margin="0,0,6,4"/>
            <Button Content="Register from run" Command="{Binding RegisterArtifactFromRunCommand}" Margin="0,0,6,4"/>
            <Button Content="Keep" Command="{Binding KeepArtifactCommand}" Margin="0,0,6,4"/>
            <Button Content="Reject" Command="{Binding RejectArtifactCommand}" Margin="0,0,6,4"/>
          </WrapPanel>
          <ListBox ItemsSource="{Binding Artifacts.ModelArtifacts}"
                   SelectedItem="{Binding Artifacts.SelectedModelArtifact}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:ArtifactDisplayItem">
                <StackPanel Margin="0,2">
                  <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Integrity}" Foreground="{DynamicResource AppTextMuted}" FontSize="11"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
        <TextBox Grid.Column="1" Margin="16,0,0,0" Text="{Binding Artifacts.ArtifactDetail}"
                 IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas"
                 TextWrapping="Wrap" VerticalAlignment="Stretch"/>
      </Grid>
    </TabItem>

          </TabControl>

          <!-- Quality right panel: summary + the structured metric grid (colored via the converter). -->
          <ScrollViewer Grid.Row="1" Grid.Column="2">
            <StackPanel Margin="10" Spacing="6">
              <TextBlock Text="Quality" FontWeight="Bold" FontSize="16"/>
              <Button Content="Run quality check" Command="{Binding RunQualityCommand}" HorizontalAlignment="Left"/>
              <TextBlock Text="{Binding Quality.QualitySummary}" TextWrapping="Wrap"/>
              <ItemsControl ItemsSource="{Binding Quality.QualityMetrics}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:QualityMetric">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,1">
                      <TextBlock Text="{Binding Label}" Width="150"/>
                      <TextBlock Text="{Binding Value}"
                                 Foreground="{Binding StatusColor, Converter={StaticResource StringToBrush}}"/>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="Debt trend" FontWeight="SemiBold" Margin="0,10,0,0"/>
              <TextBlock Text="{Binding Quality.DebtTrendSummary}" TextWrapping="Wrap" FontSize="11"/>
            </StackPanel>
          </ScrollViewer>
        </Grid>

      </Panel>

      <!-- Docked panels (mutually exclusive), toggled from the activity bar. -->
      <Border Grid.Row="1" Height="180" Background="{DynamicResource AppBackground}" BorderBrush="{DynamicResource AppBorder}"
              BorderThickness="0,1,0,0" IsVisible="{Binding ProblemsPanelVisible}">
        <DockPanel Margin="12,8">
          <TextBlock DockPanel.Dock="Top" Text="{Binding ProblemsSummary}" FontWeight="Bold" Margin="0,0,0,6"/>
          <ListBox ItemsSource="{Binding Problems}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:ProblemItem">
                <StackPanel Margin="0,2">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                             Foreground="{Binding SeverityColor, Converter={StaticResource StringToBrush}}"/>
                  <TextBlock Text="{Binding Message}" FontSize="11"/>
                  <TextBlock Text="{Binding Fix}" FontSize="11" Foreground="{DynamicResource AppAccent}"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>
      <Border Grid.Row="1" Height="180" Background="#0F172A" IsVisible="{Binding OutputPanelVisible}">
        <DockPanel Margin="12,8">
          <TextBlock DockPanel.Dock="Top" Text="{Binding OutputSummary}" FontWeight="Bold"
                     Foreground="White" Margin="0,0,0,6"/>
          <ListBox ItemsSource="{Binding OutputLog}" Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:EngineLogEntry">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding Timestamp}" Foreground="{DynamicResource AppTextMuted}" FontFamily="Consolas" FontSize="11"/>
                  <TextBlock Text="{Binding Command}" Foreground="White" FontFamily="Consolas" FontSize="11"/>
                  <TextBlock Text="{Binding ArgsSummary}" Foreground="#94A3B8" FontFamily="Consolas" FontSize="11"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

    </Grid>
  </Grid>
</Window>
