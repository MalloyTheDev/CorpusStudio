{
  "$defs": {
    "AdapterMethod": {
      "enum": [
        "none",
        "lora",
        "qlora",
        "dora",
        "ia3",
        "full_finetune",
        "prompt_tuning",
        "prefix_tuning"
      ],
      "title": "AdapterMethod",
      "type": "string"
    },
    "AdapterSpec": {
      "additionalProperties": false,
      "properties": {
        "bias": {
          "anyOf": [
            {
              "enum": [
                "none",
                "all",
                "lora_only"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bias"
        },
        "lora_alpha": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lora Alpha"
        },
        "lora_dropout": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lora Dropout"
        },
        "lora_r": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lora R"
        },
        "method": {
          "$ref": "#/$defs/AdapterMethod"
        },
        "target_modules": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Modules"
        }
      },
      "required": [
        "method"
      ],
      "title": "AdapterSpec",
      "type": "object"
    },
    "AttentionExecutionPolicy": {
      "additionalProperties": false,
      "description": "Exact model attention API plus the one runtime kernel that is permitted.",
      "properties": {
        "effective_backend_required": {
          "$ref": "#/$defs/AttentionKernel"
        },
        "evidence_kind": {
          "enum": [
            "functional_probe",
            "cpu_reference"
          ],
          "title": "Evidence Kind",
          "type": "string"
        },
        "fallback_policy": {
          "const": "refuse",
          "default": "refuse",
          "title": "Fallback Policy",
          "type": "string"
        },
        "flash_attention_package": {
          "anyOf": [
            {
              "$ref": "#/$defs/PackageLock"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "flash_sdp_enabled": {
          "title": "Flash Sdp Enabled",
          "type": "boolean"
        },
        "kernel_probe_ref": {
          "$ref": "#/$defs/Ref"
        },
        "math_sdp_enabled": {
          "title": "Math Sdp Enabled",
          "type": "boolean"
        },
        "mem_efficient_sdp_enabled": {
          "title": "Mem Efficient Sdp Enabled",
          "type": "boolean"
        },
        "model_attention_api": {
          "$ref": "#/$defs/ModelAttentionApi"
        },
        "safety_mandate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Safety Mandate"
        },
        "verification_requirement": {
          "$ref": "#/$defs/ExecutionVerificationRequirement",
          "default": "require_verified"
        }
      },
      "required": [
        "model_attention_api",
        "effective_backend_required",
        "flash_sdp_enabled",
        "mem_efficient_sdp_enabled",
        "math_sdp_enabled",
        "kernel_probe_ref",
        "evidence_kind"
      ],
      "title": "AttentionExecutionPolicy",
      "type": "object"
    },
    "AttentionKernel": {
      "description": "The exact attention implementation an execution policy permits at runtime.",
      "enum": [
        "eager",
        "torch_sdpa_math",
        "torch_sdpa_flash",
        "torch_sdpa_mem_efficient",
        "flash_attention_2",
        "flash_attention_3",
        "xformers"
      ],
      "title": "AttentionKernel",
      "type": "string"
    },
    "BatchingSpec": {
      "additionalProperties": false,
      "description": "The accumulation TARGET is expressed in SUPERVISED TOKENS, not microbatch count. A\ntoken-target-CAPABLE backend accumulates until summed supervised tokens >= target and normalizes\nthe loss by supervised tokens across the window, so the effective batch is invariant to sequence\nlength + padding. The first-party ``corpus_studio`` reference trainer is NOT token-target-capable\ntoday \u2014 it honors ``fallback_grad_accumulation_steps`` (a fixed microbatch count); the token\ntarget is the contract a future token-aware backend would satisfy.",
      "properties": {
        "fallback_grad_accumulation_steps": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fallback Grad Accumulation Steps"
        },
        "micro_batch_size": {
          "default": 1,
          "minimum": 1,
          "title": "Micro Batch Size",
          "type": "integer"
        },
        "supervised_token_accumulation_target": {
          "minimum": 1,
          "title": "Supervised Token Accumulation Target",
          "type": "integer"
        }
      },
      "required": [
        "supervised_token_accumulation_target"
      ],
      "title": "BatchingSpec",
      "type": "object"
    },
    "CheckpointImpl": {
      "enum": [
        "full_state",
        "adapter_only",
        "sharded",
        "distcp",
        "safetensors"
      ],
      "title": "CheckpointImpl",
      "type": "string"
    },
    "CheckpointPolicy": {
      "additionalProperties": false,
      "properties": {
        "cadence_optimizer_steps": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cadence Optimizer Steps"
        },
        "cadence_seconds": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cadence Seconds"
        },
        "impl": {
          "$ref": "#/$defs/CheckpointImpl"
        },
        "keep_last": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Keep Last"
        },
        "reload_verify": {
          "default": false,
          "title": "Reload Verify",
          "type": "boolean"
        }
      },
      "required": [
        "impl"
      ],
      "title": "CheckpointPolicy",
      "type": "object"
    },
    "DeviceMapEntry": {
      "additionalProperties": false,
      "properties": {
        "device": {
          "minLength": 1,
          "title": "Device",
          "type": "string"
        },
        "module": {
          "title": "Module",
          "type": "string"
        }
      },
      "required": [
        "module",
        "device"
      ],
      "title": "DeviceMapEntry",
      "type": "object"
    },
    "ExecutionInputBinding": {
      "additionalProperties": false,
      "description": "One immutable input consumed by the worker.\n\nLocal inputs pin the exact bytes (a stable file or directory digest). Hugging Face inputs pin an\nimmutable repository commit; a branch or tag is never sufficient execution identity.",
      "properties": {
        "content_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Sha256"
        },
        "kind": {
          "enum": [
            "dataset",
            "model",
            "tokenizer"
          ],
          "title": "Kind",
          "type": "string"
        },
        "location": {
          "minLength": 1,
          "title": "Location",
          "type": "string"
        },
        "ref": {
          "$ref": "#/$defs/Ref"
        },
        "resolved_revision": {
          "anyOf": [
            {
              "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolved Revision"
        },
        "source": {
          "enum": [
            "local_file",
            "local_directory",
            "huggingface"
          ],
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "ref",
        "source",
        "location"
      ],
      "title": "ExecutionInputBinding",
      "type": "object"
    },
    "ExecutionInputs": {
      "additionalProperties": false,
      "properties": {
        "dataset": {
          "$ref": "#/$defs/ExecutionInputBinding"
        },
        "model": {
          "$ref": "#/$defs/ExecutionInputBinding"
        },
        "tokenizer": {
          "$ref": "#/$defs/ExecutionInputBinding"
        }
      },
      "required": [
        "dataset",
        "model",
        "tokenizer"
      ],
      "title": "ExecutionInputs",
      "type": "object"
    },
    "ExecutionVerificationRequirement": {
      "description": "Whether the planner may seal a capability that lacks functional evidence.",
      "enum": [
        "require_verified",
        "allow_unverified"
      ],
      "title": "ExecutionVerificationRequirement",
      "type": "string"
    },
    "ExportFormat": {
      "enum": [
        "adapter_peft",
        "merged_safetensors",
        "merged_fp16",
        "gguf",
        "onnx",
        "awq",
        "gptq",
        "mlx"
      ],
      "title": "ExportFormat",
      "type": "string"
    },
    "HashRef": {
      "additionalProperties": false,
      "description": "An algorithm-tagged digest. The engine emits sha256 today; the algo tag makes a future\nmigration additive (cf. versions/version_registry.FINGERPRINT_ALGO).",
      "properties": {
        "algo": {
          "default": "sha256",
          "enum": [
            "sha256",
            "sha256-ordered-exact-v1",
            "blake3",
            "none"
          ],
          "title": "Algo",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "title": "HashRef",
      "type": "object"
    },
    "LossImpl": {
      "enum": [
        "cross_entropy",
        "liger_fused_ce",
        "chunked_ce",
        "dpo",
        "orpo",
        "kto",
        "ipo",
        "reward_bt"
      ],
      "title": "LossImpl",
      "type": "string"
    },
    "ModelAttentionApi": {
      "description": "The model-loader API selected before execution.\n\nThis is deliberately separate from :class:`AttentionKernel`: ``sdpa`` is an API that can\ndispatch to several materially different PyTorch kernels.",
      "enum": [
        "eager",
        "sdpa",
        "flash_attention_2",
        "flash_attention_3",
        "xformers"
      ],
      "title": "ModelAttentionApi",
      "type": "string"
    },
    "Optimizer": {
      "enum": [
        "adamw_torch",
        "adamw_torch_fused",
        "adamw_8bit",
        "adamw_bnb_8bit",
        "paged_adamw_8bit",
        "paged_adamw_32bit",
        "adafactor",
        "lion",
        "sgd"
      ],
      "title": "Optimizer",
      "type": "string"
    },
    "OptimizerSpec": {
      "additionalProperties": false,
      "properties": {
        "adam_beta1": {
          "default": 0.9,
          "exclusiveMaximum": 1,
          "minimum": 0,
          "title": "Adam Beta1",
          "type": "number"
        },
        "adam_beta2": {
          "default": 0.999,
          "exclusiveMaximum": 1,
          "minimum": 0,
          "title": "Adam Beta2",
          "type": "number"
        },
        "adam_epsilon": {
          "default": 1e-08,
          "exclusiveMinimum": 0,
          "title": "Adam Epsilon",
          "type": "number"
        },
        "impl": {
          "$ref": "#/$defs/Optimizer"
        },
        "learning_rate": {
          "exclusiveMinimum": 0,
          "title": "Learning Rate",
          "type": "number"
        },
        "lr_scheduler": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lr Scheduler"
        },
        "max_grad_norm": {
          "default": 1.0,
          "minimum": 0,
          "title": "Max Grad Norm",
          "type": "number"
        },
        "warmup_ratio": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Warmup Ratio"
        },
        "weight_decay": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Weight Decay"
        }
      },
      "required": [
        "impl",
        "learning_rate"
      ],
      "title": "OptimizerSpec",
      "type": "object"
    },
    "PackageLock": {
      "additionalProperties": false,
      "description": "A resolved dependency and its install provenance.\n\n``hash`` seals the installed distribution's RECORD metadata when that evidence is available; it\nis not mislabelled as the original wheel hash. ``direct_url`` and ``artifact`` preserve the\nstronger source identity pip exposes for direct/VCS/local installs. ``dependencies`` is the\ninstalled metadata dependency graph, not a second resolver.",
      "properties": {
        "artifact": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact"
        },
        "artifact_hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "dependencies": {
          "items": {
            "type": "string"
          },
          "title": "Dependencies",
          "type": "array"
        },
        "direct": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Direct"
        },
        "direct_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Direct Url"
        },
        "editable": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Editable"
        },
        "hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "installer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Installer"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "normalized_name": {
          "default": "",
          "title": "Normalized Name",
          "type": "string"
        },
        "record_entries": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Record Entries"
        },
        "record_failed_entries": {
          "items": {
            "type": "string"
          },
          "title": "Record Failed Entries",
          "type": "array"
        },
        "record_integrity": {
          "default": "unknown",
          "enum": [
            "verified",
            "failed",
            "missing",
            "unknown"
          ],
          "title": "Record Integrity",
          "type": "string"
        },
        "record_verified_entries": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Record Verified Entries"
        },
        "requested": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requested"
        },
        "source": {
          "default": "unknown",
          "enum": [
            "pypi",
            "wheel",
            "sdist",
            "conda",
            "vcs",
            "local",
            "unknown"
          ],
          "title": "Source",
          "type": "string"
        },
        "source_evidence_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Evidence Reason"
        },
        "source_index_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Index Url"
        },
        "vcs_commit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vcs Commit"
        },
        "vcs_repository": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vcs Repository"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        }
      },
      "required": [
        "name"
      ],
      "title": "PackageLock",
      "type": "object"
    },
    "PrecisionExecutionPolicy": {
      "additionalProperties": false,
      "description": "The numerical representation of each material training state.\n\n``weight_storage_dtype`` describes an unquantized frozen base; quantized bases use\n``quantized_storage_format`` instead. ``master_weight_dtype`` describes the trainable adapter\nparameters. An 8-bit optimizer may use quantized primary state plus FP32 auxiliary tensors.",
      "properties": {
        "dequantization_dtype": {
          "$ref": "#/$defs/PrecisionMode"
        },
        "forward_compute_dtype": {
          "$ref": "#/$defs/PrecisionMode"
        },
        "gradient_dtype": {
          "$ref": "#/$defs/PrecisionMode"
        },
        "master_weight_dtype": {
          "anyOf": [
            {
              "$ref": "#/$defs/PrecisionMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "optimizer_auxiliary_dtype": {
          "$ref": "#/$defs/PrecisionMode",
          "default": "fp32"
        },
        "optimizer_state_dtype": {
          "anyOf": [
            {
              "$ref": "#/$defs/PrecisionMode"
            },
            {
              "$ref": "#/$defs/QuantizationMode"
            }
          ],
          "title": "Optimizer State Dtype"
        },
        "quantized_storage_format": {
          "$ref": "#/$defs/QuantizationMode",
          "default": "none"
        },
        "weight_storage_dtype": {
          "anyOf": [
            {
              "$ref": "#/$defs/PrecisionMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "dequantization_dtype",
        "forward_compute_dtype",
        "gradient_dtype",
        "optimizer_state_dtype"
      ],
      "title": "PrecisionExecutionPolicy",
      "type": "object"
    },
    "PrecisionMode": {
      "enum": [
        "fp32",
        "tf32",
        "fp16",
        "bf16",
        "fp8",
        "mixed_bf16",
        "mixed_fp16"
      ],
      "title": "PrecisionMode",
      "type": "string"
    },
    "QuantizationMode": {
      "enum": [
        "none",
        "int8",
        "int4",
        "nf4",
        "fp4",
        "gptq",
        "awq",
        "hqq"
      ],
      "title": "QuantizationMode",
      "type": "string"
    },
    "Ref": {
      "additionalProperties": false,
      "description": "A stable reference to another contract instance by id, optionally pinned to a content hash so\nthe reference cannot silently re-point.",
      "properties": {
        "hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/HashRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        }
      },
      "required": [
        "id"
      ],
      "title": "Ref",
      "type": "object"
    },
    "SequenceSpec": {
      "additionalProperties": false,
      "description": "Sequence handling. Buckets let variable-length rows batch efficiently; the max bucket ==\nthe trainer's sequence_len (config_templates.sequence_len, default 4096).",
      "properties": {
        "buckets": {
          "items": {
            "type": "integer"
          },
          "title": "Buckets",
          "type": "array"
        },
        "max_sequence_len": {
          "default": 4096,
          "minimum": 1,
          "title": "Max Sequence Len",
          "type": "integer"
        },
        "packing": {
          "default": false,
          "title": "Packing",
          "type": "boolean"
        },
        "truncation_allowed": {
          "default": true,
          "title": "Truncation Allowed",
          "type": "boolean"
        }
      },
      "title": "SequenceSpec",
      "type": "object"
    },
    "TrainerInterfacePolicy": {
      "additionalProperties": false,
      "description": "Version- and field-exact adapter to the installed TRL/Transformers surface.",
      "properties": {
        "disable_tqdm": {
          "default": true,
          "title": "Disable Tqdm",
          "type": "boolean"
        },
        "logging_steps": {
          "default": 1,
          "minimum": 1,
          "title": "Logging Steps",
          "type": "integer"
        },
        "package_versions": {
          "items": {
            "$ref": "#/$defs/PackageLock"
          },
          "minItems": 1,
          "title": "Package Versions",
          "type": "array"
        },
        "report_to": {
          "items": {
            "type": "string"
          },
          "title": "Report To",
          "type": "array"
        },
        "required_sft_config_fields": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Required Sft Config Fields",
          "type": "array"
        },
        "sequence_length_field": {
          "enum": [
            "max_seq_length",
            "max_length"
          ],
          "title": "Sequence Length Field",
          "type": "string"
        },
        "tokenizer_parameter": {
          "enum": [
            "tokenizer",
            "processing_class"
          ],
          "title": "Tokenizer Parameter",
          "type": "string"
        }
