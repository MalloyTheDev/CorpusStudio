                                                   Margin="0,0,6,0" />
                                        <TextBox AutomationProperties.AutomationId="EvaluationManualNotesTextBox"
                                                 Text="{Binding EvaluationManualNotes, UpdateSourceTrigger=PropertyChanged}"
