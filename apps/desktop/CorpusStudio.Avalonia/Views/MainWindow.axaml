<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CorpusStudio.Desktop.ViewModels;assembly=CorpusStudio.Core"
        xmlns:models="clr-namespace:CorpusStudio.Desktop.Models;assembly=CorpusStudio.Core"
        xmlns:conv="clr-namespace:CorpusStudio.Avalonia.Converters"
        x:Class="CorpusStudio.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/app.ico"
        Width="1180" Height="800"
        Background="{DynamicResource Win}"
        Title="Corpus Studio — Avalonia (full shell over the shared view-models)">
  <Grid ColumnDefinitions="52,*">

    <!-- Activity bar: mode switches + panel toggles bound to the shell VM's ICommands (RelayCommand).
         The lone code-behind is the theme toggle — switching the app's light/dark variant is an
         Application/View concern (Application.Current.RequestedThemeVariant), not shared VM state. -->
    <DockPanel Grid.Column="0" Background="{DynamicResource Chrome}">
      <StackPanel DockPanel.Dock="Top" Spacing="2">
        <!-- Brand mark → Start Center. Blurple rounded-square avatar (matches the design). -->
        <Button Command="{Binding ShowStartCenterCommand}" Classes="activitybtn" Height="56"
                ToolTip.Tip="Start Center">
          <Border Width="30" Height="30" CornerRadius="8" Background="{DynamicResource Accent}">
            <TextBlock Text="C" Foreground="White" FontSize="15" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </Button>
        <Button Command="{Binding ShowFilesCommand}" Classes="activitybtn" Classes.active="{Binding IsFiles}"
                ToolTip.Tip="Files / Explorer">
          <Path Classes="ico onbar" Data="{StaticResource IcoTree}"/>
        </Button>
        <Button Command="{Binding ShowStudioCommand}" Classes="activitybtn" Classes.active="{Binding IsStudio}"
                ToolTip.Tip="Studio">
          <Path Classes="ico onbar" Data="{StaticResource IcoGridFill}"/>
        </Button>
        <Button Command="{Binding ToggleProblemsPanelCommand}" Classes="activitybtn"
                Classes.active="{Binding ProblemsPanelVisible}" ToolTip.Tip="Problems">
          <Path Classes="ico onbar" Data="{StaticResource IcoWarnDiamond}"/>
        </Button>
        <Button Command="{Binding ToggleOutputPanelCommand}" Classes="activitybtn"
                Classes.active="{Binding OutputPanelVisible}" ToolTip.Tip="Output">
          <Path Classes="ico onbar" Data="{StaticResource IcoListDashes}"/>
        </Button>
      </StackPanel>
      <!-- Pinned to the bottom: theme cycle (System → Light → Dark) + Settings. -->
      <Button DockPanel.Dock="Bottom" Command="{Binding SelectStudioTabCommand}" CommandParameter="Settings"
              Classes="activitybtn" VerticalAlignment="Bottom" ToolTip.Tip="Settings">
        <Path Classes="ico onbar" Data="{StaticResource IcoGear}"/>
      </Button>
      <Button DockPanel.Dock="Bottom" Click="CycleTheme_Click" Classes="activitybtn" VerticalAlignment="Bottom"
              ToolTip.Tip="Theme: System → Light → Dark">
        <Path Classes="ico onbar" Data="{StaticResource IcoMoon}"/>
      </Button>
    </DockPanel>

    <Grid Grid.Column="1" RowDefinitions="*,Auto">
      <Panel Grid.Row="0">

        <!-- Start Center mode (IsVisible←IsStartCenter): Nocturne landing — brand + start actions +
             the recent-workspaces registry + engine status. New Dataset Project enters the Studio and
             Open Project opens the file Explorer (the Avalonia head has no scaffold/folder-picker
             command; Import Dataset / Import from HF are the real engine commands). -->
        <ScrollViewer IsVisible="{Binding IsStartCenter}" Background="{DynamicResource Win}">
          <ScrollViewer.Resources>
            <conv:ProjectInitialsConverter x:Key="Initials"/>
          </ScrollViewer.Resources>
          <Grid Margin="56,44,56,44" ColumnDefinitions="Auto,44,Auto" HorizontalAlignment="Left">

            <!-- LEFT: brand + description + START actions -->
            <StackPanel Grid.Column="0" Width="660">
              <Grid ColumnDefinitions="Auto,*">
                <Border Grid.Column="0" Width="52" Height="52" CornerRadius="12" Background="{DynamicResource Accent}"
                        VerticalAlignment="Center">
                  <TextBlock Text="C" FontSize="26" FontWeight="Bold" Foreground="White"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="1">
                  <TextBlock Text="Corpus Studio" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource Text}"/>
                  <TextBlock Text="Local-first dataset creation studio" Foreground="{DynamicResource T3}"/>
                </StackPanel>
              </Grid>
              <TextBlock Margin="0,18,0,0" MaxWidth="560" HorizontalAlignment="Left" FontSize="14"
                         Foreground="{DynamicResource T3}" TextWrapping="Wrap"
                         Text="Author, clean, gate, split, evaluate and version fine-tuning datasets — entirely on your machine. Nothing leaves this computer unless you export it."/>

              <TextBlock Text="START" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource T4}" Margin="2,30,0,10"/>

              <!-- Primary: launch the New Project wizard (scaffolds a real workspace, then opens it) -->
              <Button Click="NewProject_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                      Background="{DynamicResource Accent}" BorderThickness="0" CornerRadius="12" Padding="16" Margin="0,0,0,10">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <Path Grid.Column="0" Classes="ico" Fill="White" Data="{StaticResource IcoPlusCircle}" Width="22" Height="22"/>
                  <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="New Dataset Project" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="Pick a schema and starting point" Foreground="#e7e5fe" FontSize="12"/>
                  </StackPanel>
                  <Path Grid.Column="2" Classes="ico" Fill="White" Data="{StaticResource IcoArrowRight}" Width="18" Height="18"/>
                </Grid>
              </Button>

              <Button Command="{Binding ImportDatasetCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                      Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line2}" BorderThickness="1"
                      CornerRadius="12" Padding="16" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" Spacing="14">
                  <Path Classes="ico" Data="{StaticResource IcoImport}" Width="21" Height="21"/>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Import Dataset" Foreground="{DynamicResource Text}" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="JSONL, CSV, or a folder of files" Foreground="{DynamicResource T3}" FontSize="12"/>
                  </StackPanel>
                </StackPanel>
              </Button>

              <Button Command="{Binding ShowFilesCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                      Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line2}" BorderThickness="1"
                      CornerRadius="12" Padding="16" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" Spacing="14">
                  <Path Classes="ico" Data="{StaticResource IcoFolderOpen}" Width="21" Height="21"/>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Open Project…" Foreground="{DynamicResource Text}" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="Open an existing workspace folder" Foreground="{DynamicResource T3}" FontSize="12"/>
                  </StackPanel>
                </StackPanel>
              </Button>

              <Button Command="{Binding ImportFromHuggingFaceCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                      Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line2}" BorderThickness="1"
                      CornerRadius="12" Padding="16">
                <StackPanel Orientation="Horizontal" Spacing="14">
                  <Path Classes="ico" Data="{StaticResource IcoCloudArrowDown}" Width="21" Height="21"/>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Import from Hugging Face" Foreground="{DynamicResource Text}" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="Pull a dataset by hub id" Foreground="{DynamicResource T3}" FontSize="12"/>
                  </StackPanel>
                </StackPanel>
              </Button>
            </StackPanel>

            <!-- RIGHT: recent workspaces + engine status -->
            <StackPanel Grid.Column="2" Width="440" Margin="0,6,0,0">
              <TextBlock Text="RECENT" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource T4}" Margin="2,0,0,10"/>
              <ItemsControl ItemsSource="{Binding StartCenter.Recents}" IsVisible="{Binding StartCenter.HasRecents}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:RecentWorkspaceDisplayItem">
                    <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="12" Margin="0,0,0,10"
                            BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                      <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" Background="{DynamicResource AccentSoft}"
                                VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name, Converter={StaticResource Initials}}" FontWeight="Bold"
                                     FontSize="13" Foreground="{DynamicResource AccentInk}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                          <StackPanel Orientation="Horizontal" Spacing="0">
                            <TextBlock Text="{Binding SchemaTag}" Foreground="{DynamicResource T3}" FontSize="11.5"/>
                            <TextBlock Text=" · " Foreground="{DynamicResource T4}" FontSize="11.5"/>
                            <TextBlock Text="{Binding WhenText}" Foreground="{DynamicResource T3}" FontSize="11.5"/>
                          </StackPanel>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="missing" Foreground="{DynamicResource Warn}" FontSize="10.5"
                                   VerticalAlignment="Center" IsVisible="{Binding IsMissing}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="14"
                      BorderBrush="{DynamicResource Line2}" BorderThickness="1"
                      IsVisible="{Binding !StartCenter.HasRecents}">
                <TextBlock Text="No recent workspaces yet — create or open one to see it here."
                           Foreground="{DynamicResource T3}" FontSize="12" TextWrapping="Wrap"/>
              </Border>

              <!-- Engine status (real): green when the engine probe is available, warn otherwise. -->
              <Border CornerRadius="12" Padding="12,10" Margin="0,4,0,0"
                      Background="{DynamicResource AccentSoft}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{DynamicResource Ok}"
                           IsVisible="{Binding !IsEngineUnavailable}"/>
                  <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{DynamicResource Warn}"
                           IsVisible="{Binding IsEngineUnavailable}"/>
                  <TextBlock Text="Engine ready · local-first" Foreground="{DynamicResource T2}" FontSize="12"
                             VerticalAlignment="Center" IsVisible="{Binding !IsEngineUnavailable}"/>
                  <TextBlock Text="Engine unavailable — locate it in the shell" Foreground="{DynamicResource Warn}" FontSize="12"
                             VerticalAlignment="Center" IsVisible="{Binding IsEngineUnavailable}"/>
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </ScrollViewer>

        <!-- Files / Universal Explorer mode (IsVisible←IsFiles): VS-Code-style workspace — a file TREE
             sidebar + open-document tabs + a read-only code viewer with a line-number gutter. Every
             element binds real VM state (RootNode / OpenDocuments / ActiveDocument.TextContent); the
             gutter is computed from the actual text and nothing is synthesized. Selecting a tree node
             opens it (code-behind → Explorer.OpenNodeAsync); the tab X closes it (Explorer.CloseDocument),
             both mirroring the WPF head. -->
        <Grid IsVisible="{Binding IsFiles}" ColumnDefinitions="272,*">
          <Grid.Resources>
            <conv:TextToLineNumbersConverter x:Key="LineNos"/>
            <conv:ProjectInitialsConverter x:Key="Initials"/>
            <!-- Soft-amber banner fill. These soft tokens are declared per-panel across MainWindow
                 (not in App.axaml), so scope one here too. Semi-transparent → reads on both themes. -->
            <SolidColorBrush x:Key="WarnSoft" Color="#29d9a35f"/>
          </Grid.Resources>
          <Grid.Styles>
            <Style Selector="Button.exptool">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Width" Value="27"/>
              <Setter Property="Height" Value="25"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="CornerRadius" Value="6"/>
            </Style>
            <Style Selector="Button.exptool:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="{DynamicResource Panel}"/>
            </Style>
            <Style Selector="TreeViewItem">
              <Setter Property="Padding" Value="2,0"/>
              <Setter Property="MinHeight" Value="26"/>
              <!-- Reflect the node's expansion so RefreshTree/CollapseAll (which set node.IsExpanded)
                   actually drive the visual tree. ReflectionBinding: a Style setter has no x:DataType,
                   so a compiled binding would resolve against the Window VM instead of the node. -->
              <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}"/>
            </Style>
            <Style Selector="TreeViewItem:selected /template/ Border#PART_Header">
              <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
              <Setter Property="CornerRadius" Value="6"/>
            </Style>
            <Style Selector="TextBlock.gutter">
              <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Menlo, monospace"/>
              <Setter Property="FontSize" Value="12.5"/>
              <Setter Property="LineHeight" Value="20"/>
              <Setter Property="TextAlignment" Value="Right"/>
              <Setter Property="Foreground" Value="{DynamicResource T4}"/>
              <Setter Property="Margin" Value="16,0,14,0"/>
              <Setter Property="MinWidth" Value="26"/>
            </Style>
            <Style Selector="TextBlock.code">
              <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Menlo, monospace"/>
              <Setter Property="FontSize" Value="12.5"/>
              <Setter Property="LineHeight" Value="20"/>
              <Setter Property="Foreground" Value="{DynamicResource T2}"/>
              <Setter Property="TextWrapping" Value="NoWrap"/>
            </Style>
          </Grid.Styles>

          <!-- ── Explorer sidebar ───────────────────────────────────────────── -->
          <Border Grid.Column="0" Background="{DynamicResource Chrome}" BorderBrush="{DynamicResource Line}"
                  BorderThickness="0,0,1,0">
            <DockPanel Margin="0">
              <!-- Header: EXPLORER + toolbar (new file / new folder / refresh / collapse) -->
              <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="14,12,8,8">
                <TextBlock Grid.Column="0" Text="EXPLORER" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource T4}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="1">
                  <Button Classes="exptool" Command="{Binding Explorer.NewFileCommand}" ToolTip.Tip="New file">
                    <Path Classes="ico ico-sm" Data="{StaticResource IcoFileArrowUp}"/>
                  </Button>
                  <Button Classes="exptool" Command="{Binding Explorer.NewFolderCommand}" ToolTip.Tip="New folder">
                    <Path Classes="ico ico-sm" Data="{StaticResource IcoFolderOpen}"/>
                  </Button>
                  <Button Classes="exptool" Command="{Binding Explorer.RefreshTreeCommand}" ToolTip.Tip="Refresh">
                    <Path Classes="ico ico-sm" Data="{StaticResource IcoRefresh}"/>
                  </Button>
                  <Button Classes="exptool" Command="{Binding Explorer.CollapseAllCommand}" ToolTip.Tip="Collapse all">
                    <Path Classes="ico ico-sm" Data="{StaticResource IcoListDashes}"/>
                  </Button>
                </StackPanel>
              </Grid>

              <!-- Status line pinned to the bottom of the sidebar -->
              <TextBlock DockPanel.Dock="Bottom" Text="{Binding Explorer.ExplorerStatus}"
                         Foreground="{DynamicResource T4}" FontSize="11" Margin="16,8,12,12"
                         TextTrimming="CharacterEllipsis"/>

              <!-- No-workspace hint -->
              <TextBlock DockPanel.Dock="Top" IsVisible="{Binding !Explorer.HasWorkspace}"
                         Text="No workspace open. Open a project from the Start Center."
                         Foreground="{DynamicResource T3}" FontSize="12" TextWrapping="Wrap" Margin="16,8,12,0"/>

              <!-- Workspace root row + tree -->
              <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel IsVisible="{Binding Explorer.HasWorkspace}" Margin="6,2,6,0">
                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,2,0,6">
                    <Border Width="20" Height="20" CornerRadius="5" Background="{DynamicResource Accent}"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding Explorer.WorkspaceName, Converter={StaticResource Initials}}"
                                 Foreground="White" FontSize="10" FontWeight="Bold"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding Explorer.WorkspaceName}" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                  </StackPanel>

                  <!-- ExplorerTree is named so the per-node context menu (whose DataContext is the node)
                       can reach the shell VM's file-op commands via an element-name compiled binding (#223). -->
                  <TreeView x:Name="ExplorerTree" ItemsSource="{Binding Explorer.RootNode.Children}"
                            SelectionChanged="ExplorerTree_SelectionChanged" Background="Transparent">
                    <TreeView.ItemTemplate>
                      <TreeDataTemplate x:DataType="models:WorkspaceTreeNode" ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Spacing="8" Height="24">
                          <StackPanel.ContextMenu>
                            <ContextMenu>
                              <MenuItem Header="Rename…"
                                        Command="{Binding #ExplorerTree.((vm:MainWindowViewModel)DataContext).Explorer.RenameNodeCommand}"
                                        CommandParameter="{Binding}"/>
                              <Separator/>
                              <MenuItem Header="Delete"
                                        Command="{Binding #ExplorerTree.((vm:MainWindowViewModel)DataContext).Explorer.DeleteNodeCommand}"
                                        CommandParameter="{Binding}"/>
                            </ContextMenu>
                          </StackPanel.ContextMenu>
                          <!-- Folder glyph for directories -->
                          <Path Classes="ico ico-sm muted" Data="{StaticResource IcoFolder}" VerticalAlignment="Center"
                                IsVisible="{Binding IsDirectory}"/>
                          <!-- Colored type chip for files (JSONL / JSON / MD …) -->
                          <Border Background="{DynamicResource AccentSoft}" CornerRadius="4" Padding="4,1"
                                  VerticalAlignment="Center" IsVisible="{Binding !IsDirectory}" MinWidth="30">
                            <TextBlock Text="{Binding ChipLabel}" FontSize="8.5" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentInk}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                          </Border>
                          <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                     Foreground="{DynamicResource T2}"/>
                          <!-- Generated-artifact marker (honest: derived from the tree node) -->
                          <Ellipse Width="6" Height="6" Fill="{DynamicResource Warn}" VerticalAlignment="Center"
                                   IsVisible="{Binding IsGeneratedArtifact}"/>
                        </StackPanel>
                      </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                  </TreeView>
                </StackPanel>
              </ScrollViewer>
            </DockPanel>
          </Border>

          <!-- ── Editor pane ────────────────────────────────────────────────── -->
          <DockPanel Grid.Column="1" Background="{DynamicResource Win}">
            <!-- Open-document tab strip -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource Chrome}" BorderBrush="{DynamicResource Line}"
                    BorderThickness="0,0,0,1" MinHeight="38">
              <ListBox ItemsSource="{Binding Explorer.OpenDocuments}" SelectedItem="{Binding Explorer.ActiveDocument}"
                       Background="Transparent" BorderThickness="0" Padding="0">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                  </Style>
                  <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent"/>
                  </Style>
                  <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent"/>
                  </Style>
                  <Style Selector="ListBoxItem:selected Border.doctab">
                    <Setter Property="Background" Value="{DynamicResource Win}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:OpenWorkspaceDocument">
                    <Border Classes="doctab" Background="Transparent" BorderBrush="Transparent"
                            BorderThickness="0,2,0,0" Padding="12,0,8,0" Height="37">
                      <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                        <Path Classes="ico ico-sm accent" Data="{StaticResource IcoCode}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource Text}"
                                   VerticalAlignment="Center" FontSize="12.5"/>
                        <!-- Dirty marker -->
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource T3}" VerticalAlignment="Center"
                                 IsVisible="{Binding IsDirty}"/>
                        <!-- Close (code-behind: confirm-if-dirty → CloseDocument) -->
                        <Button Classes="exptool" Width="20" Height="20" Click="DocTabClose_Click"
                                ToolTip.Tip="Close">
                          <Path Classes="ico ico-sm muted" Data="{StaticResource IcoX}" Width="11" Height="11"/>
                        </Button>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>

            <!-- Examples.jsonl caution banner (real: Explorer.IsExamplesFile) -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource WarnSoft}" BorderBrush="{DynamicResource Warn}"
                    BorderThickness="3,0,0,0" Padding="14,10" IsVisible="{Binding Explorer.IsExamplesFile}">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Path Classes="ico ico-sm warn" Data="{StaticResource IcoWarningFill}" VerticalAlignment="Center"/>
                <TextBlock Foreground="{DynamicResource Warn}" FontSize="12.5" VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Text="This is the dataset's single source of rows. The desktop is its only writer — use Writing Studio / Import for row-level changes."/>
              </StackPanel>
            </Border>

            <!-- Editor body: empty / text / image / binary states -->
            <Panel>
              <!-- Empty state -->
              <StackPanel IsVisible="{Binding Explorer.IsNoDocument}" HorizontalAlignment="Center"
                          VerticalAlignment="Center" Spacing="10">
                <Path Classes="ico muted" Data="{StaticResource IcoTree}" Width="30" Height="30"
                      HorizontalAlignment="Center"/>
                <TextBlock Text="Select a file in the Explorer to view it."
                           Foreground="{DynamicResource T3}" FontSize="13" HorizontalAlignment="Center"/>
              </StackPanel>

              <!-- Text viewer: line-number gutter + real content (read-only) -->
              <ScrollViewer IsVisible="{Binding Explorer.IsTextDocument}"
                            VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid ColumnDefinitions="Auto,*" Margin="0,10,0,10">
                  <TextBlock Grid.Column="0" Classes="gutter"
                             Text="{Binding Explorer.ActiveDocument.TextContent, Converter={StaticResource LineNos}}"/>
                  <TextBlock Grid.Column="1" Classes="code" Margin="0,0,16,0"
                             Text="{Binding Explorer.ActiveDocument.TextContent}"/>
                </Grid>
              </ScrollViewer>

              <!-- Image preview -->
              <StackPanel IsVisible="{Binding Explorer.IsImageDocument}" HorizontalAlignment="Center"
                          VerticalAlignment="Center" Spacing="6">
                <TextBlock Text="{Binding Explorer.ActiveRelPath}" Foreground="{DynamicResource T2}"
                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Image file — open it externally to view." Foreground="{DynamicResource T3}"
                           FontSize="12.5" HorizontalAlignment="Center"/>
              </StackPanel>

              <!-- Non-text / non-image note -->
              <StackPanel IsVisible="{Binding Explorer.IsBinaryDocument}" HorizontalAlignment="Center"
                          VerticalAlignment="Center" Spacing="6">
                <TextBlock Text="{Binding Explorer.ActiveRelPath}" Foreground="{DynamicResource T2}"
                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="No text preview for this file type." Foreground="{DynamicResource T3}"
                           FontSize="12.5" HorizontalAlignment="Center"/>
              </StackPanel>
            </Panel>
          </DockPanel>
        </Grid>

        <!-- Studio mode (IsVisible←IsStudio): hero + projects sidebar + the 14-tab TabControl + Quality panel. -->
        <!-- Col2 is Auto so the Quality rail collapses (content fills) when ShowQualityRail is false. -->
        <Grid IsVisible="{Binding IsStudio}" RowDefinitions="Auto,*" ColumnDefinitions="250,*,Auto">
          <!-- App-shell CONTEXT BAR (slice 4): replaces the always-on action toolbar. Left = the
               current screen's title + subtitle (driven by SelectedStudioTabIndex). Right = the primary
               actions + a "⋯ More" toggle that reveals the secondary project actions + export controls
               (nothing lost). The redundant Debt/Eval/Splits/Train/Studio nav buttons are dropped — the
               grouped sidebar navigates now. -->
          <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,6">

            <Border Height="54" Background="{DynamicResource Win}" Padding="16,0"
                    BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding StudioViewTitle}" FontSize="15" FontWeight="SemiBold"
                             Foreground="{DynamicResource Text}"/>
                  <TextBlock Text="{Binding StudioViewSubtitle}" FontSize="11.5" Foreground="{DynamicResource T4}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <Button Content="Import" Command="{Binding ImportDatasetCommand}"/>
                  <Button Content="Run gates" Command="{Binding RunGatesCommand}"/>
                  <Button Content="Author example" Command="{Binding GoToWritingStudioCommand}"
                          Background="{DynamicResource AccentSoft}" Foreground="{DynamicResource AccentInk}"
                          BorderBrush="{DynamicResource Accent}" BorderThickness="1"/>
                  <Button Content="⋯" Width="34" Command="{Binding ToggleProjectActionsCommand}"
                          ToolTip.Tip="More project actions"/>
                </StackPanel>
              </Grid>
            </Border>

            <!-- Overflow: the secondary project actions + export controls (hidden by default). -->
            <Border IsVisible="{Binding ProjectActionsExpanded}" Background="{DynamicResource Panel2}"
                    BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="16,10">
              <StackPanel Spacing="8">
                <WrapPanel>
                  <Button Content="Import from HF" Command="{Binding ImportFromHuggingFaceCommand}" Margin="0,0,6,4"/>
                  <Button Content="Rebuild index" Command="{Binding RebuildProjectIndexCommand}" Margin="0,0,6,4"/>
                  <Button Content="Generate card" Command="{Binding GenerateDatasetCardCommand}" Margin="0,0,6,4"/>
                  <Button Content="Run chat gates" Command="{Binding RunChatGatesCommand}" Margin="0,0,6,4"/>
                  <Button Content="Check provenance" Command="{Binding RunProvenanceGateCommand}" Margin="0,0,6,4"/>
                  <Button Content="Benchmark" Command="{Binding RunBenchmarkCommand}" Margin="0,0,6,4"/>
                </WrapPanel>
                <WrapPanel VerticalAlignment="Center">
                  <CheckBox Content="dedupe" IsChecked="{Binding ExportRemoveDuplicates}" Margin="0,0,8,0"/>
                  <CheckBox Content="drop low-info" IsChecked="{Binding ExportRemoveLowInformation}" Margin="0,0,8,0"/>
                  <TextBox Text="{Binding ExportFormat}" Watermark="jsonl/csv/tsv/parquet" Width="150" Margin="0,0,6,0"/>
                  <Button Content="Export dataset" Command="{Binding ExportJsonlCommand}" Margin="0,0,10,0"/>
                </WrapPanel>
              </StackPanel>
            </Border>

            <!-- Per-row provenance verdict (conditional; the WBG licensing landmine). -->
            <StackPanel IsVisible="{Binding HasProvenanceGateReport}" Spacing="4" Margin="16,6,16,0">
              <Border CornerRadius="4" Padding="7,1" HorizontalAlignment="Left"
                      Background="{Binding ProvenanceGateColor, Converter={StaticResource StringToBrush}}">
                <TextBlock Text="{Binding ProvenanceGateStatus}" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
              </Border>
              <TextBox Text="{Binding ProvenanceGateSummary}" IsReadOnly="True" AcceptsReturn="True"
                       FontFamily="Consolas" FontSize="11.5" MaxHeight="150" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Engine setup + error banners (conditional). -->
            <WrapPanel IsVisible="{Binding IsEngineUnavailable}" Margin="16,6,16,0">
              <TextBlock Text="{Binding EngineUnavailableMessage}" Foreground="{DynamicResource AppWarn}" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <Button Content="Locate engine…" Command="{Binding LocateEngineCommand}" Margin="0,0,6,0"/>
              <Button Content="Retry" Command="{Binding RetryEngineCommand}" Margin="0,0,6,0"/>
            </WrapPanel>
            <WrapPanel IsVisible="{Binding HasError}" Margin="16,6,16,0">
              <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource AppError}" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <Button Content="Dismiss" Command="{Binding DismissErrorCommand}"/>
            </WrapPanel>

          </StackPanel>
          <!-- Grouped workflow-phase sidebar (slice 2): the Nocturne IA — a project switcher over a
               section→subsection nav that DRIVES the content-switcher via SelectStudioTabCommand.
               Active row = accent-soft via TabActiveBrush; group headers are T4 uppercase with a
               per-phase status glyph. Replaces the flat tab strip. (Real gating + Phosphor icons: a
               later slice.) -->
          <DockPanel Grid.Row="1" Grid.Column="0" Background="{DynamicResource Panel2}">
            <!-- Project switcher: the Nocturne avatar card. A blurple monogram (derived from the
                 active project title) + the bold project name over a "<schema> · <N> rows" subtitle,
                 with a small up/down switch affordance. The real Projects/SelectedProject list stays
                 one click away in the card's flyout, so switching projects still works. -->
            <Border DockPanel.Dock="Top" Padding="8" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
              <Border.Resources>
                <conv:ProjectInitialsConverter x:Key="ProjectInitials"/>
              </Border.Resources>
              <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      Padding="6" CornerRadius="10" Cursor="Hand" ToolTip.Tip="Switch project">
                <Button.Styles>
                  <Style Selector="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                  </Style>
                  <Style Selector="Button:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource Hover}"/>
                  </Style>
                  <Style Selector="Button:pressed /template/ ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource Hover}"/>
                  </Style>
                </Button.Styles>
                <Button.Flyout>
                  <Flyout Placement="BottomEdgeAlignedLeft">
                    <StackPanel Spacing="4" MinWidth="220">
                      <TextBlock Text="PROJECT" Foreground="{DynamicResource T4}" FontSize="10"
                                 FontWeight="SemiBold" Margin="4,2,0,2"/>
                      <ListBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"
                               Background="Transparent" BorderThickness="0" MaxHeight="260" Padding="0">
                        <ListBox.ItemTemplate>
                          <DataTemplate x:DataType="models:DatasetProjectListItem">
                            <TextBlock Text="{Binding DisplayName}" Margin="0,1"/>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </StackPanel>
                  </Flyout>
                </Button.Flyout>
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <!-- Avatar: blurple rounded square with the project monogram. -->
                  <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9"
                          Background="{DynamicResource Accent}" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ActiveProjectTitle, Converter={StaticResource ProjectInitials}}"
                               Foreground="{DynamicResource AccentInk}" FontSize="12.5" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <!-- Name over "<schema> · <N> rows" (real active schema + live example count). -->
                  <StackPanel Grid.Column="1" Margin="10,0,6,0" VerticalAlignment="Center" Spacing="1">
                    <TextBlock Text="{Binding ActiveProjectTitle}" Foreground="{DynamicResource Text}"
                               FontWeight="Bold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding ActiveSchemaId}" Foreground="{DynamicResource T4}" FontSize="11"/>
                      <TextBlock Text=" · " Foreground="{DynamicResource T4}" FontSize="11"/>
                      <TextBlock Text="{Binding Examples.Items.Count}" Foreground="{DynamicResource T4}" FontSize="11"/>
                      <TextBlock Text=" rows" Foreground="{DynamicResource T4}" FontSize="11"/>
                    </StackPanel>
                  </StackPanel>
                  <!-- Up/down switch affordance (plain stroked chevrons, no icon glyph). -->
                  <Path Grid.Column="2" VerticalAlignment="Center" Margin="2,0,4,0"
                        Stroke="{DynamicResource T3}" StrokeThickness="1.4"
                        StrokeLineCap="Round" StrokeJoin="Round"
                        Data="M0,4 L4,0 L8,4 M0,8 L4,12 L8,8"/>
                </Grid>
              </Button>
            </Border>
            <!-- Bottom status (design: green dot + Local-first · engine ready; warn when the engine
                 probe is unavailable — bound honestly to IsEngineUnavailable). -->
            <Border DockPanel.Dock="Bottom" Padding="12,8" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                         Fill="{DynamicResource Ok}" IsVisible="{Binding !IsEngineUnavailable}"/>
                <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                         Fill="{DynamicResource Warn}" IsVisible="{Binding IsEngineUnavailable}"/>
                <TextBlock Text="Local-first · engine ready" FontSize="11" Foreground="{DynamicResource T3}"
                           VerticalAlignment="Center" IsVisible="{Binding !IsEngineUnavailable}"/>
                <TextBlock Text="Local-first · engine unavailable" FontSize="11" Foreground="{DynamicResource Warn}"
                           VerticalAlignment="Center" IsVisible="{Binding IsEngineUnavailable}"/>
              </StackPanel>
            </Border>
            <!-- Grouped nav -->
            <ScrollViewer>
              <StackPanel Margin="8,8" Spacing="1">

                <TextBlock Text="OVERVIEW" Foreground="{DynamicResource T4}" FontSize="10" FontWeight="SemiBold" Margin="8,4,0,3"/>
                <Button Classes="navrow" CommandParameter="Dashboard" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Dashboard}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoDashboard}"/>
                    <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal" Spacing="6" Margin="8,10,0,3">
                  <TextBlock Text="AUTHOR" Foreground="{DynamicResource T4}" FontSize="10" FontWeight="SemiBold"/>
                  <Path Classes="ico ico-sm ok" Data="{StaticResource IcoCheckCircleFill}"/>
                </StackPanel>
                <Button Classes="navrow" CommandParameter="WritingStudio" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=WritingStudio}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoPencil}"/>
                    <TextBlock Text="Writing Studio" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Classes="navrow" CommandParameter="Examples" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Examples}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoRows}"/>
                    <TextBlock Text="Examples" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Classes="navrow" CommandParameter="Quarantine" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Quarantine}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoImport}"/>
                    <TextBlock Text="Import &amp; Quarantine" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Classes="navrow" CommandParameter="PreferenceReview" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=PreferenceReview}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoScales}"/>
                    <TextBlock Text="Preference Review" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Classes="navrow" CommandParameter="AiAssist" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=AiAssist}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoChats}"/>
                    <TextBlock Text="AI Assist" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal" Spacing="6" Margin="8,10,0,3">
                  <TextBlock Text="MEASURE" Foreground="{DynamicResource T4}" FontSize="10" FontWeight="SemiBold"/>
                  <Path Classes="ico ico-sm warn" Data="{StaticResource IcoWarningFill}"/>
                </StackPanel>
                <Button Classes="navrow" CommandParameter="Quality" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Quality}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoBroom}"/>
                    <TextBlock Text="Quality" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Classes="navrow" CommandParameter="Debt" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Debt}">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <Path Grid.Column="0" Classes="ico" Data="{StaticResource IcoHeart}"/>
                    <TextBlock Grid.Column="1" Text="Dataset Debt" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <Border Grid.Column="2" MinWidth="18" Height="18" CornerRadius="4" Padding="4,0" VerticalAlignment="Center"
                            IsVisible="{Binding Debt.HasGrade}"
                            Background="{Binding Debt.DebtGradeColor, Converter={StaticResource StringToBrush}}">
                      <TextBlock Text="{Binding Debt.DebtGrade}" FontSize="10.5" FontWeight="Bold" Foreground="White"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                  </Grid>
                </Button>
                <Button Classes="navrow" CommandParameter="Splits" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Splits}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoPie}"/>
                    <TextBlock Text="Splits" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal" Spacing="6" Margin="8,10,0,3">
                  <TextBlock Text="EVALUATE" Foreground="{DynamicResource T4}" FontSize="10" FontWeight="SemiBold"/>
                  <Path Classes="ico ico-sm muted" Data="{StaticResource IcoLock}"/>
                </StackPanel>
                <Button Classes="navrow" CommandParameter="Evaluation" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Evaluation}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoFlask}"/>
                    <TextBlock Text="Evaluation" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Classes="navrow" CommandParameter="Arena" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Arena}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoTrophy}"/>
                    <TextBlock Text="Model Arena" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Classes="navrow" CommandParameter="Suites" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Suites}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoChecklist}"/>
                    <TextBlock Text="Suites" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal" Spacing="6" Margin="8,10,0,3">
                  <TextBlock Text="TRAIN" Foreground="{DynamicResource T4}" FontSize="10" FontWeight="SemiBold"/>
                  <Path Classes="ico ico-sm muted" Data="{StaticResource IcoLock}"/>
                </StackPanel>
                <Button Classes="navrow" CommandParameter="Training" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Training}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoCap}"/>
                    <TextBlock Text="Training" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Classes="navrow" CommandParameter="Artifacts" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Artifacts}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoCube}"/>
                    <TextBlock Text="Artifacts" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

                <Border Height="1" Background="{DynamicResource Line}" Margin="8,10,8,6"/>
                <Button Classes="navrow" CommandParameter="Versions" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Versions}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoBranch}"/>
                    <TextBlock Text="Versions" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Classes="navrow" CommandParameter="Settings" Command="{Binding SelectStudioTabCommand}"
                        Background="{Binding SelectedStudioTabIndex, Converter={StaticResource TabActiveBrush}, ConverterParameter=Settings}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="ico" Data="{StaticResource IcoGear}"/>
                    <TextBlock Text="Settings" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>

              </StackPanel>
            </ScrollViewer>
          </DockPanel>

          <!-- Grouped-IA content-switcher (slice 2): the flat 14-tab strip is replaced by the
               sectioned nav (left) driving these overlapping view panels; exactly one is IsVisible
               via SelectedStudioTabIndex. The screen CONTENTS are the former TabItem bodies, byte
               for byte — a later slice raises each to full Nocturne fidelity. -->
          <Panel Grid.Row="1" Grid.Column="1" Margin="8,0">

    <!-- OVERVIEW · Dashboard hero (slice 3): readiness card + lifecycle strip + stat cards + quick
         actions. All read-bindings on existing shared-VM data; per-node lifecycle STATUS wiring +
         Phosphor icons + a recent-activity feed are later slices (not faked here). -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Dashboard}">
      <ScrollViewer>
        <StackPanel Margin="20" Spacing="16" MaxWidth="940" HorizontalAlignment="Left">

          <!-- Readiness hero card -->
          <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="18"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <StackPanel Spacing="16">
              <Grid ColumnDefinitions="Auto,*">
                <Border Grid.Column="0" Width="52" Height="52" CornerRadius="10" VerticalAlignment="Top"
                        Background="{Binding Debt.DebtGradeColor, Converter={StaticResource StringToBrush}}">
                  <TextBlock Text="{Binding Debt.DebtGrade}" FontSize="26" FontWeight="Bold" Foreground="White"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center" Margin="14,0,0,0">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{Binding ActiveProjectTitle}" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource AccentSoft}" CornerRadius="5" Padding="8,2" VerticalAlignment="Center">
                      <TextBlock Text="{Binding ActiveSchemaId}" FontSize="11" Foreground="{DynamicResource AccentInk}"/>
                    </Border>
                    <TextBlock Text="stale" Foreground="{DynamicResource Warn}" FontSize="11" VerticalAlignment="Center"
                               IsVisible="{Binding Debt.DebtStale}"/>
                  </StackPanel>
                  <TextBlock Text="{Binding Debt.DebtSummary}" Foreground="{DynamicResource T3}" TextWrapping="Wrap"/>
                  <Button Command="{Binding RunDatasetDebtCommand}" HorizontalAlignment="Left" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Path Classes="ico accent" Data="{StaticResource IcoRefresh}" Width="14" Height="14"/>
                      <TextBlock Text="Re-check debt" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </StackPanel>
              </Grid>

              <Border Height="1" Background="{DynamicResource Line}"/>

              <!-- Lifecycle strip: HONEST per-node status. Each node's circle colour + status glyph is
                   driven by a REAL shared-VM signal (*NodeStatus → LifecycleNode converter). Where no
                   reliable signal exists the node stays NEUTRAL (a bare Track circle, no glyph): Validate
                   and Split have no persistent "passed / generated" signal, and Train is the terminal
                   gated phase (a lock, never "done"). A completed step is never faked. -->
              <Grid Margin="0,2,0,0">
                <Border Height="2" Background="{DynamicResource Track}" VerticalAlignment="Top" Margin="58,12,58,0"/>
                <UniformGrid Columns="7">
                  <StackPanel>
                    <Border Width="26" Height="26" CornerRadius="13" BorderThickness="1.5" HorizontalAlignment="Center"
                            Background="{Binding AuthorNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=bg}"
                            BorderBrush="{Binding AuthorNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=border}">
                      <Path Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                            IsVisible="{Binding AuthorNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=hasglyph}"
                            Data="{Binding AuthorNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyph}"
                            Fill="{Binding AuthorNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyphfill}"/>
                    </Border>
                    <TextBlock Text="Author" FontSize="10" Foreground="{DynamicResource T4}"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                  </StackPanel>
                  <StackPanel>
                    <Border Width="26" Height="26" CornerRadius="13" BorderThickness="1.5" HorizontalAlignment="Center"
                            Background="{Binding ValidateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=bg}"
                            BorderBrush="{Binding ValidateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=border}">
                      <Path Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                            IsVisible="{Binding ValidateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=hasglyph}"
                            Data="{Binding ValidateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyph}"
                            Fill="{Binding ValidateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyphfill}"/>
                    </Border>
                    <TextBlock Text="Validate" FontSize="10" Foreground="{DynamicResource T4}"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                  </StackPanel>
                  <StackPanel>
                    <Border Width="26" Height="26" CornerRadius="13" BorderThickness="1.5" HorizontalAlignment="Center"
                            Background="{Binding QualityNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=bg}"
                            BorderBrush="{Binding QualityNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=border}">
                      <Path Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                            IsVisible="{Binding QualityNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=hasglyph}"
                            Data="{Binding QualityNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyph}"
                            Fill="{Binding QualityNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyphfill}"/>
                    </Border>
                    <TextBlock Text="Quality" FontSize="10" Foreground="{DynamicResource T4}"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                  </StackPanel>
                  <StackPanel>
                    <Border Width="26" Height="26" CornerRadius="13" BorderThickness="1.5" HorizontalAlignment="Center"
                            Background="{Binding GateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=bg}"
                            BorderBrush="{Binding GateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=border}">
                      <Path Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                            IsVisible="{Binding GateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=hasglyph}"
                            Data="{Binding GateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyph}"
                            Fill="{Binding GateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyphfill}"/>
                    </Border>
                    <TextBlock Text="Gate" FontSize="10" Foreground="{DynamicResource T4}"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                  </StackPanel>
                  <StackPanel>
                    <Border Width="26" Height="26" CornerRadius="13" BorderThickness="1.5" HorizontalAlignment="Center"
                            Background="{Binding SplitNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=bg}"
                            BorderBrush="{Binding SplitNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=border}">
                      <Path Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                            IsVisible="{Binding SplitNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=hasglyph}"
                            Data="{Binding SplitNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyph}"
                            Fill="{Binding SplitNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyphfill}"/>
                    </Border>
                    <TextBlock Text="Split" FontSize="10" Foreground="{DynamicResource T4}"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                  </StackPanel>
                  <StackPanel>
                    <Border Width="26" Height="26" CornerRadius="13" BorderThickness="1.5" HorizontalAlignment="Center"
                            Background="{Binding EvaluateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=bg}"
                            BorderBrush="{Binding EvaluateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=border}">
                      <Path Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                            IsVisible="{Binding EvaluateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=hasglyph}"
                            Data="{Binding EvaluateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyph}"
                            Fill="{Binding EvaluateNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyphfill}"/>
                    </Border>
                    <TextBlock Text="Evaluate" FontSize="10" Foreground="{DynamicResource T4}"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                  </StackPanel>
                  <StackPanel>
                    <Border Width="26" Height="26" CornerRadius="13" BorderThickness="1.5" HorizontalAlignment="Center"
                            Background="{Binding TrainNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=bg}"
                            BorderBrush="{Binding TrainNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=border}">
                      <Path Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                            IsVisible="{Binding TrainNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=hasglyph}"
                            Data="{Binding TrainNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyph}"
                            Fill="{Binding TrainNodeStatus, Converter={StaticResource LifecycleNode}, ConverterParameter=glyphfill}"/>
                    </Border>
                    <TextBlock Text="Train" FontSize="10" Foreground="{DynamicResource T4}"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                  </StackPanel>
                </UniformGrid>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Stat cards -->
          <TextBlock Text="AT A GLANCE" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource T4}" Margin="2,2,0,0"/>
          <WrapPanel>
            <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="14" Margin="0,0,10,10"
                    Width="182" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="3">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Path Classes="ico ico-sm muted" Data="{StaticResource IcoRows}"/>
                  <TextBlock Text="EXAMPLES" FontSize="10" Foreground="{DynamicResource T4}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding Examples.Items.Count}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource Text}"/>
                <TextBlock Text="rows in the dataset" FontSize="11" Foreground="{DynamicResource T3}"/>
              </StackPanel>
            </Border>
            <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="14" Margin="0,0,10,10"
                    Width="182" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="3">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Path Classes="ico ico-sm muted" Data="{StaticResource IcoHeart}"/>
                  <TextBlock Text="DATASET DEBT" FontSize="10" Foreground="{DynamicResource T4}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding Debt.DebtGrade}" FontSize="26" FontWeight="Bold"
                           Foreground="{Binding Debt.DebtGradeColor, Converter={StaticResource StringToBrush}}"/>
                <TextBlock Text="remediation grade" FontSize="11" Foreground="{DynamicResource T3}"/>
              </StackPanel>
            </Border>
            <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="14" Margin="0,0,10,10"
                    Width="182" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="3">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Path Classes="ico ico-sm muted" Data="{StaticResource IcoWarnDiamond}"/>
                  <TextBlock Text="OPEN PROBLEMS" FontSize="10" Foreground="{DynamicResource T4}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding Problems.Count}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource Text}"/>
                <TextBlock Text="gate findings" FontSize="11" Foreground="{DynamicResource T3}"/>
              </StackPanel>
            </Border>
            <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="14" Margin="0,0,10,10"
                    Width="234" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="3">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Path Classes="ico ico-sm muted" Data="{StaticResource IcoFlask}"/>
                  <TextBlock Text="LAST EVALUATION" FontSize="10" Foreground="{DynamicResource T4}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding Evaluation.EvaluationResultsSummary}" FontSize="13"
                           Foreground="{DynamicResource Text}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </WrapPanel>

          <!-- Quick actions -->
          <TextBlock Text="QUICK ACTIONS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource T4}" Margin="2,4,0,0"/>
          <WrapPanel>
            <Button Command="{Binding GoToWritingStudioCommand}" Width="222" Margin="0,0,10,10" Padding="12"
                    HorizontalContentAlignment="Left" Background="{DynamicResource Panel}"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1" CornerRadius="11">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource AccentSoft}">
                  <Path Classes="ico accent" Data="{StaticResource IcoPencil}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Author examples" Foreground="{DynamicResource Text}" FontWeight="SemiBold"/>
                  <TextBlock Text="write &amp; validate rows" Foreground="{DynamicResource T3}" FontSize="11"/>
                </StackPanel>
              </StackPanel>
            </Button>
            <Button Command="{Binding RunQualityCommand}" Width="222" Margin="0,0,10,10" Padding="12"
                    HorizontalContentAlignment="Left" Background="{DynamicResource Panel}"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1" CornerRadius="11">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource AccentSoft}">
                  <Path Classes="ico accent" Data="{StaticResource IcoBroom}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Run quality" Foreground="{DynamicResource Text}" FontWeight="SemiBold"/>
                  <TextBlock Text="scan for issues" Foreground="{DynamicResource T3}" FontSize="11"/>
                </StackPanel>
              </StackPanel>
            </Button>
            <Button Command="{Binding GenerateSplitsCommand}" Width="222" Margin="0,0,10,10" Padding="12"
                    HorizontalContentAlignment="Left" Background="{DynamicResource Panel}"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1" CornerRadius="11">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource AccentSoft}">
                  <Path Classes="ico accent" Data="{StaticResource IcoShuffle}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Generate splits" Foreground="{DynamicResource Text}" FontWeight="SemiBold"/>
                  <TextBlock Text="train / val / test" Foreground="{DynamicResource T3}" FontSize="11"/>
                </StackPanel>
              </StackPanel>
            </Button>
            <Button Command="{Binding GoToEvaluationCommand}" Width="222" Margin="0,0,10,10" Padding="12"
                    HorizontalContentAlignment="Left" Background="{DynamicResource Panel}"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1" CornerRadius="11">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource AccentSoft}">
                  <Path Classes="ico accent" Data="{StaticResource IcoFlask}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Run evaluation" Foreground="{DynamicResource Text}" FontWeight="SemiBold"/>
                  <TextBlock Text="score vs a model" Foreground="{DynamicResource T3}" FontSize="11"/>
                </StackPanel>
              </StackPanel>
            </Button>
            <Button Command="{Binding GoToTrainingCommand}" Width="222" Margin="0,0,10,10" Padding="12"
                    HorizontalContentAlignment="Left" Background="{DynamicResource Panel}"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1" CornerRadius="11">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource AccentSoft}">
                  <Path Classes="ico accent" Data="{StaticResource IcoCap}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Training config" Foreground="{DynamicResource Text}" FontWeight="SemiBold"/>
                  <TextBlock Text="configure a run" Foreground="{DynamicResource T3}" FontSize="11"/>
                </StackPanel>
              </StackPanel>
            </Button>
            <Button Command="{Binding CaptureDatasetVersionCommand}" Width="222" Margin="0,0,10,10" Padding="12"
                    HorizontalContentAlignment="Left" Background="{DynamicResource Panel}"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1" CornerRadius="11">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource AccentSoft}">
                  <Path Classes="ico accent" Data="{StaticResource IcoGitCommit}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Capture version" Foreground="{DynamicResource Text}" FontWeight="SemiBold"/>
                  <TextBlock Text="snapshot the dataset" Foreground="{DynamicResource T3}" FontSize="11"/>
                </StackPanel>
              </StackPanel>
            </Button>
          </WrapPanel>

          <!-- Recent activity: the REAL engine command log (shell OutputLog), newest first and capped.
               Each row's leading glyph is chosen PURELY from the real verb/outcome (quality → broom,
               import → import, gate/validate → check-circle, capture/version → git-commit, a failure →
               warning, else a neutral list) via EngineLogEntry.ActivityGlyphKey; the message and time are
               the entry's own fields. No activity model is invented — an empty log shows a neutral
               empty-state line (IsNoOutput), never a fabricated feed. The two converters are declared
               locally so App.axaml/Icons.axaml are untouched. -->
          <TextBlock Text="RECENT ACTIVITY" FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource T4}" Margin="2,4,0,0"/>
          <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="6"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <Border.Resources>
              <conv:RecentActivityConverter x:Key="RecentActivity"/>
              <conv:ActivityGlyphConverter x:Key="ActivityGlyph"/>
            </Border.Resources>
            <StackPanel>
              <!-- Empty state (IsNoOutput): honest neutral line, never fabricated rows. -->
              <StackPanel Orientation="Horizontal" Spacing="10" Margin="8,12" IsVisible="{Binding IsNoOutput}">
                <Path Classes="ico ico-sm muted" Data="{StaticResource IcoListDashes}" VerticalAlignment="Center"/>
                <TextBlock Text="No activity yet — run a check or import to see it here"
                           Foreground="{DynamicResource T3}" FontSize="12.5" VerticalAlignment="Center"/>
              </StackPanel>
              <!-- Real log rows, newest first (RecentActivity converter reverses + caps OutputLog). -->
              <ItemsControl IsVisible="{Binding HasOutput}"
                            ItemsSource="{Binding OutputLog, Converter={StaticResource RecentActivity}}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:EngineLogEntry">
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="8,7">
                      <Path Grid.Column="0" Classes="ico" Width="15" Height="15" VerticalAlignment="Center"
                            Data="{Binding ActivityGlyphKey, Converter={StaticResource ActivityGlyph}, ConverterParameter=glyph}"
                            Fill="{Binding ActivityGlyphKey, Converter={StaticResource ActivityGlyph}, ConverterParameter=fill}"/>
                      <TextBlock Grid.Column="1" Text="{Binding ActivityMessage}" Margin="11,0,10,0"
                                 Foreground="{DynamicResource T2}" VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Grid.Column="2" Text="{Binding ActivityMeta}" Foreground="{DynamicResource T4}"
                                 FontSize="11" VerticalAlignment="Center"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Dataset Debt (slice 5 fidelity): grade hero card + severity-ranked ledger cards. Same shared
         Debt VM data (DebtItems already ordered highest-severity-first by the engine). -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Debt}">
      <ScrollViewer>
        <StackPanel Margin="20" Spacing="14" MaxWidth="880" HorizontalAlignment="Left">

          <!-- Grade hero card: badge · verdict headline + summary · weekly mini bar-chart. -->
          <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="18"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*,Auto">
              <!-- Grade badge (gray for N/A / "—" / stale — never green). -->
              <Border Grid.Column="0" Width="64" Height="64" CornerRadius="12" VerticalAlignment="Top"
                      Background="{Binding Debt.DebtGradeColor, Converter={StaticResource StringToBrush}}">
                <TextBlock Text="{Binding Debt.DebtGrade}" FontSize="34" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <!-- Verdict headline (honest, follows the real grade) + descriptive summary. -->
              <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center" Margin="14,0,0,0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="{Binding Debt.DebtVerdict}" FontSize="18" FontWeight="Bold"
                             Foreground="{DynamicResource Text}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                  <TextBlock Text="stale" Foreground="{DynamicResource Warn}" FontSize="11"
                             VerticalAlignment="Center" IsVisible="{Binding Debt.DebtStale}"/>
                </StackPanel>
                <TextBlock Text="{Binding Debt.DebtSummary}" Foreground="{DynamicResource T3}" TextWrapping="Wrap"/>
                <Button Content="Run debt check" Command="{Binding RunDatasetDebtCommand}"
                        HorizontalAlignment="Left" Margin="0,4,0,0"/>
              </StackPanel>
              <!-- Weekly mini bar-chart: one accent bar per recorded quality run, height scaled to the
                   tallest (real Quality.DebtTrend points, latest run at full opacity). Hidden entirely
                   when no trend has been recorded — no fabricated bars. -->
              <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="18,2,0,0" Spacing="5"
                          IsVisible="{Binding Quality.HasDebtTrendPoints}">
                <Border Height="56" MinWidth="72" Padding="1,0" VerticalAlignment="Bottom">
                  <ItemsControl ItemsSource="{Binding Quality.DebtTrend}" VerticalAlignment="Bottom">
                    <ItemsControl.Styles>
                      <Style Selector="Border.bar">
                        <Setter Property="Opacity" Value="0.5"/>
                      </Style>
                      <Style Selector="Border.bar.latest">
                        <Setter Property="Opacity" Value="1"/>
                      </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="models:DebtTrendPoint">
                        <Border Classes="bar" Classes.latest="{Binding IsLatest}"
                                Width="9" Height="{Binding BarHeight}" Margin="0,0,4,0"
                                CornerRadius="2,2,0,0" VerticalAlignment="Bottom"
                                Background="{DynamicResource Accent}" ToolTip.Tip="{Binding Tooltip}"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>
                <TextBlock Text="issue rate · recent runs" FontSize="9.5" Foreground="{DynamicResource T4}"
                           HorizontalAlignment="Center"/>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Section label above the severity-ranked ledger (T4 eyebrow, matches the design). -->
          <TextBlock Text="REMEDIATION LEDGER · highest severity first" FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource T4}" Margin="2,4,0,0"/>

          <!-- Ledger cards (highest severity first) -->
          <ItemsControl ItemsSource="{Binding Debt.DebtItems}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:DebtDisplayItem">
                <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="14" Margin="0,0,0,8"
                        BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <Border Grid.Column="0" CornerRadius="5" Padding="7,2" VerticalAlignment="Center"
                              Background="{Binding SeverityColor, Converter={StaticResource StringToBrush}}">
                        <TextBlock Text="{Binding SeverityBadge}" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                      </Border>
                      <TextBlock Grid.Column="1" Text="{Binding Item.Category}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource Text}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                      <TextBlock Grid.Column="2" Text="{Binding Measure}" Foreground="{DynamicResource T3}"
                                 FontSize="12" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="{Binding Item.Message}" Foreground="{DynamicResource T2}" TextWrapping="Wrap"/>
                    <TextBlock TextWrapping="Wrap">
                      <Run Text="Fix: " Foreground="{DynamicResource T4}"/>
                      <Run Text="{Binding Item.Remediation}" Foreground="{DynamicResource T3}"/>
                    </TextBlock>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Quality (fidelity slice B): the standalone MEASURE screen the design shows but the shell was
         missing — a status header + a metric-card grid + synthetic-issue triage, all over the shared
         Quality VM (populated by Run quality). Honesty: before a run the metrics are empty and the
         header reads the neutral summary; the triage is a green clean-state until real issues exist. -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Quality}">
      <ScrollViewer>
        <StackPanel Margin="20" Spacing="14" MaxWidth="900" HorizontalAlignment="Left">

          <!-- Status header + run -->
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
              <TextBlock Text="{Binding Quality.QualityStatusLine}" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource Text}" TextWrapping="Wrap"
                         IsVisible="{Binding Quality.HasQualityMetrics}"/>
              <TextBlock Text="{Binding Quality.QualitySummary}" Foreground="{DynamicResource T3}"
                         TextWrapping="Wrap" MaxWidth="560" HorizontalAlignment="Left"
                         IsVisible="{Binding !Quality.HasQualityMetrics}"/>
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding RunQualityCommand}" VerticalAlignment="Center"
                    Background="{DynamicResource AccentSoft}" Foreground="{DynamicResource AccentInk}"
                    BorderBrush="{DynamicResource Accent}" BorderThickness="1">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <Path Classes="ico accent" Data="{StaticResource IcoBroom}" Width="15" Height="15"/>
                <TextBlock Text="Run quality" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </Grid>

          <!-- Metric card grid (one card per structured quality metric). -->
          <ItemsControl ItemsSource="{Binding Quality.QualityMetrics}" IsVisible="{Binding Quality.HasQualityMetrics}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:QualityMetric">
                <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="14" Margin="0,0,10,10"
                        Width="220" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                  <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{DynamicResource T2}"
                                 FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,6,0"/>
                      <Border Grid.Column="1" CornerRadius="5" Padding="6,1" VerticalAlignment="Center"
                              Background="{Binding StatusColor, Converter={StaticResource StringToBrush}}">
                        <TextBlock Text="{Binding SeverityBadge}" Foreground="White" FontSize="9.5" FontWeight="Bold"/>
                      </Border>
                    </Grid>
                    <TextBlock Text="{Binding Value}" FontSize="26" FontWeight="Bold"
                               Foreground="{Binding StatusColor, Converter={StaticResource StringToBrush}}"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Synthetic issue triage -->
          <TextBlock Text="SYNTHETIC ISSUE TRIAGE" FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource T4}" Margin="2,4,0,0"
                     IsVisible="{Binding Quality.HasQualityMetrics}"/>
          <!-- Clean state (no synthetic issues) -->
          <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="14"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1"
                  IsVisible="{Binding !Quality.HasSyntheticPatternIssues}">
            <Grid ColumnDefinitions="Auto,*">
              <Path Grid.Column="0" Classes="ico ok" Data="{StaticResource IcoCheckCircleFill}" VerticalAlignment="Top"/>
              <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="3">
                <TextBlock Text="No synthetic-pattern issues detected" Foreground="{DynamicResource Text}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Quality.QualityTriageSummary}" Foreground="{DynamicResource T3}"
                           FontSize="11.5" TextWrapping="Wrap"/>
              </StackPanel>
            </Grid>
          </Border>
          <!-- Flagged synthetic issues -->
          <ItemsControl ItemsSource="{Binding Quality.SyntheticPatternIssues}"
                        IsVisible="{Binding Quality.HasSyntheticPatternIssues}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:SyntheticPatternIssue">
                <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="14" Margin="0,0,0,8"
                        BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                  <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="Auto,*">
                      <Border Grid.Column="0" CornerRadius="5" Padding="6,1" VerticalAlignment="Center"
                              Background="{DynamicResource Warn}">
                        <TextBlock Text="{Binding Severity}" Foreground="White" FontSize="9.5" FontWeight="Bold"/>
                      </Border>
                      <TextBlock Grid.Column="1" Text="{Binding Message}" Foreground="{DynamicResource Text}"
                                 FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/>
                    </Grid>
                    <TextBlock TextWrapping="Wrap">
                      <Run Text="Fix: " Foreground="{DynamicResource T4}"/>
                      <Run Text="{Binding Suggestion}" Foreground="{DynamicResource T3}"/>
                    </TextBlock>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Model Arena (production re-skin): results-first hierarchy — a compact summary line + Run,
         ranked STANDINGS cards, a HEAD-TO-HEAD strip, with the config form + full transcript demoted
         into collapsed overflow below. Binds the additive display props on ArenaViewModel. -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Arena}">
      <ScrollViewer>
        <StackPanel Margin="20" Spacing="14" MaxWidth="820" HorizontalAlignment="Left">

          <!-- Results-first header: compact summary line + Run arena. -->
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="{Binding Arena.ArenaResultsLine}" VerticalAlignment="Center"
                       Foreground="{DynamicResource T3}" FontSize="13" TextWrapping="Wrap"/>
            <Button Grid.Column="1" Command="{Binding RunArenaCommand}" VerticalAlignment="Center"
                    Background="{DynamicResource AccentSoft}" Foreground="{DynamicResource AccentInk}"
                    BorderBrush="{DynamicResource Accent}" BorderThickness="1">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <Path Classes="ico accent" Data="{StaticResource IcoTrophy}" Width="15" Height="15"/>
                <TextBlock Text="Run arena" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </Grid>

          <!-- Empty / pre-run state. -->
          <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="18"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1"
                  IsVisible="{Binding !Arena.HasArenaReport}">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <Path Classes="ico muted" Data="{StaticResource IcoTrophy}" Width="20" Height="20" VerticalAlignment="Top"/>
              <StackPanel Spacing="3">
                <TextBlock Text="No arena results yet" Foreground="{DynamicResource Text}" FontWeight="SemiBold"/>
                <TextBlock Text="Add prompts and models in Arena configuration below, then run the arena to rank models head-to-head."
                           Foreground="{DynamicResource T3}" FontSize="12" TextWrapping="Wrap" MaxWidth="520"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- STANDINGS eyebrow + ranked cards. -->
          <TextBlock Text="STANDINGS" FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource T4}" Margin="2,4,0,0"
                     IsVisible="{Binding Arena.HasArenaReport}"/>
          <ItemsControl ItemsSource="{Binding Arena.Standings}" IsVisible="{Binding Arena.HasArenaReport}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:ArenaStandingItem">
                <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="16" Margin="0,0,0,10"
                        BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding RankDisplay}" FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource T4}" VerticalAlignment="Center"
                               MinWidth="24" Margin="0,0,16,0"/>
                    <StackPanel Grid.Column="1" Spacing="9" VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal" Spacing="7">
                        <TextBlock Text="{Binding Model}" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                        <Path Data="{StaticResource IcoTrophy}" Width="14" Height="14" Stretch="Uniform"
                              VerticalAlignment="Center" Fill="{DynamicResource Grade}"
                              IsVisible="{Binding IsFirst}"/>
                      </StackPanel>
                      <!-- Two-layer win-rate bar: Accent fill over a Track track. -->
                      <Grid Height="8">
                        <Border Background="{DynamicResource Track}" CornerRadius="4"/>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding WinRate, Converter={StaticResource FractionToStar}}"/>
                            <ColumnDefinition Width="{Binding WinRate, Converter={StaticResource FractionToStar}, ConverterParameter=rest}"/>
                          </Grid.ColumnDefinitions>
                          <Border Grid.Column="0" Background="{DynamicResource Accent}" CornerRadius="4"/>
                        </Grid>
                      </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="18,0,0,0">
                      <TextBlock Text="{Binding WinRateDisplay}" FontSize="24" FontWeight="Bold"
                                 Foreground="{DynamicResource AccentStrong}" HorizontalAlignment="Right"/>
                      <TextBlock Text="{Binding RecordDisplay}" FontSize="11"
                                 Foreground="{DynamicResource T4}" HorizontalAlignment="Right"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- HEAD-TO-HEAD eyebrow + per-prompt strip. -->
          <TextBlock Text="{Binding Arena.HeadToHeadLabel}" FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource T4}" Margin="2,6,0,0"
                     IsVisible="{Binding Arena.HasHeadToHead}"/>
          <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="6,2"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1"
                  IsVisible="{Binding Arena.HasHeadToHead}">
            <ItemsControl ItemsSource="{Binding Arena.HeadToHead}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:ArenaHeadToHeadItem">
                  <Border BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="10,11">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0" Text="{Binding Prompt}" Foreground="{DynamicResource T2}"
                                 VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                      <Border Grid.Column="1" IsVisible="{Binding IsWin}" VerticalAlignment="Center"
                              Background="{DynamicResource AccentSoft}" CornerRadius="7" Padding="10,4">
                        <TextBlock Text="{Binding ResultLabel}" Foreground="{DynamicResource AccentInk}"
                                   FontSize="12" FontWeight="SemiBold"/>
                      </Border>
                      <Border Grid.Column="1" IsVisible="{Binding !IsWin}" VerticalAlignment="Center"
                              Background="{DynamicResource Line2}" CornerRadius="7" Padding="10,4">
                        <TextBlock Text="{Binding ResultLabel}" Foreground="{DynamicResource T3}" FontSize="12"/>
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>

          <!-- Demoted overflow: the input form (collapsed) so results lead. -->
          <Expander Header="Arena configuration" Margin="0,4,0,0">
            <StackPanel Spacing="8" Margin="0,6,0,0">
              <TextBlock Text="PROMPTS (one per line)" FontSize="10" Foreground="{DynamicResource T4}"/>
              <TextBox Text="{Binding Arena.ArenaPromptsInput}" AcceptsReturn="True" Height="90"/>
              <TextBlock Text="MODELS (comma or newline)" FontSize="10" Foreground="{DynamicResource T4}"/>
              <TextBox Text="{Binding Arena.ArenaModelsInput}"/>
              <TextBlock Text="JUDGE MODEL (optional)" FontSize="10" Foreground="{DynamicResource T4}"/>
              <TextBox Text="{Binding Arena.ArenaJudgeModelInput}"/>
              <Button Content="Run Arena" Command="{Binding RunArenaCommand}" HorizontalAlignment="Left"
                      Background="{DynamicResource AccentSoft}" Foreground="{DynamicResource AccentInk}"
                      BorderBrush="{DynamicResource Accent}" BorderThickness="1"/>
            </StackPanel>
          </Expander>

          <!-- Full transcript (collapsed): the honest per-prompt responses + judge rationale. -->
          <Expander Header="Full transcript" IsVisible="{Binding Arena.HasArenaReport}">
            <TextBlock Text="{Binding Arena.ArenaSummary}" Foreground="{DynamicResource T2}"
                       TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" Margin="0,6,0,0"/>
          </Expander>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Settings (production re-skin): four sectioned Nocturne cards — Appearance / Engine / Provider
         generation policy / Gate thresholds. The old monospace summary blobs are replaced by labelled
         rows. Honesty: engine "ready" reflects the real IsEngineUnavailable probe; the Python row shows
         the real interpreter PATH (no version is probed, so none is invented); the Ollama endpoint is the
         configured host shown with a neutral "configured" (not a faked "detected") status; the provider
         policy renders the product's fail-closed invariant (cloud = evaluator-only, local = generate). -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Settings}">
      <!-- OkSoft: an Ok-tinted chip fill, scoped here so the Settings pills stay theme-aware without a
           global token. Mirrors AccentSoft's alpha over the Ok token for each variant. -->
      <Border.Resources>
        <ResourceDictionary>
          <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Dark">
              <SolidColorBrush x:Key="OkSoft" Color="#296bbf9a"/>
            </ResourceDictionary>
            <ResourceDictionary x:Key="Light">
              <SolidColorBrush x:Key="OkSoft" Color="#1f3f9b73"/>
            </ResourceDictionary>
          </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
      </Border.Resources>
      <Border.Styles>
        <Style Selector="Border.card">
          <Setter Property="Background" Value="{DynamicResource Panel}"/>
          <Setter Property="CornerRadius" Value="12"/>
          <Setter Property="Padding" Value="18"/>
          <Setter Property="BorderBrush" Value="{DynamicResource Line2}"/>
          <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBlock.cardtitle">
          <Setter Property="FontWeight" Value="SemiBold"/>
          <Setter Property="Foreground" Value="{DynamicResource Text}"/>
          <Setter Property="FontSize" Value="14"/>
        </Style>
        <!-- Appearance segmented toggle: transparent segments; the selected one fills accent-soft. -->
        <Style Selector="Button.segbtn">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="Foreground" Value="{DynamicResource T2}"/>
          <Setter Property="BorderThickness" Value="0"/>
          <Setter Property="CornerRadius" Value="6"/>
          <Setter Property="Padding" Value="22,6"/>
          <Setter Property="FontSize" Value="13"/>
          <Setter Property="MinWidth" Value="82"/>
          <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.segbtn:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="{DynamicResource Hover}"/>
        </Style>
        <Style Selector="Button.segbtn.selected">
          <Setter Property="Foreground" Value="{DynamicResource AccentInk}"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.segbtn.selected /template/ ContentPresenter">
          <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
        </Style>
        <!-- Ok-tinted "on" / role chips + neutral base. -->
        <Style Selector="Border.chip">
          <Setter Property="CornerRadius" Value="6"/>
          <Setter Property="Padding" Value="11,2"/>
          <Setter Property="Background" Value="{DynamicResource Track}"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.chip.on"><Setter Property="Background" Value="{DynamicResource OkSoft}"/></Style>
        <Style Selector="Ellipse.statusdot">
          <Setter Property="Width" Value="7"/>
          <Setter Property="Height" Value="7"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.rowlabel">
          <Setter Property="Foreground" Value="{DynamicResource T2}"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
          <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.rowvalue">
          <Setter Property="Foreground" Value="{DynamicResource T3}"/>
          <Setter Property="FontFamily" Value="Consolas"/>
          <Setter Property="FontSize" Value="12.5"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
          <Setter Property="TextAlignment" Value="Right"/>
          <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBlock.statusword">
          <Setter Property="FontSize" Value="12.5"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
      </Border.Styles>
      <ScrollViewer>
        <StackPanel Margin="20" Spacing="14" MaxWidth="780" HorizontalAlignment="Left">

          <!-- 1. Appearance -->
          <Border Classes="card">
            <StackPanel Spacing="14">
              <TextBlock Classes="cardtitle" Text="Appearance"/>
              <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Classes="rowlabel" Text="Theme"/>
                <Border Grid.Column="1" Background="{DynamicResource Panel2}" CornerRadius="8" Padding="3"
                        BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                  <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button x:Name="ThemeDarkButton" Classes="segbtn" Content="Dark" Click="SelectDarkTheme_Click"/>
                    <Button x:Name="ThemeLightButton" Classes="segbtn" Content="Light" Click="SelectLightTheme_Click"/>
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </Border>

          <!-- 2. Engine -->
          <Border Classes="card">
            <StackPanel Spacing="12">
              <TextBlock Classes="cardtitle" Text="Engine"/>
              <!-- Python: value = real interpreter path; status = the real engine-availability probe. -->
              <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Classes="rowlabel" Text="Python"/>
                <TextBlock Grid.Column="1" Classes="rowvalue" Margin="14,0,12,0"
                           Text="{Binding Settings.PythonExecutableDisplay}"
                           ToolTip.Tip="{Binding Settings.PythonExecutableDisplay}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                  <Ellipse Classes="statusdot" Fill="{DynamicResource Ok}" IsVisible="{Binding !IsEngineUnavailable}"/>
                  <Ellipse Classes="statusdot" Fill="{DynamicResource Warn}" IsVisible="{Binding IsEngineUnavailable}"/>
                  <TextBlock Classes="statusword" Text="ready" Foreground="{DynamicResource Ok}"
                             IsVisible="{Binding !IsEngineUnavailable}"/>
                  <TextBlock Classes="statusword" Text="unavailable" Foreground="{DynamicResource Warn}"
                             IsVisible="{Binding IsEngineUnavailable}"/>
                </StackPanel>
              </Grid>
              <!-- Ollama: value = configured local endpoint; status is neutral (configured, not probed). -->
              <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Classes="rowlabel" Text="Ollama"/>
                <TextBlock Grid.Column="1" Classes="rowvalue" Margin="14,0,12,0"
                           Text="{Binding AiAssistConnection.AiAssistBaseUrl}"
                           ToolTip.Tip="{Binding AiAssistConnection.AiAssistBaseUrl}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                  <Ellipse Classes="statusdot" Fill="{DynamicResource T4}"/>
                  <TextBlock Classes="statusword" Text="configured" Foreground="{DynamicResource T3}"/>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <!-- 3. Provider generation policy (fail-closed invariant: cloud = evaluator-only forever). -->
          <Border Classes="card">
            <StackPanel Spacing="12">
              <StackPanel Spacing="3">
                <TextBlock Classes="cardtitle" Text="Provider generation policy"/>
                <TextBlock Foreground="{DynamicResource T4}" FontSize="12" TextWrapping="Wrap"
                           Text="Local-first. Cloud providers are evaluator-only — they can never generate training rows."/>
              </StackPanel>
              <!-- OpenAI -->
              <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <Ellipse Grid.Column="0" Classes="statusdot" Fill="{DynamicResource T4}"/>
                <TextBlock Grid.Column="1" Classes="rowlabel" Text="OpenAI" Margin="10,0,0,0"/>
                <Border Grid.Column="2" Classes="chip">
                  <TextBlock Text="evaluator-only" Foreground="{DynamicResource T3}" FontSize="12"/>
                </Border>
              </Grid>
              <!-- Anthropic -->
              <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <Ellipse Grid.Column="0" Classes="statusdot" Fill="{DynamicResource T4}"/>
                <TextBlock Grid.Column="1" Classes="rowlabel" Text="Anthropic" Margin="10,0,0,0"/>
                <Border Grid.Column="2" Classes="chip">
                  <TextBlock Text="evaluator-only" Foreground="{DynamicResource T3}" FontSize="12"/>
                </Border>
              </Grid>
              <!-- Ollama (local) — the only provider that may generate trainable rows. -->
              <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <Ellipse Grid.Column="0" Classes="statusdot" Fill="{DynamicResource Ok}"/>
                <TextBlock Grid.Column="1" Classes="rowlabel" Text="Ollama" Margin="10,0,0,0"/>
                <Border Grid.Column="2" Classes="chip on">
                  <TextBlock Text="generate ✓" Foreground="{DynamicResource Ok}" FontSize="12" FontWeight="SemiBold"/>
                </Border>
              </Grid>
              <!-- Approve/Revoke a local model for generation (kept from the wired commands). -->
              <Border Background="{DynamicResource Line2}" Height="1" Margin="0,2"/>
              <Grid ColumnDefinitions="*,*">
                <TextBox Grid.Column="0" Text="{Binding Settings.ProviderApprovalProvider}" Watermark="provider" Margin="0,0,6,0"/>
                <TextBox Grid.Column="1" Text="{Binding Settings.ProviderApprovalModel}" Watermark="model"/>
              </Grid>
              <WrapPanel>
                <Button Content="Refresh policies" Command="{Binding RefreshProviderPoliciesCommand}" Margin="0,0,6,4"/>
                <Button Content="Approve" Command="{Binding ApproveProviderGenerationCommand}" Margin="0,0,6,4"/>
                <Button Content="Revoke" Command="{Binding RevokeProviderGenerationCommand}" Margin="0,0,6,4"/>
              </WrapPanel>
              <TextBlock Text="{Binding Settings.ProviderPolicySummary}" Foreground="{DynamicResource T4}"
                         FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <!-- 4. Gate thresholds (bound to the effective per-project GateThresholds). -->
          <Border Classes="card">
            <StackPanel Spacing="12">
              <TextBlock Classes="cardtitle" Text="Gate thresholds"/>
              <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Classes="rowlabel" Text="Block on exact duplicates"/>
                <Border Grid.Column="1" Classes="chip" Classes.on="{Binding Settings.GateThresholds.BlockExactDuplicates}">
                  <Panel>
                    <TextBlock Text="on" Foreground="{DynamicResource Ok}" FontSize="12" FontWeight="SemiBold"
                               IsVisible="{Binding Settings.GateThresholds.BlockExactDuplicates}"/>
                    <TextBlock Text="off" Foreground="{DynamicResource T4}" FontSize="12"
                               IsVisible="{Binding !Settings.GateThresholds.BlockExactDuplicates}"/>
                  </Panel>
                </Border>
              </Grid>
              <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Classes="rowlabel" Text="Block on PII / secrets"/>
                <Border Grid.Column="1" Classes="chip" Classes.on="{Binding Settings.GateThresholds.BlockOnHighSeverityPii}">
                  <Panel>
                    <TextBlock Text="on" Foreground="{DynamicResource Ok}" FontSize="12" FontWeight="SemiBold"
                               IsVisible="{Binding Settings.GateThresholds.BlockOnHighSeverityPii}"/>
                    <TextBlock Text="off" Foreground="{DynamicResource T4}" FontSize="12"
                               IsVisible="{Binding !Settings.GateThresholds.BlockOnHighSeverityPii}"/>
                  </Panel>
                </Border>
              </Grid>
              <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Classes="rowlabel" Text="Max regression score drop"/>
                <TextBlock Grid.Column="1" Classes="rowvalue"
                           Text="{Binding Settings.GateThresholds.MaxRegressionScoreDrop, StringFormat='{}{0:0.0}'}"/>
              </Grid>
              <Border Background="{DynamicResource Line2}" Height="1" Margin="0,2"/>
              <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="{Binding Settings.GateThresholdsSummary}" Foreground="{DynamicResource T4}"
                           FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button Grid.Column="1" Content="Save" Command="{Binding SaveGateThresholdsCommand}"
                        VerticalAlignment="Center"/>
              </Grid>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Versions (slice 9 fidelity): a version-timeline list card + an actions/detail card. -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Versions}">
      <ScrollViewer>
        <StackPanel Margin="20" Spacing="12" MaxWidth="820" HorizontalAlignment="Left">
          <!-- Header: snapshot summary + a ghost "Capture version" (git-commit) -->
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="{Binding Versions.DatasetVersionSummary}" Foreground="{DynamicResource T3}"
                       FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Command="{Binding CaptureDatasetVersionCommand}" VerticalAlignment="Center"
                    Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Path Classes="ico" Data="{StaticResource IcoGitCommit}" Width="14" Height="14"/>
                <TextBlock Text="Capture version" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </Grid>
          <!-- Label input + secondary actions (kept, compact) -->
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0" Text="{Binding Versions.DatasetVersionLabel}" Watermark="version label (optional)"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="8,0,0,0" VerticalAlignment="Center">
              <Button Content="Refresh" Command="{Binding RefreshDatasetVersionsCommand}"/>
              <Button Content="View card" Command="{Binding ViewDatasetVersionCardCommand}"/>
              <Button Content="Diff" Command="{Binding DiffVersionsCommand}"/>
              <Button Content="Clean up" Command="{Binding RunRowStoreGcCommand}"/>
            </StackPanel>
          </Grid>
          <!-- Vertical timeline: a left rail with node dots + a stack of version cards. The head
               (newest) row is marked CURRENT; older rows carry a per-card Restore. -->
          <ListBox x:Name="VersionsTimeline" ItemsSource="{Binding Versions.DatasetVersions}"
                   SelectedItem="{Binding Versions.SelectedDatasetVersion}"
                   Background="Transparent" BorderThickness="0" Padding="0">
            <ListBox.Styles>
              <Style Selector="ListBoxItem"><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0"/></Style>
              <Style Selector="ListBoxItem:selected /template/ ContentPresenter"><Setter Property="Background" Value="Transparent"/></Style>
              <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="Transparent"/></Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:DatasetVersionDisplayItem">
                <Grid ColumnDefinitions="20,*">
                  <!-- rail + node dot (current = accent, others = muted) -->
                  <Panel Grid.Column="0">
                    <Border Width="2" Background="{DynamicResource Line2}" HorizontalAlignment="Center"/>
                    <Ellipse Width="11" Height="11" VerticalAlignment="Top" Margin="0,18,0,0" HorizontalAlignment="Center"
                             Fill="{DynamicResource Accent}" IsVisible="{Binding IsCurrent}"/>
                    <Ellipse Width="10" Height="10" VerticalAlignment="Top" Margin="0,18,0,0" HorizontalAlignment="Center"
                             Fill="{DynamicResource Track}" Stroke="{DynamicResource Line2}" StrokeThickness="1"
                             IsVisible="{Binding !IsCurrent}"/>
                  </Panel>
                  <Border Grid.Column="1" Margin="6,8,0,8" Background="{DynamicResource Panel}" CornerRadius="11" Padding="14"
                          BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                    <StackPanel Spacing="7">
                      <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" IsVisible="{Binding IsCurrent}" Margin="8,0,0,0" CornerRadius="5" Padding="7,2"
                                Background="{DynamicResource AccentSoft}" VerticalAlignment="Center">
                          <TextBlock Text="CURRENT" FontSize="9.5" FontWeight="Bold" Foreground="{DynamicResource AccentInk}"/>
                        </Border>
                        <TextBlock Grid.Column="3" Text="{Binding Timestamp}" Foreground="{DynamicResource T4}"
                                   FontSize="11" VerticalAlignment="Center"/>
                      </Grid>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border CornerRadius="5" Padding="6,1" VerticalAlignment="Center"
                                Background="{Binding IntegrityColor, Converter={StaticResource StringToBrush}}">
                          <TextBlock Text="{Binding Integrity}" FontSize="9.5" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <TextBlock Text="{Binding MetaLine}" Foreground="{DynamicResource T3}" FontSize="11.5"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                      </StackPanel>
                      <Button Content="Restore" IsVisible="{Binding !IsCurrent}" HorizontalAlignment="Left"
                              Command="{Binding #VersionsTimeline.((vm:MainWindowViewModel)DataContext).RestoreDatasetVersionByItemCommand}"
                              CommandParameter="{Binding}"/>
                    </StackPanel>
                  </Border>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <TextBlock Text="{Binding Versions.DatasetVersionDetail}" Foreground="{DynamicResource T4}"
                     FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Suites (slice 8 fidelity): registered-suites list card + a new-suite card + a report card. -->
    <!-- Suites (production re-skin): one scrolling column of full-width suite cards (was a 300px list |
         report split). Each card renders the suite's REAL registry fields — name, a valid/invalid status
         badge, a leading glyph by validity, a case-count meta token — with a right-aligned Run. The
         selected suite's last-run verdict folds into the "Last run" section below. HONESTY: `suite-list`
         carries no per-suite score/model/metric/trigger, so none is invented; the badge is NEUTRAL for a
         parseable file and warn for a malformed one (never a green "pass"); an errored run stays
         neutral/red through the shared status→colour map. -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Suites}">
      <!-- BadSoft: a Bad-tinted chip fill for the "invalid" badge; OkSoft mirrors the Settings screen. -->
      <Border.Resources>
        <ResourceDictionary>
          <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Dark">
              <SolidColorBrush x:Key="BadSoft" Color="#29d76d6d"/>
            </ResourceDictionary>
            <ResourceDictionary x:Key="Light">
              <SolidColorBrush x:Key="BadSoft" Color="#1fc85552"/>
            </ResourceDictionary>
          </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
      </Border.Resources>
      <Border.Styles>
        <!-- The ListBox is the single card column; each card owns its selected/hover cue via the inner
             Border, so the ListBoxItem chrome is stripped and cards are spaced with a bottom margin. -->
        <Style Selector="ListBox.suitelist">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="Padding" Value="0"/>
          <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ListBox.suitelist ListBoxItem">
          <Setter Property="Padding" Value="0"/>
          <Setter Property="Margin" Value="0,0,0,12"/>
          <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox.suitelist ListBoxItem:selected /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Border.suitecard">
          <Setter Property="Background" Value="{DynamicResource Panel}"/>
          <Setter Property="CornerRadius" Value="11"/>
          <Setter Property="Padding" Value="15,13"/>
          <Setter Property="BorderBrush" Value="{DynamicResource Line2}"/>
          <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="ListBox.suitelist ListBoxItem:selected Border.suitecard">
          <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
        </Style>
        <Style Selector="ListBox.suitelist ListBoxItem:pointerover Border.suitecard">
          <Setter Property="Background" Value="{DynamicResource Panel2}"/>
        </Style>
        <!-- Status badge beside the name: neutral base, warn variant for an invalid suite. -->
        <Style Selector="Border.badge">
          <Setter Property="CornerRadius" Value="6"/>
          <Setter Property="Padding" Value="8,1"/>
          <Setter Property="Background" Value="{DynamicResource Panel2}"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.badge TextBlock">
          <Setter Property="Foreground" Value="{DynamicResource T3}"/>
          <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="Border.badge.warn"><Setter Property="Background" Value="{DynamicResource BadSoft}"/></Style>
        <Style Selector="Border.badge.warn TextBlock"><Setter Property="Foreground" Value="{DynamicResource Bad}"/></Style>
        <!-- Muted meta tokens under the name. -->
        <Style Selector="TextBlock.meta">
          <Setter Property="Foreground" Value="{DynamicResource T4}"/>
          <Setter Property="FontSize" Value="11"/>
        </Style>
        <!-- Outlined per-card Run. -->
        <Style Selector="Button.runbtn">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="Foreground" Value="{DynamicResource T2}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource Line2}"/>
          <Setter Property="BorderThickness" Value="1"/>
          <Setter Property="CornerRadius" Value="7"/>
          <Setter Property="Padding" Value="18,5"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.runbtn:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="{DynamicResource Hover}"/>
        </Style>
        <!-- Accent "+ New suite" pill; neutral "Refresh" ghost. -->
        <Style Selector="Button.pill">
          <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
          <Setter Property="Foreground" Value="{DynamicResource AccentInk}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
          <Setter Property="BorderThickness" Value="1"/>
          <Setter Property="CornerRadius" Value="8"/>
          <Setter Property="Padding" Value="14,6"/>
        </Style>
        <Style Selector="Button.ghost">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="Foreground" Value="{DynamicResource T2}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource Line2}"/>
          <Setter Property="BorderThickness" Value="1"/>
          <Setter Property="CornerRadius" Value="8"/>
          <Setter Property="Padding" Value="12,6"/>
        </Style>
      </Border.Styles>

      <ScrollViewer>
        <StackPanel Margin="20" Spacing="14" MaxWidth="940" HorizontalAlignment="Stretch">

          <!-- Header: "N saved suites" (left) + new-suite name box, Refresh, and the accent "+ New suite"
               pill (right). The count + status are real; the name box feeds the shell's NewSuiteCommand. -->
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
              <TextBlock Text="{Binding Suites.Suites.Count, StringFormat='{}{0} saved suites'}"
                         Foreground="{DynamicResource T3}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding Suites.SuitesStatus}" Foreground="{DynamicResource T4}"
                         FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBox Text="{Binding Suites.NewSuiteName}" Watermark="new suite name" Width="170"
                       VerticalAlignment="Center"/>
              <Button Content="Refresh" Classes="ghost" Command="{Binding RefreshSuitesCommand}"
                      ToolTip.Tip="Reload the suite registry (suite-list)"/>
              <Button Classes="pill" Content="+ New suite" Command="{Binding NewSuiteCommand}"
                      ToolTip.Tip="Scaffold a new suite from the name box"/>
            </StackPanel>
          </Grid>

          <!-- Empty state: shown when the registry has no suites (real HasSuites flag). -->
          <Border IsVisible="{Binding !Suites.HasSuites}" Background="{DynamicResource Panel}"
                  CornerRadius="11" Padding="24" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <StackPanel Spacing="6" HorizontalAlignment="Center">
              <Path Classes="ico" Data="{StaticResource IcoChecklist}" Width="22" Height="22"
                    HorizontalAlignment="Center"/>
              <TextBlock Text="No suites yet" Foreground="{DynamicResource Text}" FontWeight="SemiBold"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="Name one above and choose New suite, then edit its cases in Files."
                         Foreground="{DynamicResource T4}" FontSize="12" TextWrapping="Wrap"
                         TextAlignment="Center" MaxWidth="360"/>
            </StackPanel>
          </Border>

          <!-- The single card column. Selection (two-way to SelectedSuite) drives the "Last run" section
               below AND the shell's selection-based RunSuiteCommand; clicking a card selects its suite. -->
          <ListBox Name="SuitesList" Classes="suitelist" ItemsSource="{Binding Suites.Suites}"
                   SelectedItem="{Binding Suites.SelectedSuite}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:SuiteSummary">
                <Border Classes="suitecard">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- Leading glyph by validity: checklist (parseable) / shield-warning (malformed). -->
                    <Panel Grid.Column="0" Width="20" VerticalAlignment="Top" Margin="0,1,12,0">
                      <Path Classes="ico accent" Data="{StaticResource IcoChecklist}" Width="16" Height="16"
                            IsVisible="{Binding Valid}"/>
                      <Path Classes="ico warn" Data="{StaticResource IcoShieldWarningFill}" Width="16" Height="16"
                            IsVisible="{Binding IsInvalid}"/>
                    </Panel>
                    <StackPanel Grid.Column="1" Spacing="7">
                      <StackPanel Orientation="Horizontal" Spacing="9">
                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Text}"
                                   FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        <Border Classes="badge" Classes.warn="{Binding IsInvalid}">
                          <TextBlock Text="{Binding StatusBadgeText}"/>
                        </Border>
                      </StackPanel>
                      <!-- Meta tokens: only REAL registry attributes (case count; the parse error when
                           invalid). No model/metric/trigger token is shown — `suite-list` doesn't carry them. -->
                      <WrapPanel Orientation="Horizontal">
                        <TextBlock Classes="meta" Text="{Binding CaseCountLabel}" Margin="0,0,14,0"/>
                        <TextBlock Classes="meta" Text="{Binding Error}" Foreground="{DynamicResource Bad}"
                                   IsVisible="{Binding IsInvalid}" TextTrimming="CharacterEllipsis" MaxWidth="420"/>
                      </WrapPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Classes="runbtn" Content="Run" VerticalAlignment="Top"
                            Command="{Binding #SuitesList.((vm:MainWindowViewModel)DataContext).RunSuiteCommand}"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- Last run: the selected suite's report folds in here — per-metric roll-up (never a folded
               cross-metric score), the overall verdict, and the honesty note. -->
          <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="15,14"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <StackPanel Spacing="7">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Last run" FontWeight="SemiBold" Foreground="{DynamicResource Text}"
                           FontSize="14" VerticalAlignment="Center"/>
                <Border Classes="badge" IsVisible="{Binding Suites.HasSuiteReport}"
                        Background="{Binding Suites.SuiteOverallColor, Converter={StaticResource StringToBrush}}">
                  <TextBlock Text="{Binding Suites.SuiteOverallStatus}" Foreground="{DynamicResource OnAccent}"
                             FontWeight="SemiBold"/>
                </Border>
              </StackPanel>
              <TextBlock Text="{Binding Suites.SuiteReportSummary}" Foreground="{DynamicResource T2}"
                         TextWrapping="Wrap"/>
              <TextBlock Text="PER-METRIC ROLLUP" FontSize="10" Foreground="{DynamicResource T4}" Margin="0,4,0,0"
                         IsVisible="{Binding Suites.HasSuiteReport}"/>
              <ItemsControl ItemsSource="{Binding Suites.SuiteMetricRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:SuiteMetricRollup">
                    <TextBlock Text="{Binding DisplayLabel}" Foreground="{DynamicResource T3}" FontSize="12" Margin="0,1"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="{Binding Suites.SuiteHonestyNote}" Foreground="{DynamicResource T4}"
                         FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Splits (slice 5 fidelity): config card + result card. Same shared Splits VM inputs/summary. -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Splits}">
      <ScrollViewer>
        <StackPanel Margin="20" Spacing="14" MaxWidth="620" HorizontalAlignment="Left">
          <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="18"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Split configuration" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
              <!-- Four boxes to match the design; TEST % is read-only (derived 100 − train − val)
                   so the ratios always sum to a whole and there is no fourth editable field. -->
              <Grid ColumnDefinitions="*,*,*,*">
                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,10,0">
                  <TextBlock Text="TRAIN %" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <TextBox Text="{Binding Splits.SplitTrainPercent}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,10,0">
                  <TextBlock Text="VALIDATION %" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <TextBox Text="{Binding Splits.SplitValidationPercent}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,10,0">
                  <TextBlock Text="TEST %" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <TextBox Text="{Binding Splits.SplitTestPercent}" IsReadOnly="True" Foreground="{DynamicResource T2}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Spacing="4">
                  <TextBlock Text="SEED" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <TextBox Text="{Binding Splits.SplitSeed}"/>
                </StackPanel>
              </Grid>
              <Button Command="{Binding GenerateSplitsCommand}"
                      HorizontalAlignment="Left" Background="{DynamicResource AccentSoft}"
                      Foreground="{DynamicResource AccentInk}" BorderBrush="{DynamicResource Accent}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="7">
                  <Path Classes="ico accent" Data="{StaticResource IcoShuffle}" Width="15" Height="15"/>
                  <TextBlock Text="Generate splits" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>
          <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="18"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <StackPanel Spacing="12">
              <!-- Title + leakage chip. The chip binds the real RowsSharedAcrossSplits signal:
                   Ok-tinted "No leakage" at 0, Bad-tinted "Leakage" above 0; hidden pre-run. -->
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Result" FontWeight="SemiBold" Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                <Border IsVisible="{Binding Splits.ShowNoLeakageChip}" Background="{DynamicResource AccentSoft}"
                        CornerRadius="6" Padding="8,3" VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal" Spacing="5">
                    <Path Classes="ico ok ico-sm" Data="{StaticResource IcoCheckCircleFill}"/>
                    <TextBlock Text="No leakage" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource Ok}" VerticalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <Border IsVisible="{Binding Splits.ShowLeakageChip}" Background="{DynamicResource AccentSoft}"
                        CornerRadius="6" Padding="8,3" VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal" Spacing="5">
                    <Path Classes="ico ico-sm" Data="{StaticResource IcoWarningFill}" Fill="{DynamicResource Bad}"/>
                    <TextBlock Text="Leakage" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource Bad}" VerticalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </StackPanel>

              <!-- Pre-run / in-progress / error: neutral text (no fabricated bar or counts). -->
              <TextBlock IsVisible="{Binding !Splits.HasReport}" Text="{Binding Splits.SplitSummary}"
                         Foreground="{DynamicResource T2}" TextWrapping="Wrap"/>

              <!-- Populated result: proportion bar (widths = real ratios) + counts footer. -->
              <StackPanel IsVisible="{Binding Splits.HasReport}" Spacing="12">
                <Border CornerRadius="8" ClipToBounds="True" Height="34">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="{Binding Splits.TrainRatio, Converter={StaticResource FractionToStar}}"/>
                      <ColumnDefinition Width="{Binding Splits.ValidationRatio, Converter={StaticResource FractionToStar}}"/>
                      <ColumnDefinition Width="{Binding Splits.TestRatio, Converter={StaticResource FractionToStar}}"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource Accent}">
                      <TextBlock Text="train" FontSize="12" Foreground="{DynamicResource OnAccent}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="1" Background="{DynamicResource Ok}">
                      <TextBlock Text="val" FontSize="12" Foreground="{DynamicResource OnAccent}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource Warn}">
                      <TextBlock Text="test" FontSize="12" Foreground="{DynamicResource OnAccent}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                  </Grid>
                </Border>

                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Splits.TrainCount}" FontWeight="Bold" Foreground="{DynamicResource Text}"/>
                    <TextBlock Text="train" Foreground="{DynamicResource T3}"/>
                    <TextBlock Text="·" Foreground="{DynamicResource T4}"/>
                    <TextBlock Text="{Binding Splits.ValidationCount}" FontWeight="Bold" Foreground="{DynamicResource Text}"/>
                    <TextBlock Text="validation" Foreground="{DynamicResource T3}"/>
                    <TextBlock Text="·" Foreground="{DynamicResource T4}"/>
                    <TextBlock Text="{Binding Splits.TestCount}" FontWeight="Bold" Foreground="{DynamicResource Text}"/>
                    <TextBlock Text="test" Foreground="{DynamicResource T3}"/>
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding Splits.SharedRowsDetail}" FontSize="12.5"
                             Margin="16,0,0,0" Foreground="{DynamicResource T3}" VerticalAlignment="Center"/>
                </Grid>
              </StackPanel>

              <!-- Real engine warnings (kept honest — shown whenever the report carried any). -->
              <TextBlock IsVisible="{Binding Splits.HasWarnings}" Text="{Binding Splits.SplitWarnings}"
                         Foreground="{DynamicResource Warn}" FontSize="12.5" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Examples (slice 7 fidelity): a list card + a JSON-viewer card. -->
    <!-- Examples (fidelity slice): a top control row (search + All/Clean/Flagged pills) over the
         list/detail grid. The list shows a muted row number + preview + a real per-row status icon; the
         detail pane is structured (title + status badge + edit/delete affordances, INSTRUCTION / OUTPUT,
         a divider, and a Tags/Source/Tokens/Added metadata row). HONESTY: the Clean/Flagged split,
         per-row status, tokens and metadata are derived from each row's real JSON — absent fields read
         "—" (SavedExampleItem.MissingField). Edit/delete have NO backing command in the shell (none
         exists; adding one is out of this slice + forbidden on the shell VM), so they render as
         presentational header glyphs. -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Examples}">
      <Border.Styles>
        <!-- Filter pills: transparent by default; the active one fills accent-soft with accent ink. -->
        <Style Selector="Button.pill">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="Foreground" Value="{DynamicResource T3}"/>
          <Setter Property="BorderThickness" Value="0"/>
          <Setter Property="CornerRadius" Value="8"/>
          <Setter Property="Padding" Value="14,6"/>
          <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.pill:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="{DynamicResource Hover}"/>
        </Style>
        <Style Selector="Button.pill.active">
          <Setter Property="Foreground" Value="{DynamicResource AccentInk}"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.pill.active /template/ ContentPresenter">
          <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
        </Style>
        <!-- Bad-toned status icon (no global .bad ico modifier). -->
        <Style Selector="Path.ico.bad"><Setter Property="Fill" Value="{DynamicResource Bad}"/></Style>
      </Border.Styles>
      <Grid Margin="16" RowDefinitions="Auto,*">

        <!-- Control row: full-width search + the three status pills. -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
          <Border Grid.Column="0" Background="{DynamicResource Panel2}" CornerRadius="9" Padding="12,9"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*">
              <Path Grid.Column="0" Classes="ico muted" Data="{StaticResource IcoMagnifier}" VerticalAlignment="Center"/>
              <TextBox Grid.Column="1" Margin="9,0,0,0" Background="Transparent" BorderThickness="0" Padding="0"
                       VerticalContentAlignment="Center"
                       Text="{Binding Examples.SearchText, Mode=TwoWay}"
                       Watermark="{Binding Examples.SearchWatermark}"/>
            </Grid>
          </Border>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="12,0,0,0" VerticalAlignment="Center">
            <Button Classes="pill" Classes.active="{Binding Examples.IsFilterAll}"
                    Command="{Binding Examples.SetFilterCommand}" CommandParameter="All"
                    Content="{Binding Examples.AllPillLabel}"/>
            <Button Classes="pill" Classes.active="{Binding Examples.IsFilterClean}"
                    Command="{Binding Examples.SetFilterCommand}" CommandParameter="Clean"
                    Content="{Binding Examples.CleanPillLabel}"/>
            <Button Classes="pill" Classes.active="{Binding Examples.IsFilterFlagged}"
                    Command="{Binding Examples.SetFilterCommand}" CommandParameter="Flagged"
                    Content="{Binding Examples.FlaggedPillLabel}"/>
          </StackPanel>
        </Grid>

        <!-- List / detail. -->
        <Grid Grid.Row="1" ColumnDefinitions="300,*">
          <Border Grid.Column="0" Background="{DynamicResource Panel}" CornerRadius="11" Padding="6"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <Grid>
              <ListBox ItemsSource="{Binding Examples.FilteredItems}" SelectedItem="{Binding Examples.SelectedExample}"
                       Background="Transparent" BorderThickness="0"
                       IsVisible="{Binding Examples.HasVisibleExamples}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:SavedExampleItem">
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,1">
                      <TextBlock Grid.Column="0" Text="{Binding RowNumber}" Foreground="{DynamicResource T4}"
                                 FontSize="12.5" MinWidth="24" TextAlignment="Right" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding Preview}" Foreground="{DynamicResource T2}"
                                 Margin="12,0,10,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                      <Path Grid.Column="2" Classes="ico ico-sm ok" Data="{StaticResource IcoCheckCircleFill}"
                            VerticalAlignment="Center" IsVisible="{Binding IsOk}"/>
                      <Path Grid.Column="2" Classes="ico ico-sm warn" Data="{StaticResource IcoWarningFill}"
                            VerticalAlignment="Center" IsVisible="{Binding IsWarn}"/>
                      <Path Grid.Column="2" Classes="ico ico-sm bad" Data="{StaticResource IcoXCircle}"
                            VerticalAlignment="Center" IsVisible="{Binding IsBad}"/>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <!-- Empty state: no rows match the current search/filter (or the dataset is empty). -->
              <TextBlock IsVisible="{Binding !Examples.HasVisibleExamples}" Margin="14"
                         VerticalAlignment="Top" TextWrapping="Wrap" Foreground="{DynamicResource T3}"
                         FontSize="12.5" Text="No examples match the current search or filter."/>
            </Grid>
          </Border>

          <Border Grid.Column="1" Margin="16,0,0,0" Background="{DynamicResource Panel}" CornerRadius="11" Padding="18"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <Panel>
              <!-- Structured detail (a row is selected). -->
              <ScrollViewer IsVisible="{Binding Examples.HasSelectedExample}">
                <StackPanel Spacing="14">
                  <!-- Header: title + real status badge + presentational edit/delete glyphs. -->
                  <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" VerticalAlignment="Center">
                    <TextBlock Grid.Column="0" Text="{Binding Examples.SelectedExample.Title}"
                               FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Text}"
                               VerticalAlignment="Center"/>
                    <!-- Status badge (one of three, by the row's real status). -->
                    <Border Grid.Column="1" Margin="10,0,0,0" CornerRadius="5" Padding="7,2" VerticalAlignment="Center"
                            Background="{DynamicResource Panel2}" BorderThickness="1" BorderBrush="{DynamicResource Line2}"
                            IsVisible="{Binding Examples.SelectedExample.IsOk}">
                      <TextBlock Text="CLEAN" FontSize="10.5" FontWeight="Bold" Foreground="{DynamicResource Ok}"/>
                    </Border>
                    <Border Grid.Column="1" Margin="10,0,0,0" CornerRadius="5" Padding="7,2" VerticalAlignment="Center"
                            Background="{DynamicResource Panel2}" BorderThickness="1" BorderBrush="{DynamicResource Line2}"
                            IsVisible="{Binding Examples.SelectedExample.IsWarn}">
                      <TextBlock Text="FLAGGED" FontSize="10.5" FontWeight="Bold" Foreground="{DynamicResource Warn}"/>
                    </Border>
                    <Border Grid.Column="1" Margin="10,0,0,0" CornerRadius="5" Padding="7,2" VerticalAlignment="Center"
                            Background="{DynamicResource Panel2}" BorderThickness="1" BorderBrush="{DynamicResource Line2}"
                            IsVisible="{Binding Examples.SelectedExample.IsBad}">
                      <TextBlock Text="BROKEN" FontSize="10.5" FontWeight="Bold" Foreground="{DynamicResource Bad}"/>
                    </Border>
                    <!-- Edit / delete: presentational (no shell command exists to bind). -->
                    <Path Grid.Column="3" Classes="ico muted" Data="{StaticResource IcoPencil}"
                          Margin="0,0,12,0" VerticalAlignment="Center" ToolTip.Tip="Edit example"/>
                    <Path Grid.Column="4" Classes="ico muted" Data="{StaticResource IcoXCircle}"
                          VerticalAlignment="Center" ToolTip.Tip="Delete example"/>
                  </Grid>

                  <StackPanel Spacing="5">
                    <TextBlock Text="INSTRUCTION" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource T4}"/>
                    <TextBlock Text="{Binding Examples.SelectedExample.Instruction}" Foreground="{DynamicResource T2}"
                               TextWrapping="Wrap"/>
                  </StackPanel>

                  <StackPanel Spacing="5">
                    <TextBlock Text="OUTPUT" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource T4}"/>
                    <TextBlock Text="{Binding Examples.SelectedExample.Output}" Foreground="{DynamicResource T2}"
                               TextWrapping="Wrap"/>
                  </StackPanel>

                  <!-- Divider. -->
                  <Border Height="1" Background="{DynamicResource Line2}" Margin="0,2"/>

                  <!-- Metadata row (real fields; "—" where the row carries none). -->
                  <StackPanel Orientation="Horizontal" Spacing="40">
                    <StackPanel Spacing="3" MaxWidth="240">
                      <TextBlock Text="Tags" FontSize="10.5" Foreground="{DynamicResource T4}"/>
                      <TextBlock Text="{Binding Examples.SelectedExample.Tags}" Foreground="{DynamicResource T2}"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Spacing="3">
                      <TextBlock Text="Source" FontSize="10.5" Foreground="{DynamicResource T4}"/>
                      <TextBlock Text="{Binding Examples.SelectedExample.Source}" Foreground="{DynamicResource T2}"/>
                    </StackPanel>
                    <StackPanel Spacing="3">
                      <TextBlock Text="Tokens" FontSize="10.5" Foreground="{DynamicResource T4}"/>
                      <TextBlock Text="{Binding Examples.SelectedExample.Tokens}" Foreground="{DynamicResource T2}"/>
                    </StackPanel>
                    <StackPanel Spacing="3">
                      <TextBlock Text="Added" FontSize="10.5" Foreground="{DynamicResource T4}"/>
                      <TextBlock Text="{Binding Examples.SelectedExample.Added}" Foreground="{DynamicResource T2}"/>
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </ScrollViewer>

              <!-- Empty/prompt state (nothing selected) — surfaces the honest SelectedExampleJson message. -->
              <TextBlock IsVisible="{Binding !Examples.HasSelectedExample}"
                         Text="{Binding Examples.SelectedExampleJson}" TextWrapping="Wrap"
                         Foreground="{DynamicResource T3}" VerticalAlignment="Top"/>
            </Panel>
          </Border>
        </Grid>
      </Grid>
    </Border>

    <!-- Import & Quarantine (slice 7 fidelity): rejected-rows list card + a detail card. -->
    <!-- Import & Quarantine (fidelity slice): a single stacked column — an Import-rows card on top,
         then the quarantine reject list — over the shared Quarantine VM. Honesty: no file/mapping
         state is loaded in the shell, so the Import card shows neutral prompts (no fabricated
         filename / row-count / column mapping); the reject list, the "N rejected" badge and the
         summary all bind to the real ImportQuarantineItems. "Import & validate" runs the real
         ImportDatasetCommand; per-item "Repair" mirrors the WPF head's retry (code-behind, since the
         shell exposes RetrySelectedImportQuarantineItem() as a method, not an ICommand). -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Quarantine}">
      <Border.Styles>
        <!-- Segmented source selector: transparent segments; the checked one fills accent-soft. -->
        <Style Selector="ToggleButton.seg">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="Foreground" Value="{DynamicResource T2}"/>
          <Setter Property="BorderThickness" Value="0"/>
          <Setter Property="CornerRadius" Value="7"/>
          <Setter Property="Padding" Value="16,7"/>
          <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="ToggleButton.seg:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="{DynamicResource Hover}"/>
        </Style>
        <Style Selector="ToggleButton.seg:checked">
          <Setter Property="Foreground" Value="{DynamicResource AccentInk}"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="ToggleButton.seg:checked /template/ ContentPresenter">
          <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
        </Style>
        <!-- AccentSoft mapping-target pill + Bad-toned reject icon (no global .bad ico modifier). -->
        <Style Selector="Border.pill">
          <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
          <Setter Property="CornerRadius" Value="6"/>
          <Setter Property="Padding" Value="11,3"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
          <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style Selector="Path.ico.bad"><Setter Property="Fill" Value="{DynamicResource Bad}"/></Style>
      </Border.Styles>
      <ScrollViewer>
        <StackPanel Margin="20" Spacing="14" MaxWidth="920" HorizontalAlignment="Left">

          <!-- Import rows card -->
          <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="18"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <StackPanel Spacing="14">
              <TextBlock Text="Import rows" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>

              <!-- Segmented source row. Presentational (the shell has no source-kind state to bind);
                   JSONL / CSV is the default-checked segment, matching the design. -->
              <Border Background="{DynamicResource Panel2}" CornerRadius="9" Padding="4" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <ToggleButton Classes="seg" IsChecked="True" Content="JSONL / CSV"/>
                  <ToggleButton Classes="seg" Content="Hugging Face"/>
                  <ToggleButton Classes="seg" Content="Folder"/>
                </StackPanel>
              </Border>

              <!-- File row — neutral prompt (no file is selected in the shell; no fake filename/count). -->
              <Border Background="{DynamicResource Panel2}" CornerRadius="9" Padding="14,12"
                      BorderBrush="{DynamicResource Line}" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <Path Grid.Column="0" Classes="ico muted" Data="{StaticResource IcoImport}" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center" TextWrapping="Wrap"
                             Text="No file selected — choose a JSONL or CSV file to import"
                             Foreground="{DynamicResource T3}"/>
                  <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="12"
                             Text="0 rows detected" Foreground="{DynamicResource T4}"/>
                </Grid>
              </Border>

              <!-- Field mapping — neutral prompt (column→field mapping only exists once a file is parsed). -->
              <StackPanel Spacing="8">
                <TextBlock Text="FIELD MAPPING" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource T4}"/>
                <TextBlock Text="Column-to-field mapping appears here once a source file is selected."
                           Foreground="{DynamicResource T3}" FontSize="12.5" TextWrapping="Wrap"/>
              </StackPanel>

              <!-- Import & validate → the real shell import command. -->
              <Button HorizontalAlignment="Left" Command="{Binding ImportDatasetCommand}"
                      Background="{DynamicResource AccentSoft}" Foreground="{DynamicResource AccentInk}"
                      BorderBrush="{DynamicResource Accent}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="7">
                  <Path Classes="ico accent" Data="{StaticResource IcoImport}" Width="15" Height="15"/>
                  <TextBlock Text="Import &amp; validate" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>

          <!-- Quarantine section header — bound to the real reject count; hidden when nothing is quarantined. -->
          <Grid ColumnDefinitions="Auto,Auto,*" IsVisible="{Binding Quarantine.HasQuarantine}">
            <TextBlock Grid.Column="0" Text="Quarantine" FontWeight="SemiBold" FontSize="15"
                       Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
            <Border Grid.Column="1" Margin="10,0,0,0" Background="{DynamicResource Warn}" CornerRadius="6"
                    Padding="8,2" VerticalAlignment="Center">
              <TextBlock Text="{Binding Quarantine.RejectedBadge}" Foreground="White" FontSize="11" FontWeight="Bold"/>
            </Border>
            <TextBlock Grid.Column="2" Text="{Binding Quarantine.QuarantineSummary}" HorizontalAlignment="Right"
                       VerticalAlignment="Center" Foreground="{DynamicResource T3}" FontSize="12.5"/>
          </Grid>

          <!-- Reject cards: Bad-toned warning icon | message + JSON snippet | Repair. -->
          <ItemsControl ItemsSource="{Binding Quarantine.ImportQuarantineItems}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:ImportQuarantineItem">
                <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="14" Margin="0,0,0,8"
                        BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <Path Grid.Column="0" Classes="ico bad" Data="{StaticResource IcoWarningFill}"
                          VerticalAlignment="Top" Margin="0,2,0,0"/>
                    <StackPanel Grid.Column="1" Margin="12,0,12,0" Spacing="5">
                      <TextBlock Text="{Binding Headline}" Foreground="{DynamicResource Text}"
                                 FontWeight="SemiBold" TextWrapping="Wrap"/>
                      <TextBlock Text="{Binding Raw}" Foreground="{DynamicResource T4}" FontFamily="Consolas"
                                 FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Repair" VerticalAlignment="Center"
                            Click="RepairQuarantineItem_Click"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Empty state — nothing quarantined (also the fresh-project state). -->
          <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="14"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1"
                  IsVisible="{Binding !Quarantine.HasQuarantine}">
            <Grid ColumnDefinitions="Auto,*">
              <Path Grid.Column="0" Classes="ico ok" Data="{StaticResource IcoCheckCircleFill}" VerticalAlignment="Top"/>
              <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="3">
                <TextBlock Text="No rows in quarantine" Foreground="{DynamicResource Text}" FontWeight="SemiBold"/>
                <TextBlock Text="Rejected rows from a mixed import appear here for inspection and repair."
                           Foreground="{DynamicResource T3}" FontSize="11.5" TextWrapping="Wrap"/>
              </StackPanel>
            </Grid>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Preference Review (slice 7 fidelity): list card + prompt card + Chosen/Rejected side-by-side. -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=PreferenceReview}">
      <Border.Styles>
        <!-- Actions lead with an accent "Export ranking"; the rest stay available but de-emphasized. -->
        <Style Selector="Button.leadaction">
          <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
          <Setter Property="Foreground" Value="{DynamicResource AccentInk}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
          <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button.subtle">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="Foreground" Value="{DynamicResource T3}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource Line2}"/>
          <Setter Property="BorderThickness" Value="1"/>
        </Style>
      </Border.Styles>
      <Grid Margin="16" ColumnDefinitions="300,*">
        <Border Grid.Column="0" Background="{DynamicResource Panel}" CornerRadius="11" Padding="8"
                BorderBrush="{DynamicResource Line2}" BorderThickness="1">
          <ListBox ItemsSource="{Binding PreferenceReview.PreferenceReviewItems}"
                   SelectedItem="{Binding PreferenceReview.SelectedPreferenceReviewItem}"
                   Background="Transparent" BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:PreferenceReviewItem">
                <!-- Two-line pair item (mirrors Versions/Quarantine): prompt + real contrast band. -->
                <StackPanel Spacing="2" Margin="0,2">
                  <TextBlock Text="{Binding Prompt}" TextTrimming="CharacterEllipsis"
                             FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                  <TextBlock Text="{Binding ContrastLine}" FontSize="11"
                             Foreground="{DynamicResource T4}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
        <ScrollViewer Grid.Column="1" Margin="16,0,0,0">
          <StackPanel Spacing="12">
            <!-- Header row: ranking summary (left) + a right-aligned Contrast filter. -->
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="{Binding PreferenceReview.PreferenceRankingSummary}"
                         Foreground="{DynamicResource T3}" TextWrapping="Wrap" VerticalAlignment="Center"/>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Contrast" FontSize="12" Foreground="{DynamicResource T4}" VerticalAlignment="Center"/>
                <ComboBox MinWidth="120"
                          ItemsSource="{Binding PreferenceReview.PreferenceContrastFilterOptions}"
                          SelectedItem="{Binding PreferenceReview.PreferenceContrastFilter}"/>
              </StackPanel>
            </Grid>
            <WrapPanel>
              <Button Classes="leadaction" Content="Export ranking" Command="{Binding ExportPreferenceRankingCommand}" Margin="0,0,6,4"/>
              <Button Classes="subtle" Content="Export for training" Command="{Binding ExportPreferenceForTrainingCommand}" Margin="0,0,6,4"/>
              <Button Classes="subtle" Content="Prepare judge review" Command="{Binding PreparePreferenceJudgeReviewCommand}" Margin="0,0,6,4"/>
              <Button Classes="subtle" Content="Batch judge" Command="{Binding PreparePreferenceBatchJudgeReviewCommand}" Margin="0,0,6,4"/>
            </WrapPanel>
            <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="14"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="4">
                <TextBlock Text="PROMPT" FontSize="10" Foreground="{DynamicResource T4}"/>
                <TextBlock Text="{Binding PreferenceReview.PreferencePromptText}" Foreground="{DynamicResource T2}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <Grid ColumnDefinitions="*,*">
              <Border Grid.Column="0" Margin="0,0,6,0" Background="{DynamicResource Panel}" CornerRadius="11" Padding="14"
                      BorderBrush="{DynamicResource Ok}" BorderThickness="1">
                <StackPanel Spacing="4">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Classes="ico ok" Data="{StaticResource IcoCheckCircleFill}" Width="14" Height="14"/>
                    <TextBlock Text="CHOSEN" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource Ok}" VerticalAlignment="Center"/>
                  </StackPanel>
                  <TextBlock Text="{Binding PreferenceReview.PreferenceChosenText}" Foreground="{DynamicResource T2}" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Margin="6,0,0,0" Background="{DynamicResource Panel}" CornerRadius="11" Padding="14"
                      BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                <StackPanel Spacing="4">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Classes="ico muted" Data="{StaticResource IcoChats}" Width="14" Height="14"/>
                    <TextBlock Text="REJECTED" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource T4}" VerticalAlignment="Center"/>
                  </StackPanel>
                  <TextBlock Text="{Binding PreferenceReview.PreferenceRejectedText}" Foreground="{DynamicResource T3}" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
            </Grid>
            <!-- REASON card — clones the PROMPT card so the pane's rationale reads as first-class. -->
            <Border Background="{DynamicResource Panel}" CornerRadius="11" Padding="14"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="4">
                <TextBlock Text="REASON" FontSize="10" Foreground="{DynamicResource T4}"/>
                <TextBlock Text="{Binding PreferenceReview.PreferenceReviewSummary}" Foreground="{DynamicResource T2}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Writing Studio (slice 7 fidelity): a header/actions card + the draft-editor card. -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=WritingStudio}">
      <ScrollViewer>
        <StackPanel Margin="20" Spacing="14" MaxWidth="900" HorizontalAlignment="Left">

          <!-- Header: schema pill + draft-saved state + Validate / Save actions -->
          <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
            <Border Grid.Column="0" Background="{DynamicResource AccentSoft}" CornerRadius="5" Padding="8,3" VerticalAlignment="Center">
              <TextBlock Text="{Binding ActiveSchemaId, StringFormat='{}{0} schema'}" FontSize="11.5"
                         Foreground="{DynamicResource AccentInk}"/>
            </Border>
            <TextBlock Grid.Column="1" Margin="10,0,0,0" Text="Draft · not saved" FontSize="12"
                       Foreground="{DynamicResource Warn}" VerticalAlignment="Center"
                       IsVisible="{Binding WritingStudio.IsDraftDirty}"/>
            <TextBlock Grid.Column="1" Margin="10,0,0,0" Text="Draft · saved" FontSize="12"
                       Foreground="{DynamicResource T4}" VerticalAlignment="Center"
                       IsVisible="{Binding !WritingStudio.IsDraftDirty}"/>
            <Button Grid.Column="3" Command="{Binding ValidateDraftCommand}" Margin="0,0,8,0" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Path Classes="ico" Data="{StaticResource IcoCheckCircleFill}" Width="14" Height="14"/>
                <TextBlock Text="Validate" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Grid.Column="4" Command="{Binding SaveExampleCommand}" VerticalAlignment="Center"
                    Background="{DynamicResource AccentSoft}" Foreground="{DynamicResource AccentInk}"
                    BorderBrush="{DynamicResource Accent}" BorderThickness="1">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Path Classes="ico accent" Data="{StaticResource IcoFloppy}" Width="14" Height="14"/>
                <TextBlock Text="Save example" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </Grid>

          <!-- Structured instruction form (only when the draft is an instruction-shaped JSON object;
               a chat / preference / malformed draft uses the raw editor below so a field edit can
               never corrupt a draft it can't round-trip). -->
          <StackPanel IsVisible="{Binding WritingStudio.IsInstructionShapedDraft}" Spacing="12">
            <StackPanel Spacing="5">
              <TextBlock Text="INSTRUCTION" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource T4}"/>
              <Border Background="{DynamicResource Panel}" CornerRadius="10" Padding="4"
                      BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                <TextBox Text="{Binding WritingStudio.DraftInstruction}" AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="72" Background="Transparent" BorderThickness="0"/>
              </Border>
            </StackPanel>
            <StackPanel Spacing="5">
              <TextBlock FontSize="10" FontWeight="SemiBold">
                <Run Text="INPUT " Foreground="{DynamicResource T4}"/><Run Text="· optional context" Foreground="{DynamicResource T4}" FontWeight="Normal"/>
              </TextBlock>
              <Border Background="{DynamicResource Panel}" CornerRadius="10" Padding="4"
                      BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                <TextBox Text="{Binding WritingStudio.DraftInput}" AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="44" Watermark="Leave blank if none" Background="Transparent" BorderThickness="0"/>
              </Border>
            </StackPanel>
            <StackPanel Spacing="5">
              <TextBlock Text="OUTPUT" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource T4}"/>
              <Border Background="{DynamicResource Panel}" CornerRadius="10" Padding="4"
                      BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                <TextBox Text="{Binding WritingStudio.DraftOutput}" AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="96" Background="Transparent" BorderThickness="0"/>
              </Border>
            </StackPanel>
          </StackPanel>

          <!-- Raw JSON editor fallback (non-instruction schema, or a draft that isn't valid JSON). -->
          <StackPanel IsVisible="{Binding !WritingStudio.IsInstructionShapedDraft}" Spacing="5">
            <TextBlock Text="RAW JSON" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource T4}"/>
            <Border Background="{DynamicResource Panel}" CornerRadius="10" Padding="8"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <TextBox Text="{Binding WritingStudio.DraftText}" AcceptsReturn="True" FontFamily="Consolas"
                       TextWrapping="NoWrap" MinHeight="200" Background="Transparent" BorderThickness="0"/>
            </Border>
          </StackPanel>

          <!-- Validation result (the shell's real ValidationSummary — the actual state, not a faked pass). -->
          <Border Background="{DynamicResource Panel}" CornerRadius="10" Padding="12"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <StackPanel Spacing="3">
              <TextBlock Text="VALIDATION" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource T4}"/>
              <TextBlock Text="{Binding ValidationSummary}" Foreground="{DynamicResource T3}" FontSize="11.5" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- AI Assist (slice 9 fidelity): connection/queue card | instruction+gate card / suggested-JSONL card. -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=AiAssist}">
      <Grid Margin="16" ColumnDefinitions="320,*" RowDefinitions="Auto,*">
        <Border Grid.Column="0" Grid.RowSpan="2" Background="{DynamicResource Panel}" CornerRadius="11" Padding="12"
                BorderBrush="{DynamicResource Line2}" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="BACKEND / MODEL" FontSize="10" Foreground="{DynamicResource T4}"/>
            <TextBox Text="{Binding AiAssistConnection.AiAssistBackend}"/>
            <TextBox Text="{Binding AiAssistConnection.AiAssistModel}"/>
            <TextBox Text="{Binding AiAssistConnection.AiAssistBaseUrl}"/>
            <TextBlock Text="{Binding AiAssistConnection.AiAssistModelListSummary}"
                       Foreground="{DynamicResource T4}" FontSize="11" TextWrapping="Wrap"/>
            <TextBlock Text="ACTION" FontSize="10" Foreground="{DynamicResource T4}" Margin="0,6,0,0"/>
            <ComboBox HorizontalAlignment="Stretch"
                      ItemsSource="{Binding AiAssist.AiAssistActionPresets}"
                      SelectedItem="{Binding AiAssist.AiAssistAction}"/>
            <TextBlock Text="{Binding AiAssist.AiAssistQueueSummary}" Foreground="{DynamicResource T3}" Margin="0,6,0,0"/>
            <ComboBox HorizontalAlignment="Stretch"
                      ItemsSource="{Binding AiAssist.AiAssistQueueFilterOptions}"
                      SelectedItem="{Binding AiAssist.AiAssistQueueFilter}"/>
            <TextBox Text="{Binding AiAssist.AiAssistQueueSearch}" Watermark="search"/>
            <ListBox ItemsSource="{Binding AiAssist.AiAssistReviewQueue}"
                     SelectedItem="{Binding AiAssist.SelectedAiAssistReviewQueueItem}" Height="200"
                     Background="Transparent" BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:AiAssistReviewQueueItem">
                  <StackPanel Margin="0,2">
                    <TextBlock Text="{Binding ReviewId}" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                    <TextBlock Text="{Binding ReviewState}" Foreground="{DynamicResource T4}" FontSize="11"/>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Grid.Row="0" Margin="16,0,0,0" Background="{DynamicResource Panel}" CornerRadius="11" Padding="12"
                BorderBrush="{DynamicResource Line2}" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="INSTRUCTION" FontSize="10" Foreground="{DynamicResource T4}"/>
            <TextBox Text="{Binding AiAssist.AiAssistInstruction}" AcceptsReturn="True" Height="60"/>
            <WrapPanel>
              <Button Content="Check backend" Command="{Binding CheckAiAssistBackendCommand}" Margin="0,0,6,4"/>
              <Button Content="Refresh models" Command="{Binding RefreshAiAssistModelsCommand}" Margin="0,0,6,4"/>
              <Button Content="Run AI Assist" Command="{Binding RunAiAssistCommand}" Margin="0,0,6,4"
                      Background="{DynamicResource AccentSoft}" Foreground="{DynamicResource AccentInk}"
                      BorderBrush="{DynamicResource Accent}" BorderThickness="1"/>
            </WrapPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Candidate gate:" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
              <TextBlock Text="{Binding AiAssist.AiAssistCandidateGateStatus}" FontWeight="Bold"
                         Foreground="{Binding AiAssist.AiAssistCandidateGateColor, Converter={StaticResource StringToBrush}}"/>
            </StackPanel>
            <TextBlock Text="{Binding AiAssist.AiAssistSummary}" Foreground="{DynamicResource T2}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Grid.Row="1" Margin="16,12,0,0" Background="{DynamicResource Panel}" CornerRadius="11" Padding="10"
                BorderBrush="{DynamicResource Line2}" BorderThickness="1">
          <TextBox Text="{Binding AiAssist.AiAssistSuggestedJsonlText}" IsReadOnly="True"
                   AcceptsReturn="True" FontFamily="Consolas" TextWrapping="Wrap"
                   Background="Transparent" BorderThickness="0"/>
        </Border>
      </Grid>
    </Border>

    <!-- Evaluation (slice 6 fidelity): config card + results card (status chips) | detail/comparison cards. -->
    <!-- Evaluation (production-UI re-skin): single full-width column — a top run-config toolbar, a KPI
         stat-card row, a wide per-example results table, then the example-detail / report-comparison
         cards below (no always-on right rail). Binds real Evaluation VM data throughout. -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Evaluation}">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">

          <!-- Run configuration: full-width top toolbar (a label above each control). -->
          <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="16"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="Auto,1.4*,2*,Auto,Auto">
                <!-- Backend status chip -->
                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,14,0">
                  <TextBlock Text="BACKEND" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <Border CornerRadius="7" Padding="10,6" Background="{DynamicResource Panel2}"
                          BorderBrush="{DynamicResource Line2}" BorderThickness="1" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                      <Ellipse Width="8" Height="8" Fill="{DynamicResource Ok}"/>
                      <TextBlock Text="{Binding EvaluationConnection.EvaluationBackend}" Foreground="{DynamicResource Text}"
                                 FontSize="12.5" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </StackPanel>
                <!-- Model -->
                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,14,0">
                  <TextBlock Text="MODEL" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <ComboBox HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                            ItemsSource="{Binding EvaluationConnection.EvaluationAvailableModels}"
                            SelectedItem="{Binding EvaluationConnection.EvaluationModel}"
                            PlaceholderText="{Binding EvaluationConnection.EvaluationModel}"/>
                </StackPanel>
                <!-- Judge (optional) -->
                <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,14,0">
                  <TextBlock Text="JUDGE MODEL · OPTIONAL" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <TextBox Text="{Binding EvaluationConnection.EvaluationJudgeModel}" VerticalAlignment="Bottom"
                           Watermark="keyword-overlap (none)"/>
                </StackPanel>
                <!-- Threshold -->
                <StackPanel Grid.Column="3" Spacing="4" Margin="0,0,14,0">
                  <TextBlock Text="THRESHOLD" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <TextBox Text="{Binding Evaluation.EvaluationScoreThreshold}" Width="72" VerticalAlignment="Bottom"/>
                </StackPanel>
                <!-- Run evaluation (accent, leading play glyph) -->
                <StackPanel Grid.Column="4" Spacing="4">
                  <TextBlock Text=" " FontSize="10" Foreground="{DynamicResource T4}"/>
                  <Button Command="{Binding RunEvaluationCommand}" VerticalAlignment="Bottom" Padding="14,7"
                          Background="{DynamicResource AccentSoft}" Foreground="{DynamicResource AccentInk}"
                          BorderBrush="{DynamicResource Accent}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                      <Path Classes="ico accent ico-sm" Data="{StaticResource IcoPlay}"/>
                      <TextBlock Text="Run evaluation" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </StackPanel>
              </Grid>

              <!-- Live run progress -->
              <StackPanel IsVisible="{Binding Evaluation.IsEvaluationInProgress}" Spacing="3">
                <TextBlock Text="{Binding Evaluation.EvaluationProgressText}" FontSize="11" Foreground="{DynamicResource T3}"/>
                <ProgressBar Minimum="0" Maximum="100" Value="{Binding Evaluation.EvaluationProgressPercent}"/>
              </StackPanel>

              <!-- Secondary run controls + actions (moved out of the primary row) -->
              <Border Height="1" Background="{DynamicResource Line}"/>
              <Grid ColumnDefinitions="Auto,1.4*,2*">
                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,14,0">
                  <TextBlock Text="LIMIT" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <TextBox Text="{Binding Evaluation.EvaluationLimit}" Width="72"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,14,0">
                  <TextBlock Text="JUDGE BACKEND" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <TextBox Text="{Binding EvaluationConnection.EvaluationJudgeBackend}"
                           Watermark="blank = eval backend"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                  <TextBlock Text="JUDGE BASE URL" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <TextBox Text="{Binding EvaluationConnection.EvaluationJudgeBaseUrl}"
                           Watermark="blank = eval base url"/>
                </StackPanel>
              </Grid>
              <WrapPanel>
                <Button Content="Check backend" Command="{Binding CheckEvaluationBackendCommand}" Margin="0,0,6,4"/>
                <Button Content="Refresh models" Command="{Binding RefreshEvaluationModelsCommand}" Margin="0,0,6,4"/>
                <Button Content="Rerun report" Command="{Binding RerunEvaluationReportCommand}" Margin="0,0,6,4"/>
                <Button Content="Prepare failure review" Command="{Binding PrepareEvaluationFailureReviewCommand}" Margin="0,0,6,4"/>
              </WrapPanel>
              <TextBlock Text="{Binding Evaluation.EvaluationSummary}" Foreground="{DynamicResource T2}" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <!-- KPI stat-card row (post-run only; hidden pre-run so no faked numbers show). -->
          <Grid ColumnDefinitions="*,*,*,*" IsVisible="{Binding Evaluation.HasEvaluationReport}">
            <Border Grid.Column="0" Margin="0,0,6,0" Background="{DynamicResource Panel}" CornerRadius="12"
                    Padding="16" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="6">
                <TextBlock Text="Average score" FontSize="12" Foreground="{DynamicResource T3}"/>
                <TextBlock Text="{Binding Evaluation.AverageScoreDisplay}" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource Text}"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Margin="3,0,3,0" Background="{DynamicResource Panel}" CornerRadius="12"
                    Padding="16" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="6">
                <TextBlock Text="Pass rate" FontSize="12" Foreground="{DynamicResource T3}"/>
                <TextBlock Text="{Binding Evaluation.PassRateDisplay}" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource Ok}"/>
                <TextBlock Text="{Binding Evaluation.PassRateDetail}" FontSize="11" Foreground="{DynamicResource T4}"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="2" Margin="3,0,3,0" Background="{DynamicResource Panel}" CornerRadius="12"
                    Padding="16" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="6">
                <TextBlock Text="Evaluated" FontSize="12" Foreground="{DynamicResource T3}"/>
                <TextBlock Text="{Binding Evaluation.EvaluatedDisplay}" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource Text}"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="3" Margin="6,0,0,0" Background="{DynamicResource Panel}" CornerRadius="12"
                    Padding="16" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="6">
                <TextBlock Text="Metric" FontSize="12" Foreground="{DynamicResource T3}"/>
                <TextBlock Text="{Binding Evaluation.MetricDisplay}" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource Text}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </Grid>

          <!-- Per-example results (wide), with a segmented All / Pass N / Fail N filter. -->
          <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="16"
                  BorderBrush="{DynamicResource Line2}" BorderThickness="1">
            <Border.Styles>
              <Style Selector="Button.seg">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="7"/>
                <Setter Property="Padding" Value="13,4"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource T3}"/>
              </Style>
              <Style Selector="Button.seg.active">
                <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
                <Setter Property="Foreground" Value="{DynamicResource AccentInk}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
              </Style>
            </Border.Styles>
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="Per-example results" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                  <TextBlock Text="{Binding Evaluation.EvaluationResultsSummary}" Foreground="{DynamicResource T3}" FontSize="12"/>
                </StackPanel>
                <Border Grid.Column="1" CornerRadius="9" Padding="3" Background="{DynamicResource Panel2}"
                        BorderBrush="{DynamicResource Line2}" BorderThickness="1" VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Classes="seg" Classes.active="{Binding Evaluation.IsAllResultsFilterActive}"
                            Command="{Binding Evaluation.ShowAllResultsCommand}" Content="All"/>
                    <Button Classes="seg" Classes.active="{Binding Evaluation.IsPassedResultsFilterActive}"
                            Command="{Binding Evaluation.ShowPassedResultsCommand}"
                            Content="{Binding Evaluation.EvaluationPassCount, StringFormat='Pass {0}'}"/>
                    <Button Classes="seg" Classes.active="{Binding Evaluation.IsFailedResultsFilterActive}"
                            Command="{Binding Evaluation.ShowFailedResultsCommand}"
                            Content="{Binding Evaluation.EvaluationFailCount, StringFormat='Fail {0}'}"/>
                  </StackPanel>
                </Border>
              </Grid>
              <ListBox ItemsSource="{Binding Evaluation.EvaluationResults}"
                       SelectedItem="{Binding Evaluation.SelectedEvaluationExampleResult}" Height="320"
                       Background="Transparent">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:EvaluationExampleResult">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,4">
                      <TextBlock Grid.Column="0" Text="{Binding ExampleId}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                      <!-- Proportional score bar: fixed Track, inner fill width ~ Score/100, Ok when
                           passed else Warn (before the numeric score). -->
                      <Border Grid.Column="1" Width="130" Height="6" CornerRadius="3"
                              Background="{DynamicResource Track}" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Border HorizontalAlignment="Left" Height="6" CornerRadius="3"
                                Width="{Binding ScoreBarWidth}"
                                Background="{Binding ScoreBarColor, Converter={StaticResource StringToBrush}}"/>
                      </Border>
                      <TextBlock Grid.Column="2" Text="{Binding Score, StringFormat='{}{0:0.#}'}"
                                 Foreground="{DynamicResource T2}" FontSize="12.5" MinWidth="30"
                                 TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                      <Border Grid.Column="3" CornerRadius="5" Padding="7,1" VerticalAlignment="Center"
                              Background="{Binding StatusColor, Converter={StaticResource StringToBrush}}">
                        <TextBlock Text="{Binding StatusLabel}" Foreground="White" FontSize="9.5" FontWeight="Bold"/>
                      </Border>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </StackPanel>
          </Border>

          <!-- Example detail + report comparison (relocated below the table). -->
          <Grid ColumnDefinitions="*,*">
            <Border Grid.Column="0" Margin="0,0,6,0" Background="{DynamicResource Panel}" CornerRadius="12"
                    Padding="16" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="6">
                <TextBlock Text="Example detail" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Text="{Binding Evaluation.SelectedEvaluationExampleDetail}" Foreground="{DynamicResource T2}" TextWrapping="Wrap"/>
                <TextBlock Text="Manual score / notes" FontSize="11" Foreground="{DynamicResource T4}" Margin="0,6,0,0"/>
                <TextBox Text="{Binding Evaluation.EvaluationManualScore}"/>
                <TextBox Text="{Binding Evaluation.EvaluationManualNotes}" AcceptsReturn="True" Height="50"/>
                <TextBlock Text="{Binding Evaluation.EvaluationReviewSummary}" Foreground="{DynamicResource T3}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Margin="6,0,0,0" Background="{DynamicResource Panel}" CornerRadius="12"
                    Padding="16" BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="6">
                <TextBlock Text="Report comparison" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <ComboBox HorizontalAlignment="Stretch"
                          ItemsSource="{Binding Evaluation.EvaluationReportHistory}"
                          SelectedItem="{Binding Evaluation.SelectedEvaluationReportHistoryItem}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:EvaluationReportHistoryItem">
                      <TextBlock Text="{Binding DisplayName}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Compare reports" Command="{Binding Evaluation.CompareReportsCommand}" HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding Evaluation.EvaluationComparisonSummary}" Foreground="{DynamicResource T2}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </Grid>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Training (slice 10 fidelity): configuration card | run + first-party + download + log cards. -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Training}">
      <!-- Theme-aware soft status tints (alpha over the Ok/Warn/Bad tokens), scoped to the Training panel
           so the status chip + regression-gate callout read in both themes without a global token —
           mirrors the Artifacts/Settings pattern. -->
      <Border.Resources>
        <ResourceDictionary>
          <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Dark">
              <SolidColorBrush x:Key="OkSoft" Color="#296bbf9a"/>
              <SolidColorBrush x:Key="WarnSoft" Color="#29d9a35f"/>
              <SolidColorBrush x:Key="BadSoft" Color="#29d76d6d"/>
            </ResourceDictionary>
            <ResourceDictionary x:Key="Light">
              <SolidColorBrush x:Key="OkSoft" Color="#1f3f9b73"/>
              <SolidColorBrush x:Key="WarnSoft" Color="#1fb8792e"/>
              <SolidColorBrush x:Key="BadSoft" Color="#1fc85552"/>
            </ResourceDictionary>
          </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
      </Border.Resources>
      <Border.Styles>
        <!-- Method segmented control (READ-ONLY): each segment reflects the derived method; the selected
             one fills Panel2 + gets an Accent border. Borders (not Buttons) — there is no method setter. -->
        <Style Selector="Border.methodseg">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="BorderBrush" Value="Transparent"/>
          <Setter Property="BorderThickness" Value="1"/>
          <Setter Property="CornerRadius" Value="7"/>
          <Setter Property="Padding" Value="12,7"/>
        </Style>
        <Style Selector="Border.methodseg.selected">
          <Setter Property="Background" Value="{DynamicResource Panel2}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
        </Style>
        <Style Selector="Border.methodseg > TextBlock">
          <Setter Property="HorizontalAlignment" Value="Center"/>
          <Setter Property="FontSize" Value="13"/>
          <Setter Property="Foreground" Value="{DynamicResource T3}"/>
        </Style>
        <Style Selector="Border.methodseg.selected > TextBlock">
          <Setter Property="Foreground" Value="{DynamicResource Text}"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <!-- Status chip variants (neutral base + Ok/Warn/Bad tints). -->
        <Style Selector="Border.statuschip">
          <Setter Property="CornerRadius" Value="7"/>
          <Setter Property="Padding" Value="9,4"/>
          <Setter Property="Background" Value="{DynamicResource Panel2}"/>
          <Setter Property="BorderThickness" Value="1"/>
          <Setter Property="BorderBrush" Value="{DynamicResource Line2}"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.statuschip.ok"><Setter Property="Background" Value="{DynamicResource OkSoft}"/><Setter Property="BorderBrush" Value="{DynamicResource Ok}"/></Style>
        <Style Selector="Border.statuschip.warn"><Setter Property="Background" Value="{DynamicResource WarnSoft}"/><Setter Property="BorderBrush" Value="{DynamicResource Warn}"/></Style>
        <Style Selector="Border.statuschip.bad"><Setter Property="Background" Value="{DynamicResource BadSoft}"/><Setter Property="BorderBrush" Value="{DynamicResource Bad}"/></Style>
        <!-- Stat tiles: small T4 cap over a large value. -->
        <Style Selector="TextBlock.statcap">
          <Setter Property="Foreground" Value="{DynamicResource T4}"/>
          <Setter Property="FontSize" Value="10"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TextBlock.statval">
          <Setter Property="Foreground" Value="{DynamicResource Text}"/>
          <Setter Property="FontSize" Value="22"/>
          <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
      </Border.Styles>
      <Grid Margin="16" ColumnDefinitions="*,*">
        <Border Grid.Column="0" Margin="0,0,10,0" Background="{DynamicResource Panel}" CornerRadius="12" Padding="16"
                BorderBrush="{DynamicResource Line2}" BorderThickness="1" VerticalAlignment="Top">
          <StackPanel Spacing="6">
            <TextBlock Text="Configuration" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Text}"/>
            <!-- Method (read-only): the desktop VM has no training-method state (TokenBudget.Method is the
                 token estimator name, not the method) and no 4-bit signal, so the method is DERIVED from the
                 real LoRA rank — LoRA when rank>0, else Full. QLoRA stays inactive because it cannot be
                 honestly asserted. Reflects config; it is not an input. -->
            <TextBlock Text="METHOD" FontSize="10" Foreground="{DynamicResource T4}" Margin="0,4,0,0"/>
            <Border Background="{DynamicResource Track}" CornerRadius="9" Padding="3"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <Grid ColumnDefinitions="*,*,*">
                <Border Grid.Column="0" Classes="methodseg" Classes.selected="{Binding Training.IsMethodQlora}">
                  <TextBlock Text="QLoRA"/>
                </Border>
                <Border Grid.Column="1" Classes="methodseg" Classes.selected="{Binding Training.IsMethodLora}">
                  <TextBlock Text="LoRA"/>
                </Border>
                <Border Grid.Column="2" Classes="methodseg" Classes.selected="{Binding Training.IsMethodFull}">
                  <TextBlock Text="Full"/>
                </Border>
              </Grid>
            </Border>
            <TextBlock Text="TARGET" FontSize="10" Foreground="{DynamicResource T4}"/>
            <TextBox Text="{Binding Training.TrainingTarget}" Watermark="target"/>
            <TextBlock Text="BASE MODEL" FontSize="10" Foreground="{DynamicResource T4}"/>
            <TextBox Text="{Binding Training.TrainingBaseModel}" Watermark="base model"/>
            <TextBlock Text="FORMAT" FontSize="10" Foreground="{DynamicResource T4}"/>
            <TextBox Text="{Binding Training.TrainingFormat}" Watermark="format"/>
            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                <TextBlock Text="SEQ LEN" FontSize="10" Foreground="{DynamicResource T4}"/>
                <TextBox Text="{Binding Training.TrainingSequenceLen}" Watermark="seq len"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="LEARNING RATE" FontSize="10" Foreground="{DynamicResource T4}"/>
                <TextBox Text="{Binding Training.TrainingLearningRate}" Watermark="learning rate"/>
              </StackPanel>
            </Grid>
            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                <TextBlock Text="LORA R" FontSize="10" Foreground="{DynamicResource T4}"/>
                <TextBox Text="{Binding Training.TrainingLoraR}" Watermark="lora r"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="LORA ALPHA" FontSize="10" Foreground="{DynamicResource T4}"/>
                <TextBox Text="{Binding Training.TrainingLoraAlpha}" Watermark="lora alpha"/>
              </StackPanel>
            </Grid>
            <WrapPanel Margin="0,6,0,0">
              <Button Content="Check compatibility" Command="{Binding CheckTrainingCompatibilityCommand}" Margin="0,0,6,4"/>
              <Button Content="Generate config" Command="{Binding GenerateTrainingConfigCommand}" Margin="0,0,6,4"/>
            </WrapPanel>
            <TextBlock Text="{Binding Training.TrainingSummary}" Foreground="{DynamicResource T2}" TextWrapping="Wrap" Margin="0,4,0,0"/>
            <!-- Hero Launch (item 5): full-width accent, bound to the existing launch command; enabled only
                 once a generated config yields a launch argv and pre-flight allows it (CanLaunchTraining). -->
            <Button Command="{Binding LaunchTrainingCommand}" IsEnabled="{Binding Training.CanLaunchTraining}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,8,0,0" Padding="0,10"
                    Background="{DynamicResource AccentSoft}" Foreground="{DynamicResource AccentInk}"
                    BorderBrush="{DynamicResource Accent}" BorderThickness="1">
              <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <Path Classes="ico accent" Data="{StaticResource IcoCap}"/>
                <TextBlock Text="Launch training run" VerticalAlignment="Center" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Border>
        <ScrollViewer Grid.Column="1" Margin="10,0,0,0">
          <StackPanel Spacing="12">
            <!-- Run card -->
            <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="14"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="12">
                <!-- Header: "Run" + the real session run label (monospace, "—" before any launch) left;
                     the real run-status chip right (Ok+check when complete, Warn running, Bad failed). -->
                <Grid ColumnDefinitions="Auto,Auto,*,Auto" VerticalAlignment="Center">
                  <TextBlock Grid.Column="0" Text="Run" FontWeight="SemiBold" FontSize="14"
                             Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding Training.TrainingRunLabel}" Margin="8,0,0,0"
                             FontFamily="Consolas" FontSize="13" Foreground="{DynamicResource T3}" VerticalAlignment="Center"/>
                  <Border Grid.Column="3" Classes="statuschip"
                          Classes.ok="{Binding Training.IsTrainingComplete}"
                          Classes.warn="{Binding Training.IsTrainingRunning}"
                          Classes.bad="{Binding Training.IsTrainingFailed}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Path Classes="ico ico-sm ok" Data="{StaticResource IcoCheckCircleFill}"
                            IsVisible="{Binding Training.IsTrainingComplete}"/>
                      <TextBlock Text="{Binding Training.TrainingRunStatus}" FontSize="12"
                                 Foreground="{DynamicResource T2}" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </Grid>

                <!-- Run stats. HONEST NEUTRAL STATE: the VM/run-record carry no final-loss / steps / wall
                     fields, so these render permanent "—" placeholders — never fabricated numbers. The
                     labels mark where those metrics would land once the run pipeline captures them. -->
                <Grid ColumnDefinitions="*,*,*">
                  <StackPanel Grid.Column="0" Spacing="1">
                    <TextBlock Classes="statcap" Text="FINAL LOSS"/>
                    <TextBlock Classes="statval" Text="—"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="1">
                    <TextBlock Classes="statcap" Text="STEPS"/>
                    <TextBlock Classes="statval" Text="—"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="1">
                    <TextBlock Classes="statcap" Text="WALL"/>
                    <TextBlock Classes="statval" Text="—"/>
                  </StackPanel>
                </Grid>

                <!-- Loss curve intentionally OMITTED: no loss-points / history collection exists on the
                     Training VM to bind a Polyline to, and fabricating points is disallowed. The live text
                     run log below is the real run-progress surface. -->

                <!-- Regression-gate callout: shown only on a real WARN/BLOCK (or could-not-run) verdict
                     from the gate; the body is the real gate summary. -->
                <Border IsVisible="{Binding Training.HasGateWarning}" Background="{DynamicResource WarnSoft}"
                        BorderBrush="{DynamicResource Warn}" BorderThickness="1" CornerRadius="10" Padding="12">
                  <Grid ColumnDefinitions="Auto,*">
                    <Path Grid.Column="0" Classes="ico warn" Data="{StaticResource IcoWarningFill}"
                          VerticalAlignment="Top" Margin="0,1,10,0"/>
                    <StackPanel Grid.Column="1" Spacing="3">
                      <TextBlock Text="Regression gate" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                      <TextBlock Text="{Binding Training.TrainingRunGateSummary}" Foreground="{DynamicResource T2}"
                                 FontSize="12.5" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <!-- Run controls (the gate button feeds the callout above; checkpoints feed resume). -->
                <WrapPanel>
                  <Button Content="Stop" Command="{Binding StopTrainingCommand}" IsEnabled="{Binding Training.IsTrainingRunning}" Margin="0,0,6,4"/>
                  <Button Content="Resume" Command="{Binding ResumeTrainingCommand}" IsEnabled="{Binding Training.CanResumeTraining}" Margin="0,0,6,4"/>
                  <Button Content="Refresh checkpoints" Command="{Binding RefreshTrainingCheckpointsCommand}" Margin="0,0,6,4"/>
                  <Button Content="Regression gate" Command="{Binding GateTrainingRunCommand}" Margin="0,0,6,4"/>
                </WrapPanel>
              </StackPanel>
            </Border>
            <!-- First-party trainer card (corpus_studio target) -->
            <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="14"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1" IsVisible="{Binding Training.IsFirstPartyTarget}">
              <StackPanel Spacing="8">
                <TextBlock Text="First-party trainer" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <WrapPanel>
                  <Button Content="Check runtime" Command="{Binding CheckTrainingRuntimeCommand}" Margin="0,0,6,4"
                          ToolTip.Tip="Preflight the first-party training runtime (train-check): deps, GPU, QLoRA vs CPU-toy"/>
                  <CheckBox Content="CPU toy" IsChecked="{Binding Training.CpuToyMode}" Margin="0,0,6,4"
                            ToolTip.Tip="Run the tiny CPU smoke path — proves the pipeline runs; does NOT train a usable model"/>
                  <Button Content="Merge adapter" Command="{Binding MergeAdapterCommand}" IsEnabled="{Binding Training.CanMergeAdapter}" Margin="0,0,6,4"
                          ToolTip.Tip="Merge the trained LoRA adapter into its base (train-merge, auto → GPU / CPU-offload / adapter-only)"/>
                  <Button Content="Model card" Command="{Binding ShowModelCardCommand}" IsEnabled="{Binding Training.CanMergeAdapter}" Margin="0,0,6,4"
                          ToolTip.Tip="Generate + show the trained adapter's model card (base model + license, LoRA config, honesty notes)"/>
                </WrapPanel>
              </StackPanel>
            </Border>
            <!-- Base-model download card -->
            <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="14"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="8">
                <TextBlock Text="Download base model" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBox Text="{Binding Training.ModelFetchRepoId}" Width="280" Watermark="HF repo id (prefer MIT/Apache)"
                           ToolTip.Tip="e.g. HuggingFaceTB/SmolLM2-135M-Instruct — the base model's license governs the trained result"/>
                  <Button Content="Download" Command="{Binding FetchModelCommand}" IsEnabled="{Binding Training.CanFetchModel}"/>
                </StackPanel>
                <TextBox Text="{Binding Training.ModelFetchSummary}" IsReadOnly="True" AcceptsReturn="True"
                         FontFamily="Consolas" FontSize="11" MaxHeight="120" TextWrapping="Wrap"
                         Background="Transparent" BorderThickness="0"/>
              </StackPanel>
            </Border>
            <!-- Run log card -->
            <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="12"
                    BorderBrush="{DynamicResource Line2}" BorderThickness="1">
              <StackPanel Spacing="6">
                <TextBlock Text="Run log" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Text="{Binding Training.TrainingLaunchCommand}" Foreground="{DynamicResource T4}"
                           FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                <TextBox Text="{Binding Training.TrainingRunLog}" IsReadOnly="True" AcceptsReturn="True"
                         FontFamily="Consolas" Height="200" TextWrapping="Wrap" Background="Transparent" BorderThickness="0"/>
                <TextBlock Text="{Binding Training.TrainingCheckpointsSummary}" Foreground="{DynamicResource T3}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Training.TrainingComparisonSummary}" Foreground="{DynamicResource T3}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <TextBox Text="{Binding Training.TrainingRuntimeSummary}" IsVisible="{Binding Training.IsFirstPartyTarget}"
                     IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" FontSize="11" MaxHeight="140" TextWrapping="Wrap"/>
            <TextBox Text="{Binding Training.TrainingMergeSummary}" IsVisible="{Binding Training.IsFirstPartyTarget}"
                     IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" FontSize="11" MaxHeight="140" TextWrapping="Wrap"/>
            <TextBox Text="{Binding Training.ModelCardText}" IsVisible="{Binding Training.IsFirstPartyTarget}"
                     IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" FontSize="11" MaxHeight="180" TextWrapping="Wrap"/>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Artifacts (production re-skin): a full-width single column of rich weight-artifact cards.
         Each card renders header/integrity-chip/metadata/actions INLINE (the old 320px list + Consolas
         detail split is gone). The integrity chip + block message are the REAL provenance verdict
         (fingerprint match / mismatch / missing path), surfaced truthfully — never a faked "present".
         Per-card Keep/Weight card bind to the EXISTING selection-based shell commands; showing the
         action row only on the SELECTED card guarantees those parameterless commands act on this card.
         The rendered weight card / promote-gate verdict lands in the collapsible detail surface below. -->
    <Border IsVisible="{Binding SelectedStudioTabIndex, Converter={StaticResource TabIs}, ConverterParameter=Artifacts}">
      <!-- Ok/Warn/Bad-tinted chip fills, scoped here (theme-aware) so the integrity chips read in both
           themes without a global token — mirrors the alpha-over-token pattern used on the Settings tab. -->
      <Border.Resources>
        <ResourceDictionary>
          <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Dark">
              <SolidColorBrush x:Key="OkSoft" Color="#296bbf9a"/>
              <SolidColorBrush x:Key="WarnSoft" Color="#29d9a35f"/>
              <SolidColorBrush x:Key="BadSoft" Color="#29d76d6d"/>
            </ResourceDictionary>
            <ResourceDictionary x:Key="Light">
              <SolidColorBrush x:Key="OkSoft" Color="#1f3f9b73"/>
              <SolidColorBrush x:Key="WarnSoft" Color="#1fb8792e"/>
              <SolidColorBrush x:Key="BadSoft" Color="#1fc85552"/>
            </ResourceDictionary>
          </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
      </Border.Resources>
      <Border.Styles>
        <!-- Cards render as a plain scrolling column: strip the ListBox/ListBoxItem chrome so the
             per-artifact Border IS the card; the selected card gets an accent border instead. -->
        <Style Selector="ListBox.artifactlist">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="BorderThickness" Value="0"/>
          <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBox.artifactlist > ListBoxItem">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="Padding" Value="0"/>
          <Setter Property="Margin" Value="0,0,0,12"/>
          <Setter Property="CornerRadius" Value="11"/>
        </Style>
        <Style Selector="ListBox.artifactlist > ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox.artifactlist > ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox.artifactlist > ListBoxItem:selected Border.artifactcard">
          <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
        </Style>
        <Style Selector="TextBlock.metacap">
          <Setter Property="Foreground" Value="{DynamicResource T4}"/>
          <Setter Property="FontSize" Value="10"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TextBlock.metaval">
          <Setter Property="Foreground" Value="{DynamicResource T2}"/>
          <Setter Property="FontSize" Value="13"/>
          <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>
        <Style Selector="Border.intchip">
          <Setter Property="CornerRadius" Value="7"/>
          <Setter Property="Padding" Value="9,4"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
      </Border.Styles>

      <DockPanel Margin="16">
        <!-- Honest state line: kept / integrity-flagged counts (or the empty-state prompt). -->
        <TextBlock DockPanel.Dock="Top" Text="{Binding Artifacts.ArtifactSummary}" Foreground="{DynamicResource T3}"
                   FontSize="12.5" TextWrapping="Wrap" Margin="2,0,2,12"/>

        <!-- Collapsible detail surface: the rendered weight card OR the promote-gate verdict from Keep.
             Shown only when there is real content (not the idle hint) — keeps the clean card column. -->
        <Border DockPanel.Dock="Bottom" IsVisible="{Binding Artifacts.HasArtifactDetail}"
                Background="{DynamicResource Panel2}" CornerRadius="11" Padding="14" Margin="0,12,0,0"
                BorderBrush="{DynamicResource Line2}" BorderThickness="1">
          <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="WEIGHT CARD / GATE VERDICT" Classes="metacap" Margin="0,0,0,8"/>
            <ScrollViewer MaxHeight="220" HorizontalScrollBarVisibility="Disabled">
              <TextBlock Text="{Binding Artifacts.ArtifactDetail}" Foreground="{DynamicResource T2}"
                         FontSize="12.5" TextWrapping="Wrap"/>
            </ScrollViewer>
          </DockPanel>
        </Border>

        <!-- Card column (fills) + empty state, mutually exclusive on the real HasArtifacts signal. -->
        <Panel>
          <Border IsVisible="{Binding !Artifacts.HasArtifacts}" Background="{DynamicResource Panel}" CornerRadius="11"
                  Padding="24" BorderBrush="{DynamicResource Line2}" BorderThickness="1"
                  HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <StackPanel HorizontalAlignment="Center" Spacing="8">
              <Path Classes="ico" Data="{StaticResource IcoCube}" Width="26" Height="26" Fill="{DynamicResource T4}"/>
              <TextBlock Text="No trained-weight artifacts yet" Foreground="{DynamicResource T2}"
                         FontWeight="SemiBold" HorizontalAlignment="Center"/>
              <TextBlock Text="Register one from a completed training run to track its weights and provenance."
                         Foreground="{DynamicResource T4}" FontSize="12" TextWrapping="Wrap"
                         TextAlignment="Center" MaxWidth="360"/>
            </StackPanel>
          </Border>

          <ListBox Classes="artifactlist" IsVisible="{Binding Artifacts.HasArtifacts}"
                   ItemsSource="{Binding Artifacts.ModelArtifacts}"
                   SelectedItem="{Binding Artifacts.SelectedModelArtifact}"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:ArtifactDisplayItem">
                <Border Classes="artifactcard" Background="{DynamicResource Panel}" CornerRadius="11" Padding="16"
                        BorderBrush="{DynamicResource Line2}" BorderThickness="1" HorizontalAlignment="Stretch">
                  <StackPanel Spacing="12">
                    <!-- Header: cube + base-model headline + source-run + integrity chip. -->
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                        <Path Classes="ico" Data="{StaticResource IcoCube}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PrimaryName}" FontWeight="SemiBold" FontSize="14.5"
                                   Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Record.RunId}" Foreground="{DynamicResource T4}" FontSize="12"
                                   VerticalAlignment="Center" Margin="2,1,0,0"/>
                      </StackPanel>

                      <!-- integrity: present (ok) -->
                      <Border Grid.Column="1" Classes="intchip" Background="{DynamicResource OkSoft}"
                              IsVisible="{Binding IsOk}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <Path Classes="ico ico-sm" Data="{StaticResource IcoCheckCircleFill}" Fill="{DynamicResource Ok}"/>
                          <TextBlock Text="{Binding IntegrityLabel}" Foreground="{DynamicResource Ok}" FontSize="12"
                                     FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                      </Border>
                      <!-- integrity: modified (fingerprint mismatch) -->
                      <Border Grid.Column="1" Classes="intchip" Background="{DynamicResource WarnSoft}"
                              IsVisible="{Binding IsModified}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <Path Classes="ico ico-sm" Data="{StaticResource IcoWarningFill}" Fill="{DynamicResource Warn}"/>
                          <TextBlock Text="{Binding IntegrityLabel}" Foreground="{DynamicResource Warn}" FontSize="12"
                                     FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                      </Border>
                      <!-- integrity: missing (recorded path gone) -->
                      <Border Grid.Column="1" Classes="intchip" Background="{DynamicResource BadSoft}"
                              IsVisible="{Binding IsMissing}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <Path Classes="ico ico-sm" Data="{StaticResource IcoWarningFill}" Fill="{DynamicResource Bad}"/>
                          <TextBlock Text="{Binding IntegrityLabel}" Foreground="{DynamicResource Bad}" FontSize="12"
                                     FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                      </Border>
                    </Grid>

                    <!-- Metadata: labeled columns from real artifact fields (base is the headline above). -->
                    <StackPanel Orientation="Horizontal" Spacing="40">
                      <StackPanel>
                        <TextBlock Classes="metacap" Text="KIND"/>
                        <TextBlock Classes="metaval" Text="{Binding Record.Kind}"/>
                      </StackPanel>
                      <StackPanel>
                        <TextBlock Classes="metacap" Text="STATUS"/>
                        <TextBlock Classes="metaval" Text="{Binding Record.Status}"/>
                      </StackPanel>
                      <StackPanel>
                        <TextBlock Classes="metacap" Text="CREATED"/>
                        <TextBlock Classes="metaval" Text="{Binding CreatedDisplay}"/>
                      </StackPanel>
                    </StackPanel>

                    <!-- Modified/missing: honest promote-block reason from the real integrity signal. -->
                    <TextBlock Text="{Binding IntegrityBlockMessage}" Foreground="{DynamicResource Bad}"
                               FontSize="12.5" TextWrapping="Wrap" IsVisible="{Binding IsFlagged}"/>

                    <!-- Actions: only on the SELECTED card, so the parameterless selection-based shell
                         commands (Keep/Weight card) act on THIS artifact. Compare has no shell command
                         (see report) so it is present-but-disabled rather than faking an action. -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}">
                      <Button Content="Keep"
                              Background="{DynamicResource AccentSoft}" Foreground="{DynamicResource AccentInk}"
                              BorderBrush="{DynamicResource Accent}" BorderThickness="1"
                              Command="{Binding ((vm:MainWindowViewModel)DataContext).KeepArtifactCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                      <Button Content="Weight card"
                              Command="{Binding ((vm:MainWindowViewModel)DataContext).ViewArtifactCardCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                      <Button Content="Compare" IsEnabled="False"
                              ToolTip.Tip="Artifact comparison is not wired in the shell yet."/>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Panel>
      </DockPanel>
    </Border>

          </Panel>

          <!-- Quality right rail (slice 6 fidelity): a Nocturne signal card + a debt-trend card.
               Audit fix: shown only on the design's rail screens (ShowQualityRail); the Auto column
               collapses it elsewhere so the content area fills. -->
          <ScrollViewer Grid.Row="1" Grid.Column="2" Width="300" IsVisible="{Binding ShowQualityRail}">
            <StackPanel Margin="12" Spacing="10">
              <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="14"
                      BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Quality" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Command="{Binding RunQualityCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="5">
                        <Path Classes="ico accent" Data="{StaticResource IcoPlay}" Width="11" Height="11"/>
                        <TextBlock Text="Run" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                  </Grid>
                  <!-- PII-aware status banner: the alert callout from the design, driven by the real
                       Quality.QualityStatusColor/Background (red on PII/secrets, amber on issues, green
                       clean). Self-contained soft chip — readable in both themes. -->
                  <Border CornerRadius="8" Padding="9,7" IsVisible="{Binding Quality.HasQualityMetrics}"
                          Background="{Binding Quality.QualityStatusBackground, Converter={StaticResource StringToBrush}}">
                    <Grid ColumnDefinitions="Auto,*">
                      <Path Grid.Column="0" Classes="ico" Width="15" Height="15" VerticalAlignment="Top"
                            Data="{StaticResource IcoShieldWarningFill}"
                            Fill="{Binding Quality.QualityStatusColor, Converter={StaticResource StringToBrush}}"/>
                      <TextBlock Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap" FontSize="11.5"
                                 Text="{Binding Quality.QualityStatusLine}"
                                 Foreground="{Binding Quality.QualityStatusColor, Converter={StaticResource StringToBrush}}"/>
                    </Grid>
                  </Border>
                  <TextBlock Text="{Binding Quality.QualitySummary}" Foreground="{DynamicResource T3}"
                             FontSize="12" TextWrapping="Wrap" IsVisible="{Binding !Quality.HasQualityMetrics}"/>
                  <Border Height="1" Background="{DynamicResource Line}" IsVisible="{Binding Quality.HasQualityMetrics}"/>
                  <ItemsControl ItemsSource="{Binding Quality.QualityMetrics}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="models:QualityMetric">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                          <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{DynamicResource T2}" FontSize="12"/>
                          <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold" FontSize="12"
                                     Foreground="{Binding StatusColor, Converter={StaticResource StringToBrush}}"/>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
              <!-- Validation card: bound to the real (honest) shell ValidationSummary — shows the
                   actual validation state, not a faked "Passed" chip. -->
              <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="14"
                      BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                <StackPanel Spacing="4">
                  <TextBlock Text="VALIDATION" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <TextBlock Text="{Binding ValidationSummary}" Foreground="{DynamicResource T3}"
                             FontSize="11.5" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource Panel}" CornerRadius="12" Padding="14"
                      BorderBrush="{DynamicResource Line2}" BorderThickness="1">
                <StackPanel Spacing="4">
                  <TextBlock Text="DEBT TREND" FontSize="10" Foreground="{DynamicResource T4}"/>
                  <TextBlock Text="{Binding Quality.DebtTrendSummary}" Foreground="{DynamicResource T3}"
                             FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Grid>

      </Panel>

      <!-- Nocturne docked console (bottom dock). Two REAL surfaces — Problems and Output — driven by
           the mutually-exclusive ProblemsPanelVisible / OutputPanelVisible flags. There is NO terminal
           feature in this app, so the Terminal tab is rendered visibly disabled (never a fake shell).
           The wrapper Grid only hosts the shared tab/list styles once; the shared VS-Code-style tab
           header is repeated inside each border, but because the borders are mutually exclusive exactly
           one header is ever on screen. Active tab = accent underline via Classes.active bound straight
           to the panel flag; tabs switch panels through the EXISTING toggle commands. No VM members and
           no converters are added. -->
      <Grid Grid.Row="1">
        <Grid.Styles>
          <!-- Console tab buttons: transparent, accent underline when active (bound to the flags). -->
          <Style Selector="Button.constab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="3,9"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{DynamicResource T3}"/>
          </Style>
          <Style Selector="Button.constab /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="Button.constab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="Button.constab:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource Text}"/>
          </Style>
          <Style Selector="Button.constab.active">
            <Setter Property="Foreground" Value="{DynamicResource Text}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentStrong}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
          </Style>
          <Style Selector="Button.constab:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="Button.constab:disabled">
            <Setter Property="Foreground" Value="{DynamicResource T4}"/>
            <Setter Property="Opacity" Value="0.6"/>
          </Style>
          <!-- Collapse chevron -->
          <Style Selector="Button.conschev">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
          </Style>
          <Style Selector="Button.conschev:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Hover}"/>
          </Style>
          <!-- Console readouts: flat, no selection chrome (a readout, not a picker). -->
          <Style Selector="ListBox.consolelist">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
          </Style>
          <Style Selector="ListBox.consolelist ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="ListBox.consolelist ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="ListBox.consolelist ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Hover}"/>
          </Style>
        </Grid.Styles>

        <!-- PROBLEMS surface -->
        <Border Height="208" Background="{DynamicResource Panel2}"
                BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0"
                IsVisible="{Binding ProblemsPanelVisible}">
          <DockPanel>
            <Border DockPanel.Dock="Top" Background="{DynamicResource Chrome}"
                    BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="10,0">
              <Grid ColumnDefinitions="*,Auto" Height="38">
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                  <Button Classes="constab" Classes.active="{Binding ProblemsPanelVisible}"
                          Command="{Binding ToggleProblemsPanelCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                      <TextBlock Text="Problems" VerticalAlignment="Center"/>
                      <Border IsVisible="{Binding HasProblemsBadge}" CornerRadius="9" MinWidth="18" Height="18"
                              Background="{DynamicResource AccentSoft}" Padding="6,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ProblemsBadge}" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentInk}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                    </StackPanel>
                  </Button>
                  <Button Classes="constab" Classes.active="{Binding OutputPanelVisible}"
                          Command="{Binding ToggleOutputPanelCommand}" Content="Output"/>
                  <Button Classes="constab" IsEnabled="False" Content="Terminal"
                          ToolTip.Tip="Terminal is not available in this build."/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                  <TextBlock Text="{Binding ProblemsSummary}" Foreground="{DynamicResource T3}" FontSize="11"
                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="360"/>
                  <Button Classes="conschev" Command="{Binding ToggleProblemsPanelCommand}"
                          ToolTip.Tip="Collapse panel">
                    <Path Data="M2,3 L7,8 L12,3" Stroke="{DynamicResource T3}" StrokeThickness="1.6"
                          StrokeLineCap="Round" StrokeJoin="Round"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Button>
                </StackPanel>
              </Grid>
            </Border>
            <Panel Margin="14,10">
              <TextBlock Text="No problems — run gates to check this dataset." IsVisible="{Binding IsNoProblems}"
                         Foreground="{DynamicResource T4}" FontSize="12" VerticalAlignment="Top"/>
              <ListBox Classes="consolelist" ItemsSource="{Binding Problems}" IsVisible="{Binding !IsNoProblems}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:ProblemItem">
                    <StackPanel Margin="0,3">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12.5"
                                 Foreground="{Binding SeverityColor, Converter={StaticResource StringToBrush}}"/>
                      <TextBlock Text="{Binding Message}" FontSize="11.5" Foreground="{DynamicResource T2}" TextWrapping="Wrap"/>
                      <TextBlock Text="{Binding Fix}" FontSize="11.5" Foreground="{DynamicResource Accent}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Panel>
          </DockPanel>
        </Border>

        <!-- OUTPUT surface -->
        <Border Height="208" Background="{DynamicResource Panel2}"
                BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0"
                IsVisible="{Binding OutputPanelVisible}">
          <DockPanel>
            <Border DockPanel.Dock="Top" Background="{DynamicResource Chrome}"
                    BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="10,0">
              <Grid ColumnDefinitions="*,Auto" Height="38">
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                  <Button Classes="constab" Classes.active="{Binding ProblemsPanelVisible}"
                          Command="{Binding ToggleProblemsPanelCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                      <TextBlock Text="Problems" VerticalAlignment="Center"/>
                      <Border IsVisible="{Binding HasProblemsBadge}" CornerRadius="9" MinWidth="18" Height="18"
                              Background="{DynamicResource AccentSoft}" Padding="6,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ProblemsBadge}" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentInk}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                    </StackPanel>
                  </Button>
                  <Button Classes="constab" Classes.active="{Binding OutputPanelVisible}"
                          Command="{Binding ToggleOutputPanelCommand}" Content="Output"/>
                  <Button Classes="constab" IsEnabled="False" Content="Terminal"
                          ToolTip.Tip="Terminal is not available in this build."/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                  <TextBlock Text="{Binding OutputSummary}" Foreground="{DynamicResource T3}" FontSize="11"
                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="360"/>
                  <Button Classes="conschev" Command="{Binding ToggleOutputPanelCommand}"
                          ToolTip.Tip="Collapse panel">
                    <Path Data="M2,3 L7,8 L12,3" Stroke="{DynamicResource T3}" StrokeThickness="1.6"
                          StrokeLineCap="Round" StrokeJoin="Round"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Button>
                </StackPanel>
              </Grid>
            </Border>
            <Panel Margin="14,10">
              <TextBlock Text="Engine activity will appear here as you run commands." IsVisible="{Binding IsNoOutput}"
                         Foreground="{DynamicResource T4}" FontSize="12" VerticalAlignment="Top"/>
              <ListBox Classes="consolelist" ItemsSource="{Binding OutputLog}" IsVisible="{Binding HasOutput}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:EngineLogEntry">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                      <TextBlock Text="{Binding Timestamp}" Foreground="{DynamicResource T4}" FontFamily="Consolas" FontSize="11.5"/>
                      <TextBlock Text="{Binding Command}" Foreground="{DynamicResource Text}" FontFamily="Consolas" FontSize="11.5"/>
                      <TextBlock Text="{Binding ArgsSummary}" Foreground="{DynamicResource T3}" FontFamily="Consolas" FontSize="11.5"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Panel>
          </DockPanel>
        </Border>
      </Grid>

    </Grid>
  </Grid>
</Window>
