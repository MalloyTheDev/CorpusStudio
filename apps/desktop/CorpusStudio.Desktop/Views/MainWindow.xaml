                                               Style="{StaticResource CaptionTextStyle}"
                                               Margin="0,0,0,6" />
                                    <TextBox AutomationProperties.AutomationId="BenchmarkModelsTextBox"
                                             Text="{Binding BenchmarkModelsInput, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             MinHeight="52"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Margin="0,0,0,6" />
                                    <Button Style="{StaticResource PrimaryButtonStyle}"
                                            AutomationProperties.AutomationId="RunBenchmarkButton"
                                            Content="Run _Benchmark"
                                            HorizontalAlignment="Left"
                                            Click="RunBenchmarkButton_Click" />
                                    <TextBox AutomationProperties.AutomationId="BenchmarkSummaryTextBox"
                                             Text="{Binding BenchmarkSummary, Mode=OneWay}"
                                             IsReadOnly="True"
                                             MinHeight="80"
                                             Margin="0,8,0,0"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="2"
                                  Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="320" />
                                    <ColumnDefinition Width="*" />
