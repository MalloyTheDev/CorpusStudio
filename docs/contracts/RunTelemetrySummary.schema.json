{
  "$defs": {
    "AttentionImpl": {
      "description": "``math``/``eager`` is forced on native-Windows/WDDM Blackwell sm_120 because the fused flash\nkernel deadlocks there. Other platforms require their own functional capability result; WSL\nevidence is not bare-Linux proof.",
      "enum": [
        "math",
        "eager",
        "sdpa",
        "flash_attention_2",
        "flash_attention_3",
        "mem_efficient",
        "xformers"
      ],
      "title": "AttentionImpl",
      "type": "string"
    },
    "EnergyIntegration": {
      "additionalProperties": false,
      "description": "GPU energy from the trapezoidal rule over adjacent power samples\n``E = sum(0.5*(P_i+P_{i+1})*(t_{i+1}-t_i))`` (research ``METRICS.md``). Intervals crossing the\nmeasured-window boundary are linearly clipped. All power in watts, time from the monotonic clock;\njoules are null when no power sample exists (never zero).",
      "properties": {
        "boundary_clipped": {
          "default": false,
          "title": "Boundary Clipped",
          "type": "boolean"
        },
        "coverage_fraction": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Coverage Fraction"
        },
        "energy_per_1000_nonpadding_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Energy Per 1000 Nonpadding Tokens"
        },
        "joules_per_measured_optimizer_step": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Joules Per Measured Optimizer Step"
        },
        "max_power_watts": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Power Watts"
        },
        "measured_window_joules": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Measured Window Joules"
        },
        "median_measured_power_watts": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Median Measured Power Watts"
        },
        "method": {
          "const": "trapezoidal-power-over-monotonic-time-v1",
          "default": "trapezoidal-power-over-monotonic-time-v1",
          "title": "Method",
          "type": "string"
        },
        "power_sample_count": {
          "default": 0,
          "minimum": 0,
          "title": "Power Sample Count",
          "type": "integer"
        },
        "run_joules": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Run Joules"
        },
        "time_weighted_mean_power_watts": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Time Weighted Mean Power Watts"
        }
      },
      "title": "EnergyIntegration",
      "type": "object"
    },
    "FailureTaxonomy": {
      "description": "Terminal outcome category. ``PASS`` is included so the same enum classifies a completed\nprobe/run, not only failures. Grounded in the exact hazards the engine documents: the sm_120\nfused-attention deadlock (KERNEL_STALL), the WDDM silent spill (ACCIDENTAL_SPILL vs a clean\nOOM), and env/dependency mismatches (ENVIRONMENT_FAILURE).",
      "enum": [
        "PASS",
        "FAIL",
        "OOM",
        "TIMEOUT",
        "KERNEL_STALL",
        "NUMERICAL_FAILURE",
        "GRADIENT_FAILURE",
        "LOSS_EVIDENCE_FAILURE",
        "OPTIMIZER_FAILURE",
        "UPDATE_FAILURE",
        "ARTIFACT_FAILURE",
        "CHECKPOINT_FAILURE",
        "ENVIRONMENT_FAILURE",
        "UNSUPPORTED_CONFIGURATION",
        "ACCIDENTAL_SPILL",
        "CONTROLLED_OFFLOAD"
      ],
      "title": "FailureTaxonomy",
      "type": "string"
    },
    "FitClass": {
      "description": "The fit verdict. ``NATIVE_*`` = fully resident. ``CONTROLLED_*`` = a deliberate, planned\noffload (acceptable, slower). ``ACCIDENTAL_*`` / ``THRASHING`` = an unplanned spill the platform\ndid silently (the failure mode the engine warns about). ``FAIL`` = will not run.",
      "enum": [
        "PLANNED_UNPROVEN",
        "NATIVE_SAFE",
        "NATIVE_TIGHT",
        "NATIVE_UNPROVEN",
        "MARGINAL",
        "CONTROLLED_ACTIVATION_OFFLOAD",
        "CONTROLLED_OPTIMIZER_OFFLOAD",
        "CONTROLLED_PARAMETER_OFFLOAD",
        "ACCIDENTAL_UNIFIED_MEMORY_PAGING",
        "ACCIDENTAL_WDDM_SPILL",
        "THRASHING",
        "FAIL"
      ],
      "title": "FitClass",
      "type": "string"
    },
    "FitClassification": {
      "additionalProperties": false,
      "description": "The planner/calibrator verdict on whether a resolved RunPlan fits the target environment, and\nHOW: a native fit, a deliberately-offloaded fit, or an ACCIDENTAL spill (the silent WDDM/unified\npaging that looks frozen but crawls at 10-25x). NEW \u2014 the engine emits only a coarse warn/pass\nVRAM band (preflight.gpu_memory, _VRAM_SAFETY_MARGIN_GB).",
      "properties": {
        "attention_path": {
          "anyOf": [
            {
              "$ref": "#/$defs/AttentionImpl"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "classification": {
          "$ref": "#/$defs/FitClass"
        },
        "contract_version": {
          "const": "1.0.0",
          "default": "1.0.0",
          "title": "Contract Version",
          "type": "string"
        },
        "device_capacity_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Device Capacity Bytes"
        },
        "estimated_peak_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Peak Bytes"
        },
        "headroom_bytes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Headroom Bytes"
        },
        "rationale": {
          "default": "",
          "title": "Rationale",
          "type": "string"
        }
      },
      "required": [
        "classification"
      ],
      "title": "FitClassification",
      "type": "object"
    },
    "GpuTelemetrySummary": {
      "additionalProperties": false,
      "description": "Derived GPU aggregates over the MEASURED window (plus explicit whole-run temperature bounds).",
