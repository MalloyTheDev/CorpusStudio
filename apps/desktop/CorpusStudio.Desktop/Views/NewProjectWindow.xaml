<Window x:Class="CorpusStudio.Desktop.Views.NewProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Dataset Project"
        Width="560"
        Height="600"
        MinWidth="520"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="New Dataset Project" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Pick a template and create the local project files. The example row is pre-filled into the editor so you can see the exact format."
                       Margin="0,4,0,0"
                       Opacity="0.7"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Project name" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox x:Name="ProjectNameTextBox"
                     AutomationProperties.AutomationId="ProjectNameTextBox"
                     MinHeight="32"
                     TextChanged="ProjectNameTextBox_TextChanged" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Project ID" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox x:Name="ProjectIdTextBox"
                     AutomationProperties.AutomationId="ProjectIdTextBox"
                     MinHeight="32"
                     TextChanged="ProjectIdTextBox_TextChanged" />
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Template" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ComboBox Grid.Row="1"
                      x:Name="SchemaComboBox"
                      AutomationProperties.AutomationId="SchemaComboBox"
                      MinHeight="32"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      SelectionChanged="SchemaComboBox_SelectionChanged" />

            <TextBlock Grid.Row="2"
                       x:Name="SchemaDescriptionTextBlock"
                       AutomationProperties.AutomationId="SchemaDescriptionTextBlock"
                       Margin="0,8,0,0"
                       Opacity="0.8"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="3"
                       Text="Example row (pre-filled into the editor)"
                       FontWeight="SemiBold"
                       Margin="0,12,0,4" />
            <Border Grid.Row="4"
                    BorderBrush="#CAD5E3"
                    BorderThickness="1"
                    CornerRadius="5"
                    Background="#F8FAFC">
                <TextBox x:Name="SchemaExampleTextBox"
                         AutomationProperties.AutomationId="SchemaExampleTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         BorderThickness="0"
                         Background="Transparent"
                         FontFamily="Consolas"
                         FontSize="12"
                         Padding="8"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         MinHeight="120" />
            </Border>

            <TextBlock Grid.Row="5"
                       x:Name="ErrorTextBlock"
                       Margin="0,12,0,0"
                       Foreground="#A40000"
                       TextWrapping="Wrap" />
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="_Cancel"
                    Width="92"
                    Margin="0,0,8,0"
                    IsCancel="True" />
            <Button AutomationProperties.AutomationId="CreateProjectButton"
                    Content="_Create"
                    Width="92"
                    IsDefault="True"
                    Click="CreateButton_Click" />
        </StackPanel>
    </Grid>
</Window>
