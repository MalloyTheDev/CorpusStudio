<Window x:Class="CorpusStudio.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CorpusStudio.Desktop.ViewModels"
        Title="Corpus Studio"
        Height="720"
        Width="1180"
        MinHeight="600"
        MinWidth="960">
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="0,0,1,0" Padding="16">
            <StackPanel>
                <TextBlock Text="Corpus Studio" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="Dataset Creation Studio" Margin="0,4,0,24" Opacity="0.7" />

                <Button AutomationProperties.AutomationId="NewDatasetProjectButton"
                        Content="New Dataset Project"
                        Margin="0,0,0,8"
                        Click="NewDatasetProjectButton_Click" />
                <Button Content="Import Dataset" Margin="0,0,0,8" />
                <Button Content="Export Center" Margin="0,0,0,24" />

                <TextBlock Text="Projects" FontWeight="Bold" Margin="0,0,0,8" />
                <ListBox AutomationProperties.AutomationId="ProjectsListBox"
                         ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                         DisplayMemberPath="DisplayName"
                         SelectionChanged="ProjectsListBox_SelectionChanged" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="{Binding ActiveProjectTitle}" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ActiveSchemaDescription}" Opacity="0.7" />
                </StackPanel>

                <TabControl Grid.Row="1">
                    <TabItem Header="Writing Studio">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,0,8">
                                <Button AutomationProperties.AutomationId="SaveExampleButton"
                                        Content="Save Example"
                                        Width="112"
                                        Click="SaveExampleButton_Click" />
                            </StackPanel>

                            <TextBox Grid.Row="1"
                                     AutomationProperties.AutomationId="DraftTextBox"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding DraftText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas"
                                     FontSize="14" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Examples">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ListBox Grid.Column="0"
                                     AutomationProperties.AutomationId="ExamplesListBox"
                                     ItemsSource="{Binding Examples}"
                                     SelectedItem="{Binding SelectedExample, Mode=TwoWay}"
                                     DisplayMemberPath="DisplayName" />

                            <TextBox Grid.Column="1"
                                     AutomationProperties.AutomationId="SelectedExampleTextBox"
                                     Text="{Binding SelectedExampleJson, Mode=OneWay}"
                                     Margin="12,0,0,0"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Splits">
                        <TextBlock Text="Train / validation / test split manager placeholder" Margin="16" />
                    </TabItem>
                    <TabItem Header="Settings">
                        <TextBox Text="{Binding SettingsSummary, Mode=OneWay}"
                                 Margin="8"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1,0,0,0" Padding="16">
            <StackPanel>
                <TextBlock Text="Validation" FontSize="18" FontWeight="Bold" />
                <TextBox Text="{Binding ValidationSummary, Mode=OneWay}"
                         Margin="0,8,0,24"
                         MinHeight="150"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />

                <TextBlock Text="Quality" FontSize="18" FontWeight="Bold" />
                <TextBox AutomationProperties.AutomationId="QualitySummaryTextBox"
                         Text="{Binding QualitySummary, Mode=OneWay}"
                         Margin="0,8,0,8"
                         MinHeight="96"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
                <Button AutomationProperties.AutomationId="RunQualityButton"
                        Content="Run Quality"
                        Margin="0,0,0,24"
                        Click="RunQualityButton_Click" />

                <TextBlock Text="Export" FontSize="18" FontWeight="Bold" />
                <Button AutomationProperties.AutomationId="ValidateButton"
                        Content="Validate"
                        Margin="0,8,0,8"
                        Click="ValidateButton_Click" />
                <Button AutomationProperties.AutomationId="ExportJsonlButton"
                        Content="Export JSONL"
                        Click="ExportJsonlButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
