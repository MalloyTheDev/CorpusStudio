<Window x:Class="CorpusStudio.Desktop.Views.HfImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import from Hugging Face"
        Width="720" Height="640"
        MinWidth="620" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        Background="#F4F7FB">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="BorderBrush" Value="#CAD5E3" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Margin" Value="0,14,0,4" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="22,20,22,8">
            <StackPanel>
                <TextBlock Text="Import from Hugging Face" FontSize="21" FontWeight="Bold" Foreground="#0F172A" />
                <TextBlock Text="Read-only import of a PUBLIC dataset. Rows are mapped to this project's schema and staged, then run through the normal import preview so nothing is written without your review."
                           Foreground="#64748B" FontSize="12.5" TextWrapping="Wrap" Margin="0,4,0,0" />

                <TextBlock Text="Dataset id" Style="{StaticResource FieldLabel}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             AutomationProperties.AutomationId="HfDatasetIdTextBox"
                             Text="{Binding DatasetId, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" VerticalContentAlignment="Center" />
                    <Button Grid.Column="1" Content="_Inspect" Click="InspectButton_Click"
                            IsEnabled="{Binding CanInspect}" Padding="14,6" Margin="8,0,0,0" Cursor="Hand" />
                </Grid>

                <!-- License banner + mapping appear after Inspect. -->
                <Border Background="#FEF9C3" BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="6"
                        Padding="11,9" Margin="0,14,0,0"
                        Visibility="{Binding HasInspection, Converter={StaticResource BoolVis}}">
                    <StackPanel>
                        <TextBlock Text="⚠ License" FontWeight="Bold" Foreground="#92400E" FontSize="12" />
                        <TextBlock Text="{Binding LicenseNote}" Foreground="#78350F" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,3,0,0" />
                    </StackPanel>
                </Border>

                <StackPanel Visibility="{Binding HasInspection, Converter={StaticResource BoolVis}}">
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Config / split" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding ConfigsSplits}" SelectedItem="{Binding SelectedConfigSplit}"
                                      DisplayMemberPath="Display" Padding="6,4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Max rows" Style="{StaticResource FieldLabel}" />
                            <TextBox AutomationProperties.AutomationId="HfLimitTextBox"
                                     Text="{Binding RowLimit, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Map columns → schema fields" Style="{StaticResource FieldLabel}" />
                    <TextBlock Text="Each field takes one dataset column (blank = leave unmapped). Required fields must be mapped or those rows will be rejected in preview."
                               Foreground="#64748B" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,6" />
                    <ItemsControl ItemsSource="{Binding FieldMappings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6"
                                        Padding="10,7" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="230" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FieldName}" FontWeight="SemiBold"
                                                       FontFamily="Consolas" FontSize="13" Foreground="#0F172A" />
                                            <TextBlock Text="required" FontSize="10.5" Foreground="#B91C1C"
                                                       Visibility="{Binding Required, Converter={StaticResource BoolVis}}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding AvailableColumns}"
                                                  SelectedItem="{Binding SelectedColumn}"
                                                  Padding="6,4" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="22,12">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" FontSize="12"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="360"
                           HorizontalAlignment="Left" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Cancel" IsCancel="True" Padding="16,7" MinWidth="88" Cursor="Hand" />
                    <Button Content="_Import" Click="ImportButton_Click" IsEnabled="{Binding CanImport}"
                            Padding="16,7" MinWidth="88" Margin="8,0,0,0" Cursor="Hand"
                            Background="#2563EB" Foreground="White" FontWeight="SemiBold" BorderBrush="#2563EB" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
