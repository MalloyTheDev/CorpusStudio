{
  "$schema": "https://corpusstudio.dev/design/nocturne-tokens/1.0",
  "name": "Nocturne",
  "version": "1.0.0",
  "description": "Framework-agnostic design tokens for the Corpus Studio production UI. Single source of truth consumed by BOTH desktop shells: the Avalonia interim head (as ResourceDictionary brushes, #AARRGGBB) and the eventual Tauri/React shell (as CSS custom properties). Extracted from docs/design/handoff/. Theming is a token-set swap between dark (primary) and light.",
  "notes": "Color values are given in web form (#RRGGBB or rgba()); color-mix() values from the handoff are resolved here to concrete rgba for portability. (Framework-agnostic tokens; the WPF/Avalonia desktop that consumed them was removed - #545.)",
  "themes": {
    "dark": {
      "win": "#12141f",
      "chrome": "#0e1019",
      "panel": "#232532",
      "panel-2": "#1b1d29",
      "line": "rgba(233,233,237,0.12)",
      "line-2": "#2c2f3e",
      "text": "#e9e9ed",
      "t2": "#b2b6ca",
      "t3": "#9397ab",
      "t4": "#75798c",
      "accent": "#968ae0",
      "accent-strong": "#b5abfc",
      "accent-ink": "#e7e5fe",
      "accent-soft": "rgba(150,138,224,0.16)",
      "hover": "rgba(233,233,237,0.07)",
      "track": "#33384a",
      "ok": "#6bbf9a",
      "warn": "#d9a35f",
      "bad": "#d76d6d",
      "grade": "#d98f52",
      "on-accent": "#161826"
    },
    "light": {
      "win": "#eef0f5",
      "chrome": "#e6e8ef",
      "panel": "#ffffff",
      "panel-2": "#f4f6fa",
      "line": "rgba(26,28,40,0.10)",
      "line-2": "#e0e3ec",
      "text": "#1a1c28",
      "t2": "#3f434f",
      "t3": "#5b6070",
      "t4": "#868b9c",
      "accent": "#6c5fd0",
      "accent-strong": "#5d5294",
      "accent-ink": "#463c7d",
      "accent-soft": "rgba(108,95,208,0.12)",
      "hover": "rgba(26,28,40,0.05)",
      "track": "#dfe3ec",
      "ok": "#3f9b73",
      "warn": "#b8792e",
      "bad": "#c85552",
      "grade": "#c07636",
      "on-accent": "#161826"
    }
  },
  "usage": {
    "win": "window body ground",
    "chrome": "titlebar, activity bar, console",
    "panel": "cards / surfaces",
    "panel-2": "sidebar, insets, inputs",
    "line": "hairline dividers",
    "line-2": "solid borders, input borders",
    "text": "primary text",
    "t2": "secondary text",
    "t3": "tertiary/muted",
    "t4": "faint labels, disabled icons",
    "accent": "accent line/glow",
    "accent-strong": "accent hover / emphasis",
    "accent-ink": "text on accent-soft",
    "accent-soft": "accent tint fills, active nav",
    "hover": "hover tint",
    "track": "progress/bar tracks",
    "ok": "pass / clean / success",
    "warn": "warn / moderate",
    "bad": "block / error / critical",
    "grade": "dataset-debt grade badge",
    "on-accent": "near-black ink on a solid accent/ok/grade fill"
  },
  "accentScale": {
    "100": "#f5f4ff", "200": "#e7e5fe", "300": "#d2cefd", "400": "#b5abfc",
    "500": "#968ae0", "600": "#796cbf", "700": "#5d5294", "800": "#423a6a", "900": "#2b2741"
  },
  "typography": {
    "family": "Inter, system-ui, sans-serif",
    "mono": "ui-monospace, Menlo, Consolas, monospace",
    "weights": [400, 500, 600, 700],
    "tabularNumerals": true,
    "scale": {
      "bigMetric": {"size": 26, "weight": 600},
      "gradeBadge": {"size": 30, "weight": 700},
      "screenTitle": {"size": 15, "weight": 600},
      "cardTitle": {"size": 13, "weight": 600},
      "body": {"size": 12.5, "weight": 400},
      "navItem": {"size": 13, "weight": 500},
      "smallLabel": {"size": 11, "weight": 500},
      "micro": {"size": 10.5, "weight": 500},
      "groupHeader": {"size": 10, "weight": 600, "uppercase": true, "letterSpacing": "0.12em"}
    }
  },
  "radii": {"card": 12, "button": 8, "input": 8, "chip": 6, "pill": 13, "navRow": 7, "avatar": 8},
  "spacing": {"cardPadding": 14, "sectionPadding": [18, 20], "gap": 10},
  "elevation": {
    "sm": "0 0 0 1px #3f424d",
    "md": "0 0 0 1px #595d6c, 0 6px 18px rgba(0,0,0,0.55)",
    "lg": "0 0 0 1px #9397ab, 0 16px 40px rgba(0,0,0,0.65)"
  },
  "icons": {"set": "Phosphor", "react": "@phosphor-icons/react", "web": "@phosphor-icons/web@2.1.1"}
}
