          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "record_kind",
        "path",
        "sha256",
        "line_count"
      ],
      "title": "RawRecordBinding",
      "type": "object"
    },
