<Window x:Class="CorpusStudio.Desktop.Views.WorkspaceWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Dataset Project"
        Width="860" Height="640"
        MinWidth="720" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        Background="#F4F7FB">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="NoteVis" />
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="BorderBrush" Value="#CAD5E3" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Margin" Value="0,14,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="22,20,22,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="22" />
                <ColumnDefinition Width="328" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: form -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="New Dataset Project" FontSize="21" FontWeight="Bold" Foreground="#0F172A" />
                    <TextBlock Text="A dataset is a workspace. Pick a schema and a template — Corpus Studio scaffolds the folders and writes a .corpus manifest, then opens it."
                               Foreground="#64748B" FontSize="12.5" TextWrapping="Wrap" Margin="0,4,0,0" />

                    <TextBlock Text="Project name" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Project id" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding ProjectId, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" />

                    <TextBlock Text="Location" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" FontFamily="Consolas" Margin="0" VerticalContentAlignment="Center" />
                        <Button Grid.Column="1" Content="Browse…" Click="BrowseButton_Click" Padding="12,6" Margin="8,0,0,0" Cursor="Hand" />
                    </Grid>

                    <TextBlock Text="Dataset schema" Style="{StaticResource FieldLabel}" />
                    <ComboBox ItemsSource="{Binding Schemas}" SelectedItem="{Binding SelectedSchema}" DisplayMemberPath="Name" Margin="0,4,0,0" Padding="6,4" />

                    <TextBlock Text="Template" Style="{StaticResource FieldLabel}" />
                    <ListBox ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate}"
                             BorderThickness="0" Background="Transparent" Margin="0,4,0,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,0,0,7" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Card" Background="#FFFFFF" BorderBrush="#D8E0EA" BorderThickness="1" CornerRadius="8" Padding="12,10" Cursor="Hand">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Card" Property="BorderBrush" Value="#93B4F8" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Card" Property="BorderBrush" Value="#2563EB" />
                                                    <Setter TargetName="Card" Property="Background" Value="#EEF4FF" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="#0F172A" />
                                    <TextBlock Text="{Binding Description}" Foreground="#64748B" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT: live preview -->
            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#D8E0EA" BorderThickness="1" CornerRadius="8">
                <DockPanel Margin="14">
                    <TextBlock DockPanel.Dock="Top" Text="WILL CREATE" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8" />
                    <Border DockPanel.Dock="Bottom" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="6" Padding="9,7" Margin="0,10,0,0"
                            Visibility="{Binding HasPreviewNote, Converter={StaticResource NoteVis}}">
                        <TextBlock Text="{Binding PreviewNote}" Foreground="#1E40AF" FontSize="11.5" TextWrapping="Wrap" />
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PreviewLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Height="20">
                                        <Border Width="{Binding Indent}" />
                                        <Ellipse x:Name="Dot" Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,7,0" Fill="#94A3B8" />
                                        <TextBlock x:Name="Label" Text="{Binding Text}" FontFamily="Consolas" FontSize="12" Foreground="#334155" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                            <Setter TargetName="Dot" Property="Fill" Value="#2563EB" />
                                            <Setter TargetName="Label" Property="Foreground" Value="#1D4ED8" />
                                            <Setter TargetName="Label" Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- footer -->
        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="22,12">
            <Grid>
                <TextBlock Text="{Binding ValidationMessage}" Foreground="#64748B" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="ErrorText" Foreground="#B91C1C" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0" TextWrapping="Wrap" MaxWidth="280" />
                    <Button Content="Cancel" IsCancel="True" Padding="16,7" MinWidth="88" Cursor="Hand" />
                    <Button Content="Create" Click="CreateButton_Click" IsEnabled="{Binding CanCreate}" Padding="16,7" MinWidth="88" Margin="8,0,0,0" Cursor="Hand"
                            Background="#2563EB" Foreground="White" FontWeight="SemiBold" BorderBrush="#2563EB" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
