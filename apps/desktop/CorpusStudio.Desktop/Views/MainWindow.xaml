                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />

                                    <TextBlock Grid.Row="1"
                                               Text="Report History"
                                               FontWeight="SemiBold"
                                               Margin="0,8,0,4" />

