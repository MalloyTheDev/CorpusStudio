<Window x:Class="CorpusStudio.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CorpusStudio.Desktop.ViewModels"
        xmlns:local="clr-namespace:CorpusStudio.Desktop"
        Title="Corpus Studio"
        Height="800"
        Width="1180"
        MinHeight="680"
        MinWidth="960"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F7FB" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D8E0EA" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#101828" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#F8FAFC" />

        <Style TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#102033" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#B8C4D4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF4FF" />
                                <Setter Property="BorderBrush" Value="#93B4F8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DBEAFE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#94A3B8" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF2F7" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D8E0EA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="#CAD5E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="SelectionBrush" Value="#BBD3FF" />
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="#CAD5E3" />
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="#CAD5E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="#E8EEF6"
                                BorderBrush="#D2DCE9"
                                BorderThickness="1"
                                CornerRadius="6,6,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource PanelBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
                                <Setter Property="Foreground" Value="#0F172A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StagePillStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#EEF4FF" />
            <Setter Property="BorderBrush" Value="#C7D7FE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <SolidColorBrush x:Key="HeadingTextBrush" Color="#0F172A" />

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E40AF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#E2E8F0" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#93B4F8" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#93B4F8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeaderTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource HeadingTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="FilterGroupBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#FBFCFE" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />

        <Style x:Key="ListEmptyPlaceholderStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="16" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="#1F2937"
                BorderThickness="0,0,1,0"
                Padding="18">
            <StackPanel>
                <TextBlock Text="Corpus Studio"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#F8FAFC" />
                <TextBlock Text="Dataset Creation Studio"
                           Margin="0,4,0,24"
                           Foreground="#CBD5E1" />

                <Button Style="{StaticResource PrimaryButtonStyle}"
                        AutomationProperties.AutomationId="NewDatasetProjectButton"
                        Content="New Dataset Project"
                        Margin="0,0,0,8"
                        Click="NewDatasetProjectButton_Click" />
                <Button AutomationProperties.AutomationId="ImportDatasetButton"
                        Content="Import Dataset"
                        Margin="0,0,0,8"
                        Click="ImportDatasetButton_Click" />
                <Button AutomationProperties.AutomationId="ExportCenterButton"
                        Content="Export Center"
                        Margin="0,0,0,24"
                        Click="ExportCenterButton_Click" />

                <TextBlock Text="Projects"
                           FontWeight="Bold"
                           Foreground="#E2E8F0"
                           Margin="0,0,0,8" />
                <TextBox AutomationProperties.AutomationId="ProjectSearchTextBox"
                         Text="{Binding ProjectSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Filter projects by name, id, or schema"
                         Margin="0,0,0,6" />
                <ListBox AutomationProperties.AutomationId="ProjectsListBox"
                         ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                         DisplayMemberPath="DisplayName"
                         SelectionChanged="ProjectsListBox_SelectionChanged" />

                <Button AutomationProperties.AutomationId="RebuildProjectIndexButton"
                        Content="Rebuild Index"
                        Margin="0,10,0,6"
                        Click="RebuildProjectIndexButton_Click" />
                <TextBlock AutomationProperties.AutomationId="ProjectIndexSummaryTextBlock"
                           Text="{Binding ProjectIndexSummary, Mode=OneWay}"
                           Foreground="#94A3B8"
                           FontSize="11"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Padding="20"
                Background="{StaticResource AppBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding ActiveProjectTitle}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />
                            <TextBlock Text="{Binding ActiveSchemaDescription}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />
                            <WrapPanel Margin="0,10,0,0">
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Dataset" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Validate" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Split" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Evaluate" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Assist" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Export" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource StagePillStyle}">
                                    <TextBlock Text="Train Config" Foreground="#1D4ED8" FontWeight="SemiBold" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="#ECFDF5"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,8"
                                Margin="16,0,0,0"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Local-first"
                                           FontWeight="SemiBold"
                                           Foreground="#166534" />
                                <TextBlock Text="Files stay inspectable"
                                           Foreground="#166534" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#FEF2F2"
                        BorderBrush="#FCA5A5"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,0,0,12"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="&#x26A0;"
                                       FontSize="15"
                                       Foreground="#B91C1C"
                                       VerticalAlignment="Top"
                                       Margin="0,0,10,0" />
                            <TextBlock AutomationProperties.AutomationId="ErrorBannerTextBlock"
                                       Text="{Binding ErrorMessage, Mode=OneWay}"
                                       Foreground="#7F1D1D"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                AutomationProperties.AutomationId="DismissErrorButton"
                                Content="Dismiss"
                                Width="88"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                Click="DismissErrorButton_Click" />
                    </Grid>
                </Border>

                <TabControl Grid.Row="2">
                    <TabItem x:Name="DashboardTab" Header="Dashboard">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="8">
                            <StackPanel>
                                <TextBlock Text="Quick actions"
                                           Style="{StaticResource SectionHeaderTextStyle}" />
                                <WrapPanel Margin="0,0,0,16">
                                    <Button Style="{StaticResource PrimaryButtonStyle}"
                                            AutomationProperties.AutomationId="DashboardAuthorButton"
                                            Content="Author examples"
                                            Width="140" Margin="0,0,8,8"
                                            Click="GoToWritingStudioButton_Click" />
                                    <Button AutomationProperties.AutomationId="DashboardRunQualityButton"
                                            Content="Run quality"
                                            Width="120" Margin="0,0,8,8"
                                            Click="RunQualityButton_Click" />
                                    <Button AutomationProperties.AutomationId="DashboardSplitsButton"
                                            Content="Generate splits"
                                            Width="128" Margin="0,0,8,8"
                                            Click="GoToSplitsButton_Click" />
                                    <Button AutomationProperties.AutomationId="DashboardEvaluationButton"
                                            Content="Run evaluation"
                                            Width="128" Margin="0,0,8,8"
                                            Click="GoToEvaluationButton_Click" />
                                    <Button AutomationProperties.AutomationId="DashboardTrainingButton"
                                            Content="Training config"
                                            Width="128" Margin="0,0,8,8"
                                            Click="GoToTrainingButton_Click" />
                                    <Button AutomationProperties.AutomationId="DashboardNewProjectButton"
                                            Content="New project"
                                            Width="120" Margin="0,0,8,8"
                                            Click="NewDatasetProjectButton_Click" />
                                </WrapPanel>

                                <TextBlock Text="Project overview"
                                           Style="{StaticResource SectionHeaderTextStyle}" />
                                <WrapPanel>
                                    <Border Style="{StaticResource CardBorderStyle}"
                                            Width="332" Margin="0,0,12,12" VerticalAlignment="Top">
                                        <StackPanel>
                                            <TextBlock Text="Dataset"
                                                       Style="{StaticResource SectionHeaderTextStyle}" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Examples.Count, Mode=OneWay}"
                                                           FontSize="26" FontWeight="Bold"
                                                           Foreground="{StaticResource HeadingTextBrush}" />
                                                <TextBlock Text="saved examples"
                                                           Style="{StaticResource CaptionTextStyle}"
                                                           VerticalAlignment="Bottom"
                                                           Margin="8,0,0,4" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding ActiveSchemaDescription, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding QualityHistorySummary, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorderStyle}"
                                            Width="332" Margin="0,0,12,12" VerticalAlignment="Top">
                                        <StackPanel>
                                            <TextBlock Text="Quality"
                                                       Style="{StaticResource SectionHeaderTextStyle}" />
                                            <TextBlock Text="{Binding QualitySummary, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorderStyle}"
                                            Width="332" Margin="0,0,12,12" VerticalAlignment="Top">
                                        <StackPanel>
                                            <TextBlock Text="Splits"
                                                       Style="{StaticResource SectionHeaderTextStyle}" />
                                            <TextBlock Text="{Binding SplitSummary, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorderStyle}"
                                            Width="332" Margin="0,0,12,12" VerticalAlignment="Top">
                                        <StackPanel>
                                            <TextBlock Text="Evaluation"
                                                       Style="{StaticResource SectionHeaderTextStyle}" />
                                            <TextBlock Text="{Binding EvaluationSummary, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem x:Name="WritingStudioTab" Header="Writing Studio">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,0,8">
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        AutomationProperties.AutomationId="SaveExampleButton"
                                        Content="Save Example"
                                        Width="112"
                                        Click="SaveExampleButton_Click" />
                            </StackPanel>

                            <TextBox x:Name="DraftTextBox"
                                     Grid.Row="1"
                                     AutomationProperties.AutomationId="DraftTextBox"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding DraftText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas"
                                     FontSize="14" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Examples">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <ListBox x:Name="ExamplesListBox"
                                         AutomationProperties.AutomationId="ExamplesListBox"
                                         ItemsSource="{Binding Examples}"
                                         SelectedItem="{Binding SelectedExample, Mode=TwoWay}"
                                         DisplayMemberPath="DisplayName" />
                                <TextBlock Style="{StaticResource ListEmptyPlaceholderStyle}"
                                           Text="No examples yet. Author one in Writing Studio, or import a JSONL file."
                                           Visibility="{Binding HasItems, ElementName=ExamplesListBox, Converter={StaticResource InverseBoolToVis}}" />
                            </Grid>

                            <TextBox Grid.Column="1"
                                     AutomationProperties.AutomationId="SelectedExampleTextBox"
                                     Text="{Binding SelectedExampleJson, Mode=OneWay}"
                                     Margin="12,0,0,0"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Preference Review">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="2*" />
                                <RowDefinition Height="3*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="3"
                                       AutomationProperties.AutomationId="PreferenceReviewSummaryTextBlock"
                                       Text="{Binding PreferenceReviewSummary, Mode=OneWay}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />

                            <WrapPanel Grid.Row="1"
                                       Grid.ColumnSpan="3"
                                       Margin="0,0,0,8">
                                <TextBlock Text="Contrast"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <ComboBox AutomationProperties.AutomationId="PreferenceContrastFilterComboBox"
                                          ItemsSource="{Binding PreferenceContrastFilterOptions}"
                                          SelectedItem="{Binding PreferenceContrastFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Width="112"
                                          Margin="0,0,10,0" />
                                <TextBlock AutomationProperties.AutomationId="PreferenceRankingSummaryTextBlock"
                                           Text="{Binding PreferenceRankingSummary, Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                            </WrapPanel>

                            <ListBox Grid.Row="2"
                                     Grid.RowSpan="2"
                                     Grid.Column="0"
                                     AutomationProperties.AutomationId="PreferenceExamplesListBox"
                                     ItemsSource="{Binding PreferenceReviewItems}"
                                     SelectedItem="{Binding SelectedPreferenceReviewItem, Mode=TwoWay}"
                                     DisplayMemberPath="DisplayName"
                                     Margin="0,0,12,0" />

                            <DockPanel Grid.Row="2"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Top"
                                           Text="Prompt"
                                           Style="{StaticResource SectionHeaderTextStyle}"
                                           Margin="0,0,0,3" />
                                <TextBox AutomationProperties.AutomationId="PreferencePromptTextBox"
                                         Text="{Binding PreferencePromptText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </DockPanel>

                            <DockPanel Grid.Row="3"
                                       Grid.Column="1"
                                       Margin="0,0,8,0">
                                <TextBlock DockPanel.Dock="Top"
                                           Text="Chosen response"
                                           Style="{StaticResource SectionHeaderTextStyle}"
                                           Margin="0,0,0,3" />
                                <TextBox AutomationProperties.AutomationId="PreferenceChosenTextBox"
                                         Text="{Binding PreferenceChosenText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </DockPanel>

                            <DockPanel Grid.Row="3"
                                       Grid.Column="2">
                                <TextBlock DockPanel.Dock="Top"
                                           Text="Rejected response"
                                           Style="{StaticResource SectionHeaderTextStyle}"
                                           Margin="0,0,0,3" />
                                <TextBox AutomationProperties.AutomationId="PreferenceRejectedTextBox"
                                         Text="{Binding PreferenceRejectedText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </DockPanel>

                            <DockPanel Grid.Row="4"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       Margin="0,8,8,0">
                                <TextBlock DockPanel.Dock="Top"
                                           Text="Reason"
                                           Style="{StaticResource SectionHeaderTextStyle}"
                                           Margin="0,0,0,3" />
                                <TextBox AutomationProperties.AutomationId="PreferenceReasonTextBox"
                                         Text="{Binding PreferenceReasonText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
