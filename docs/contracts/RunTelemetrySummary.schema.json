        },
        "device_uuid": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Device Uuid"
        },
        "graphics_clock_mhz": {
          "anyOf": [
            {
              "$ref": "#/$defs/MetricSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "max_run_temperature_c": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Run Temperature C"
        },
        "memory": {
          "anyOf": [
            {
              "$ref": "#/$defs/MemoryWindowSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "memory_clock_mhz": {
          "anyOf": [
            {
              "$ref": "#/$defs/MetricSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "memory_controller_utilization_percent": {
          "anyOf": [
            {
              "$ref": "#/$defs/MetricSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "observed_performance_states": {
          "items": {
            "type": "string"
          },
          "title": "Observed Performance States",
          "type": "array"
        },
        "observed_throttle_reasons": {
          "items": {
            "type": "string"
          },
          "title": "Observed Throttle Reasons",
          "type": "array"
        },
        "power_watts": {
          "anyOf": [
            {
              "$ref": "#/$defs/MetricSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "starting_temperature_c": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Starting Temperature C"
        },
        "temperature_c": {
          "anyOf": [
            {
              "$ref": "#/$defs/MetricSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "utilization_percent": {
          "anyOf": [
            {
              "$ref": "#/$defs/MetricSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "GpuTelemetrySummary",
      "type": "object"
    },
    "HostTelemetrySummary": {
