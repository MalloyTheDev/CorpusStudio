<Application x:Class="CorpusStudio.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- No StartupUri: the main window is created from the DI container in App.OnStartup. -->
    <!-- Theme: the Light dictionary is merged at index 0 by default (its values are identical to the
         previous hardcoded colors, so light mode is unchanged). ThemeManager swaps in Dark at runtime;
         controls read {DynamicResource ...} so the swap is live. -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Light.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
