    },
    "loss_impl": {
      "$ref": "#/$defs/LossImpl"
    },
    "offload_strategy": {
      "$ref": "#/$defs/OffloadStrategy",
      "default": "none"
    },
    "optimizer": {
      "$ref": "#/$defs/OptimizerSpec"
    },
    "parameter_accounting_ref": {
