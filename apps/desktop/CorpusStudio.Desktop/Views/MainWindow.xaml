                                                            Content="Apply Filter"
                                                            Width="96"
                                                            Margin="0,0,8,4"
                                                            Click="ApplyEvaluationFailureFilterButton_Click" />
                                                </WrapPanel>
                                                <TextBlock AutomationProperties.AutomationId="EvaluationFailureFilterSummaryTextBlock"
                                                           Text="{Binding EvaluationFailureFilterSummary, Mode=OneWay}"
                                                           Style="{StaticResource CaptionTextStyle}"
                                                           Margin="0,2,0,0" />
