                                        Content="Export Ranking"
                                        Height="32"
                                        Click="ExportPreferenceRankingButton_Click" />
                                <ComboBox AutomationProperties.AutomationId="PreferenceExportFormatComboBox"
                                          ItemsSource="{Binding PreferenceReview.PreferenceExportFormatOptions}"
                                          SelectedItem="{Binding PreferenceReview.PreferenceExportFormat, Mode=TwoWay}"
                                          Height="30"
                                          Margin="0,6,0,6" />
                                <Button AutomationProperties.AutomationId="ExportPreferenceForTrainingButton"
                                        Content="Export for Training"
                                        Height="32"
                                        Click="ExportPreferenceForTrainingButton_Click" />
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Quarantine">
                        <Grid Margin="16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Row="0" Grid.Column="0">
                                <ListBox x:Name="ImportQuarantineListBox"
                                         AutomationProperties.AutomationId="ImportQuarantineListBox"
