                                           FontWeight="Bold"
                                           Foreground="#0F172A" />
                                <TextBlock Text="Compare how models answer the same prompts. Responses are comparison artifacts, not dataset rows."
                                           Foreground="#475569"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,8" />
                                <TextBlock Text="Prompts (one per line)"
                                           FontWeight="SemiBold"
                                           Foreground="#334155" />
                                <TextBox AutomationProperties.AutomationId="ArenaPromptsTextBox"
                                         Text="{Binding Arena.ArenaPromptsInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         MinHeight="120"
                                         Margin="0,4,0,8"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                                <TextBlock Text="Models (comma or newline separated)"
                                           FontWeight="SemiBold"
                                           Foreground="#334155" />
                                <TextBox AutomationProperties.AutomationId="ArenaModelsTextBox"
                                         Text="{Binding Arena.ArenaModelsInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         MinHeight="48"
                                         Margin="0,4,0,8"
                                         TextWrapping="Wrap" />
                                <TextBlock Text="Judge model (optional, evaluator)"
                                           FontWeight="SemiBold"
                                           Foreground="#334155" />
                                <TextBox AutomationProperties.AutomationId="ArenaJudgeModelTextBox"
                                         Text="{Binding Arena.ArenaJudgeModelInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,8"
                                         VerticalContentAlignment="Center" />
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        AutomationProperties.AutomationId="RunArenaButton"
                                        Content="Run _Arena"
                                        Click="RunArenaButton_Click" />
                            </StackPanel>

                            <TextBox Grid.Column="1"
                                     AutomationProperties.AutomationId="ArenaSummaryTextBox"
                                     Text="{Binding Arena.ArenaSummary, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Artifacts">
                        <Grid Margin="16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Model Artifacts"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#0F172A" />
                                <TextBlock Text="Track adapters/checkpoints a run produced, and keep or reject them. Paths are referenced, never moved — a record flags 'modified' or 'missing' if the weights change on disk."
                                           Foreground="#475569"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,8" />
                                <TextBlock AutomationProperties.AutomationId="ArtifactSummaryTextBlock"
                                           Text="{Binding Artifacts.ArtifactSummary, Mode=OneWay}"
                                           Foreground="#334155"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                            </StackPanel>
                            <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                                <Button AutomationProperties.AutomationId="RegisterArtifactFromRunButton"
                                        Content="Register latest run's output"
                                        ToolTip="Register the newest training run's output directory as an artifact"
                                        Margin="0,0,8,0"
                                        Click="RegisterArtifactFromRunButton_Click" />
                                <Button AutomationProperties.AutomationId="KeepArtifactButton"
                                        Content="Keep"
                                        Margin="0,0,8,0"
                                        Click="KeepArtifactButton_Click" />
                                <Button AutomationProperties.AutomationId="RejectArtifactButton"
                                        Content="Reject"
                                        Margin="0,0,8,0"
                                        Click="RejectArtifactButton_Click" />
                                <Button AutomationProperties.AutomationId="ViewArtifactCardButton"
                                        Content="View card"
                                        Margin="0,0,8,0"
                                        Click="ViewArtifactCardButton_Click" />
                                <Button AutomationProperties.AutomationId="RefreshArtifactsButton"
                                        Content="Refresh"
                                        Click="RefreshArtifactsButton_Click" />
                            </WrapPanel>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ListBox Grid.Column="0"
                                         AutomationProperties.AutomationId="ModelArtifactsListBox"
                                         ItemsSource="{Binding Artifacts.ModelArtifacts}"
                                         SelectedItem="{Binding Artifacts.SelectedModelArtifact, Mode=TwoWay}"
                                         DisplayMemberPath="DisplayName"
                                         FontFamily="Consolas"
                                         FontSize="12" />
                                <TextBox Grid.Column="1"
                                         AutomationProperties.AutomationId="ArtifactDetailTextBox"
                                         Text="{Binding Artifacts.ArtifactDetail, Mode=OneWay}"
                                         Margin="12,0,0,0"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="SuitesTab" Header="Suites">
                        <Grid Margin="16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Evaluation Suites" FontSize="18" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock Text="Run a reusable set of evaluation cases as one unit. Create a suite, edit its cases in Files, then Run — each case is a live backend evaluation. Verdicts case structure + score thresholds, not model quality."
                                           Foreground="#475569" TextWrapping="Wrap" Margin="0,4,0,8" />
                                <TextBlock AutomationProperties.AutomationId="SuitesStatusTextBlock"
                                           Text="{Binding Suites.SuitesStatus, Mode=OneWay}" Foreground="#334155"
                                           TextWrapping="Wrap" Margin="0,0,0,8" />
                            </StackPanel>
                            <WrapPanel Grid.Row="1" Margin="0,0,0,8" VerticalAlignment="Center">
                                <TextBox x:Name="NewSuiteNameBox" Width="180" Height="30" VerticalContentAlignment="Center"
                                         AutomationProperties.AutomationId="NewSuiteNameTextBox" Padding="6,0" Margin="0,0,8,0" />
                                <Button AutomationProperties.AutomationId="NewSuiteButton" Content="New"
                                        ToolTip="Scaffold evaluation_suites/&lt;name&gt;.json — then edit it in Files"
                                        Margin="0,0,8,0" Click="NewSuiteButton_Click" />
                                <Button AutomationProperties.AutomationId="RunSuiteButton" Content="Run"
                                        ToolTip="Run the selected suite (live backend evaluations)"
                                        IsEnabled="{Binding Suites.CanRunSuite}" Margin="0,0,8,0" Click="RunSuiteButton_Click" />
                                <Button AutomationProperties.AutomationId="RefreshSuitesButton" Content="Refresh"
                                        Click="RefreshSuitesButton_Click" />
                            </WrapPanel>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.9*" />
                                    <ColumnDefinition Width="1.1*" />
                                </Grid.ColumnDefinitions>
                                <ListBox Grid.Column="0"
                                         AutomationProperties.AutomationId="SuitesListBox"
                                         ItemsSource="{Binding Suites.Suites}"
                                         SelectedItem="{Binding Suites.SelectedSuite, Mode=TwoWay}"
                                         DisplayMemberPath="DisplayLabel"
                                         FontFamily="Consolas" FontSize="12" />
                                <!-- report panel -->
                                <Grid Grid.Column="1" Margin="12,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <!-- overall verdict badge -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                                Visibility="{Binding Suites.HasSuiteReport, Converter={StaticResource BoolToVis}}">
                                        <Border Background="{Binding Suites.SuiteOverallColor}" CornerRadius="4" Padding="10,3">
                                            <TextBlock Text="{Binding Suites.SuiteOverallStatus}" Foreground="White" FontWeight="Bold" FontSize="12" />
                                        </Border>
                                        <TextBlock Text="{Binding Suites.SuiteReportSummary}" Foreground="#334155"
                                                   VerticalAlignment="Center" Margin="10,0,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <!-- empty / not-run-yet state -->
                                    <TextBlock Grid.Row="0" Text="{Binding Suites.SuiteReportSummary}" Foreground="#64748B"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding Suites.HasSuiteReport, Converter={StaticResource InverseBoolToVis}}" />
                                    <!-- per-metric roll-up -->
                                    <TextBlock Grid.Row="1" Text="Per metric" FontWeight="SemiBold" Foreground="#64748B"
                                               FontSize="11" Margin="0,10,0,3"
                                               Visibility="{Binding Suites.HasSuiteReport, Converter={StaticResource BoolToVis}}" />
                                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Suites.SuiteMetricRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayLabel}" FontFamily="Consolas"
                                                           FontSize="12" Foreground="#334155" Margin="0,1" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- per-case rows -->
                                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                                        <ItemsControl ItemsSource="{Binding Suites.SuiteCaseRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Background="{Binding StatusColor}" CornerRadius="3" Padding="5,1" Margin="0,0,8,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" />
                                                            </Border>
                                                            <TextBlock Text="{Binding CaseLine}" FontFamily="Consolas" FontSize="12"
                                                                       Foreground="#1E293B" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <TextBlock Grid.Row="4" Text="{Binding Suites.SuiteHonestyNote}" Foreground="#94A3B8"
                                               FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Margin="0,8,0,0" />
                                </Grid>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Versions">
                        <Grid Margin="16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Dataset Version History"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#0F172A" />
                                <TextBlock Text="A version records the dataset's fingerprint + row count and links to the runs, artifacts, and evaluations from that state. Capture is opt-in and goes through the engine, so integrity is verified — not guessed."
                                           Foreground="#475569"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,8" />
                                <TextBlock AutomationProperties.AutomationId="DatasetVersionSummaryTextBlock"
                                           Text="{Binding Versions.DatasetVersionSummary, Mode=OneWay}"
                                           Foreground="#334155"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <TextBlock AutomationProperties.AutomationId="DatasetDiffBaseTextBlock"
                                           Text="{Binding Versions.DatasetDiffBaseLabel, Mode=OneWay}"
                                           Foreground="#64748B"
                                           FontStyle="Italic"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Label (optional):"
                                               VerticalAlignment="Center"
                                               Foreground="#334155"
                                               Margin="0,0,8,0" />
                                    <TextBox AutomationProperties.AutomationId="DatasetVersionLabelTextBox"
                                             Text="{Binding Versions.DatasetVersionLabel, UpdateSourceTrigger=PropertyChanged}"
                                             Width="280" />
                                </StackPanel>
                            </StackPanel>
                            <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                                <Button AutomationProperties.AutomationId="CaptureDatasetVersionButton"
                                        Content="Capture version"
                                        ToolTip="Record the current dataset (examples.jsonl) as a version, via the engine"
                                        Margin="0,0,8,0"
                                        Click="CaptureDatasetVersionButton_Click" />
                                <Button AutomationProperties.AutomationId="ViewDatasetVersionCardButton"
                                        Content="View card"
                                        Margin="0,0,8,0"
                                        Click="ViewDatasetVersionCardButton_Click" />
                                <Button AutomationProperties.AutomationId="RestoreDatasetVersionButton"
                                        Content="Restore this version"
                                        ToolTip="Overwrite the current dataset with this version (your current dataset is captured first so you can undo)"
                                        Margin="0,0,8,0"
                                        Click="RestoreDatasetVersionButton_Click" />
                                <Button AutomationProperties.AutomationId="SetDiffBaseButton"
                                        Content="Set diff base"
                                        ToolTip="Pin the selected version as the base for a diff"
                                        Margin="0,0,8,0"
                                        Click="SetDiffBaseButton_Click" />
                                <Button AutomationProperties.AutomationId="DiffVersionsButton"
                                        Content="Diff base → selected"
                                        ToolTip="Compare the pinned base version to the selected version (added/removed/common rows)"
                                        Margin="0,0,8,0"
                                        Click="DiffVersionsButton_Click" />
                                <Button AutomationProperties.AutomationId="RefreshDatasetVersionsButton"
                                        Content="Refresh"
                                        Click="RefreshDatasetVersionsButton_Click" />
                            </WrapPanel>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ListBox Grid.Column="0"
                                         AutomationProperties.AutomationId="DatasetVersionsListBox"
                                         ItemsSource="{Binding Versions.DatasetVersions}"
                                         SelectedItem="{Binding Versions.SelectedDatasetVersion, Mode=TwoWay}"
                                         DisplayMemberPath="DisplayName"
                                         FontFamily="Consolas"
                                         FontSize="12" />
                                <TextBox Grid.Column="1"
                                         AutomationProperties.AutomationId="DatasetVersionDetailTextBox"
                                         Text="{Binding Versions.DatasetVersionDetail, Mode=OneWay}"
                                         Margin="12,0,0,0"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="DebtTab" Header="Debt">
                        <Grid Margin="16,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Dataset Debt"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#0F172A" />
                                <TextBlock Text="Debt normalizes the quality signals by dataset size, ranks them, and grades the dataset so you know what to fix first. Secrets/PII are graded by presence, not rate. Re-run after changing the dataset."
                                           Foreground="#475569"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,8" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                                <TextBlock Text="Grade"
                                           Foreground="#64748B"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,10,6" />
                                <TextBlock AutomationProperties.AutomationId="DebtGradeTextBlock"
                                           Text="{Binding Debt.DebtGrade, Mode=OneWay}"
                                           Foreground="{Binding Debt.DebtGradeColor, Mode=OneWay}"
                                           FontSize="40"
                                           FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Grid.Row="2">
                                <TextBlock AutomationProperties.AutomationId="DebtSummaryTextBlock"
                                           Text="{Binding Debt.DebtSummary, Mode=OneWay}"
                                           Foreground="#334155"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <Button AutomationProperties.AutomationId="RunDatasetDebtButton"
                                        Content="Run debt check"
                                        ToolTip="Assess the current dataset's debt (via the engine) and grade it"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,8"
                                        Click="RunDatasetDebtButton_Click" />
                            </StackPanel>
                            <ListBox Grid.Row="3"
                                     AutomationProperties.AutomationId="DebtItemsListBox"
                                     ItemsSource="{Binding Debt.DebtItems}"
                                     DisplayMemberPath="DisplayName"
                                     FontFamily="Consolas"
                                     FontSize="12" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Settings">
                        <StackPanel Margin="16,14">
                            <TextBox Text="{Binding Settings.SettingsSummary, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     MinHeight="120"
                                     Margin="0,0,0,8"
                                     VerticalScrollBarVisibility="Auto" />
                            <TextBlock Text="{Binding LabSettingsSummary, Mode=OneWay}"
                                       AutomationProperties.AutomationId="LabSettingsSummaryTextBlock"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <Button AutomationProperties.AutomationId="SaveLabSettingsButton"
                                    Content="Save Lab Settings"
                                    Width="140"
                                    HorizontalAlignment="Left"
                                    Click="SaveLabSettingsButton_Click" />

                            <TextBlock Text="Provider Generation Policy"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#0F172A"
                                       Margin="0,20,0,4" />
                            <TextBlock Text="OpenAI/Anthropic are evaluator-only. Approve a local model (Ollama or a local OpenAI-compatible server) to let AI Assist use it for trainable generation — always review-required."
                                       Foreground="#475569"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <TextBox AutomationProperties.AutomationId="ProviderPolicySummaryTextBox"
                                     Text="{Binding Settings.ProviderPolicySummary, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     MinHeight="120"
                                     Margin="0,0,0,8"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ComboBox x:Name="ProviderApprovalProviderComboBox"
                                          AutomationProperties.AutomationId="ProviderApprovalProviderComboBox"
                                          Width="180"
                                          SelectedIndex="0"
                                          Margin="0,0,8,0">
                                    <ComboBoxItem Content="ollama" />
                                    <ComboBoxItem Content="openai_compatible" />
                                </ComboBox>
                                <TextBox x:Name="ProviderApprovalModelTextBox"
                                         AutomationProperties.AutomationId="ProviderApprovalModelTextBox"
                                         Width="200"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Model name to approve, e.g. llama3"
                                         Margin="0,0,8,0" />
                                <Button AutomationProperties.AutomationId="ApproveProviderGenerationButton"
                                        Content="Approve"
                                        Margin="0,0,8,0"
                                        Click="ApproveProviderGenerationButton_Click" />
                                <Button AutomationProperties.AutomationId="RevokeProviderGenerationButton"
                                        Content="Revoke"
                                        Margin="0,0,8,0"
                                        Click="RevokeProviderGenerationButton_Click" />
                                <Button AutomationProperties.AutomationId="RefreshProviderPoliciesButton"
                                        Content="Refresh"
                                        Click="RefreshProviderPoliciesButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1,0,0,0"
                Padding="22,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <!-- Right panel: extra vertical rhythm so the stacked sections (Validation /
                 Quality / Gates / Synthetic / History / Debt trend / Export) don't read as a
                 single dense wall. Section headers get top margin via StackPanel spacing below. -->
            <StackPanel>
                <TextBlock Text="Validation"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#0F172A" />
                <TextBox AutomationProperties.AutomationId="ValidationSummaryTextBox"
                         Text="{Binding ValidationSummary, Mode=OneWay}"
                         Margin="0,8,0,8"
                         MinHeight="120"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
                <TextBlock Text="Issues"
                           FontWeight="SemiBold"
                           Foreground="#334155" />
                <Grid Margin="0,8,0,24">
                    <ListBox x:Name="ValidationIssuesListBox"
                             AutomationProperties.AutomationId="ValidationIssuesListBox"
                             ItemsSource="{Binding ValidationIssues}"
                             SelectedItem="{Binding SelectedValidationIssue, Mode=TwoWay}"
                             DisplayMemberPath="DisplayName"
                             SelectionChanged="ValidationIssuesListBox_SelectionChanged"
                             Height="96" />
                    <TextBlock Style="{StaticResource ListEmptyPlaceholderStyle}"
                               Text="No validation issues. Validate a draft to see any errors here."
                               Visibility="{Binding HasItems, ElementName=ValidationIssuesListBox, Converter={StaticResource InverseBoolToVis}}" />
                </Grid>

                <TextBlock Text="Quality"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           Margin="0,22,0,0" />
                <!-- Structured quality metrics (v1.2.12). Before a run (or on error) the panel
                     falls back to the QualitySummary text; after a run it shows a PII-aware status
                     banner, the count rows, and the optional flagged-row detail. -->
                <TextBox AutomationProperties.AutomationId="QualitySummaryTextBox"
                         Text="{Binding QualitySummary, Mode=OneWay}"
                         Margin="0,8,0,8"
                         MinHeight="72"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Visibility="{Binding HasQualityMetrics, Converter={StaticResource InverseBoolToVis}}" />
                <StackPanel Margin="0,10,0,8"
                            Visibility="{Binding HasQualityMetrics, Converter={StaticResource BoolToVis}}">
                    <Border Background="{Binding QualityStatusBackground}" CornerRadius="7"
                            Padding="11,8" Margin="0,0,0,10">
                        <TextBlock AutomationProperties.AutomationId="QualityStatusTextBlock"
                                   Text="{Binding QualityStatusLine}" Foreground="{Binding QualityStatusColor}"
                                   FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap" />
                    </Border>
                    <ItemsControl AutomationProperties.AutomationId="QualityMetricsList"
                                  ItemsSource="{Binding QualityMetrics}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="18" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12.5"
                                               Foreground="#334155" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12.5"
                                               FontWeight="SemiBold" Foreground="{Binding StatusColor}"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatusIcon}" FontSize="12"
                                               Foreground="{Binding StatusColor}" VerticalAlignment="Center"
                                               TextAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBox Text="{Binding QualityDetail, Mode=OneWay}"
                             Margin="0,10,0,0" MaxHeight="150" IsReadOnly="True" TextWrapping="Wrap"
                             FontSize="11.5" VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding HasQualityDetail, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        AutomationProperties.AutomationId="RunQualityButton"
                        Content="Run _Quality"
                        Margin="0,4,0,8"
                        Click="RunQualityButton_Click" />
                <TextBlock Text="Gates"
                           FontWeight="SemiBold"
                           Foreground="#334155"
                           Margin="0,18,0,0" />
                <TextBox AutomationProperties.AutomationId="GateSummaryTextBox"
                         Text="{Binding GateSummary, Mode=OneWay}"
                         Margin="0,8,0,8"
                         MinHeight="96"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
                <Button AutomationProperties.AutomationId="RunGatesButton"
                        Content="Run _Gates"
                        ToolTip="Check whether this dataset passes the schema, quality, and PII gates"
                        Margin="0,0,0,8"
                        Click="RunGatesButton_Click" />
                <Button AutomationProperties.AutomationId="RunChatGatesButton"
                        Content="Run chat gates"
                        ToolTip="Check conversation structure (role alternation, dangling turns, system placement…) — chat datasets only"
                        Margin="0,0,0,8"
                        Visibility="{Binding IsChatProject, Converter={StaticResource BoolToVis}}"
                        Click="RunChatGatesButton_Click" />
                <TextBlock Text="Synthetic Triage"
                           FontWeight="SemiBold"
                           Foreground="#334155"
                           Margin="0,18,0,0" />
                <Grid Margin="0,8,0,8">
                    <ListBox x:Name="SyntheticPatternIssuesListBox"
                             AutomationProperties.AutomationId="SyntheticPatternIssuesListBox"
                             ItemsSource="{Binding SyntheticPatternIssues}"
                             SelectedItem="{Binding SelectedSyntheticPatternIssue, Mode=TwoWay}"
                             DisplayMemberPath="DisplayName"
                             Height="92" />
                    <TextBlock Style="{StaticResource ListEmptyPlaceholderStyle}"
                               Text="No synthetic-pattern issues found."
                               Visibility="{Binding HasItems, ElementName=SyntheticPatternIssuesListBox, Converter={StaticResource InverseBoolToVis}}" />
                </Grid>
                <TextBlock AutomationProperties.AutomationId="QualityTriageSummaryTextBlock"
                           Text="{Binding QualityTriageSummary, Mode=OneWay}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />
                <Button AutomationProperties.AutomationId="PrepareSyntheticRewriteButton"
                        Content="Prepare Rewrite"
                        Margin="0,0,0,8"
                        Click="PrepareSyntheticRewriteButton_Click" />
                <Button AutomationProperties.AutomationId="PrepareSyntheticBatchRewriteButton"
                        Content="Prepare Batch Rewrite"
                        Margin="0,0,0,8"
                        Click="PrepareSyntheticBatchRewriteButton_Click" />
                <TextBlock Text="History"
                           FontWeight="SemiBold"
                           Foreground="#334155"
                           Margin="0,18,0,0" />
                <TextBox AutomationProperties.AutomationId="QualityHistoryTextBox"
                         Text="{Binding QualityHistorySummary, Mode=OneWay}"
                         Margin="0,8,0,12"
                         MinHeight="72"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />

                <!-- Debt trend mini-chart (v1.2.9): quality issue rate per run over time. -->
                <StackPanel Orientation="Horizontal" Margin="0,18,0,4">
                    <TextBlock Text="Debt trend" FontWeight="SemiBold" Foreground="#334155"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DebtTrendDirection}" FontWeight="SemiBold" FontSize="12"
                               Foreground="{Binding DebtTrendDirectionColor}" Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasDebtTrend, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                              HorizontalAlignment="Left" MaxWidth="520"
                              Visibility="{Binding HasDebtTrendPoints, Converter={StaticResource BoolToVis}}">
                    <Border Height="64" Background="#F8FAFC" BorderBrush="#EEF2F7" BorderThickness="1"
                            CornerRadius="6" Padding="8,4">
                        <ItemsControl AutomationProperties.AutomationId="DebtTrendChart"
                                      ItemsSource="{Binding DebtTrend}" VerticalAlignment="Bottom">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="14" Height="{Binding BarHeight}" Margin="0,0,4,0"
                                            VerticalAlignment="Bottom" Background="{Binding BarColor}"
                                            CornerRadius="2,2,0,0" ToolTip="{Binding Tooltip}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </ScrollViewer>
                <TextBlock Text="{Binding DebtTrendSummary}"
                           Style="{StaticResource CaptionTextStyle}"
                           TextWrapping="Wrap" Margin="0,6,0,24" />

                <TextBlock Text="Export"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           Margin="0,24,0,0" />
                <Button AutomationProperties.AutomationId="ValidateButton"
                        Content="_Validate"
                        Margin="0,8,0,8"
                        Click="ValidateButton_Click" />
                <TextBlock Text="Cleaning (applied only to the exported file):"
                           Foreground="#475569"
                           Margin="0,4,0,4"
                           TextWrapping="Wrap" />
                <CheckBox x:Name="ExportRemoveDuplicatesCheckBox"
                          AutomationProperties.AutomationId="ExportRemoveDuplicatesCheckBox"
                          Content="Remove duplicate rows (exact + normalized)"
                          Margin="0,0,0,4" />
                <CheckBox x:Name="ExportRemoveLowInformationCheckBox"
                          AutomationProperties.AutomationId="ExportRemoveLowInformationCheckBox"
                          Content="Remove low-information rows"
                          Margin="0,0,0,8" />
                <Button x:Name="ExportJsonlButton"
                        Style="{StaticResource PrimaryButtonStyle}"
                        AutomationProperties.AutomationId="ExportJsonlButton"
                        Content="_Export JSONL"
                        Click="ExportJsonlButton_Click" />
                <Button AutomationProperties.AutomationId="GenerateDatasetCardButton"
                        Content="Generate Dataset Card"
                        Margin="0,8,0,8"
                        Click="GenerateDatasetCardButton_Click" />
                <TextBox AutomationProperties.AutomationId="DatasetCardSummaryTextBox"
                         Text="{Binding DatasetCardSummary, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         MinHeight="48"
                         Margin="0,0,0,8"
                         VerticalScrollBarVisibility="Auto" />
                <TextBox AutomationProperties.AutomationId="DatasetCardPreviewTextBox"
                         Text="{Binding DatasetCardPreview, Mode=OneWay}"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         TextWrapping="NoWrap"
                         MinHeight="120"
                         Margin="0,0,0,8"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>
            </ScrollViewer>
        </Border>
        <Border Grid.ColumnSpan="3"
                Panel.ZIndex="100"
                Background="#73101828"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="28,22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock AutomationProperties.AutomationId="BusyStatusTextBlock"
                               Text="{Binding BusyStatus, Mode=OneWay}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource HeadingTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14" />
                    <ProgressBar IsIndeterminate="True" Width="240" Height="6" />
                    <Button x:Name="CancelEngineButton"
                            AutomationProperties.AutomationId="CancelEngineButton"
                            Content="Cancel"
                            Click="CancelEngineButton_Click"
                            HorizontalAlignment="Center"
                            Padding="16,6"
                            Margin="0,16,0,0" />
                </StackPanel>
            </Border>
        </Border>
                </Grid>

                <!-- PROBLEMS PANEL — bottom-docked gate findings (v1.2.6). Overlays the bottom
                     of whichever view is active; toggled from the activity-bar Problems button. -->
                <Border VerticalAlignment="Bottom" Height="248" Background="#FFFFFF"
                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Panel.ZIndex="50"
                        Visibility="{Binding ProblemsPanelVisible, Converter={StaticResource BoolToVis}}">
                    <DockPanel>
                        <!-- header -->
                        <Border DockPanel.Dock="Top" Height="38" Background="#F8FAFC"
                                BorderBrush="#EEF2F7" BorderThickness="0,0,0,1">
                            <Grid Margin="14,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="PROBLEMS" FontSize="11" FontWeight="Bold"
                                               Foreground="#64748B" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ProblemsSummary}" FontSize="11.5" Foreground="#475569"
                                               Margin="14,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="Run gates" Click="RunGatesButton_Click" Padding="12,5" Margin="0,0,8,0"
                                            IsEnabled="{Binding HasActiveProject}" />
                                    <Button Click="ProblemsButton_Click" ToolTip="Close panel" Style="{StaticResource ExplorerIconStyle}">
                                        <Path Data="M5,5 L15,15 M15,5 L5,15" Stroke="#64748B" StrokeThickness="1.6"
                                              Width="14" Height="14" Stretch="Uniform" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- empty state (no problems / gates not run) -->
                        <TextBlock DockPanel.Dock="Top" Margin="16,16" TextWrapping="Wrap" Foreground="#64748B" FontSize="12.5"
                                   Visibility="{Binding IsNoProblems, Converter={StaticResource BoolToVis}}"
                                   Text="No problems to show. Run gates to check this dataset — any schema, quality, PII, or leakage findings appear here. A clean gate means all checks passed; it is not approval." />
                        <!-- findings list (block-first) -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding IsNoProblems, Converter={StaticResource InverseBoolToVis}}">
                            <ItemsControl ItemsSource="{Binding Problems}" Margin="0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14,7" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding SeverityIcon}" FontSize="13"
                                                           Margin="0,0,10,0" VerticalAlignment="Top" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12.5"
                                                               Foreground="{Binding SeverityColor}" />
                                                    <TextBlock Text="{Binding Message}" FontSize="12" Foreground="#334155"
                                                               TextWrapping="Wrap" Margin="0,1,0,0" />
                                                    <TextBlock FontSize="11.5" Foreground="#2563EB" TextWrapping="Wrap" Margin="0,2,0,0"
                                                               Visibility="{Binding HasFix, Converter={StaticResource BoolToVis}}">
                                                        <Run Text="fix:" FontWeight="SemiBold" /><Run Text=" " /><Run Text="{Binding Fix}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- OUTPUT / LOGS PANEL — bottom-docked engine activity (v1.2.7). Shares the dock
                     with Problems (only one open at a time); toggled from the activity bar. -->
                <Border VerticalAlignment="Bottom" Height="248" Background="#FFFFFF"
                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Panel.ZIndex="50"
                        Visibility="{Binding OutputPanelVisible, Converter={StaticResource BoolToVis}}">
                    <DockPanel>
                        <!-- header -->
                        <Border DockPanel.Dock="Top" Height="38" Background="#F8FAFC"
                                BorderBrush="#EEF2F7" BorderThickness="0,0,0,1">
                            <Grid Margin="14,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="OUTPUT" FontSize="11" FontWeight="Bold"
                                               Foreground="#64748B" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding OutputSummary}" FontSize="11.5" Foreground="#475569"
                                               Margin="14,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="Clear" Click="ClearOutputButton_Click" Padding="12,5" Margin="0,0,8,0"
                                            IsEnabled="{Binding HasOutput}" />
                                    <Button Click="OutputButton_Click" ToolTip="Close panel" Style="{StaticResource ExplorerIconStyle}">
                                        <Path Data="M5,5 L15,15 M15,5 L5,15" Stroke="#64748B" StrokeThickness="1.6"
                                              Width="14" Height="14" Stretch="Uniform" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- empty state -->
                        <TextBlock DockPanel.Dock="Top" Margin="16,16" TextWrapping="Wrap" Foreground="#64748B" FontSize="12.5"
                                   Visibility="{Binding IsNoOutput, Converter={StaticResource BoolToVis}}"
                                   Text="No engine activity yet. Each command the app runs (validate, quality, gates, export, evaluation, AI Assist, …) is logged here with its outcome and timing. Local diagnostics only — nothing is sent anywhere." />
                        <!-- log list (newest last) -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding IsNoOutput, Converter={StaticResource InverseBoolToVis}}">
                            <ItemsControl ItemsSource="{Binding OutputLog}" Margin="0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14,5" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Timestamp}" FontFamily="Consolas" FontSize="11"
                                                               Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                    <TextBlock Text="{Binding StatusIcon}" FontSize="12" Foreground="{Binding StatusColor}"
                                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                                    <TextBlock Text="{Binding Command}" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#1E293B" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding ArgsSummary}" FontFamily="Consolas" FontSize="11.5"
                                                               Foreground="#64748B" VerticalAlignment="Center" Margin="8,0,0,0"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding DurationLabel}" FontSize="11" Foreground="#94A3B8"
                                                               VerticalAlignment="Center" Margin="10,0,0,0" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Detail}" FontFamily="Consolas" FontSize="11" Foreground="#B91C1C"
                                                           TextWrapping="Wrap" Margin="34,2,0,0"
                                                           Visibility="{Binding HasDetail, Converter={StaticResource BoolToVis}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- SEARCH PANEL — bottom-docked workspace content search ("find in files").
                     Shares the dock with Problems/Output (only one open); toggled from the
                     activity-bar Search button. Double-click a result to open the file. -->
                <Border VerticalAlignment="Bottom" Height="248" Background="#FFFFFF"
                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Panel.ZIndex="50"
                        Visibility="{Binding SearchPanelVisible, Converter={StaticResource BoolToVis}}">
                    <DockPanel>
                        <!-- header: query box + case toggle + run + close -->
                        <Border DockPanel.Dock="Top" Height="44" Background="#F8FAFC"
                                BorderBrush="#EEF2F7" BorderThickness="0,0,0,1">
                            <Grid Margin="14,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="SEARCH" FontSize="11" FontWeight="Bold"
                                               Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <TextBox x:Name="SearchQueryBox" Width="280" Height="26" VerticalContentAlignment="Center"
                                             AutomationProperties.AutomationId="WorkspaceSearchTextBox"
                                             Text="{Binding Search.Query, UpdateSourceTrigger=PropertyChanged}"
                                             KeyDown="SearchQueryBox_KeyDown" Padding="6,0" />
                                    <CheckBox Content="Aa" ToolTip="Match case" VerticalAlignment="Center" Margin="10,0,0,0"
                                              IsChecked="{Binding Search.CaseSensitive}" />
                                    <Button Content="Search" Click="SearchRunButton_Click" Padding="12,4" Margin="10,0,0,0"
                                            IsEnabled="{Binding HasActiveProject}" />
                                    <TextBlock Text="{Binding Search.Status}" FontSize="11.5" Foreground="#475569"
                                               Margin="14,0,0,0" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" MaxWidth="360" />
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Click="SearchCloseButton_Click" ToolTip="Close panel" Style="{StaticResource ExplorerIconStyle}">
                                    <Path Data="M5,5 L15,15 M15,5 L5,15" Stroke="#64748B" StrokeThickness="1.6"
                                          Width="14" Height="14" Stretch="Uniform" />
                                </Button>
                            </Grid>
                        </Border>
                        <!-- empty state -->
                        <TextBlock DockPanel.Dock="Top" Margin="16,16" TextWrapping="Wrap" Foreground="#64748B" FontSize="12.5"
                                   Visibility="{Binding Search.HasResults, Converter={StaticResource InverseBoolToVis}}"
                                   Text="Type a term and press Enter to find it across this workspace's text files (datasets, reports, docs, configs). Binaries, oversize files, and build/VCS folders are skipped. Double-click a result to open the file." />
                        <!-- results list; double-click opens the file in the Explorer -->
                        <ListBox x:Name="SearchResultsList" ItemsSource="{Binding Search.Results}"
                                 MouseDoubleClick="SearchResult_DoubleClick" KeyDown="SearchResultsList_KeyDown"
                                 BorderThickness="0" Background="Transparent" Margin="0,2"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Visibility="{Binding Search.HasResults, Converter={StaticResource BoolToVis}}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,3">
                                        <TextBlock Text="{Binding Location}" FontFamily="Consolas" FontSize="11.5"
                                                   FontWeight="SemiBold" Foreground="#2563EB" />
                                        <TextBlock FontFamily="Consolas" FontSize="11.5" Foreground="#334155"
                                                   TextTrimming="CharacterEllipsis" Margin="0,1,0,0"><Run Text="{Binding BeforeMatch}" /><Run Text="{Binding MatchText}" FontWeight="Bold" Foreground="#B45309" Background="#FEF3C7" /><Run Text="{Binding AfterMatch}" /></TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ===================== START CENTER (full window, no workspace) ===================== -->
        <Grid Visibility="{Binding IsStartCenter, Converter={StaticResource BoolToVis}}" Background="{StaticResource AppBackgroundBrush}">
            <DockPanel>
                <!-- brand strip -->
                <Border DockPanel.Dock="Top" Height="52" Background="{StaticResource SidebarBrush}">
                    <Grid Margin="22,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="26" Height="26" CornerRadius="6" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#2563EB" Offset="0" />
                                        <GradientStop Color="#1D4ED8" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="C" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Corpus Studio" Foreground="#F8FAFC" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                            <TextBlock Text="Dataset Creation Studio" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Fill="#34D399" Margin="0,0,7,0" />
                            <TextBlock Text="Local-first · nothing leaves this machine" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- body -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="32,44">
                        <Grid HorizontalAlignment="Center" MaxWidth="1060">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="388" />
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: hero + actions -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Start a workspace" FontSize="30" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="14" Margin="0,8,0,0" TextWrapping="Wrap"
                                           Text="A dataset is a workspace, not just rows. Create a new dataset project from a template, or open an existing folder — Corpus Studio never mutates your files without asking." />

                                <Button Style="{StaticResource StartActionPrimaryStyle}" Click="StartNewProject_Click" Margin="0,26,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="34" Height="34" CornerRadius="8" Background="#3B82F6" Margin="0,0,13,0">
                                            <TextBlock Text="+" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="New Dataset Project" Foreground="White" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="Pick a schema + template, preview the structure" Foreground="#DBEAFE" FontSize="12" Margin="0,1,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource StartActionSecondaryStyle}" Click="StartOpenFolder_Click" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="34" Height="34" CornerRadius="8" Background="#EEF4FF" Margin="0,0,13,0">
                                            <Path Data="M3,7 A2,2 0 0 1 5,5 H9 L11,7 H19 A2,2 0 0 1 21,9 V17 A2,2 0 0 1 19,19 H5 A2,2 0 0 1 3,17 Z" Stroke="#2563EB" StrokeThickness="1.8" Fill="Transparent" Width="18" Height="18" Stretch="Uniform" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Open Existing Folder" Foreground="#0F172A" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="Detects manifest / dataset / empty / other" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,1,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource StartActionSecondaryStyle}" Click="StartImport_Click" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="34" Height="34" CornerRadius="8" Background="#EEF4FF" Margin="0,0,13,0">
                                            <Path Data="M12,3 V15 M8,11 L12,15 L16,11 M5,21 H19" Stroke="#2563EB" StrokeThickness="1.8" Fill="Transparent" Width="18" Height="18" Stretch="Uniform" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Import Dataset" Foreground="#0F172A" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="Preview + quarantine rows into a workspace" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,1,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <Border Margin="0,24,0,0" Padding="12" CornerRadius="8" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Safe by default" Foreground="#166534" FontWeight="SemiBold" FontSize="12" />
                                        <TextBlock Foreground="#166534" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap"
                                                   Text="Generated reports open read-only · examples.jsonl has one writer · no path escapes the workspace root · nothing is deleted." />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- RIGHT: recent workspaces -->
                            <StackPanel Grid.Column="2">
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Recent Workspaces" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StartCenter.RecentCountLabel}" Foreground="#94A3B8" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>

                                <TextBlock Text="No recent workspaces yet. Create or open one to see it here."
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="Wrap"
                                           Visibility="{Binding StartCenter.HasRecents, Converter={StaticResource InverseBoolToVis}}" />

                                <ItemsControl ItemsSource="{Binding StartCenter.Recents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="RecentOpen_Click" HorizontalContentAlignment="Stretch" Margin="0,0,0,9" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="{x:Type Button}">
                                                        <Border x:Name="Card" Background="#FFFFFF" BorderBrush="#D8E0EA" BorderThickness="1" CornerRadius="9" Padding="12,11">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Card" Property="Background" Value="#FBFCFE" />
                                                                <Setter TargetName="Card" Property="BorderBrush" Value="#93B4F8" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#EEF4FF" Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding SchemaTag}" Foreground="#1D4ED8" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="#0F172A" TextTrimming="CharacterEllipsis" />
                                                            <Border Background="#EEF4FF" BorderBrush="#C7D7FE" BorderThickness="1" CornerRadius="10" Padding="7,1" Margin="8,0,0,0"
                                                                    Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="Pinned" Foreground="#1D4ED8" FontSize="10" />
                                                            </Border>
                                                            <Border Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="10" Padding="7,1" Margin="8,0,0,0"
                                                                    Visibility="{Binding IsMissing, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="Missing" Foreground="#9A3412" FontSize="10" />
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Path}" FontFamily="Consolas" FontSize="11" Foreground="#94A3B8" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding WhenText}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center" Margin="10,0" />
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Click="RecentPin_Click" ToolTip="{Binding PinTitle}" Width="28" Height="28" Padding="0"
                                                                Background="Transparent" BorderThickness="0" Content="📌" FontSize="12" />
                                                        <Button Click="RecentRemove_Click" ToolTip="Remove from Recent" Width="28" Height="28" Padding="0"
                                                                Background="Transparent" BorderThickness="0" Content="✕" FontSize="12" Foreground="#94A3B8" />
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Margin="0,14,0,0" Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap"
                                           Text="Registry stored under %LOCALAPPDATA%/CorpusStudio/recent_workspaces.json. Missing folders are kept and flagged, never dropped. Pinned entries survive the 50-entry cap." />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <!-- ENGINE NOT FOUND — setup screen (v1.2.15). Covers everything when the Python
             engine tree can't be located, so the app never launches into a broken shell. -->
        <Border Panel.ZIndex="200" Background="{StaticResource AppBackgroundBrush}"
                Visibility="{Binding IsEngineUnavailable, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource CardBorderStyle}" Width="560" MaxWidth="560"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30,28">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="40" Height="40" CornerRadius="10" Background="#FEF2F2">
                            <Path Data="M12,3 L21,20 H3 Z M12,9 V14 M12,17 H12.01" Stroke="#DC2626"
                                  StrokeThickness="1.8" Fill="Transparent" Width="22" Height="22"
                                  Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Python engine not found" FontSize="19" FontWeight="Bold"
                                   Foreground="#0F172A" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="#334155" FontSize="13" Margin="0,0,0,10"
                               Text="Corpus Studio drives a local Python engine (the engine/ folder). It couldn't be located next to the app or up the folder tree." />
                    <Border Background="#F8FAFC" BorderBrush="#E6EDF5" BorderThickness="1" CornerRadius="8"
                            Padding="12,9" Margin="0,0,0,14">
                        <TextBlock Text="{Binding EngineUnavailableMessage}" TextWrapping="Wrap"
                                   FontFamily="Consolas" FontSize="11.5" Foreground="#64748B" />
                    </Border>
                    <TextBlock TextWrapping="Wrap" Foreground="#475569" FontSize="12.5" Margin="0,0,0,16"
                               Text="Locate the engine folder below, or set the CORPUS_STUDIO_ENGINE_DIR environment variable and retry. See docs/DEVELOPMENT_SETUP.md." />
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                AutomationProperties.AutomationId="LocateEngineButton"
                                Content="Locate engine folder…" Padding="16,8" Margin="0,0,10,0"
                                Click="LocateEngineButton_Click" />
                        <Button AutomationProperties.AutomationId="RetryEngineButton"
                                Content="Retry" Padding="16,8"
                                Click="RetryEngineButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</Window>
