                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <WrapPanel Grid.Row="0"
                                       Grid.ColumnSpan="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,8">
                                <TextBlock Text="Backend"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBox AutomationProperties.AutomationId="EvaluationBackendTextBox"
                                         Text="{Binding EvaluationBackend, UpdateSourceTrigger=PropertyChanged}"
                                         Width="132"
                                         Margin="0,0,12,0" />
